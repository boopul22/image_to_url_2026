---
// Email opt-in consent GATE — shown before upload for legacy signed-in users.
//
// Backend is already built (src/pages/api/email/preferences.ts + the
// email_preferences D1 table). Accounts created before the opt-in existed have
// marketing_opt_in=0 and `needsPrompt=true`. For those users we mount a
// "required to upload" consent checkbox below the uploader and LOCK uploads
// until they tick it (ticking = opt_in). Guests (401) and already-opted-in /
// declined / snoozed users are never locked — the gate fails open, so an opt-in
// hiccup can never block uploads.
//
// A single reusable node lives here (hidden) and is relocated into whichever
// uploader asks for it via `window.emailOptInGate.init(wrapper)`; only one
// uploader is ever active per page. Each uploader guards its handleFiles() with
// `await emailOptInGate.ready` then `emailOptInGate.isLocked()`.
---

<div
  id="email-optin-inline"
  class="hidden mt-3 border border-outline-variant/60 bg-surface-container-low px-3.5 py-3 text-xs leading-relaxed"
>
  <div id="email-optin-consent" class="flex items-start gap-2.5 text-on-surface-variant">
    <input
      id="email-optin-checkbox"
      type="checkbox"
      class="mt-0.5 h-4 w-4 shrink-0 accent-rose-600 cursor-pointer"
    />
    <span class="flex-1 min-w-0">
      <label for="email-optin-checkbox" class="cursor-pointer">
        Email me occasional product updates and upload reminders &mdash;
        <span class="font-semibold text-on-surface">required to upload</span>. I can unsubscribe anytime.
      </label>
    </span>
  </div>

  <p id="email-optin-confirm" class="hidden items-center gap-1.5 font-semibold text-rose-600">
    <span aria-hidden="true">&#10003;</span> Thanks &mdash; you can upload now.
  </p>
</div>

<style>
  /* Brief rose outline pulse when a locked upload is attempted. Kept subtle to
     respect the minimal-motion design system. */
  @keyframes optinFlash {
    0%, 100% { border-color: rgb(225 29 72 / 0.25); box-shadow: none; }
    25%, 60% { border-color: rgb(225 29 72 / 0.9); box-shadow: inset 0 0 0 1px rgb(225 29 72 / 0.5); }
  }
  #email-optin-inline.optin-flash { animation: optinFlash 1.2s ease; }
</style>

<script>
  const el = document.getElementById('email-optin-inline');
  const consent = document.getElementById('email-optin-consent');
  const confirm = document.getElementById('email-optin-confirm');
  const checkbox = document.getElementById('email-optin-checkbox') as HTMLInputElement | null;

  let resolved = false; // eligibility fetched once per page
  let locked = false;   // uploads blocked until consent given
  let done = false;     // opted in this page session
  let markReady: () => void;
  const ready = new Promise<void>((r) => { markReady = r; });

  async function post(action: 'opt_in') {
    try {
      await fetch('/api/email/preferences', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
    } catch {
      /* best-effort — server state already reflects the tick on next load */
    }
  }

  // Ticking the box IS the consent — opt in, unlock uploads, confirm inline.
  checkbox?.addEventListener('change', () => {
    if (done || !checkbox.checked) return;
    done = true;
    locked = false;
    consent?.classList.add('hidden');
    confirm?.classList.remove('hidden');
    confirm?.classList.add('flex');
    post('opt_in');
  });

  (window as any).emailOptInGate = {
    // Called once by the active uploader on load. Fetches eligibility and, when
    // the account needs prompting, mounts the checkbox into `mountEl` and locks.
    async init(mountEl: HTMLElement | null) {
      if (resolved) { markReady(); return; }
      resolved = true;
      try {
        if (mountEl) {
          const res = await fetch('/api/email/preferences', { credentials: 'same-origin' });
          if (res.ok) {
            const data = await res.json();
            if (data?.preferences?.needsPrompt) {
              locked = true;
              mountEl.appendChild(el!);
              el!.classList.remove('hidden');
            }
          }
          // !res.ok → guest / not signed in → never lock.
        }
      } catch {
        /* fail open — never block uploads on an opt-in error */
      }
      markReady();
    },
    // Resolves once init()'s fetch settles, so a fast drop can't race the lock.
    ready,
    isLocked() { return locked; },
    // Draw attention to the checkbox when a locked upload is attempted.
    flash() {
      if (!el) return;
      el.scrollIntoView({ block: 'center', behavior: 'smooth' });
      el.classList.remove('optin-flash');
      void el.offsetWidth; // restart the animation
      el.classList.add('optin-flash');
    },
  };
</script>

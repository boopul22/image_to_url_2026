---
// Inline post-upload email opt-in consent.
//
// Backend is already built (see src/pages/api/email/preferences.ts + the
// email_preferences D1 table). This is the missing UI: after a signed-in user
// completes an upload, the uploader calls `window.showEmailOptIn(container)`
// with its result/success panel. If the account `needsPrompt` (never opted in,
// never declined, not unsubscribed, not snoozed — i.e. legacy users who signed
// up before the opt-in existed), we mount an inline consent checkbox INSIDE
// that panel, like a privacy-policy accept row. Guests get a 401 → nothing.
//
// A single reusable node lives here (hidden) and is relocated into whichever
// uploader panel asks for it — only one uploader is ever active per page.
---

<div
  id="email-optin-inline"
  class="hidden mt-4 pt-3 border-t border-outline-variant/40 text-xs leading-relaxed"
>
  <div id="email-optin-consent" class="flex items-start gap-2.5 text-on-surface-variant">
    <input
      id="email-optin-checkbox"
      type="checkbox"
      class="mt-0.5 h-4 w-4 shrink-0 accent-rose-600 cursor-pointer"
    />
    <span class="flex-1 min-w-0">
      <label for="email-optin-checkbox" class="cursor-pointer">
        Email me occasional product updates and upload reminders. I can unsubscribe anytime.
      </label>
      <button
        id="email-optin-later"
        type="button"
        class="ms-1.5 font-semibold text-on-surface/45 hover:text-on-surface whitespace-nowrap transition-colors"
      >Not now</button>
    </span>
  </div>

  <p id="email-optin-confirm" class="hidden items-center gap-1.5 font-semibold text-rose-600">
    <span aria-hidden="true">&#10003;</span> Subscribed — you can unsubscribe anytime.
  </p>
</div>

<script>
  const el = document.getElementById('email-optin-inline');
  const consent = document.getElementById('email-optin-consent');
  const confirm = document.getElementById('email-optin-confirm');
  const checkbox = document.getElementById('email-optin-checkbox') as HTMLInputElement | null;
  const laterBtn = document.getElementById('email-optin-later');

  // Guards: resolve eligibility once per page, and act at most once.
  let resolved = false;
  let done = false;

  async function post(action: 'opt_in' | 'snooze') {
    // Fire-and-forget — the UI has already updated; a failed write just means
    // we may prompt again on a later visit.
    try {
      await fetch('/api/email/preferences', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
    } catch {
      /* best-effort */
    }
  }

  // Ticking the box IS the consent (privacy-accept style) — opt in immediately
  // and swap to a small inline confirmation.
  checkbox?.addEventListener('change', () => {
    if (done || !checkbox.checked) return;
    done = true;
    consent?.classList.add('hidden');
    confirm?.classList.remove('hidden');
    confirm?.classList.add('flex');
    post('opt_in');
  });

  // "Not now" — didn't decide; ask again in 30 days.
  laterBtn?.addEventListener('click', () => {
    if (done) return;
    done = true;
    el?.classList.add('hidden');
    post('snooze');
  });

  // Called by each uploader after a successful upload, passing the result panel
  // to mount into. Self-contained: only surfaces when the account needs it.
  (window as any).showEmailOptIn = async function showEmailOptIn(container: HTMLElement | null) {
    if (!el || !container || done || resolved) return;
    let needsPrompt = false;
    try {
      const res = await fetch('/api/email/preferences', { credentials: 'same-origin' });
      if (!res.ok) {
        resolved = true; // guest / not signed in — never ask
        return;
      }
      const data = await res.json();
      needsPrompt = Boolean(data?.preferences?.needsPrompt);
    } catch {
      return; // transient error — allow a later upload to retry
    }
    resolved = true;
    if (!needsPrompt || done) return;
    container.appendChild(el);
    el.classList.remove('hidden');
  };
</script>

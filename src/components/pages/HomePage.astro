---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getDB } from '../../lib/db';
import { getPublishedPosts } from '../../lib/cms';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const db = getDB(Astro.locals);
const { posts: previewPosts } = await getPublishedPosts(db, { limit: 3 });

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": "https://imagetourl.cloud/#software",
    "name": "ImageToURL",
    "url": "https://imagetourl.cloud",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "description": "Upload any image and instantly receive a permanent, CDN-delivered shareable URL. Supports JPG, PNG, WebP, GIF, and SVG up to 10 MB. No account required.",
    "featureList": [
      "Drag and drop image upload",
      "Instant permanent URL generation",
      "Global CDN delivery",
      "SSL-encrypted links",
      "No signup required for free tier",
      "REST API access",
      "Markdown and HTML export",
      "Custom link expiration"
    ],
    "screenshot": "https://imagetourl.cloud/favicon.svg",
    "offers": [
      {
        "@type": "Offer",
        "name": "Free",
        "price": "0",
        "priceCurrency": "USD",
        "description": "10 uploads per month, standard processing speed, public link library.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "price": "12",
        "priceCurrency": "USD",
        "billingIncrement": "P1M",
        "description": "Unlimited uploads, high-priority processing, custom link expiration, API access.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Business",
        "price": "49",
        "priceCurrency": "USD",
        "billingIncrement": "P1M",
        "description": "Everything in Pro plus team workspaces, ultra-high resolution, and dedicated support.",
        "url": "https://imagetourl.cloud/pricing"
      }
    ],
    "publisher": {
      "@id": "https://imagetourl.cloud/#organization"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "3",
      "reviewCount": "3"
    },
    "review": [
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Alex Rivera" },
        "reviewBody": "Finally, a tool that doesn't ask me to create an account for a simple 2-second task. The speed is actually insane."
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Sarah Chen" },
        "reviewBody": "We use the API to handle all our blog image assets. It's more reliable than our own previous hosting solution."
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "author": { "@type": "Person", "name": "Jordan Smith" },
        "reviewBody": "The permanent links feature is a lifesaver for my portfolio. I don't have to worry about broken images ever again."
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://imagetourl.cloud/#webpage",
    "url": "https://imagetourl.cloud",
    "name": "ImageToURL — Turn Images into Shareable Links",
    "description": "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery.",
    "isPartOf": { "@id": "https://imagetourl.cloud/#website" },
    "about": { "@id": "https://imagetourl.cloud/#software" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://imagetourl.cloud" }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is it really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The free tier gives you 10 uploads per month with permanent links and CDN delivery. No credit card needed."
        }
      },
      {
        "@type": "Question",
        "name": "Do my links expire?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Free-tier links are permanent. Pro users can optionally set custom expiration times."
        }
      },
      {
        "@type": "Question",
        "name": "What image formats are supported?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "JPG, PNG, WebP, GIF, and SVG — up to 10 MB per file."
        }
      },
      {
        "@type": "Question",
        "name": "Is there an API?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Pro and Business plans include full REST API access for automated uploads and image management."
        }
      },
      {
        "@type": "Question",
        "name": "How secure are my images?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All images are served over HTTPS with SSL encryption. Data is stored on Cloudflare's encrypted infrastructure."
        }
      }
    ]
  }
];
---

<Layout schema={pageSchema} title={t(locale, 'home.meta.title')} description={t(locale, 'home.meta.description')}>
  <Nav activePage="home" />

  <!-- Hero Section — Immediate, action-focused -->
  <section class="sm:min-h-[calc(100dvh-58px)] flex flex-col max-w-4xl mx-auto px-4 sm:px-6 pt-6 sm:pt-10 lg:pt-14 text-center">
    <div>
      <div class="hidden sm:inline-block bg-primary text-on-primary px-3 py-1 rounded-full font-label text-xs font-bold uppercase tracking-widest mb-4">
        {t(locale, 'home.hero.badge')}
      </div>
      <h1 class="font-headline text-[1.75rem] sm:text-5xl lg:text-6xl font-black text-on-background leading-[0.95] tracking-tighter mb-2 sm:mb-4">
        {t(locale, 'home.hero.headline1')} <span class="text-[#9B7D00]">{t(locale, 'home.hero.headline2')}</span>
      </h1>
      <p class="hidden sm:block font-body text-base lg:text-lg text-on-surface-variant leading-relaxed max-w-xl mx-auto mb-6">
        {t(locale, 'home.hero.subheadline')}
      </p>
    </div>

    <!-- Upload Area -->
    <div class="w-full max-w-2xl lg:max-w-3xl mx-auto">
      <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" class="hidden" />
      <div
        id="upload-panel"
        class="bg-surface-container rounded-2xl lg:rounded-3xl border border-outline-variant overflow-hidden transition-colors"
        data-uploading={t(locale, 'home.upload.uploading')}
        data-copied={t(locale, 'home.upload.copied')}
        data-copy={t(locale, 'home.upload.copy')}
        data-failed={t(locale, 'home.upload.failed')}
        data-click-or-drag={t(locale, 'home.upload.clickOrDrag')}
        data-formats={t(locale, 'home.upload.formats')}
        data-select-file={t(locale, 'home.upload.selectFile')}
        data-uploading-file={t(locale, 'home.upload.uploadingFile')}
      >
        <!-- State: idle / uploading -->
        <div id="state-idle" class="p-4 sm:p-8 lg:p-12">
          <div id="drop-zone" class="flex flex-col items-center gap-3 sm:gap-5 lg:gap-6 cursor-pointer" role="button" tabindex="0">
            <span class="material-symbols-outlined text-on-tertiary-container text-3xl sm:text-5xl lg:text-6xl" id="upload-icon">upload_file</span>
            <div class="text-center">
              <p class="text-on-surface font-bold text-base sm:text-lg lg:text-xl font-headline" id="upload-text">{t(locale, 'home.upload.clickOrDrag')}</p>
              <p class="text-xs sm:text-sm lg:text-base text-outline mt-1.5" id="upload-subtext">{t(locale, 'home.upload.formats')}</p>
            </div>
            <div class="bg-primary text-on-primary px-8 sm:px-10 lg:px-12 py-3 sm:py-3.5 lg:py-4 rounded-lg lg:rounded-xl font-bold text-sm sm:text-base lg:text-lg uppercase tracking-wider active:scale-95 transition-transform" id="upload-btn">
              {t(locale, 'home.upload.selectFile')}
            </div>
          </div>
          <div id="progress-bar" class="hidden mt-5 h-2 bg-surface-variant overflow-hidden rounded-full">
            <div id="progress-fill" class="h-full bg-primary transition-all duration-300 rounded-full" style="width: 0%"></div>
          </div>
        </div>

        <!-- State: success -->
        <div id="state-success" class="p-5 sm:p-8 lg:p-12 hidden">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-secondary text-2xl sm:text-3xl">check_circle</span>
            <span class="font-bold text-secondary text-sm sm:text-base">{t(locale, 'home.upload.uploaded')}</span>
            <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
              {t(locale, 'home.upload.uploadAnother')}
            </button>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="text" id="result-url" readonly class="flex-1 min-w-0 bg-white border border-outline-variant rounded-lg px-4 py-3 sm:py-3.5 text-sm sm:text-base font-mono text-on-surface focus:outline-none" />
            <button id="copy-btn" class="bg-primary text-on-primary px-6 py-3 sm:py-3.5 rounded-lg font-bold text-sm sm:text-base flex-shrink-0 active:scale-95 transition-transform">
              {t(locale, 'home.upload.copy')}
            </button>
          </div>
          <!-- ExtractPics cross-promo tip -->
          <a href="https://extractpics.com/?ref=imagetourl" target="_blank" rel="noopener" class="block mt-4 pt-3 border-t border-outline-variant/50 hover:opacity-80 transition-opacity group">
            <span class="text-xs sm:text-sm font-bold text-on-background">Try our new tool — ExtractPics</span>
            <p class="text-xs sm:text-sm font-medium text-error mt-1">Scrape images from any webpage — up to 3 pages deep</p>
          </a>
        </div>

        <!-- State: error -->
        <div id="state-error" class="p-5 sm:p-8 lg:p-12 hidden">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-error flex-shrink-0 text-2xl">error</span>
            <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">{t(locale, 'home.upload.failed')}</span>
            <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
              {t(locale, 'home.upload.tryAgain')}
            </button>
          </div>
          <!-- Sign in CTA for limit errors -->
          <a href="/api/auth/login" id="error-signin" class="hidden items-center gap-2 mt-3 pt-3 border-t border-outline-variant/50 text-on-background hover:opacity-80 transition-opacity group">
            <span class="material-symbols-outlined text-base text-primary">login</span>
            <span class="text-xs sm:text-sm font-bold">Sign in to get more uploads</span>
            <span class="material-symbols-outlined text-sm text-primary group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
          </a>
          <!-- ExtractPics cross-promo tip -->
          <a href="https://extractpics.com/?ref=imagetourl" target="_blank" rel="noopener" id="error-promo" class="hidden mt-3 pt-3 border-t border-outline-variant/50 hover:opacity-80 transition-opacity group">
            <span class="text-xs sm:text-sm font-bold text-on-background">Try our new tool — ExtractPics</span>
            <p class="text-xs sm:text-sm font-medium text-error mt-1">Scrape images from any webpage — up to 3 pages deep</p>
          </a>
        </div>
      </div>
    </div>

    <!-- Trust Signals — pushed to bottom of viewport -->
    <div class="flex flex-wrap justify-center gap-3 sm:gap-6 mt-4 sm:mt-8 pt-0 sm:pt-0 pb-4 sm:pb-6 text-xs sm:text-sm text-on-surface-variant font-label font-bold uppercase tracking-wider">
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">rocket_launch</span> <span class="hidden sm:inline">{t(locale, 'home.trust.cdn')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">lock</span> <span class="hidden sm:inline">{t(locale, 'home.trust.ssl')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">link</span> <span class="hidden sm:inline">{t(locale, 'home.trust.permanent')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">flash_on</span> <span class="hidden sm:inline">{t(locale, 'home.trust.instant')}</span></span>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-6 sm:py-10 bg-surface-container-low border-y border-outline-variant/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8 text-center">
      <div class="reveal">
        <div class="font-headline text-2xl sm:text-4xl font-black text-primary">{t(locale, 'home.stats.images')}</div>
        <div class="font-label text-[10px] sm:text-xs uppercase tracking-widest text-on-surface-variant font-bold mt-1">{t(locale, 'home.stats.imagesLabel')}</div>
      </div>
      <div class="reveal">
        <div class="font-headline text-2xl sm:text-4xl font-black text-primary">{t(locale, 'home.stats.uptime')}</div>
        <div class="font-label text-[10px] sm:text-xs uppercase tracking-widest text-on-surface-variant font-bold mt-1">{t(locale, 'home.stats.uptimeLabel')}</div>
      </div>
      <div class="reveal">
        <div class="font-headline text-2xl sm:text-4xl font-black text-primary">{t(locale, 'home.stats.countries')}</div>
        <div class="font-label text-[10px] sm:text-xs uppercase tracking-widest text-on-surface-variant font-bold mt-1">{t(locale, 'home.stats.countriesLabel')}</div>
      </div>
      <div class="reveal">
        <div class="font-headline text-2xl sm:text-4xl font-black text-primary">{t(locale, 'home.stats.signup')}</div>
        <div class="font-label text-[10px] sm:text-xs uppercase tracking-widest text-on-surface-variant font-bold mt-1">{t(locale, 'home.stats.signupLabel')}</div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-20">
    <div class="text-center mb-8 sm:mb-14 reveal">
      <h2 class="font-headline text-2xl sm:text-4xl lg:text-5xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.howItWorks.title')}</h2>
      <p class="font-body text-on-surface-variant text-sm sm:text-base">{t(locale, 'home.howItWorks.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8 reveal-stagger">
      <div class="reveal bg-surface-container rounded-2xl p-6 sm:p-8 relative">
        <div class="w-9 h-9 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-base font-black mb-4">1</div>
        <div>
          <span class="material-symbols-outlined text-primary text-3xl sm:text-4xl mb-3 block">cloud_upload</span>
          <h3 class="font-headline text-xl sm:text-2xl font-black text-on-background mb-2">{t(locale, 'home.howItWorks.upload.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.upload.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-6 sm:p-8 relative">
        <div class="w-9 h-9 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-base font-black mb-4">2</div>
        <div>
          <span class="material-symbols-outlined text-primary text-3xl sm:text-4xl mb-3 block">bolt</span>
          <h3 class="font-headline text-xl sm:text-2xl font-black text-on-background mb-2">{t(locale, 'home.howItWorks.convert.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.convert.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-6 sm:p-8 relative">
        <div class="w-9 h-9 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-base font-black mb-4">3</div>
        <div>
          <span class="material-symbols-outlined text-primary text-3xl sm:text-4xl mb-3 block">share</span>
          <h3 class="font-headline text-xl sm:text-2xl font-black text-on-background mb-2">{t(locale, 'home.howItWorks.share.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.share.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-8 sm:mb-14 reveal">
        <h2 class="font-headline text-2xl sm:text-4xl lg:text-5xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.features.title')}</h2>
        <p class="font-body text-on-surface-variant text-sm sm:text-base">{t(locale, 'home.features.description')}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 reveal-stagger">
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">rocket_launch</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.cdn.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.cdn.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">lock_open</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.noSignup.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.noSignup.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">link</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.permanent.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.permanent.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">https</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.ssl.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.ssl.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">flash_on</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.instant.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.instant.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-3xl mb-3 block">aspect_ratio</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.resize.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.resize.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-20">
    <div class="text-center mb-8 sm:mb-14 reveal">
      <h2 class="font-headline text-2xl sm:text-4xl lg:text-5xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.useCases.title')}</h2>
      <p class="font-body text-on-surface-variant text-sm sm:text-base">{t(locale, 'home.useCases.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 reveal-stagger">
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6">
        <span class="material-symbols-outlined text-primary text-3xl mb-3 block">edit_note</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.bloggers.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.bloggers.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6">
        <span class="material-symbols-outlined text-primary text-3xl mb-3 block">terminal</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.developers.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.developers.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6">
        <span class="material-symbols-outlined text-primary text-3xl mb-3 block">school</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.students.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.students.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6">
        <span class="material-symbols-outlined text-primary text-3xl mb-3 block">palette</span>

            <label class="block font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1.5">Your rating</label>
            <div id="review-stars" class="flex items-center gap-1" role="radiogroup" aria-label="Rating">
              {[1,2,3,4,5].map((n) => (
                <button type="button" class="review-star w-9 h-9 flex items-center justify-center cursor-pointer text-outline-variant" data-value={n} aria-label={`${n} star${n>1?'s':''}`}>
                  <Icon name="star" class="text-2xl" />
                </button>
              ))}
            </div>
          </div>
          <div>
            <label for="review-role" class="block font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1.5">What you do <span class="font-normal lowercase">(optional)</span></label>
            <input id="review-role" type="text" maxlength="40" placeholder="e.g. Web Developer" class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant/40 rounded-lg font-body text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label for="review-body" class="block font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant mb-1.5">Your review</label>
            <textarea id="review-body" rows="4" maxlength="600" placeholder="What do you use ImageToURL for, and how's it working out?" class="w-full px-3 py-2.5 bg-surface-container border border-outline-variant/40 rounded-lg font-body text-sm focus:outline-none focus:border-primary resize-none"></textarea>
          </div>
          <p id="review-msg" class="hidden text-sm font-medium"></p>
          <div class="flex items-center justify-end gap-2 pt-1">
            <button type="button" id="review-cancel" class="px-4 py-2.5 rounded-lg font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant hover:bg-surface-container-highest transition-colors cursor-pointer">Cancel</button>
            <button type="submit" id="review-submit" class="px-5 py-2.5 rounded-lg font-label text-xs font-bold uppercase tracking-wider bg-primary text-on-primary border border-outline-variant/40 hover:-translate-y-0.5 transition-transform active:scale-95 cursor-pointer disabled:opacity-60">Submit</button>
          </div>
        </form>
      </div>
    </div>
  )}
</Layout>

<script>
  import { ic_cloud_upload, ic_hourglass_top } from '../../data/icon-svgs';
  // Ad-blocker detection — analytics only, NEVER blocks or degrades uploads.
  // Shared with the tool-page uploader so both report the same signal.

  // Cached login check for the auto-delete "Never" gate.
  let isLoggedIn: boolean | null = null;
  async function fetchLoggedIn(): Promise<boolean> {
    if (isLoggedIn !== null) return isLoggedIn;
    try {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      const data = await res.json();
      isLoggedIn = !!(data && data.user);
    } catch {
      isLoggedIn = false;
    }
    return isLoggedIn;
  }

  // Auto-delete dropdown: live-update the inline hint line.
  const expiresInSel = document.getElementById('expires-in') as HTMLSelectElement | null;
  const expiresInHint = document.getElementById('expires-in-hint');
  const EXPIRY_HINTS: Record<string, string> = {
    auto: 'Auto-expires in ~2 weeks',
    never: 'Permanent — never deleted',
  };

  function refreshExpiresHint(value: string) {
    if (expiresInHint) {
      expiresInHint.textContent = EXPIRY_HINTS[value] || EXPIRY_HINTS.auto;
    }
  }

  if (expiresInSel) {
    expiresInSel.addEventListener('change', () => refreshExpiresHint(expiresInSel.value));
    refreshExpiresHint(expiresInSel.value);
  }

  const expiresHelpBtn = document.getElementById('expires-in-help');
  const expiresHelpPanel = document.getElementById('expires-in-help-panel');
  if (expiresHelpBtn && expiresHelpPanel) {
    expiresHelpBtn.addEventListener('click', () => {
      const expanded = expiresHelpBtn.getAttribute('aria-expanded') === 'true';
      expiresHelpBtn.setAttribute('aria-expanded', String(!expanded));
      expiresHelpPanel.classList.toggle('hidden');
    });
  }

  const panel = document.getElementById('upload-panel')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadIcon = document.getElementById('upload-icon')!;
  const uploadText = document.getElementById('upload-text')!;
  const uploadSubtext = document.getElementById('upload-subtext')!;
  const uploadBtn = document.getElementById('upload-btn')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressFill = document.getElementById('progress-fill')!;
  const stateIdle = document.getElementById('state-idle')!;
  const stateSuccess = document.getElementById('state-success')!;
  const stateError = document.getElementById('state-error')!;
  const resultUrl = document.getElementById('result-url') as HTMLInputElement;
  const copyBtn = document.getElementById('copy-btn')!;
  const uploadAnother = document.getElementById('upload-another')!;
  const errorRetry = document.getElementById('error-retry')!;
  const errorLogin = document.getElementById('error-login')!;
  const errorText = document.getElementById('error-text')!;
  const errorSignin = document.getElementById('error-signin')!;


  // Read i18n strings from data attributes
  const i18n = {
    uploading: panel.dataset.uploading || 'UPLOADING...',
    copied: panel.dataset.copied || 'COPIED!',
    copy: panel.dataset.copy || 'COPY',
    failed: panel.dataset.failed || 'Upload failed',
    clickOrDrag: panel.dataset.clickOrDrag || 'Click to upload or drag & drop',
    formats: panel.dataset.formats || 'JPG, PNG, WebP, GIF, SVG — up to 10 MB',
    selectFile: panel.dataset.selectFile || 'SELECT FILE',
    uploadingFile: panel.dataset.uploadingFile || 'Uploading {name}',
  };

  function showState(state: 'idle' | 'success' | 'error') {
    stateIdle.classList.toggle('hidden', state !== 'idle');
    stateSuccess.classList.toggle('hidden', state !== 'success');
    stateError.classList.toggle('hidden', state !== 'error');
  }

  function resetIdle() {
    showState('idle');
    progressBar.classList.add('hidden');
    progressFill.style.width = '0%';
    uploadIcon.innerHTML = ic_cloud_upload;
    uploadText.textContent = i18n.clickOrDrag;
    uploadSubtext.textContent = i18n.formats;
    uploadBtn.textContent = i18n.selectFile;
    fileInput.value = '';
    errorSignin.classList.add('hidden');
    errorSignin.classList.remove('flex');
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  function showLoginError() {
    errorRetry.classList.add('hidden');
    errorLogin.classList.remove('hidden');
  }

  function showRetryError() {
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  // Click to open file picker
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });
  document.getElementById('browse-btn')?.addEventListener('click', () => fileInput.click());

  // Drag and drop — target the whole panel
  panel.addEventListener('dragover', (e) => {
    e.preventDefault();
    panel.classList.add('!border-rose-400', '!bg-rose-50');
  });
  panel.addEventListener('dragleave', (e) => {
    if (!panel.contains(e.relatedTarget as Node)) {
      panel.classList.remove('!border-rose-400', '!bg-rose-50');
    }
  });
  panel.addEventListener('drop', (e) => {
    e.preventDefault();
    panel.classList.remove('!border-rose-400', '!bg-rose-50');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) uploadFile(files[0]);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) uploadFile(fileInput.files[0]);
  });

  copyBtn.addEventListener('click', () => {
    // "Get Link" — route to a random landing page that surfaces the share widget
    // (URL, copy, formats, QR, watermark) on top + side ads, for higher-RPM dwell.
    (window as any).shareGoRandom(resultUrl.value);
  });

  uploadAnother.addEventListener('click', resetIdle);
  errorRetry.addEventListener('click', resetIdle);

  // CTA button scrolls to top and opens file picker
  const ctaBtn = document.getElementById('cta-upload-btn');
  if (ctaBtn) {
    ctaBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => fileInput.click(), 500);
    });
  }

  async function uploadFile(file: File) {
    // Ad-block gate: if the user has an ad-blocker we explain why we need it off
    // and offer a retry. Cancelling leaves the uploader idle.
    if (!(await (window as any).__adblockGate?.check())) {
      fileInput.value = '';
      return;
    }

    // "Never" requires a signed-in account; server clamps anon to 24h otherwise.
    if (expiresInSel?.value === 'never') {
      const loggedIn = await fetchLoggedIn();
      if (!loggedIn) {
        showState('error');
        errorText.textContent = 'Sign in to upload images that never expire.';
        errorSignin.classList.remove('hidden');
        errorSignin.classList.add('flex');
        showLoginError();
        fileInput.value = '';
        return;
      }
    }

    // Show uploading state (stays in idle panel)
    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.innerHTML = ic_hourglass_top;
    uploadText.textContent = i18n.uploadingFile.replace('{name}', file.name);
    uploadSubtext.textContent = `${(file.size / 1024).toFixed(0)} KB · ${file.type.split('/')[1].toUpperCase()}`;
    uploadBtn.textContent = i18n.uploading;

    // Gate already passed above — blocker is either off or never was on.
    const ab = '0';

    const MIN_UPLOAD_MS = 5000;
    const startedAt = Date.now();

    const progressInterval = setInterval(() => {
      const elapsed = Date.now() - startedAt;
      const target = Math.min(95, (elapsed / MIN_UPLOAD_MS) * 95);
      progressFill.style.width = `${target}%`;
    }, 100);

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('adblock', ab);
      const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
      if (expiresInEl) formData.append('expires_in', expiresInEl.value);

      const response = await fetch('/api/upload', { method: 'POST', body: formData });
      const data = await response.json();

      if (!response.ok || data.error) {
        clearInterval(progressInterval);
        // Daily rate limit: show the friendly reason inline. Only nudge guests
        // to sign in — logged-in users already have the higher cap, so they get
        // a "try again later / email us" message instead.
        if (data.limit) {
          showState('error');
          errorText.textContent = data.error;
          const isAnon = data.limit.scope === 'anon';
          errorSignin.classList.toggle('hidden', !isAnon);
          errorSignin.classList.toggle('flex', isAnon);
          if (isAnon) showLoginError();
          else showRetryError();
          fileInput.value = '';
          return;
        }
        throw new Error(data.error || i18n.failed);
      }

      const remaining = MIN_UPLOAD_MS - (Date.now() - startedAt);
      if (remaining > 0) {
        await new Promise((r) => setTimeout(r, remaining));
      }

      clearInterval(progressInterval);
      progressFill.style.width = '100%';
      setTimeout(() => {
        showState('success');
        resultUrl.value = data.data.url;
      }, 300);

    } catch (err: any) {
      clearInterval(progressInterval);
      showState('error');
      errorText.textContent = err.message || i18n.failed;
      const isLimit = (err.message || '').toLowerCase().includes('limit');
      errorSignin.classList.toggle('hidden', !isLimit);
      errorSignin.classList.toggle('flex', isLimit);
      if (isLimit) showLoginError();
      else showRetryError();
    }
  }

  // Legacy click tracking (non-sponsor links)
  document.querySelectorAll<HTMLAnchorElement>('[data-track-click]').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.sendBeacon('/api/track/click', JSON.stringify({
        linkId: el.dataset.trackClick,
        page: window.location.pathname,
      }));
    });
  });

</script>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = btn.querySelector('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-item').forEach((faq) => {
        faq.querySelector('.faq-answer')!.classList.add('hidden');
        faq.querySelector('.faq-toggle')!.setAttribute('aria-expanded', 'false');
        faq.querySelector('.faq-icon')!.classList.remove('rotate-180');
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        answer.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>

<script>
  import { ic_star, icf_star } from '../../data/icon-svgs';
  // Review submission modal (signed-in users). Marquee animation is pure CSS.
  (() => {
    const modal = document.getElementById('review-modal');
    const openBtn = document.getElementById('review-open');
    if (!modal || !openBtn) return;
    const form = document.getElementById('review-form') as HTMLFormElement;
    const closeBtn = document.getElementById('review-close');
    const cancelBtn = document.getElementById('review-cancel');
    const backdrop = document.getElementById('review-backdrop');
    const bodyInput = document.getElementById('review-body') as HTMLTextAreaElement;
    const roleInput = document.getElementById('review-role') as HTMLInputElement;
    const msg = document.getElementById('review-msg')!;
    const submitBtn = document.getElementById('review-submit') as HTMLButtonElement;
    const starBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.review-star'));
    let rating = 0;
    let loaded = false;

    function paintStars(val: number) {
      starBtns.forEach((b) => {
        const v = Number(b.dataset.value);
        const icon = b.querySelector('.ms-icon') as HTMLElement;
        const on = v <= val;
        b.classList.toggle('text-amber-500', on);
        b.classList.toggle('text-outline-variant', !on);
        if (icon) icon.innerHTML = on ? icf_star : ic_star;
      });
    }
    function setRating(v: number) { rating = v; paintStars(v); }
    starBtns.forEach((b) => {
      b.addEventListener('mouseenter', () => paintStars(Number(b.dataset.value)));
      b.addEventListener('mouseleave', () => paintStars(rating));
      b.addEventListener('click', () => setRating(Number(b.dataset.value)));
    });

    function showMsg(text: string, ok: boolean) {
      msg.textContent = text;
      msg.classList.remove('hidden');
      msg.classList.toggle('text-primary', ok);
      msg.classList.toggle('text-error', !ok);
    }

    async function open() {
      modal!.classList.remove('hidden');
      modal!.classList.add('flex');
      document.body.style.overflow = 'hidden';
      if (!loaded) {
        loaded = true;
        try {
          const res = await fetch('/api/reviews');
          if (res.ok) {
            const { review } = await res.json();
            if (review) {
              setRating(review.rating);
              roleInput.value = review.role || '';
              bodyInput.value = review.body || '';
              showMsg(review.status === 'approved' ? 'Your review is live. Editing resubmits it for approval.' : 'You have a review pending approval. You can update it below.', true);
            }
          }
        } catch {}
      }
    }
    function close() {
      modal!.classList.add('hidden');
      modal!.classList.remove('flex');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    cancelBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal!.classList.contains('hidden')) close(); });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (rating < 1) { showMsg('Please pick a star rating.', false); return; }
      if (bodyInput.value.trim().length < 12) { showMsg('Tell us a little more (at least 12 characters).', false); return; }
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      try {
        const res = await fetch('/api/reviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rating, role: roleInput.value.trim(), body: bodyInput.value.trim() }),
        });
        const data = await res.json();
        if (res.ok) {
          showMsg(data.message || 'Thanks! Your review was submitted.', true);
          setTimeout(close, 1800);
        } else {
          showMsg(data.error || 'Something went wrong. Please try again.', false);
        }
      } catch {
        showMsg('Network error. Please try again.', false);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit';
      }
    });
  })();
</script>


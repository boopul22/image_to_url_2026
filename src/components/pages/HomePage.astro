<script>
  // Cached login check for the auto-delete "Never" gate.
  let isLoggedIn: boolean | null = null;
  async function fetchLoggedIn(): Promise<boolean> {
    if (isLoggedIn !== null) return isLoggedIn;
    try {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      const data = await res.json();
      isLoggedIn = !!(data && data.user);
    } catch {
      isLoggedIn = false;
    }
    return isLoggedIn;
  }

  // Auto-delete dropdown: live-update the hint line and the warning banner
  const expiresInSel = document.getElementById('expires-in') as HTMLSelectElement | null;
  const expiresInHint = document.getElementById('expires-in-hint');
  const expiresWarnEl = document.getElementById('expires-in-warning');
  const expiresWarnText = document.getElementById('expires-in-warning-text');
  const EXPIRY_HINTS: Record<string, string> = {
    never: 'Never auto-deleted',
    '1h': 'Auto-deletes in 1 hour',
    '24h': 'Auto-deletes in 24 hours',
    '7d': 'Auto-deletes in 7 days',
    '30d': 'Auto-deletes in 30 days',
  };
  const WARN_LABEL: Record<string, string> = {
    '1h': '1 hour',
    '24h': '24 hours',
    '7d': '7 days',
    '30d': '30 days',
  };

  function refreshExpiresWarning(value: string) {
    if (expiresInHint) {
      expiresInHint.textContent = EXPIRY_HINTS[value] || EXPIRY_HINTS['7d'];
    }
    if (!expiresWarnEl || !expiresWarnText) return;
    const label = WARN_LABEL[value];
    if (!label) {
      expiresWarnEl.classList.add('hidden');
      expiresWarnText.textContent = '';
    } else {
      expiresWarnText.textContent = `Deletes in ${label} — pick a different duration above ↑`;
      expiresWarnEl.classList.remove('hidden');
    }
  }

  if (expiresInSel) {
    expiresInSel.addEventListener('change', () => refreshExpiresWarning(expiresInSel.value));
    refreshExpiresWarning(expiresInSel.value);
  }

  const expiresHelpBtn = document.getElementById('expires-in-help');
  const expiresHelpPanel = document.getElementById('expires-in-help-panel');
  if (expiresHelpBtn && expiresHelpPanel) {
    expiresHelpBtn.addEventListener('click', () => {
      const expanded = expiresHelpBtn.getAttribute('aria-expanded') === 'true';
      expiresHelpBtn.setAttribute('aria-expanded', String(!expanded));
      expiresHelpPanel.classList.toggle('hidden');
    });
  }

  const panel = document.getElementById('upload-panel')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadIcon = document.getElementById('upload-icon')!;
  const uploadText = document.getElementById('upload-text')!;
  const uploadSubtext = document.getElementById('upload-subtext')!;
  const uploadBtn = document.getElementById('upload-btn')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressFill = document.getElementById('progress-fill')!;
  const stateIdle = document.getElementById('state-idle')!;
  const stateSuccess = document.getElementById('state-success')!;
  const stateError = document.getElementById('state-error')!;
  const resultUrl = document.getElementById('result-url') as HTMLInputElement;
  const copyBtn = document.getElementById('copy-btn')!;
  const uploadAnother = document.getElementById('upload-another')!;
  const errorRetry = document.getElementById('error-retry')!;
  const errorLogin = document.getElementById('error-login')!;
  const errorText = document.getElementById('error-text')!;
  const errorSignin = document.getElementById('error-signin')!;


  // Read i18n strings from data attributes
  const i18n = {
    uploading: panel.dataset.uploading || 'UPLOADING...',
    copied: panel.dataset.copied || 'COPIED!',
    copy: panel.dataset.copy || 'COPY',
    failed: panel.dataset.failed || 'Upload failed',
    clickOrDrag: panel.dataset.clickOrDrag || 'Click to upload or drag & drop',
    formats: panel.dataset.formats || 'JPG, PNG, WebP, GIF, SVG — up to 10 MB',
    selectFile: panel.dataset.selectFile || 'SELECT FILE',
    uploadingFile: panel.dataset.uploadingFile || 'Uploading {name}',
  };

  function showState(state: 'idle' | 'success' | 'error') {
    stateIdle.classList.toggle('hidden', state !== 'idle');
    stateSuccess.classList.toggle('hidden', state !== 'success');
    stateError.classList.toggle('hidden', state !== 'error');
  }

  function resetIdle() {
    showState('idle');
    progressBar.classList.add('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'upload_file';
    uploadText.textContent = i18n.clickOrDrag;
    uploadSubtext.textContent = i18n.formats;
    uploadBtn.textContent = i18n.selectFile;
    fileInput.value = '';
    errorSignin.classList.add('hidden');
    errorSignin.classList.remove('flex');
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  function showLoginError() {
    errorRetry.classList.add('hidden');
    errorLogin.classList.remove('hidden');
  }

  function showRetryError() {
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  // Click to open file picker
  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });

  // Drag and drop — target the whole panel
  panel.addEventListener('dragover', (e) => {
    e.preventDefault();
    panel.classList.add('!border-primary', '!bg-primary-fixed/30');
  });
  panel.addEventListener('dragleave', (e) => {
    if (!panel.contains(e.relatedTarget as Node)) {
      panel.classList.remove('!border-primary', '!bg-primary-fixed/30');
    }
  });
  panel.addEventListener('drop', (e) => {
    e.preventDefault();
    panel.classList.remove('!border-primary', '!bg-primary-fixed/30');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) uploadFile(files[0]);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) uploadFile(fileInput.files[0]);
  });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultUrl.value);
    copyBtn.textContent = i18n.copied;
    setTimeout(() => { copyBtn.textContent = i18n.copy; }, 2000);
  });

  uploadAnother.addEventListener('click', resetIdle);
  errorRetry.addEventListener('click', resetIdle);

  // CTA button scrolls to top and opens file picker
  const ctaBtn = document.getElementById('cta-upload-btn');
  if (ctaBtn) {
    ctaBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      setTimeout(() => fileInput.click(), 500);
    });
  }

  async function uploadFile(file: File) {
    // "Never" requires a signed-in account; server clamps anon to 24h otherwise.
    if (expiresInSel?.value === 'never') {
      const loggedIn = await fetchLoggedIn();
      if (!loggedIn) {
        showState('error');
        errorText.textContent = 'Sign in to upload images that never expire.';
        errorSignin.classList.remove('hidden');
        errorSignin.classList.add('flex');
        showLoginError();
        fileInput.value = '';
        return;
      }
    }

    // Show uploading state (stays in idle panel)
    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'hourglass_top';
    uploadText.textContent = i18n.uploadingFile.replace('{name}', file.name);
    uploadSubtext.textContent = `${(file.size / 1024).toFixed(0)} KB · ${file.type.split('/')[1].toUpperCase()}`;
    uploadBtn.textContent = i18n.uploading;

    const MIN_UPLOAD_MS = 5000;
    const startedAt = Date.now();

    const progressInterval = setInterval(() => {
      const elapsed = Date.now() - startedAt;
      const target = Math.min(95, (elapsed / MIN_UPLOAD_MS) * 95);
      progressFill.style.width = `${target}%`;
    }, 100);

    try {
      const formData = new FormData();
      formData.append('file', file);
      const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
      if (expiresInEl) formData.append('expires_in', expiresInEl.value);

      const response = await fetch('/api/upload', { method: 'POST', body: formData });
      const data = await response.json();

      if (!response.ok || data.error) {
        clearInterval(progressInterval);
        throw new Error(data.error || i18n.failed);
      }

      const remaining = MIN_UPLOAD_MS - (Date.now() - startedAt);
      if (remaining > 0) {
        await new Promise((r) => setTimeout(r, remaining));
      }

      clearInterval(progressInterval);
      progressFill.style.width = '100%';
      setTimeout(() => {
        showState('success');
        resultUrl.value = data.data.url;
      }, 300);

    } catch (err: any) {
      clearInterval(progressInterval);
      showState('error');
      errorText.textContent = err.message || i18n.failed;
      const isLimit = (err.message || '').toLowerCase().includes('limit');
      errorSignin.classList.toggle('hidden', !isLimit);
      errorSignin.classList.toggle('flex', isLimit);
      if (isLimit) showLoginError();
      else showRetryError();
    }
  }

  // Legacy click tracking (non-sponsor links)
  document.querySelectorAll<HTMLAnchorElement>('[data-track-click]').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.sendBeacon('/api/track/click', JSON.stringify({
        linkId: el.dataset.trackClick,
        page: window.location.pathname,
      }));
    });
  });

  // Sponsored ads: click tracking
  document.querySelectorAll<HTMLAnchorElement>('[data-track-sponsor-click]').forEach((el) => {
    el.addEventListener('click', () => {
      const adId = el.dataset.trackSponsorClick;
      if (!adId) return;
      navigator.sendBeacon('/api/track/sponsor', JSON.stringify({
        adId,
        type: 'click',
        page: window.location.pathname,
      }));
    });
  });

  // Sponsored ads: view tracking (dedupe per sessionStorage)
  const viewEls = document.querySelectorAll<HTMLElement>('[data-track-sponsor-view]');
  if (viewEls.length && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const el = entry.target as HTMLElement;
        const adId = el.dataset.trackSponsorView;
        if (!adId) { io.unobserve(el); continue; }
        const key = 'sponsor_view_' + adId;
        try {
          if (sessionStorage.getItem(key)) { io.unobserve(el); continue; }
          sessionStorage.setItem(key, '1');
        } catch {
          // sessionStorage unavailable (private mode) — still fire once per page load
        }
        navigator.sendBeacon('/api/track/sponsor', JSON.stringify({
          adId,
          type: 'view',
          page: window.location.pathname,
        }));
        io.unobserve(el);
      }
    }, { threshold: 0.5 });
    viewEls.forEach((el) => io.observe(el));
  }
</script>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer')!;
      const icon = btn.querySelector('.faq-icon')!;
      const isOpen = !answer.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.faq-item').forEach((faq) => {
        faq.querySelector('.faq-answer')!.classList.add('hidden');
        faq.querySelector('.faq-toggle')!.setAttribute('aria-expanded', 'false');
        faq.querySelector('.faq-icon')!.classList.remove('rotate-180');
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        answer.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>

<style>
  @keyframes sponsor-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }
  @keyframes sponsor-nudge {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(2px); }
  }
  .sponsor-card {
    animation: sponsor-float 4s ease-in-out infinite;
  }
  .sponsor-card:nth-of-type(1) { animation-delay: 0s; }
  .sponsor-card:nth-of-type(2) { animation-delay: 2s; }
  .sponsor-arrow {
    display: inline-block;
    animation: sponsor-nudge 2.2s ease-in-out infinite;
  }
  .sponsor-card:hover { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) {
    .sponsor-card, .sponsor-arrow { animation: none; }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';


const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}



const canonicalHomeUrl = `https://imagetourl.cloud/${locale}/`;

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "@id": "https://imagetourl.cloud/#software",
    "name": "ImageToURL",
    "url": "https://imagetourl.cloud",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript and HTML5",
    "description": "Upload any image and instantly receive a permanent, CDN-delivered shareable URL. Supports JPG, PNG, WebP, GIF, and SVG up to 10 MB. No account required.",
    "featureList": [
      "Drag and drop image upload",
      "Instant permanent URL generation",
      "Global CDN delivery",
      "SSL-encrypted links",
      "No signup required for free tier",
      "REST API access",
      "Markdown and HTML export",
      "Custom link expiration"
    ],
    "screenshot": "https://imagetourl.cloud/og-default.png",
    "offers": [
      {
        "@type": "Offer",
        "name": "Free",
        "price": "0",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "description": "10 uploads per month, standard processing speed, public link library.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "priceCurrency": "USD",
        "price": "12",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "12",
          "priceCurrency": "USD",
          "billingDuration": "P1M",
          "unitCode": "MON"
        },
        "description": "Unlimited uploads, high-priority processing, custom link expiration, API access.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Business",
        "priceCurrency": "USD",
        "price": "49",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "49",
          "priceCurrency": "USD",
          "billingDuration": "P1M",
          "unitCode": "MON"
        },
        "description": "Everything in Pro plus team workspaces, ultra-high resolution, and dedicated support.",
        "url": "https://imagetourl.cloud/pricing"
      }
    ],
    "publisher": {
      "@id": "https://imagetourl.cloud/#organization"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalHomeUrl}#webpage`,
    "url": canonicalHomeUrl,
    "name": "ImageToURL — Turn Images into Shareable Links",
    "description": "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery.",
    "inLanguage": locale,
    "isPartOf": { "@id": "https://imagetourl.cloud/#website" },
    "about": { "@id": "https://imagetourl.cloud/#software" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": canonicalHomeUrl }
      ]
    }
  }
];
---

<Layout schema={pageSchema} title={t(locale, 'home.meta.title')} description={t(locale, 'home.meta.description')}>
  <Nav activePage="home" />

  <!-- Hero Section — Immediate, action-focused -->
  <section class="max-w-4xl lg:max-w-6xl mx-auto px-4 sm:px-6 pt-6 sm:pt-8">
    <div class="w-full lg:flex lg:items-start lg:justify-center lg:gap-6">
      <!-- Vertical ad — left (160x600 wide skyscraper, bottom-aligned with upload tool) -->
      <aside class="hidden lg:block lg:flex-shrink-0 lg:w-[160px] lg:h-[600px] lg:overflow-hidden" aria-label="Sponsored">
        <ins
          class="adsbygoogle"
          style="display:inline-block;width:160px;height:600px"
          data-ad-client="ca-pub-7803867089582138"
          data-ad-slot="1115981593"
        ></ins>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </aside>

      <!-- Center column: badge, headline, upload tool -->
      <div class="flex flex-col text-center lg:flex-1 lg:max-w-2xl lg:min-w-0">
        <div class="max-w-4xl mx-auto w-full">
          <div class="inline-block bg-rose-600 text-white px-3 py-1 font-headline text-[10px] font-medium uppercase tracking-widest mb-3 border-2 border-neutral-900">
            {t(locale, 'home.hero.badge')}
          </div>
          <h1 class="font-headline text-xl sm:text-2xl md:text-3xl font-semibold text-on-background leading-[1.05] tracking-tighter uppercase mb-2 sm:mb-3">
            {t(locale, 'home.hero.headline1')} <span class="text-rose-600">{t(locale, 'home.hero.headline2')}</span>
          </h1>
          <p class="font-body text-xs sm:text-sm text-on-surface-variant leading-relaxed max-w-md mx-auto mb-4 sm:mb-5 px-2">
            {t(locale, 'home.hero.subheadline')}
          </p>
        </div>

        <!-- AdSense — slim horizontal banner -->
        <div class="w-full max-w-2xl mx-auto mb-4 overflow-hidden" style="max-height:90px">
          <ins
            class="adsbygoogle"
            style="display:block;width:100%;height:90px"
            data-ad-client="ca-pub-7803867089582138"
            data-ad-slot="8598885796"
            data-ad-format="horizontal"
            data-full-width-responsive="false"
          ></ins>
          <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>

    <div class="w-full max-w-xl mx-auto">
      <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" class="hidden" />
      <!-- Privacy / auto-delete control -->
      <div class="bg-white border-2 border-on-background border-b-0 px-4 py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4">
        <div class="flex items-center gap-2 min-w-0">
          <span class="material-symbols-outlined text-rose-600 text-lg flex-shrink-0" style="font-variation-settings: 'FILL' 1;">timer</span>
          <div class="min-w-0">
            <div class="flex items-center gap-1.5">
              <label for="expires-in" class="block text-xs font-bold uppercase tracking-wider text-on-background">Auto-delete</label>
              <button
                type="button"
                id="expires-in-help"
                aria-label="What does auto-delete do?"
                aria-expanded="false"
                aria-controls="expires-in-help-panel"
                class="inline-flex items-center justify-center w-6 h-6 sm:w-5 sm:h-5 border border-on-background text-xs sm:text-[10px] font-bold hover:bg-rose-600 hover:text-white hover:border-rose-600 transition-colors"
              >?</button>
            </div>
            <p id="expires-in-hint" class="text-[11px] leading-tight text-on-surface-variant mt-0.5">Auto-deletes in 7 days</p>
          </div>
        </div>
        <select
          id="expires-in"
          aria-describedby="expires-in-hint"
          class="w-full sm:w-auto sm:min-w-[140px] bg-white border-2 border-on-background px-4 py-3 text-sm font-bold uppercase tracking-wider focus:outline-none focus:border-rose-600 sm:flex-shrink-0 min-h-[44px]"
        >
          <option value="7d">7 days</option>
          <option value="1h">1 hour</option>
          <option value="24h">24 hours</option>
          <option value="30d">30 days</option>
          <option value="never">Never</option>
        </select>
      </div>
      <div
        id="expires-in-warning"
        class="hidden bg-white border-2 border-rose-600 border-t-0 border-b-0 px-4 py-3 text-sm sm:text-xs font-bold text-on-background leading-snug"
        role="status"
      >
        <p id="expires-in-warning-text"></p>
      </div>
      <div
        id="expires-in-help-panel"
        class="hidden bg-white border-2 border-on-background border-t-0 border-b-0 px-4 py-3 text-xs text-on-surface-variant leading-snug"
        role="region"
        aria-labelledby="expires-in-help"
      >
        Your image is auto-deleted after 7 days by default. Pick a longer window to keep it around, or a shorter one to wipe it sooner. Logged-out uploads max out at 24 hours regardless.
      </div>
      <div
        id="upload-panel"
        class="bg-white border-2 border-dashed border-on-background overflow-hidden transition-colors"
        data-uploading={t(locale, 'home.upload.uploading')}
        data-copied={t(locale, 'home.upload.copied')}
        data-copy={t(locale, 'home.upload.copy')}
        data-failed={t(locale, 'home.upload.failed')}
        data-click-or-drag={t(locale, 'home.upload.clickOrDrag')}
        data-formats={t(locale, 'home.upload.formats')}
        data-select-file={t(locale, 'home.upload.selectFile')}
        data-uploading-file={t(locale, 'home.upload.uploadingFile')}
      >
        <!-- State: idle / uploading -->
        <div id="state-idle" class="px-6 py-12 sm:px-10 sm:py-16">
          <div id="drop-zone" class="flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
            <span class="material-symbols-outlined text-on-background text-4xl sm:text-5xl" id="upload-icon">add_photo_alternate</span>
            <div class="text-center">
              <p class="text-on-background font-headline font-medium text-sm sm:text-base uppercase tracking-wider" id="upload-text">Drop image here or click to browse</p>
              <p class="text-xs sm:text-sm text-on-surface-variant mt-2" id="upload-subtext">JPG, PNG, WebP, GIF, SVG &mdash; Max 10MB</p>
            </div>
            <div class="sr-only" id="upload-btn">{t(locale, 'home.upload.selectFile')}</div>
          </div>
          <div id="progress-bar" class="hidden mt-5 h-2 bg-surface-variant overflow-hidden rounded-full">
            <div id="progress-fill" class="h-full bg-primary transition-all duration-300 rounded-full" style="width: 0%"></div>
          </div>
        </div>

        <!-- State: success -->
        <div id="state-success" class="p-4 sm:p-6 hidden">
          <div class="flex items-center gap-3 mb-4">
            <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
            <span class="font-bold text-secondary text-sm sm:text-base">{t(locale, 'home.upload.uploaded')}</span>
            <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
              {t(locale, 'home.upload.uploadAnother')}
            </button>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="text" id="result-url" readonly class="flex-1 min-w-0 bg-white border-2 border-on-background px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-600" />
            <button id="copy-btn" class="bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide flex-shrink-0">
              {t(locale, 'home.upload.copy')}
            </button>
          </div>

        </div>

        <!-- State: error -->
        <div id="state-error" class="p-4 sm:p-6 hidden">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-error flex-shrink-0 text-2xl">error</span>
            <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">{t(locale, 'home.upload.failed')}</span>
            <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
              {t(locale, 'home.upload.tryAgain')}
            </button>
            <a id="error-login" href="/api/auth/login" class="hidden text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
              LOGIN
            </a>
          </div>
          <!-- Sign in CTA for limit errors -->
          <a href="/api/auth/login" id="error-signin" class="hidden items-center gap-2 mt-3 pt-3 border-t border-outline-variant/50 text-on-background hover:opacity-80 transition-opacity group">
            <span class="material-symbols-outlined text-base text-primary">login</span>
            <span class="text-xs sm:text-sm font-bold">Sign in to get more uploads</span>
            <span class="material-symbols-outlined text-sm text-primary group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
          </a>
        </div>
      </div>

        </div>
      </div><!-- /center column -->

      <!-- Vertical ad — right (160x600 wide skyscraper, bottom-aligned with upload tool) -->
      <aside class="hidden lg:block lg:flex-shrink-0 lg:w-[160px] lg:h-[600px] lg:overflow-hidden" aria-label="Sponsored">
        <ins
          class="adsbygoogle"
          style="display:inline-block;width:160px;height:600px"
          data-ad-client="ca-pub-7803867089582138"
          data-ad-slot="1115981593"
        ></ins>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </aside>
    </div><!-- /flex wrapper -->

    <!-- Trust Signals — pushed to bottom of viewport -->
    <div class="flex flex-wrap justify-center gap-3 sm:gap-5 mt-4 sm:mt-6 pb-2 sm:pb-3 text-xs text-on-surface-variant font-label font-bold uppercase tracking-wider">
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">rocket_launch</span> <span class="hidden sm:inline">{t(locale, 'home.trust.cdn')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">lock</span> <span class="hidden sm:inline">{t(locale, 'home.trust.ssl')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">link</span> <span class="hidden sm:inline">{t(locale, 'home.trust.permanent')}</span></span>
      <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base" style="font-variation-settings: 'FILL' 1;">flash_on</span> <span class="hidden sm:inline">{t(locale, 'home.trust.instant')}</span></span>
    </div>
  </section>

  <!-- How It Works -->
  <section class="cv-auto max-w-5xl mx-auto px-4 sm:px-6 pt-2 pb-8 sm:pt-3 sm:pb-12">
    <div class="text-center mb-5 sm:mb-8 reveal">
      <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.howItWorks.title')}</h2>
      <p class="font-body text-on-surface-variant text-sm">{t(locale, 'home.howItWorks.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 reveal-stagger">
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">1</div>
        <div>
          <span class="material-symbols-outlined text-primary text-lg sm:text-xl mb-2 block">cloud_upload</span>
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.upload.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.upload.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">2</div>
        <div>
          <span class="material-symbols-outlined text-primary text-lg sm:text-xl mb-2 block">bolt</span>
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.convert.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.convert.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">3</div>
        <div>
          <span class="material-symbols-outlined text-primary text-lg sm:text-xl mb-2 block">share</span>
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.share.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.share.description')}</p>
        </div>
      </div>
    </div>
  </section>



  <!-- Features Grid -->
  <section class="cv-auto py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-5 sm:mb-8 reveal">
        <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.features.title')}</h2>
        <p class="font-body text-on-surface-variant text-sm">{t(locale, 'home.features.description')}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 reveal-stagger">
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">rocket_launch</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.cdn.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.cdn.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">lock_open</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.noSignup.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.noSignup.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">link</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.permanent.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.permanent.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">https</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.ssl.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.ssl.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">flash_on</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.instant.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.instant.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <span class="material-symbols-outlined text-primary text-2xl mb-2 block">aspect_ratio</span>
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.resize.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.resize.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="cv-auto max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-5 sm:mb-8 reveal">
      <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.useCases.title')}</h2>
      <p class="font-body text-on-surface-variant text-sm">{t(locale, 'home.useCases.subtitle')}</p>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 reveal-stagger">
      <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5">
        <span class="material-symbols-outlined text-primary text-2xl mb-2 block">edit_note</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.bloggers.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.bloggers.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5">
        <span class="material-symbols-outlined text-primary text-2xl mb-2 block">terminal</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.developers.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.developers.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5">
        <span class="material-symbols-outlined text-primary text-2xl mb-2 block">school</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.students.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.students.description')}</p>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5">
        <span class="material-symbols-outlined text-primary text-2xl mb-2 block">palette</span>
        <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.useCases.creators.title')}</h3>
        <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.useCases.creators.description')}</p>
      </div>
    </div>
  </section>



  <!-- Testimonials -->
  <section class="cv-auto px-4 sm:px-6 py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">

      {hasReviews && (
        <div class="reviews-marquee relative" aria-label="What our users say">
          <div class="reviews-marquee-track flex gap-4 sm:gap-5 w-max" style={`--marquee-duration:${Math.max(40, reviews.length * 3.5)}s`}>
            {[...reviews, ...reviews].map((r, idx) => {
              const i = idx % reviews.length;
              const dup = idx >= reviews.length;
              const initials = (r.name || '?').split(/\s+/).map((w) => w[0] || '').slice(0, 2).join('').toUpperCase();
              const avatarBg = ['bg-primary-fixed', 'bg-tertiary-fixed', 'bg-secondary-fixed'][i % 3];
              return (
                <figure

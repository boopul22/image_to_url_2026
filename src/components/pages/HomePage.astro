---
import Icon from '../Icon.astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { localizedUrl } from '../../i18n/landing/registry';
import { getDB } from '../../lib/db';
import { getApprovedReviews, getReviewStats } from '../../lib/reviews';
import AdRail from '../ads/AdRail.astro';


const locale: Locale = Astro.locals.locale ?? defaultLocale;
const currentUser = Astro.locals.user ?? null;

function lp(path: string): string {
  return `/${locale}${path}`;
}



const canonicalHomeUrl = `https://imagetourl.cloud/${locale}/`;

// Reviews come from the `reviews` table (D1): submitted by signed-in users,
// shown here once an admin approves them. See src/lib/reviews.ts.
type DisplayReview = {
  name: string;
  role: string | null;
  avatar: string | null;
  rating: number;
  date: string;
  quote: string;
};

// De-identify reviewers for public display: first name + last initial
// (e.g. "Aman Sharma" -> "Aman S."). Single-word names are left as-is.
// Real names/photos stay in the DB for admin moderation only.
function maskName(full: string): string {
  const parts = (full || '').trim().split(/\s+/).filter(Boolean);
  if (parts.length >= 2) {
    const initial = parts[parts.length - 1][0];
    return initial ? `${parts[0]} ${initial.toUpperCase()}.` : parts[0];
  }
  return parts[0] || 'ImageToURL user';
}

let reviews: DisplayReview[] = [];
let reviewStats = { total: 0, average: 0 };
try {
  const db = getDB(Astro.locals);
  const [rows, stats] = await Promise.all([
    getApprovedReviews(db, 24),
    getReviewStats(db),
  ]);
  reviewStats = stats;
  reviews = rows.map((r) => ({
    name: maskName(r.name),
    role: r.role,
    avatar: null, // de-identified: show initials, not real profile photos
    rating: r.rating,
    date: (r.created_at || '').slice(0, 10),
    quote: r.body,
  }));
} catch (err) {
  // No DB binding (e.g. during prerender/build) — degrade to an empty section.
  console.error('reviews load failed', err);
}

// Count + average across ALL approved reviews; the carousel shows a recent subset.
const reviewCount = reviewStats.total;
const ratingValue = reviewStats.average ? reviewStats.average.toFixed(1) : '5.0';
const hasReviews = reviews.length > 0;

const aggregateRating = hasReviews
  ? {
      "@type": "AggregateRating",
      "ratingValue": ratingValue,
      "bestRating": "5",
      "worstRating": "1",
      "reviewCount": String(reviewCount),
    }
  : null;

const reviewSchema = reviews.map((r) => ({
  "@type": "Review",
  "author": { "@type": "Person", "name": r.name },
  "datePublished": r.date,
  "reviewBody": r.quote,
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": String(r.rating),
    "bestRating": "5",
    "worstRating": "1",
  },
}));

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "@id": "https://imagetourl.cloud/#software",
    "name": "ImageToURL",
    "url": "https://imagetourl.cloud",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript and HTML5",
    "description": "Upload any image and instantly receive a permanent, CDN-delivered shareable URL. Supports JPG, PNG, WebP, GIF, and SVG up to 10 MB. No account required.",
    "featureList": [
      "Drag and drop image upload",
      "Instant permanent URL generation",
      "Global CDN delivery",
      "SSL-encrypted links",
      "No signup required for free tier",
      "REST API access",
      "Markdown and HTML export",
      "Custom link expiration"
    ],
    "screenshot": "https://imagetourl.cloud/og-default.png",
    "offers": [
      {
        "@type": "Offer",
        "name": "Free",
        "price": "0",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "description": "10 uploads per month, standard processing speed, public link library.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "priceCurrency": "USD",
        "price": "12",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "12",
          "priceCurrency": "USD",
          "billingDuration": "P1M",
          "unitCode": "MON"
        },
        "description": "Unlimited uploads, high-priority processing, custom link expiration, API access.",
        "url": "https://imagetourl.cloud/pricing"
      },
      {
        "@type": "Offer",
        "name": "Business",
        "priceCurrency": "USD",
        "price": "49",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "49",
          "priceCurrency": "USD",
          "billingDuration": "P1M",
          "unitCode": "MON"
        },
        "description": "Everything in Pro plus team workspaces, ultra-high resolution, and dedicated support.",
        "url": "https://imagetourl.cloud/pricing"
      }
    ],
    "publisher": {
      "@id": "https://imagetourl.cloud/#organization"
    },
    ...(hasReviews ? { aggregateRating, review: reviewSchema } : {})
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonicalHomeUrl}#webpage`,
    "url": canonicalHomeUrl,
    "name": "ImageToURL — Turn Images into Shareable Links",
    "description": "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery.",
    "inLanguage": locale,
    "isPartOf": { "@id": "https://imagetourl.cloud/#website" },
    "about": { "@id": "https://imagetourl.cloud/#software" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": canonicalHomeUrl }
      ]
    }
  }
];
---

<Layout schema={pageSchema} title={t(locale, 'home.meta.title')} description={t(locale, 'home.meta.description')}>
  <Nav activePage="home" />

  <!-- Hero Section — Immediate, action-focused -->
  <section class="max-w-4xl lg:max-w-6xl xl:max-w-7xl mx-auto px-4 sm:px-6 pt-6 sm:pt-8">
    <div class="w-full xl:flex xl:items-start xl:justify-center xl:gap-6">
      <!-- Left rail — two stacked responsive ad units (vertical + square) -->
      <AdRail side="left" />

      <!-- Center column: badge, headline, upload tool -->
      <div class="flex flex-col text-center xl:flex-1 xl:max-w-2xl xl:min-w-0">
        <div class="max-w-4xl mx-auto w-full">
          <div class="inline-block bg-rose-600 text-white px-3 py-1 font-headline text-[10px] font-medium uppercase tracking-widest mb-3 border border-outline-variant/40">
            {t(locale, 'home.hero.badge')}
          </div>
          <h1 class="font-headline text-xl sm:text-2xl md:text-3xl font-semibold text-on-background leading-[1.05] tracking-tighter uppercase mb-2 sm:mb-3">
            {t(locale, 'home.hero.headline1')} <span class="text-rose-700">{t(locale, 'home.hero.headline2')}</span>
          </h1>
          <p class="font-body text-xs sm:text-sm text-on-surface-variant leading-relaxed max-w-md mx-auto mb-4 sm:mb-5 px-2">
            {t(locale, 'home.hero.subheadline')}
          </p>
        </div>

    <div class="soft-uploader w-full max-w-xl mx-auto">
      <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" class="hidden" />

      <!-- Soft drop card: padded gray shell -->
      <div class="su-card su-inner-shadow bg-surface-container p-2 border border-outline-variant/40">
        <!-- Drop area -->
        <div
          id="upload-panel"
          class="su-drop relative bg-white border border-dashed border-outline-variant overflow-hidden transition-all duration-300"
          data-uploading={t(locale, 'home.upload.uploading')}
          data-copied={t(locale, 'home.upload.copied')}
          data-copy={t(locale, 'home.upload.copy')}
          data-failed={t(locale, 'home.upload.failed')}
          data-click-or-drag={t(locale, 'home.upload.clickOrDrag')}
          data-formats={t(locale, 'home.upload.formats')}
          data-select-file={t(locale, 'home.upload.selectFile')}
          data-uploading-file={t(locale, 'home.upload.uploadingFile')}
        >
          <!-- State: idle / uploading -->
          <div id="state-idle" class="relative min-h-[320px]">
            <div id="drop-zone" class="group absolute inset-0 flex flex-col items-center justify-center gap-4 px-6 pb-24 cursor-pointer" role="button" tabindex="0">
              <Icon name="cloud_upload" class="text-on-surface-variant/30 group-hover:text-rose-500 group-hover:scale-110 transition-all duration-300 text-5xl sm:text-6xl" id="upload-icon" />
              <div class="text-center">
                <p class="text-on-surface-variant font-medium text-sm sm:text-base transition-opacity duration-300 group-hover:opacity-70" id="upload-text">{t(locale, 'home.upload.clickOrDrag')}</p>
                <p class="text-[11px] sm:text-xs text-on-surface-variant/60 mt-1" id="upload-subtext">JPG, PNG, WebP, GIF, SVG &mdash; Max 10MB</p>
              </div>
              <div id="progress-bar" class="su-progress hidden w-full max-w-xs h-2 bg-surface-variant overflow-hidden">
                <div id="progress-fill" class="su-progress h-full bg-rose-600 transition-all duration-300" style="width: 0%"></div>
              </div>
              <div class="sr-only" id="upload-btn">{t(locale, 'home.upload.selectFile')}</div>
            </div>

            <!-- Floating action island: auto-delete + Browse -->
            <div class="su-island su-soft-shadow absolute bottom-5 left-1/2 -translate-x-1/2 z-10 bg-white border border-outline-variant/30 flex items-center gap-2 p-2 w-[92%] max-w-[380px]">
              <div class="su-control flex items-center gap-2 bg-surface-container-low px-3 py-2 flex-1 min-w-0 hover:bg-surface-container transition-colors">
                <Icon name="schedule" class="text-rose-600 text-base flex-shrink-0" fill />
                <div class="relative flex-1 min-w-0">
                  <select
                    id="expires-in"
                    aria-label="Auto-delete after"
                    aria-describedby="expires-in-hint"
                    class="su-control appearance-none w-full bg-transparent text-xs font-semibold text-on-surface pr-5 outline-none cursor-pointer"
                  >
                    <option value="auto">Auto-expire</option>
                    <option value="never">Never delete</option>
                  </select>
                  <Icon name="expand_more" class="absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant/60 text-base pointer-events-none" />
                </div>
              </div>
              <button
                type="button"
                id="browse-btn"
                class="su-btn bg-rose-600 hover:bg-rose-700 text-white text-xs font-semibold px-5 py-2.5 transition-colors whitespace-nowrap active:scale-95 flex-shrink-0"
                style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);"
              >
                {t(locale, 'home.upload.selectFile')}
              </button>
            </div>
          </div>

          <!-- State: success -->
          <div id="state-success" class="p-4 sm:p-6 hidden">
            <div class="flex items-center gap-3 mb-4">
              <Icon name="check_circle" class="text-rose-600 text-lg sm:text-xl" fill />
              <span class="font-bold text-on-surface text-sm sm:text-base">{t(locale, 'home.upload.uploaded')}</span>
              <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                {t(locale, 'home.upload.uploadAnother')}
              </button>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
              <input type="text" id="result-url" readonly class="su-control flex-1 min-w-0 bg-surface-container-low border border-outline-variant px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-500" />
              <button id="copy-btn" class="su-btn bg-rose-600 hover:bg-rose-700 text-white font-semibold text-sm py-3 px-6 transition-colors active:scale-95 flex-shrink-0" style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);">
                {t(locale, 'home.upload.getLink')}
              </button>
            </div>

          </div>

          <!-- State: error -->
          <div id="state-error" class="p-4 sm:p-6 hidden">
            <div class="flex items-center gap-3">
              <Icon name="error" class="text-error flex-shrink-0 text-2xl" />
              <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">{t(locale, 'home.upload.failed')}</span>
              <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                {t(locale, 'home.upload.tryAgain')}
              </button>
              <a id="error-login" href="/api/auth/login" class="hidden text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                LOGIN
              </a>
            </div>
            <!-- Sign in CTA for limit errors -->
            <a href="/api/auth/login" id="error-signin" class="hidden items-center gap-2 mt-3 pt-3 border-t border-outline-variant/40 text-on-background hover:opacity-80 transition-opacity group">
              <Icon name="login" class="text-base text-primary" />
              <span class="text-xs sm:text-sm font-bold">Sign in to get more uploads</span>
              <Icon name="arrow_forward" class="text-sm text-primary group-hover:translate-x-0.5 transition-transform" />
            </a>
          </div>
        </div>
      </div>

      <!-- Expiry notice: one quiet footnote line. Default behavior + permanent-link
           hint inline; the full explanation lives behind the "?" toggle. -->
      <div class="mt-3 w-full max-w-md mx-auto">
        <p class="flex items-center justify-center flex-wrap gap-x-1.5 gap-y-1 text-xs text-on-surface-variant text-center">
          <Icon name="schedule" class="text-rose-500 text-sm" fill />
          <span id="expires-in-hint" class="font-medium text-on-surface">Auto-expires in ~2 weeks</span>
          <span class="text-on-surface-variant/40">·</span>
          <a href="/api/auth/login" class="font-semibold text-primary hover:underline underline-offset-2">Sign in</a>
          <span>for permanent links</span>
          <button
            type="button"
            id="expires-in-help"
            aria-label="What does auto-delete do?"
            aria-expanded="false"
            aria-controls="expires-in-help-panel"
            class="su-control inline-flex items-center justify-center w-[16px] h-[16px] rounded-full border border-outline-variant text-[10px] font-bold text-on-surface-variant hover:bg-rose-600 hover:text-white hover:border-rose-600 transition-colors flex-shrink-0"
          >?</button>
        </p>

        <div
          id="expires-in-help-panel"
          class="su-control hidden mt-2 bg-surface-container-low border border-outline-variant/40 px-4 py-3 text-xs text-on-surface-variant leading-relaxed text-left"
          role="region"
          aria-labelledby="expires-in-help"
        >
          Auto-expire images are cleared at the start of each month, so you always get at least about two weeks. Choose "Never delete" (sign-in required) for a permanent link that never breaks.
        </div>
      </div>

        </div>
      </div><!-- /center column -->

      <!-- Right rail — two stacked responsive ad units (vertical + square) -->
      <AdRail side="right" />
    </div><!-- /flex wrapper -->

    <!-- Trust Signals — pushed to bottom of viewport -->
    <div class="flex flex-wrap justify-center gap-3 sm:gap-5 mt-4 sm:mt-6 pb-2 sm:pb-3 text-xs text-on-surface-variant font-label font-bold uppercase tracking-wider">
      <span class="flex items-center gap-1.5"><Icon name="rocket_launch" class="text-primary text-base" fill /> <span class="hidden sm:inline">{t(locale, 'home.trust.cdn')}</span></span>
      <span class="flex items-center gap-1.5"><Icon name="lock" class="text-primary text-base" fill /> <span class="hidden sm:inline">{t(locale, 'home.trust.ssl')}</span></span>
      <span class="flex items-center gap-1.5"><Icon name="link" class="text-primary text-base" fill /> <span class="hidden sm:inline">{t(locale, 'home.trust.permanent')}</span></span>
      <span class="flex items-center gap-1.5"><Icon name="flash_on" class="text-primary text-base" fill /> <span class="hidden sm:inline">{t(locale, 'home.trust.instant')}</span></span>
    </div>
  </section>

  <!-- Mobile/tablet in-content ad — fills the slot gap where desktop has skyscrapers.
       Multiplex (autorelaxed) grid; below the fold → lazy-loaded by the observer in
       Layout.astro (data-ad-lazy). -->
  <div class="xl:hidden max-w-2xl mx-auto px-4 sm:px-6 mb-6">
    <div class="ad-reserve">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="1349470215"
        data-ad-lazy></ins>
    </div>
  </div>

  <!-- How It Works -->
  <section class="cv-auto max-w-5xl mx-auto px-4 sm:px-6 pt-2 pb-8 sm:pt-3 sm:pb-12">
    <div class="text-center mb-5 sm:mb-8 reveal">
      <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.howItWorks.title')}</h2>
      <p class="font-body text-on-surface-variant text-sm">{t(locale, 'home.howItWorks.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 reveal-stagger">
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">1</div>
        <div>
          <Icon name="cloud_upload" class="text-primary text-lg sm:text-xl mb-2 block" />
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.upload.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.upload.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">2</div>
        <div>
          <Icon name="bolt" class="text-primary text-lg sm:text-xl mb-2 block" />
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.convert.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.convert.description')}</p>
        </div>
      </div>
      <div class="reveal bg-surface-container rounded-2xl p-5 sm:p-6 relative">
        <div class="w-8 h-8 rounded-full bg-primary text-on-primary flex items-center justify-center font-headline text-sm font-black mb-3">3</div>
        <div>
          <Icon name="share" class="text-primary text-lg sm:text-xl mb-2 block" />
          <h3 class="font-headline text-lg sm:text-xl font-black text-on-background mb-1.5">{t(locale, 'home.howItWorks.share.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.howItWorks.share.description')}</p>
        </div>
      </div>
    </div>
  </section>



  <!-- Features Grid -->
  <section class="cv-auto py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-5 sm:mb-8 reveal">
        <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.features.title')}</h2>
        <p class="font-body text-on-surface-variant text-sm">{t(locale, 'home.features.description')}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 reveal-stagger">
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="rocket_launch" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.cdn.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.cdn.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="lock_open" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.noSignup.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.noSignup.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="link" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.permanent.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.permanent.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="https" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.ssl.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.ssl.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="flash_on" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.instant.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.instant.description')}</p>
        </div>
        <div class="reveal bg-surface-container rounded-2xl p-4 sm:p-5 hover:-translate-y-0.5 transition-transform cursor-default">
          <Icon name="aspect_ratio" class="text-primary text-2xl mb-2 block" />
          <h3 class="font-headline text-lg font-black text-on-background mb-1">{t(locale, 'home.features.grid.resize.title')}</h3>
          <p class="font-body text-on-surface-variant text-sm leading-relaxed">{t(locale, 'home.features.grid.resize.description')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="cv-auto max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <div class="text-center mb-5 sm:mb-8 reveal">
      <h2 class="font-headline text-lg sm:text-xl font-black text-on-background mb-2 sm:mb-3">{t(locale, 'home.useCases.title')}</h2>

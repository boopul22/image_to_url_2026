  <Footer />

  {/* Review modal — kept at the top level (outside the cv-auto/overflow-hidden
      reviews section) so `position: fixed` is relative to the viewport. Nesting it
      inside a content-visibility/overflow-hidden ancestor clipped + mis-positioned
      it, making the dialog appear stuck under the nav. */}
  {currentUser && (
    <div id="review-modal" class="hidden fixed inset-0 z-[60] items-center justify-center p-4">
      <div id="review-backdrop" class="absolute inset-0 bg-on-surface/50 backdrop-blur-sm"></div>
      <div role="dialog" aria-modal="true" aria-labelledby="review-modal-title" class="relative w-full max-w-md max-h-[90vh] overflow-y-auto bg-surface border border-outline-variant/40 rounded-2xl p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 id="review-modal-title" class="font-headline font-black text-on-background text-base">Write a review</h3>
          <button type="button" id="review-close" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-surface-container-highest transition-colors cursor-pointer" aria-label="Close">
            <Icon name="close" class="text-lg" />
          </button>

---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;
---

<Layout title={t(locale, 'privacy.meta.title')} description={t(locale, 'privacy.meta.description')}>
  <Nav activePage="" />

  <main class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="font-headline text-2xl sm:text-3xl font-semibold text-on-background mb-4">{t(locale, 'privacy.title')}</h1>
    <p class="text-lg text-outline mb-8">{t(locale, 'privacy.subtitle')}</p>

    <div class="landing-prose">

      <!-- Section 1: Information We Collect -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s1.title')}</h2>
        <div class="space-y-4">
          <div>
            <h3 class="text-lg font-semibold text-on-background mb-2">{t(locale, 'privacy.s1.techTitle')}</h3>
            <ul class="list-disc pl-6 space-y-2">
              <li>{t(locale, 'privacy.s1.tech1')}</li>
              <li>{t(locale, 'privacy.s1.tech2')}</li>
              <li>{t(locale, 'privacy.s1.tech3')}</li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-on-background mb-2">{t(locale, 'privacy.s1.analyticsTitle')}</h3>
            <p>{t(locale, 'privacy.s1.analyticsDesc')}</p>
          </div>
        </div>
      </section>

      <!-- Section 2: How We Protect Your Data -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s2.title')}</h2>
        <div class="space-y-4">
          <div>
            <h4 class="font-semibold text-on-background">{t(locale, 'privacy.s2.httpsTitle')}</h4>
            <p>{t(locale, 'privacy.s2.httpsDesc')}</p>
          </div>
          <div>
            <h4 class="font-semibold text-on-background">{t(locale, 'privacy.s2.storageTitle')}</h4>
            <p>{t(locale, 'privacy.s2.storageDesc')}</p>
          </div>
          <div>
            <h4 class="font-semibold text-on-background">{t(locale, 'privacy.s2.noRegTitle')}</h4>
            <p>{t(locale, 'privacy.s2.noRegDesc')}</p>
          </div>
        </div>
      </section>

      <!-- Section 3: Data Retention -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s3.title')}</h2>
        <div class="space-y-2">
          <p><strong>{t(locale, 'privacy.s3.imagesLabel')}</strong> {t(locale, 'privacy.s3.imagesDesc')}</p>
          <p><strong>{t(locale, 'privacy.s3.techLogsLabel')}</strong> {t(locale, 'privacy.s3.techLogsDesc')}</p>
          <p><strong>{t(locale, 'privacy.s3.errorLogsLabel')}</strong> {t(locale, 'privacy.s3.errorLogsDesc')}</p>
        </div>
      </section>

      <!-- Section 4: Third-Party Services -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s4.title')}</h2>
        <div class="space-y-4">
          <div>
            <h4 class="font-semibold text-on-background">{t(locale, 'privacy.s4.r2Title')}</h4>
            <p>{t(locale, 'privacy.s4.r2Desc')}</p>
          </div>
          <div>
            <h4 class="font-semibold text-on-background">{t(locale, 'privacy.s4.gaTitle')}</h4>
            <p>{t(locale, 'privacy.s4.gaDesc')}</p>
          </div>
          <div>
            <h4 class="font-semibold text-on-background">Google AdSense &amp; Advertising Cookies</h4>
            <p>
              We use Google AdSense, a third-party advertising service, to display ads on some pages of this site.
              Google and its third-party vendors (including the DoubleClick DART cookie) use cookies to serve ads
              based on your prior visits to this website or other websites. Google's use of advertising cookies
              enables it and its partners to serve ads to you based on your visit to our site and other sites on
              the Internet.
            </p>
            <p class="mt-3">
              You may opt out of personalized advertising by visiting
              <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener" class="underline">Google Ads Settings</a>,
              or opt out of a third-party vendor's use of cookies for personalized advertising by visiting
              <a href="https://www.aboutads.info/" target="_blank" rel="noopener" class="underline">www.aboutads.info</a>.
              For more information on how Google uses data, see
              <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener" class="underline">How Google uses information from sites or apps that use our services</a>.
            </p>
          </div>
        </div>
      </section>

      <!-- Section 5: Your Rights -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s5.title')}</h2>
        <p>{t(locale, 'privacy.s5.intro')}</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li>{t(locale, 'privacy.s5.item1')}</li>
          <li>{t(locale, 'privacy.s5.item2')}</li>
          <li>{t(locale, 'privacy.s5.item3')}</li>
        </ul>
        <p class="mt-4">{t(locale, 'privacy.s5.contact')}</p>
      </section>

      <!-- Section 6: Policy Updates -->
      <section>
        <h2 class="text-2xl font-headline font-bold text-on-background mb-4">{t(locale, 'privacy.s6.title')}</h2>
        <p>{t(locale, 'privacy.s6.intro')}</p>
        <ul class="list-disc pl-6 space-y-2 mt-4">
          <li>{t(locale, 'privacy.s6.item1')}</li>
          <li>{t(locale, 'privacy.s6.item2')}</li>
          <li>{t(locale, 'privacy.s6.item3')}</li>
        </ul>
        <p class="mt-4">{t(locale, 'privacy.s6.outro')}</p>
      </section>

      <!-- Section 7: Contact -->
      <section>
        <p><strong>{t(locale, 'privacy.s7.label')}</strong></p>
        <p>{t(locale, 'privacy.s7.contactIntro')} <a href={`mailto:${t(locale, 'privacy.s7.email')}`} class="underline">{t(locale, 'privacy.s7.email')}</a></p>
      </section>

    </div>

    <p class="text-sm text-outline mt-12">{t(locale, 'privacy.lastUpdated')}</p>
  </main>

  <Footer />
</Layout>

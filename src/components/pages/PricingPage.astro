---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return locale === defaultLocale ? path : `/${locale}${path}`;
}

const pageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://imagetourl.cloud/pricing#webpage",
    "url": "https://imagetourl.cloud/pricing",
    "name": t(locale, 'pricing.meta.title'),
    "description": t(locale, 'pricing.meta.description'),
    "isPartOf": { "@id": "https://imagetourl.cloud/#website" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": t(locale, 'nav.home'), "item": "https://imagetourl.cloud" },
        { "@type": "ListItem", "position": 2, "name": t(locale, 'nav.pricing'), "item": "https://imagetourl.cloud/pricing" }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": `ImageToURL ${t(locale, 'pricing.free.name')}`,
    "description": t(locale, 'pricing.free.description'),
    "url": "https://imagetourl.cloud/pricing",
    "brand": { "@id": "https://imagetourl.cloud/#organization" },
    "offers": {
      "@type": "Offer",
      "name": t(locale, 'pricing.free.name'),
      "price": "0",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://imagetourl.cloud/pricing",
      "priceValidUntil": "2027-12-31"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": `ImageToURL ${t(locale, 'pricing.pro.name')}`,
    "description": t(locale, 'pricing.pro.description'),
    "url": "https://imagetourl.cloud/pricing",
    "brand": { "@id": "https://imagetourl.cloud/#organization" },
    "offers": {
      "@type": "Offer",
      "name": t(locale, 'pricing.pro.name'),
      "price": "12",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://imagetourl.cloud/pricing",
      "priceValidUntil": "2027-12-31"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": `ImageToURL ${t(locale, 'pricing.business.name')}`,
    "description": t(locale, 'pricing.business.description'),
    "url": "https://imagetourl.cloud/pricing",
    "brand": { "@id": "https://imagetourl.cloud/#organization" },
    "offers": {
      "@type": "Offer",
      "name": t(locale, 'pricing.business.name'),
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://imagetourl.cloud/pricing",
      "priceValidUntil": "2027-12-31"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": t(locale, 'pricing.faq.q1'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": t(locale, 'pricing.faq.a1')
        }
      },
      {
        "@type": "Question",
        "name": t(locale, 'pricing.faq.q2'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": t(locale, 'pricing.faq.a2')
        }
      },
      {
        "@type": "Question",
        "name": t(locale, 'pricing.faq.q3'),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": t(locale, 'pricing.faq.a3')
        }
      }
    ]
  }
];
---

<Layout title={t(locale, 'pricing.meta.title')} description={t(locale, 'pricing.meta.description')} schema={pageSchema}>
  <Nav activePage="pricing" />

  <main class="max-w-7xl mx-auto px-6 py-20 relative">
    <!-- Floating Doodles -->
    <div class="absolute top-10 right-10 opacity-20 hidden lg:block">
      <span class="material-symbols-outlined text-6xl text-tertiary">flare</span>
    </div>
    <div class="absolute top-40 left-10 opacity-20 hidden lg:block">
      <span class="material-symbols-outlined text-5xl text-secondary">auto_awesome</span>
    </div>

    <!-- Header -->
    <header class="text-center mb-20">
      <h1 class="font-headline italic font-black text-6xl md:text-7xl lg:text-8xl tracking-tight mb-6">
        {t(locale, 'pricing.hero.title1')} <span class="bg-tertiary-fixed px-2">{t(locale, 'pricing.hero.title2')}</span>{t(locale, 'pricing.hero.title3')}
      </h1>
      <p class="font-body text-xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
        {t(locale, 'pricing.hero.description')}
      </p>
    </header>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      <!-- Tier: Free -->
      <div class="bg-surface-container-lowest border-2 border-on-background rounded-xl p-8 transition-transform duration-200">
        <div class="mb-8">
          <span class="font-label uppercase tracking-widest text-xs font-black text-outline">{t(locale, 'pricing.free.label')}</span>
          <h3 class="font-headline font-bold text-4xl mt-2 italic">{t(locale, 'pricing.free.name')}</h3>
          <p class="text-on-surface-variant mt-2">{t(locale, 'pricing.free.description')}</p>
        </div>
        <div class="text-5xl font-headline font-black mb-8 italic">{t(locale, 'pricing.free.price')}<span class="text-lg font-body font-normal not-italic text-outline">{t(locale, 'pricing.free.period')}</span></div>
        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.free.feature1')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.free.feature2')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.free.feature3')}</span>
          </li>
        </ul>
        <button class="w-full py-4 rounded-lg border-2 border-on-background bg-surface-container hover:bg-surface-variant font-bold text-on-background transition-colors">
          {t(locale, 'pricing.free.cta')}
        </button>
      </div>

      <!-- Tier: Pro (Recommended) -->
      <div class="relative bg-surface-container-lowest border-2 border-on-background rounded-xl p-8 transition-transform duration-200 hard-shadow md:-mt-8">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-on-primary px-4 py-1 rounded-full text-xs font-bold tracking-widest uppercase border-2 border-on-background">
          {t(locale, 'pricing.pro.badge')}
        </div>
        <span class="material-symbols-outlined absolute -top-8 -right-8 text-4xl text-tertiary hidden lg:block" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="material-symbols-outlined absolute -bottom-8 -left-8 text-3xl text-secondary hidden lg:block" style="font-variation-settings: 'FILL' 1;">celebration</span>
        <div class="mb-8">
          <span class="font-label uppercase tracking-widest text-xs font-black text-primary">{t(locale, 'pricing.pro.label')}</span>
          <h3 class="font-headline font-bold text-4xl mt-2 italic">{t(locale, 'pricing.pro.name')}</h3>
          <p class="text-on-surface-variant mt-2">{t(locale, 'pricing.pro.description')}</p>
        </div>
        <div class="text-5xl font-headline font-black mb-8 italic">{t(locale, 'pricing.pro.price')}<span class="text-lg font-body font-normal not-italic text-outline">{t(locale, 'pricing.pro.period')}</span></div>
        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">draw</span>
            <span class="text-sm font-bold">{t(locale, 'pricing.pro.feature1')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">draw</span>
            <span class="text-sm font-bold">{t(locale, 'pricing.pro.feature2')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">draw</span>
            <span class="text-sm font-bold">{t(locale, 'pricing.pro.feature3')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">draw</span>
            <span class="text-sm font-bold">{t(locale, 'pricing.pro.feature4')}</span>
          </li>
        </ul>
        <button class="w-full py-4 rounded-lg bg-primary text-on-primary border-2 border-on-background font-black text-lg hard-shadow-hover transition-all">
          {t(locale, 'pricing.pro.cta')}
        </button>
      </div>

      <!-- Tier: Business -->
      <div class="bg-surface-container-lowest border-2 border-on-background rounded-xl p-8 transition-transform duration-200">
        <div class="mb-8">
          <span class="font-label uppercase tracking-widest text-xs font-black text-outline">{t(locale, 'pricing.business.label')}</span>
          <h3 class="font-headline font-bold text-4xl mt-2 italic">{t(locale, 'pricing.business.name')}</h3>
          <p class="text-on-surface-variant mt-2">{t(locale, 'pricing.business.description')}</p>
        </div>
        <div class="text-5xl font-headline font-black mb-8 italic">{t(locale, 'pricing.business.price')}<span class="text-lg font-body font-normal not-italic text-outline">{t(locale, 'pricing.business.period')}</span></div>
        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.business.feature1')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.business.feature2')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.business.feature3')}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary">draw</span>
            <span class="text-sm font-medium">{t(locale, 'pricing.business.feature4')}</span>
          </li>
        </ul>
        <button class="w-full py-4 rounded-lg border-2 border-on-background bg-surface-container-high hover:bg-surface-variant font-bold text-on-background transition-colors">
          {t(locale, 'pricing.business.cta')}
        </button>
      </div>
    </div>

    <!-- FAQ Section -->
    <section class="mt-40 max-w-4xl mx-auto">
      <h2 class="font-headline font-black text-5xl italic text-center mb-16 underline decoration-tertiary-fixed decoration-8 underline-offset-4">{t(locale, 'pricing.faq.title')}</h2>
      <div class="space-y-6">
        <div class="bg-secondary-container border-2 border-on-background rounded-xl p-6 hard-shadow">
          <h4 class="font-headline font-bold text-2xl mb-2 italic">{t(locale, 'pricing.faq.q1')}</h4>
          <p class="font-body text-on-secondary-container leading-relaxed">{t(locale, 'pricing.faq.a1')}</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background rounded-xl p-6 hard-shadow">
          <h4 class="font-headline font-bold text-2xl mb-2 italic">{t(locale, 'pricing.faq.q2')}</h4>
          <p class="font-body text-on-tertiary-fixed-variant leading-relaxed">{t(locale, 'pricing.faq.a2')}</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background rounded-xl p-6 hard-shadow">
          <h4 class="font-headline font-bold text-2xl mb-2 italic">{t(locale, 'pricing.faq.q3')}</h4>
          <p class="font-body text-on-secondary-container leading-relaxed">{t(locale, 'pricing.faq.a3')}</p>
        </div>
      </div>
    </section>

    <!-- CTA Visual Section -->
    <section class="mt-40 bg-surface-container border-2 border-on-background rounded-2xl overflow-hidden flex flex-col md:flex-row items-center p-8 md:p-12 relative">
      <div class="md:w-1/2 mb-10 md:mb-0">
        <h2 class="font-headline font-black text-4xl md:text-5xl italic mb-6">{t(locale, 'pricing.cta.title')}</h2>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-8 py-4 rounded-xl border-2 border-on-background hard-shadow hard-shadow-hover transition-all font-black text-xl">
          {t(locale, 'pricing.cta.btn')}
        </a>
      </div>
      <div class="md:w-1/2 flex justify-center">
        <img class="rounded-xl border-2 border-on-background rotate-3 hard-shadow max-w-full h-auto" alt="Creative digital collage" src="https://lh3.googleusercontent.com/aida-public/AB6AXuByHLTv0yKepjxJ8SlAYwhbJuZ-YcFiNsOwzBVx-4FUdRZDekcEGhAD-1H35uQKF4s1RePLiLB4-KADLHTpt8OK9mSQPA0EnwRQoMeCtylOYpBdk7vrJd1NYBzIw7vmjFs74Z65Hs7XD_iCHvgw7fJCt11lerimYUlNivB_bhsWYVlgY-9J43xK26iYWx1MMiiMcRSh_ORPUl17fGaGc0HfVScHRtu-niYI2Mh9xiaYoVjBpzn_bOdUup6YJDJidhpovAMMMrwvr90" width="500" height="400" loading="lazy" decoding="async" />
      </div>
    </section>
  </main>

  <Footer />
</Layout>

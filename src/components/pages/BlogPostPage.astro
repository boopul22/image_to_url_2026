---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getDB } from '../../lib/db';
import { getPostBySlug, getRelatedPosts } from '../../lib/cms';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return locale === defaultLocale ? path : `/${locale}${path}`;
}

const { slug } = Astro.params;
const db = getDB(Astro.locals);
const post = await getPostBySlug(db, slug as string);

if (!post) {
  return Astro.redirect(lp('/blog'));
}

// ISR: Cache at CDN edge for 10 min, serve stale up to 1 day while revalidating.
// Blog posts change infrequently so longer cache is safe.
Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=600, stale-while-revalidate=86400');
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');

const relatedPosts = await getRelatedPosts(db, post.relatedSlugs);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt || '',
  "image": post.coverImage || undefined,
  "datePublished": post.publishedAt || undefined,
  "dateModified": post.updatedAt || post.publishedAt || undefined,
  "author": {
    "@type": "Person",
    "name": post.authorName,
  },
  "publisher": {
    "@id": "https://imagetourl.cloud/#organization"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://imagetourl.cloud/blog/${slug}`
  }
};
---

<Layout
  title={`${post.title} — ImageToURL Blog`}
  description={post.excerpt || ''}
  ogImage={post.coverImage || '/og-default.png'}
  ogType="article"
  schema={articleSchema}
>
  <Nav activePage="blog" />

  <main class="pt-12 pb-24 px-6 md:px-0">
    <article class="max-w-3xl mx-auto">
      <!-- Article Header -->
      <header class="mb-12">
        <span class="inline-block py-1 px-4 bg-tertiary-fixed text-on-tertiary-fixed border-2 border-on-surface rounded-full text-xs font-bold uppercase tracking-widest mb-6">
          {post.categoryName || t(locale, 'blogPost.uncategorized')}
        </span>
        <h1 class="text-5xl md:text-7xl font-headline italic font-black leading-[1.1] tracking-tight text-on-surface mb-8">
          <Fragment set:html={post.title.replace(/SVG/g, '<span class="relative">SVG<span class="absolute bottom-1 left-0 w-full h-3 bg-tertiary/20 -z-10"></span></span>')} />
        </h1>
        <div class="flex flex-wrap items-center gap-6 border-b-2 border-surface-variant pb-8">
          <div class="flex items-center gap-3">
            <img
              alt={post.authorName}
              class="w-12 h-12 rounded-full border-2 border-on-surface p-0.5 bg-surface-container object-cover"
              src={post.authorAvatar}
              width="48"
              height="48"
              loading="lazy"
              decoding="async"
            />
            <div>
              <p class="font-bold text-on-surface">{post.authorName}</p>
              <p class="text-xs uppercase tracking-tighter text-outline">{post.authorRole}</p>
            </div>
          </div>
          <div class="h-8 w-px bg-outline-variant hidden sm:block"></div>
          <div class="flex flex-col">
            <span class="text-xs uppercase tracking-widest text-outline">{t(locale, 'blogPost.published')}</span>
            <span class="font-medium">{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : ''}</span>
          </div>
          <div class="ml-auto">
            <span class="bg-primary-fixed text-on-primary-fixed-variant px-3 py-1 border-2 border-on-surface rounded-lg text-sm font-bold flex items-center gap-2 hard-shadow">
              <span class="material-symbols-outlined text-sm">schedule</span>
              {post.readTime}
            </span>
          </div>
        </div>
      </header>

      <!-- Article Body -->
      <div class="prose prose-on-surface max-w-none text-lg leading-relaxed space-y-8">
        <p class="text-xl font-medium leading-relaxed">
          {post.content.intro}
        </p>

        {post.content.sections.map((section, i) => (
          <>
            <h2 class="text-3xl font-headline italic font-bold mt-12 mb-4 text-primary">
              {section.number}. {section.heading}
            </h2>
            <p set:html={section.body} />

            {/* Show blockquote after first section if available */}
            {i === 0 && post.content.blockquote && (
              <div class="my-12 p-8 bg-surface-container border-2 border-primary border-l-8 rounded-lg relative overflow-hidden">
                <span class="material-symbols-outlined absolute -right-4 -top-4 text-8xl text-primary/5 rotate-12">format_quote</span>
                <blockquote class="italic font-headline text-2xl text-on-surface relative z-10">
                  {post.content.blockquote}
                </blockquote>
              </div>
            )}

            {/* Show callout after second section if available */}
            {i === 1 && post.content.callout && (
              <div class="my-12 p-8 bg-tertiary-fixed border-2 border-on-surface rounded-xl hard-shadow flex gap-6 items-start" style="box-shadow: 6px 6px 0px 0px rgba(30,26,37,1);">
                <div class="bg-on-surface text-tertiary-fixed p-3 rounded-lg rotate-[-3deg] flex-shrink-0">
                  <span class="material-symbols-outlined">lightbulb</span>
                </div>
                <div>
                  <h4 class="font-headline font-black text-xl mb-2">{post.content.callout.title}</h4>
                  <p class="text-on-surface/80 leading-snug">{post.content.callout.body}</p>
                </div>
              </div>
            )}
          </>
        ))}

        <p>{post.content.outro}</p>
      </div>

      <!-- Share Section -->
      <section class="mt-20 p-8 bg-secondary-container border-2 border-on-surface rounded-2xl relative">
        <div class="absolute -top-6 left-8 bg-on-surface text-secondary-container px-6 py-2 font-black italic font-headline border-2 border-on-surface -rotate-1" style="box-shadow: 4px 4px 0px 0px rgba(103,95,43,0.3);">
          {t(locale, 'blogPost.share')}
        </div>
        <div class="flex flex-wrap justify-between items-center gap-6 mt-4">
          <p class="font-headline text-xl italic font-bold">{t(locale, 'blogPost.shareDescription')}</p>
          <div class="flex gap-4">
            <button class="w-12 h-12 bg-surface border-2 border-on-surface rounded-full flex items-center justify-center hover:-translate-y-1 hover:rotate-6 transition-all" style="box-shadow: 3px 3px 0px 0px rgba(30,26,37,1);">
              <span class="material-symbols-outlined">share</span>
            </button>
            <button class="w-12 h-12 bg-surface border-2 border-on-surface rounded-full flex items-center justify-center hover:-translate-y-1 hover:-rotate-6 transition-all" style="box-shadow: 3px 3px 0px 0px rgba(30,26,37,1);">
              <span class="material-symbols-outlined">link</span>
            </button>
            <button class="w-12 h-12 bg-surface border-2 border-on-surface rounded-full flex items-center justify-center hover:-translate-y-1 hover:rotate-3 transition-all" style="box-shadow: 3px 3px 0px 0px rgba(30,26,37,1);">
              <span class="material-symbols-outlined">mail</span>
            </button>
          </div>
        </div>
      </section>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <section class="mt-24">
          <h3 class="text-3xl font-headline italic font-black mb-10 flex items-center gap-4">
            {t(locale, 'blogPost.related')}
            <span class="h-1 flex-grow bg-surface-variant rounded-full"></span>
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map((related) => (
              <a
                class="group block border-2 border-on-surface bg-surface hover:translate-x-1 hover:translate-y-1 transition-all"
                style="box-shadow: 4px 4px 0px 0px rgba(30,26,37,1);"
                href={lp(`/blog/${related.slug}`)}
              >
                <div class={`h-40 border-b-2 border-on-surface overflow-hidden ${related.coverImage ? '' : (related.iconBg || 'bg-primary-fixed')} flex items-center justify-center`}>
                  {related.coverImage ? (
                    <img
                      alt={related.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" decoding="async"
                      src={related.coverImage}
                    />
                  ) : (
                    <span class="material-symbols-outlined text-8xl text-on-surface/20">
                      {related.iconFallback || 'article'}
                    </span>
                  )}
                </div>
                <div class="p-4">
                  <span class={`text-[10px] font-bold uppercase tracking-widest text-${related.categoryColor || 'primary'}`}>{related.categoryName || t(locale, 'blogPost.uncategorized')}</span>
                  <h4 class="font-headline font-bold text-lg leading-tight mt-1 group-hover:underline">{related.title}</h4>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>

  <Footer />
</Layout>

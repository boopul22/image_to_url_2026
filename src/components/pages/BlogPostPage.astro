---
import Icon from '../Icon.astro';
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getDB } from '../../lib/db';
import { getPostBySlugLocalized, getRelatedPosts } from '../../lib/cms';
import { imgUrl, imgUrlAbs, rewriteOwnedCdnImagesInHtml } from '../../lib/img';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const { slug } = Astro.params;
const db = getDB(Astro.locals);

// Degrade gracefully when the (local) D1 has empty/missing cms tables —
// treat a thrown fetch like a missing post (same not-found path below).
let post: Awaited<ReturnType<typeof getPostBySlugLocalized>> = null;
try {
  post = await getPostBySlugLocalized(db, slug as string, locale);
} catch (err) {
  // No DB binding / empty tables (e.g. credential-free local dev) — not found.
  console.error('blog post load failed', err);
}

if (!post) {
  return Astro.redirect(lp('/blog'));
}

// Fetch all locale slugs for this post so the language switcher can emit
// canonical translated URLs directly (no 301 hop).
let blogLocaleSlugs: Record<string, string> = {};
try {
  // Always seed with English slug. For translated views `post.id` still
  // refers to the base post, and `post.slug` is the translated slug — so we
  // look up the English slug from the base posts table.
  const enRow = await db.prepare('SELECT slug FROM posts WHERE id = ?').bind(post.id).first<{ slug: string }>();
  if (enRow?.slug) blogLocaleSlugs.en = enRow.slug;
  const rows = await db
    .prepare('SELECT locale, slug FROM post_translations WHERE post_id = ?')
    .bind(post.id)
    .all<{ locale: string; slug: string }>();
  for (const r of rows.results ?? []) blogLocaleSlugs[r.locale] = r.slug;
} catch { /* non-fatal — language switcher just falls back to same-path behavior */ }

// ISR: Cache at CDN edge for 10 min, serve stale up to 1 day while revalidating.
// Blog posts change infrequently so longer cache is safe.
Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=600, stale-while-revalidate=86400');
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');

const relatedPosts = await getRelatedPosts(db, post.relatedSlugs);

// --- Table of contents ---------------------------------------------------
// Build a TOC from H2/H3 headings. For htmlContent posts we also inject
// stable `id` attributes on the headings so the anchor links work.
type TocItem = { id: string; text: string; level: 2 | 3 };

function slugify(input: string): string {
  return input
    .toLowerCase()
    .replace(/<[^>]*>/g, '')
    .replace(/&[a-z]+;/g, ' ')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .slice(0, 60) || 'section';
}

let tocItems: TocItem[] = [];
let renderedHtml: string | null = null;

if (post.htmlContent) {
  const used = new Set<string>();
  renderedHtml = post.htmlContent.replace(
    /<(h2|h3)([^>]*)>([\s\S]*?)<\/\1>/gi,
    (_m, tag: string, attrs: string, inner: string) => {
      const level = tag.toLowerCase() === 'h2' ? 2 : 3;
      const text = inner.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
      if (!text) return `<${tag}${attrs}>${inner}</${tag}>`;
      const existingId = attrs.match(/\sid=["']([^"']+)["']/i)?.[1];
      let id = existingId || slugify(text);
      let n = 2;
      while (used.has(id)) id = `${slugify(text)}-${n++}`;
      used.add(id);
      const newAttrs = existingId
        ? attrs
        : `${attrs} id="${id}"`;
      tocItems.push({ id, text, level: level as 2 | 3 });
      return `<${tag}${newAttrs}>${inner}</${tag}>`;
    }
  );
} else if (post.content?.sections) {
  tocItems = post.content.sections.map((s: any) => ({
    id: slugify(`${s.number}-${s.heading}`),
    text: `${s.number}. ${s.heading}`,
    level: 2,
  }));
}

const displayHtml = post.htmlContent
  ? rewriteOwnedCdnImagesInHtml(renderedHtml ?? post.htmlContent, 800)
  : null;

const showToc = tocItems.length >= 3;

// `t()` returns the key string when a translation is missing, so a plain
// `t() || fallback` short-circuit doesn't work. Detect that case explicitly.
const tocLabelRaw = t(locale, 'blogPost.toc');
const tocLabel = tocLabelRaw && tocLabelRaw !== 'blogPost.toc' ? tocLabelRaw : 'Table of contents';

const updatedLabelRaw = t(locale, 'blogPost.updated');
const updatedLabel = updatedLabelRaw && updatedLabelRaw !== 'blogPost.updated' ? updatedLabelRaw : 'Last updated';

// SQLite's `datetime('now')` returns "YYYY-MM-DD HH:MM:SS" in UTC (no `T`, no `Z`),
// which is not valid ISO 8601 for JSON-LD. Normalize every date we emit — both
// in schema and in the visible <time datetime="…"> — so Google's parser and
// readers agree. `publishedAt` is already `.toISOString()` from the API layer;
// this is safe for both shapes.
function toIsoUtc(dt: string | null | undefined): string | undefined {
  if (!dt) return undefined;
  const candidate = /T.*(Z|[+-]\d{2}:?\d{2})$/.test(dt) ? dt : dt.replace(' ', 'T') + 'Z';
  const d = new Date(candidate);
  return isNaN(d.getTime()) ? undefined : d.toISOString();
}

const publishedIso = toIsoUtc(post.publishedAt);
const updatedIso = toIsoUtc(post.updatedAt) || publishedIso;

function fmtDate(iso: string | undefined): string {
  if (!iso) return '';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Only surface "Last updated" when it's a different calendar day than
// publish. Google's guidance: show `dateModified` when content has
// substantively changed; don't bump visibly for same-day edits/typos.
const showUpdated = !!updatedIso && !!publishedIso && updatedIso.slice(0, 10) !== publishedIso.slice(0, 10);

// Canonical post URL is locale-prefixed (root /blog/* 301s to /{locale}/blog/*),
// so mainEntityOfPage must match it — a bare /blog/${slug} never matched the
// canonical for any locale.
const canonicalPostUrl = `https://imagetourl.cloud/${locale}/blog/${slug}`;

// Link the author to the sitewide founder Person node (defined in Layout's
// Organization schema with url + sameAs) when the byline matches, so Google and
// AI engines resolve full author authority instead of a bare name string.
const FOUNDER_NAME = 'Bipul';
const isFounderAuthor = post.authorName?.trim().toLowerCase() === FOUNDER_NAME.toLowerCase();

// Google ignores headline past ~110 chars; cap so it stays eligible.
const headline = post.title.length > 110 ? post.title.slice(0, 109).trimEnd() + '…' : post.title;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": headline,
  "description": post.excerpt || '',
  "image": imgUrlAbs(post.coverImage, 1200) || 'https://imagetourl.cloud/og-default.png',
  "datePublished": publishedIso,
  "dateModified": updatedIso,
  "inLanguage": locale,
  "author": isFounderAuthor
    ? { "@id": "https://imagetourl.cloud/#founder" }
    : { "@type": "Person", "name": post.authorName },
  "publisher": {
    "@id": "https://imagetourl.cloud/#organization"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalPostUrl
  }
};

const faqSchema = post.faqItems?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": locale,
  "mainEntity": post.faqItems.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    }
  }))
} : null;
---

<Layout
  title={`${post.title} — ImageToURL Blog`}
  description={post.excerpt || ''}
  ogImage={imgUrl(post.coverImage, 1200) || '/og-default.png'}
  ogType="article"
  schema={articleSchema}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <Nav activePage="blog" blogLocaleSlugs={blogLocaleSlugs} />

  <!-- Reading progress -->
  <div
    id="read-progress"
    aria-hidden="true"
    class="fixed top-0 inset-x-0 h-[3px] bg-primary z-50 origin-left scale-x-0 will-change-transform"
  ></div>

  <main class="pt-5 sm:pt-8 pb-16 sm:pb-24 px-5 sm:px-6">
    <article class="blog-article max-w-2xl mx-auto">
      <!-- Article Header -->
      <header class="mb-8 sm:mb-10">
        <a
          href={lp('/blog')}
          class="inline-flex items-center gap-1.5 text-sm font-medium text-outline hover:text-primary no-underline mb-6 transition-colors"
        >
          <Icon name="arrow_back" class="text-base" />
          {(() => { const r = t(locale, 'blogPost.back'); return r && r !== 'blogPost.back' ? r : 'All articles'; })()}
        </a>
        <span class="inline-block py-1 px-3.5 bg-tertiary-fixed text-on-tertiary-fixed border border-outline-variant/40 rounded-full text-xs font-bold uppercase tracking-widest mb-5">
          {post.categoryName || t(locale, 'blogPost.uncategorized')}
        </span>
        <h1
          class="font-headline font-black tracking-tight text-on-surface [overflow-wrap:break-word] [text-wrap:balance]"
          style="font-size:clamp(2rem,6vw,3.35rem);font-weight:800;line-height:1.08;letter-spacing:-0.022em;"
        >
          <Fragment set:html={post.title.replace(/SVG/g, '<span class="relative whitespace-nowrap">SVG<span class="absolute bottom-1 left-0 w-full h-3 bg-tertiary/25 -z-10"></span></span>')} />
        </h1>
        {post.excerpt && (
          <p class="mt-4 sm:mt-5 text-lg sm:text-xl leading-relaxed text-on-surface-variant max-w-[42rem]">
            {post.excerpt}
          </p>
        )}
        <div class="mt-7 sm:mt-8 flex flex-wrap items-center gap-x-5 gap-y-4">
          <div class="flex items-center gap-3">
            <img
              alt={post.authorName}
              class="w-11 h-11 border border-outline-variant/40 bg-surface-container object-cover"
              style="border-radius:9999px"
              src={post.authorAvatar}
              width="44"
              height="44"
              loading="lazy"
              decoding="async"
            />
            <div class="leading-tight">
              <p class="font-bold text-sm text-on-surface">{post.authorName}</p>
              <p class="text-xs text-outline">{post.authorRole}</p>
            </div>
          </div>
          <div class="hidden sm:block h-8 w-px bg-outline-variant/60"></div>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-on-surface-variant">
            <span class="inline-flex items-center gap-1.5">
              <Icon name="calendar_today" class="text-sm text-outline" />
              <time datetime={publishedIso}>{fmtDate(publishedIso)}</time>
            </span>
            <span class="inline-flex items-center gap-1.5">
              <Icon name="schedule" class="text-sm text-outline" />
              {post.readTime}
            </span>
            {showUpdated && (
              <span class="inline-flex items-center gap-1.5 text-outline">
                <Icon name="update" class="text-sm" />
                {updatedLabel} {fmtDate(updatedIso)}
              </span>
            )}
          </div>
        </div>
      </header>

      <!-- Cover image -->
      {post.coverImage && (
        <figure class="mb-9 sm:mb-12">
          <img
            src={imgUrl(post.coverImage, 1200)}
            srcset={`${imgUrl(post.coverImage, 800)} 800w, ${imgUrl(post.coverImage, 1200)} 1200w`}
            sizes="(min-width: 704px) 672px, 100vw"
            alt={post.title}
            width="1200"
            height="675"
            class="w-full aspect-[16/9] object-cover border border-outline-variant/40 bg-surface-container"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </figure>
      )}

      <!-- Table of Contents -->
      {showToc && (
        <details
          open
          class="blog-toc group mb-10 sm:mb-12 bg-surface-container border border-outline-variant/40 rounded-xl"
        >
          <summary class="cursor-pointer list-none px-4 sm:px-5 py-3.5 flex items-center justify-between gap-3 group-open:border-b group-open:border-outline-variant/40">
            <span class="text-xs uppercase tracking-widest font-black text-on-surface flex items-center gap-2">
              <Icon name="list" class="text-base text-primary" />
              {tocLabel}
            </span>
            <Icon name="expand_more" class="text-lg text-outline transition-transform group-open:rotate-180" />
          </summary>
          <nav aria-label={tocLabel} class="px-4 sm:px-5 py-4">
            <ol class="space-y-1 list-none p-0 m-0">
              {tocItems.map((item, idx) => (
                <li class={item.level === 3 ? 'pl-4 sm:pl-5' : ''}>
                  <a
                    href={`#${item.id}`}
                    class="flex items-baseline gap-3 py-1.5 text-sm sm:text-[0.95rem] text-on-surface-variant hover:text-primary font-medium leading-snug no-underline break-words transition-colors"
                  >
                    <span class="text-[11px] font-black text-outline tabular-nums w-6 flex-none pt-0.5">
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <span class="min-w-0 break-words">{item.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )}

      <!-- Article Body -->
      {post.htmlContent ? (
        <div class="landing-prose blog-html-content" set:html={displayHtml ?? post.htmlContent} />
      ) : (
        <div class="landing-prose">
          <p class="blog-lead">
            {post.content.intro}
          </p>

          {post.content.sections.map((section, i) => (
            <>
              <h2 id={slugify(`${section.number}-${section.heading}`)} class="scroll-mt-24">
                {section.number}. {section.heading}
              </h2>
              <p set:html={section.body} />

              {/* Show blockquote after first section if available */}
              {i === 0 && post.content.blockquote && (
                <figure class="my-10 p-6 sm:p-8 bg-surface-container border border-outline-variant/40 rounded-xl relative overflow-hidden">
                  <Icon name="format_quote" class="absolute right-3 top-1 text-7xl text-primary/10" />
                  <blockquote class="font-headline font-bold text-xl sm:text-2xl leading-snug text-on-surface relative z-10 m-0">
                    {post.content.blockquote}
                  </blockquote>
                </figure>
              )}

              {/* Show callout after second section if available */}
              {i === 1 && post.content.callout && (
                <aside class="my-10 p-5 sm:p-7 bg-tertiary-fixed border border-outline-variant/40 rounded-xl flex gap-4 items-start">
                  <div class="bg-on-surface text-tertiary-fixed p-2.5 rounded-lg flex-shrink-0">
                    <Icon name="lightbulb" />
                  </div>
                  <div>
                    <h4 class="font-headline font-bold text-lg mb-1.5 text-on-surface">{post.content.callout.title}</h4>
                    <p class="text-on-surface/80 leading-relaxed m-0">{post.content.callout.body}</p>
                  </div>
                </aside>
              )}
            </>
          ))}

          <p>{post.content.outro}</p>
        </div>
      )}

      <!-- FAQ Section -->
      {post.faqItems && post.faqItems.length > 0 && (
        <section class="mt-14 sm:mt-16">
          <h2 class="text-2xl sm:text-3xl font-headline font-black mb-6 flex items-center gap-3 text-on-surface tracking-tight">
            <Icon name="help" class="text-primary" />
            Frequently Asked Questions
          </h2>
          <div class="space-y-3">
            {post.faqItems.map((faq) => (
              <details class="group border border-outline-variant/40 rounded-xl overflow-hidden bg-surface-container">
                <summary class="cursor-pointer px-5 py-4 hover:bg-surface-container-highest transition-colors flex items-center justify-between gap-4 font-headline font-bold text-on-surface list-none">
                  <span>{faq.question}</span>
                  <Icon name="expand_more" class="text-lg text-outline group-open:rotate-180 transition-transform flex-none" />
                </summary>
                <div class="px-5 pb-4 pt-1 text-on-surface-variant leading-relaxed border-t border-outline-variant/40">
                  <p class="mt-3">{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- Share Section -->
      <section
        id="share"
        class="mt-14 sm:mt-16 pt-8 border-t border-outline-variant/40 flex flex-wrap items-center justify-between gap-5"
        data-share-url={canonicalPostUrl}
        data-share-title={post.title}
      >
        <div>
          <p class="font-headline font-bold text-lg text-on-surface">{t(locale, 'blogPost.share')}</p>
          <p class="text-sm text-on-surface-variant mt-0.5">{t(locale, 'blogPost.shareDescription')}</p>
        </div>
        <div class="flex gap-3">
          <button type="button" id="share-native" aria-label={t(locale, 'blogPost.share')} style="border-radius:9999px" class="w-11 h-11 bg-surface-container border border-outline-variant/40 flex items-center justify-center text-on-surface hover:bg-surface-container-highest hover:text-primary active:scale-95 transition-all">
            <Icon name="share" />
          </button>
          <button type="button" id="share-copy" aria-label={t(locale, 'blogPost.copyLink')} style="border-radius:9999px" class="w-11 h-11 bg-surface-container border border-outline-variant/40 flex items-center justify-center text-on-surface hover:bg-surface-container-highest hover:text-primary active:scale-95 transition-all">
            <Icon name="link" />
            <Icon name="check" style="display:none" />
          </button>
          <a href={`mailto:?subject=${encodeURIComponent(post.title)}&body=${encodeURIComponent(canonicalPostUrl)}`} aria-label={t(locale, 'blogPost.shareByEmail')} style="border-radius:9999px" class="w-11 h-11 bg-surface-container border border-outline-variant/40 flex items-center justify-center text-on-surface hover:bg-surface-container-highest hover:text-primary active:scale-95 transition-all no-underline">
            <Icon name="mail" />
          </a>
        </div>
      </section>
    </article>

    <!-- Related Posts (breaks out wider than the reading column) -->
    {relatedPosts.length > 0 && (
      <section class="max-w-5xl mx-auto mt-16 sm:mt-24">
        <h2 class="text-2xl sm:text-3xl font-headline font-black mb-8 sm:mb-10 text-on-surface tracking-tight">
          {t(locale, 'blogPost.related')}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
          {relatedPosts.map((related) => (
            <a
              class="group flex flex-col border border-outline-variant/40 bg-surface-container rounded-xl overflow-hidden hover:border-primary/50 transition-colors"
              href={lp(`/blog/${related.slug}`)}
            >
              <div class={`aspect-[16/10] border-b border-outline-variant/40 overflow-hidden ${related.coverImage ? '' : (related.iconBg || 'bg-primary-fixed')} flex items-center justify-center`}>
                {related.coverImage ? (
                  <img
                    alt={related.title}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" loading="lazy" decoding="async"
                    src={imgUrl(related.coverImage, 400)}
                    srcset={`${imgUrl(related.coverImage, 400)} 1x, ${imgUrl(related.coverImage, 800)} 2x`}
                    width="400"
                    height="250"
                  />
                ) : (
                  <Icon name={related.iconFallback || 'article'} class="text-7xl text-on-surface/20" />
                )}
              </div>
              <div class="p-4 sm:p-5">
                <span class="text-xs font-bold uppercase tracking-widest text-primary">{related.categoryName || t(locale, 'blogPost.uncategorized')}</span>
                <h3 class="font-headline font-bold text-lg leading-snug mt-1.5 text-on-surface group-hover:text-primary transition-colors">{related.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  .blog-html-content :is(h2, h3)[id],
  article :is(h2, h3)[id] {
    scroll-margin-top: 6rem;
  }
  .blog-toc summary::-webkit-details-marker { display: none; }
  .blog-toc summary { -webkit-tap-highlight-color: transparent; }
  #read-progress { transition: transform 80ms linear; }
  @media (max-width: 640px) {
    .blog-toc a { min-height: 44px; align-items: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    #read-progress { transition: none; }
  }
</style>

<script>
  // Reading progress + TOC scroll-spy + share actions.
  const bar = document.getElementById('read-progress');
  const article = document.querySelector('.blog-article');
  const tocLinks = Array.from(document.querySelectorAll('.blog-toc a[href^="#"]'));
  const headings = tocLinks
    .map((a) => document.getElementById((a.getAttribute('href') || '').slice(1)))
    .filter((el): el is HTMLElement => !!el);

  function update() {
    if (bar && article) {
      const total = article.scrollHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(window.scrollY - (article as HTMLElement).offsetTop, 0), Math.max(total, 1));
      bar.style.transform = `scaleX(${total > 0 ? scrolled / total : 0})`;
    }
    if (headings.length) {
      let current = '';
      for (const h of headings) {
        if (h.getBoundingClientRect().top - 120 <= 0) current = h.id;
      }
      tocLinks.forEach((a) => a.classList.toggle('is-active', a.getAttribute('href') === '#' + current));
    }
  }
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });
  update();

  // Share actions
  const shareRoot = document.getElementById('share');
  const url = shareRoot?.getAttribute('data-share-url') || location.href;
  const title = shareRoot?.getAttribute('data-share-title') || document.title;
  document.getElementById('share-native')?.addEventListener('click', async () => {
    if (navigator.share) { try { await navigator.share({ title, url }); } catch {} }
    else { try { await navigator.clipboard.writeText(url); } catch {} }
  });
  const copyBtn = document.getElementById('share-copy');
  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(url);
      const link = copyBtn.children[0] as HTMLElement | undefined;
      const check = copyBtn.children[1] as HTMLElement | undefined;
      if (link && check) {
        link.style.display = 'none';
        check.style.display = '';
        setTimeout(() => { link.style.display = ''; check.style.display = 'none'; }, 1600);
      }
    } catch {}
  });
</script>

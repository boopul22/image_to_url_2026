---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getDB } from '../../lib/db';
import { getPublishedPostsLocalized, getCategories } from '../../lib/cms';
import { imgUrl } from '../../lib/img';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

// ISR: Cache at CDN edge for 5 min, serve stale up to 1 hour while revalidating
Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=300, stale-while-revalidate=3600');
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');

const db = getDB(Astro.locals);
const { posts } = await getPublishedPostsLocalized(db, locale, { limit: 50 });
const categories = await getCategories(db);

---

<Layout title={t(locale, 'blog.meta.title')} description={t(locale, 'blog.meta.description')} noindex={posts.length === 0}>
  <Nav activePage="blog" />

  <main>
    <!-- Hero Section -->
    <section class="bg-surface-container py-12 sm:py-24 px-4 sm:px-6 overflow-hidden relative border-b-2 border-on-surface">
      <div class="max-w-5xl mx-auto relative z-10">
        <div class="inline-block px-4 py-1 bg-tertiary-fixed border-2 border-on-surface mb-6 rotate-[-2deg]">
          <span class="font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed">{t(locale, 'blog.badge')}</span>
        </div>
        <h1 class="font-headline text-4xl sm:text-4xl lg:text-8xl font-black text-on-surface leading-tight tracking-tight mb-6">
          {t(locale, 'blog.hero.title1')}<br />
          <span class="relative">
            {t(locale, 'blog.hero.title2')}
          </span>
        </h1>
        <p class="font-headline font-medium text-lg sm:text-xl lg:text-2xl text-on-surface-variant max-w-2xl leading-relaxed">
          {t(locale, 'blog.hero.description')}
        </p>
      </div>
      <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-20 pointer-events-none hidden lg:block">
        <span class="material-symbols-outlined text-[20rem] text-primary">draw</span>
      </div>
    </section>

    <!-- Search & Filter Bar -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 -mt-8 relative z-20">
      <div class="bg-surface border-2 border-on-surface p-3 sm:p-4 flex flex-col md:flex-row gap-3 sm:gap-4 items-stretch md:items-center hard-shadow">
        <div class="flex-1 flex items-center gap-3 px-4 py-2.5 sm:py-2 bg-surface-container-lowest border-2 border-on-surface w-full">
          <span class="material-symbols-outlined text-outline">search</span>
          <input type="text" placeholder={t(locale, 'blog.search.placeholder')} class="bg-transparent border-none focus:ring-0 focus:outline-none w-full font-body text-sm sm:text-sm text-base" />
        </div>
        <div class="flex gap-2 overflow-x-auto w-full md:w-auto scroll-snap-x md:scroll-snap-none -mx-1 px-1">
          <button class="px-4 py-2.5 sm:py-2 border-2 border-on-surface bg-secondary-fixed text-on-secondary-fixed font-label text-xs font-bold uppercase whitespace-nowrap flex-shrink-0">{t(locale, 'blog.filter.all')}</button>
          {categories.map((cat) => (
            <button class="px-4 py-2.5 sm:py-2 border-2 border-on-surface bg-surface-container-highest text-on-surface-variant font-label text-xs font-bold uppercase whitespace-nowrap flex-shrink-0 hover:bg-secondary-fixed active:bg-secondary-fixed transition-colors" data-category={cat.id}>
              {cat.name}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {posts.map((post, i) => {
          const isWide = i === posts.length - 1 && posts.length % 3 === 0;
          return (
            <article class:list={["group", { "lg:col-span-2": isWide }]}>
              <a href={lp(`/blog/${post.slug}`)} class="block h-full">
                <div class:list={[
                  "bg-surface border-2 border-on-surface h-full flex hard-shadow hard-shadow-hover transition-all duration-200",
                  isWide ? "flex-col md:flex-row" : "flex-col",
                ]}>
                  {isWide ? (
                    <>
                      <div class="p-8 flex flex-col justify-center flex-1">
                        <span class={`font-label text-xs font-bold uppercase text-${post.categoryColor || 'primary'} tracking-widest mb-4 block`}>{post.categoryName || t(locale, 'blog.uncategorized')}</span>
                        <h3 class="font-headline text-3xl font-black text-on-surface mb-4 group-hover:text-on-background transition-colors">{post.title}</h3>
                        <p class="font-body text-on-surface-variant mb-6 leading-relaxed">{post.excerpt}</p>
                        <span class="font-label text-xs font-black uppercase text-on-background flex items-center gap-1">
                          {t(locale, 'blog.readMore')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </span>
                      </div>
                      <div class={`w-full md:w-2/5 h-64 md:h-auto border-t-2 md:border-t-0 md:border-l-2 border-on-surface flex items-center justify-center relative overflow-hidden ${post.iconBg || 'bg-surface-container-highest'}`}>
                        {post.coverImage ? (
                          <img
                            alt={post.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                            decoding="async"
                            src={imgUrl(post.coverImage, 400)}
                            srcset={`${imgUrl(post.coverImage, 400)} 1x, ${imgUrl(post.coverImage, 800)} 2x`}
                            width="400"
                            height="256"
                          />
                        ) : (
                          <>
                            <span class="material-symbols-outlined text-[12rem] text-primary/10 absolute rotate-12">auto_fix_high</span>
                            <div class="text-center p-6 relative z-10">
                              <span class="material-symbols-outlined text-6xl text-primary mb-4">{post.iconFallback || 'article'}</span>
                              <div class="font-headline italic text-xl">{post.categoryName || t(locale, 'blog.uncategorized')}</div>
                            </div>
                          </>
                        )}
                      </div>
                    </>
                  ) : (
                    <>
                      <div class={`h-48 relative border-b-2 border-on-surface overflow-hidden ${!post.coverImage ? (post.iconBg || 'bg-surface-container-highest') + ' flex items-center justify-center' : ''}`}>
                        {post.coverImage ? (
                          <img
                            alt={post.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading={i === 0 ? 'eager' : 'lazy'}
                            decoding="async"
                            fetchpriority={i === 0 ? 'high' : undefined}
                            src={imgUrl(post.coverImage, 308)}
                            srcset={`${imgUrl(post.coverImage, 308)} 1x, ${imgUrl(post.coverImage, 616)} 2x`}
                            width="308"
                            height="192"
                          />
                        ) : (
                          <div class="relative z-10 flex flex-col items-center">
                            <span class="material-symbols-outlined text-6xl text-on-surface/20">{post.iconFallback || 'article'}</span>
                            <span class="font-headline text-lg italic mt-2">{post.categoryName || t(locale, 'blog.uncategorized')}</span>
                          </div>
                        )}
                      </div>
                      <div class="p-6 flex flex-col flex-1">
                        <span class={`font-label text-xs font-bold uppercase text-${post.categoryColor || 'primary'} tracking-widest mb-3 block`}>{post.categoryName || t(locale, 'blog.uncategorized')}</span>
                        <h3 class="font-headline text-2xl font-black text-on-surface mb-4 group-hover:text-on-background transition-colors">{post.title}</h3>
                        <p class="font-body text-sm text-on-surface-variant mb-6 flex-1">{post.excerpt}</p>
                        <span class="font-label text-xs font-black uppercase text-on-background flex items-center gap-1 mt-auto">
                          {t(locale, 'blog.readMore')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </span>
                      </div>
                    </>
                  )}
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </section>


  </main>

  <Footer />
</Layout>

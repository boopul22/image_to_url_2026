---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import Footer from '../Footer.astro';
import { t } from '../../i18n/utils';
import { defaultLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return locale === defaultLocale ? path : `/${locale}${path}`;
}
---

<Layout title={t(locale, 'features.meta.title')} description={t(locale, 'features.meta.description')}>
  <Nav activePage="features" />

  <main class="max-w-7xl mx-auto px-6 py-16">
    <header class="mb-20">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-4 border border-on-background">{t(locale, 'features.badge')}</span>
      <h1 class="text-6xl md:text-8xl font-black font-headline leading-none tracking-tighter mb-6">
        {t(locale, 'features.hero.title1')} <span class="italic text-primary">{t(locale, 'features.hero.title2')}</span>
      </h1>
      <p class="text-xl md:text-2xl font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        {t(locale, 'features.hero.description')}
      </p>
    </header>

    <section class="mb-24">
      <div class="flex items-baseline gap-4 mb-10">
        <h2 class="text-4xl font-black font-headline tracking-tight">{t(locale, 'features.speed.title')}</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        <div class="md:col-span-7 bg-secondary-container border-2 border-on-background p-10 rounded-xl hard-shadow relative overflow-hidden group">
          <div class="absolute top-4 right-4 text-secondary opacity-20 group-hover:rotate-12 transition-transform duration-300">
            <span class="material-symbols-outlined text-[120px]">bolt</span>
          </div>
          <div class="relative z-10">
            <h3 class="text-3xl font-black font-headline mb-4">{t(locale, 'features.speed.cdn.title')}</h3>
            <p class="text-lg font-headline font-medium mb-8 max-w-md">{t(locale, 'features.speed.cdn.description')}</p>
            <a href="#" class="inline-flex items-center gap-2 bg-secondary text-on-secondary px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
              {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="md:col-span-5 bg-surface-container-highest border-2 border-on-background p-10 rounded-xl hard-shadow flex flex-col justify-center text-center">
          <div class="mb-6"><span class="material-symbols-outlined text-primary text-5xl">speed</span></div>
          <h3 class="text-2xl font-black font-headline mb-2">{t(locale, 'features.speed.uptime.title')}</h3>
          <p class="font-body text-on-surface-variant">{t(locale, 'features.speed.uptime.description')}</p>
        </div>
      </div>
    </section>

    <section class="mb-24">
      <div class="flex items-baseline gap-4 mb-10">
        <h2 class="text-4xl font-black font-headline tracking-tight">{t(locale, 'features.security.title')}</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="relative group">
          <div class="bg-tertiary-fixed border-2 border-on-background p-2 rounded-xl hard-shadow h-full">
            <div class="overflow-hidden rounded-lg border-2 border-on-background h-64 relative">
              <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" alt="HTTPS Security" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCSdRwuOrmCj4ycUILmrlyMqINJmIzdLRXee66AW4UlJ_KzbNGVelXR1A-OxUB53ZxyAwFYHex5aHKj6-IwjRa9Tj1xZf-Z4xIFliAuIqH1QXRhzWTUyPCNAqMbBN7E8zxlAxL4CRk5h4pK9TReXntJQaa-qrowLCwfRZ5AtkWtGikuQuZUBZO8VYAZa87yW7a_YSBJHMamaJ1C0Eoamp9C6Al8nR1oUEUs8g5Cgq9seLdIBOpDlf-NA0_MbSLE05x29s6HBZVxSJE" width="500" height="256" loading="lazy" decoding="async" />
              <div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-black font-headline mb-2">{t(locale, 'features.security.https.title')}</h3>
              <p class="font-body text-on-surface-variant mb-4">{t(locale, 'features.security.https.description')}</p>
              <a href="#" class="inline-flex items-center gap-2 bg-secondary text-on-secondary px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
                {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>
        <div class="relative group">
          <div class="bg-surface-variant border-2 border-on-background p-2 rounded-xl hard-shadow h-full">
            <div class="overflow-hidden rounded-lg border-2 border-on-background h-64 relative">
              <img class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" alt="No Signup Required" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCZjDa9o2JxdS7bGm1oXpigcU9nx0vwEcY-Wkyi5TG6ai-sn9BsyeG2XOGfA6Zz0Xu7vYFSN_Yg-u9M8TAWFt2vRc4Ie19zsVEVn8_qi96bYHyiE2GtIQ5qfVZzO-aUQpl7UQot0I6jvct23gjaVSU9H1KvT7Z7XpsWH0JhAMlpt_-rin-b7I1yX7ANp1Z3_Ahdt4xvsgocXNdWcxv4Vcr9bRbLA3iWxWxctOwWmDbbwJVKVYtFalYHgqWm2LXVzol_teioziOU79A" width="500" height="256" loading="lazy" decoding="async" />
              <div class="absolute inset-0 bg-secondary/10 mix-blend-multiply"></div>
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-black font-headline mb-2">{t(locale, 'features.security.noSignup.title')}</h3>
              <p class="font-body text-on-surface-variant mb-4">{t(locale, 'features.security.noSignup.description')}</p>
              <a href="#" class="inline-flex items-center gap-2 bg-secondary text-on-secondary px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
                {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="flex items-baseline gap-4 mb-10">
        <h2 class="text-4xl font-black font-headline tracking-tight">{t(locale, 'features.devtools.title')}</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-primary-fixed border-2 border-on-background p-8 rounded-xl hard-shadow flex flex-col">
          <div class="w-16 h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-6 -rotate-3">
            <span class="material-symbols-outlined text-primary text-3xl">terminal</span>
          </div>
          <h3 class="text-2xl font-black font-headline mb-3">{t(locale, 'features.devtools.api.title')}</h3>
          <p class="font-body text-on-surface-variant mb-8 flex-grow">{t(locale, 'features.devtools.api.description')}</p>
          <a href={lp('/docs')} class="inline-flex items-center gap-2 bg-secondary text-on-secondary w-fit px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
            {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-8 rounded-xl hard-shadow flex flex-col">
          <div class="w-16 h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-6 rotate-2">
            <span class="material-symbols-outlined text-tertiary text-3xl">code</span>
          </div>
          <h3 class="text-2xl font-black font-headline mb-3">{t(locale, 'features.devtools.markdown.title')}</h3>
          <p class="font-body text-on-surface-variant mb-8 flex-grow">{t(locale, 'features.devtools.markdown.description')}</p>
          <a href="#" class="inline-flex items-center gap-2 bg-secondary text-on-secondary w-fit px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
            {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-8 rounded-xl hard-shadow flex flex-col">
          <div class="w-16 h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-6 -rotate-2">
            <span class="material-symbols-outlined text-secondary text-3xl">hub</span>
          </div>
          <h3 class="text-2xl font-black font-headline mb-3">{t(locale, 'features.devtools.endpoints.title')}</h3>
          <p class="font-body text-on-surface-variant mb-8 flex-grow">{t(locale, 'features.devtools.endpoints.description')}</p>
          <a href="#" class="inline-flex items-center gap-2 bg-secondary text-on-secondary w-fit px-4 py-2 rounded-full font-bold font-label text-xs uppercase tracking-wider border-2 border-on-background hard-shadow-hover transition-all">
            {t(locale, 'features.exploreAll')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <section class="bg-surface-container py-24 border-t-2 border-on-background mt-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-5xl font-black font-headline mb-8 leading-tight">{t(locale, 'features.cta.title', { highlight: '' })} <span class="text-primary underline decoration-4 underline-offset-8">{t(locale, 'features.cta.highlight')}</span></h2>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={lp('/')} class="bg-primary text-on-primary border-2 border-on-background px-10 py-5 text-xl font-bold hard-shadow hover:-translate-y-1 hover:-translate-x-1 transition-all">
          {t(locale, 'features.cta.uploadBtn')}
        </a>
        <a href={lp('/docs')} class="bg-white text-on-background border-2 border-on-background px-10 py-5 text-xl font-bold hard-shadow hover:-translate-y-1 hover:-translate-x-1 transition-all">
          {t(locale, 'features.cta.docsBtn')}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

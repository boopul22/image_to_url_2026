---
/**
 * Wraps a tool widget (HEIC converter, canvas converter, PDF converter,
 * image compressor, image resizer, etc.) with the site's Ookla-style ad frame
 * (fixed sizes, in normal flow, non-sticky):
 *   - A 728x90 LEADERBOARD across the top (xl+).
 *   - A 120x450 vertical unit on the LEFT + two stacked 400x400 squares on the
 *     RIGHT flanking the widget (xl+).
 *   - A mobile/tablet responsive in-content Multiplex unit below the widget,
 *     lazy-loaded, which is all the phone/tablet layout shows.
 *
 * The wrapper breaks out of its parent's frame at xl via
 * left-1/2 / -translate-x-1/2 / w-screen so the three columns + gaps fit
 * (120 + 672 + 400) inside an xl:max-w-7xl frame. Below xl the leaderboard +
 * rails are hidden and only the responsive in-content unit remains.
 */
import AdRail from './ads/AdRail.astro';
import AdLeaderboard from './ads/AdLeaderboard.astro';
import { AD_CLIENT, AD_SLOTS } from '../lib/ads';
---
<div class="w-full mb-8 sm:mb-10 xl:relative xl:left-1/2 xl:-translate-x-1/2 xl:w-screen xl:max-w-7xl xl:px-6">
  <AdLeaderboard />
  <div class="w-full xl:flex xl:items-start xl:justify-center xl:gap-6">
    <AdRail side="left" />

    <!-- Center column fills the space between the two equal 300px rails, so the
         tool sits at the true viewport center. -->
    <div class="w-full xl:flex-1 xl:min-w-0">
      <slot />
    </div>

    <AdRail side="right" />
  </div>

  <!-- Mobile/tablet in-content Multiplex — fills the slot gap where desktop has
       rails. Kept LAST in DOM (after both rails) so its lazy fill can't steal an
       earlier eager rail's push. Below the fold → lazy-loaded by the observer. -->
  <div class="xl:hidden w-full max-w-2xl mx-auto mt-6">
    <div class="ad-reserve">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client={AD_CLIENT}
        data-ad-slot={AD_SLOTS.inContent}
        data-ad-lazy></ins>
    </div>
  </div>
</div>

---
/**
 * Wraps a tool widget (HEIC converter, canvas converter, PDF converter,
 * image compressor, image resizer, etc.) with the homepage-style 3-slot
 * ad layout: left + right 160x600 skyscrapers on lg+, plus a 90px
 * horizontal banner above the widget.
 *
 * Uses the standard left-1/2/-translate-x-1/2 breakout so the wrapper
 * expands from its parent's max-w-5xl frame up to lg:max-w-6xl, giving
 * room for 160 + ~672 + 160 columns + gaps (~1040px). Below lg the
 * skyscrapers are hidden and the horizontal banner stays visible.
 */
---
<div class="w-full mb-8 sm:mb-10 xl:relative xl:left-1/2 xl:-translate-x-1/2 xl:w-screen xl:max-w-7xl xl:px-6">
  <div class="w-full xl:flex xl:items-start xl:justify-center xl:gap-6">
    <aside class="hidden xl:block xl:flex-shrink-0 xl:w-[280px] xl:sticky xl:top-20 xl:self-start" aria-label="Sponsored">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="1349470215"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <div class="w-full xl:flex-1 xl:max-w-2xl xl:min-w-0">
      <div class="w-full max-w-2xl mx-auto mb-4">
        <div class="ad-reserve">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-format="autorelaxed"
            data-ad-client="ca-pub-7803867089582138"
            data-ad-slot="7116802219"></ins>
        </div>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <slot />
      <!-- Mobile/tablet in-content ad — fills the slot gap where desktop has skyscrapers.
           Below the fold → lazy-loaded by the observer in Layout.astro (data-ad-lazy). -->
      <div class="xl:hidden w-full max-w-2xl mx-auto mt-6">
        <div class="ad-reserve">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-format="autorelaxed"
            data-ad-client="ca-pub-7803867089582138"
            data-ad-slot="7116802219"
            data-ad-lazy></ins>
        </div>
      </div>
    </div>

    <aside class="hidden xl:block xl:flex-shrink-0 xl:w-[280px] xl:sticky xl:top-20 xl:self-start" aria-label="Sponsored">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="1349470215"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
  </div>
</div>

---
/**
 * Wraps a tool widget (HEIC converter, canvas converter, PDF converter,
 * image compressor, image resizer, etc.) with the site's responsive ad layout:
 *   - Left + right sticky RAILS (two stacked units each), xl+ only.
 *   - A BANNER (two units side-by-side on sm+) above the widget.
 *   - A mobile/tablet in-content Multiplex unit below the widget, lazy-loaded,
 *     to fill the gap where desktop shows the rails.
 *
 * The wrapper breaks out of its parent's max-w-5xl frame at xl via
 * left-1/2 / -translate-x-1/2 / w-screen so the three columns + gaps fit
 * (~280 + 672 + 280) inside an xl:max-w-7xl frame. Below xl the rails are
 * hidden and only the banner + in-content units remain.
 */
import AdRail from './ads/AdRail.astro';
import AdBanner from './ads/AdBanner.astro';
---
<div class="w-full mb-8 sm:mb-10 xl:relative xl:left-1/2 xl:-translate-x-1/2 xl:w-screen xl:max-w-7xl xl:px-6">
  <div class="w-full xl:flex xl:items-start xl:justify-center xl:gap-6">
    <AdRail side="left" />

    <div class="w-full xl:flex-1 xl:max-w-2xl xl:min-w-0">
      <AdBanner class="mb-4" />
      <slot />
    </div>

    <AdRail side="right" />
  </div>

  <!-- Mobile/tablet in-content Multiplex — fills the slot gap where desktop has
       rails. Kept LAST in DOM (after both rails) so its lazy fill can't steal an
       earlier eager rail's push. Below the fold → lazy-loaded by the observer. -->
  <div class="xl:hidden w-full max-w-2xl mx-auto mt-6">
    <div class="ad-reserve">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="1349470215"
        data-ad-lazy></ins>
    </div>
  </div>
</div>

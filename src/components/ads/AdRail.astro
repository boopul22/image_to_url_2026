---
/**
 * Ookla-style side column (2026-07-03). Fixed pixel sizes, in normal flow,
 * shown only on xl+ (mobile/tablet collapse to the single in-content unit).
 *
 *   side="left"  → ONE 160x600 skyscraper, centred in a 300px column.
 *   side="right" → TWO stacked 300x250 rectangles, in a 300px column.
 *
 * BOTH columns are the SAME 300px width (ads centred inside) so the center
 * column — and the tool in it — sits at the true viewport center. If the two
 * columns had different widths (160 vs 300) the tool would be pushed off-centre.
 * Ad sizes still mirror speedtest.net (160x600 skyscraper + two 300x250).
 *
 * Loading: each <ins> keeps its own inline push({}) right after it — AdSense
 * fills statusless <ins> in DOM order, so an inline push immediately after each
 * one always targets THAT slot. Don't reorder into a lazy/observer scheme — a
 * bare push() can't target a specific slot, so out-of-DOM-order fills misalign.
 *
 * Mobile/tablet (< xl): the <aside> is display:none, so each <ins> has zero
 * width. Pushing a 0-width slot makes AdSense throw `No slot size for
 * availableWidth=0` (a Best-Practices console-error fail). The inline guard
 * below only push()es at xl+ (min-width:1280); below xl it strips the
 * `adsbygoogle` class off the hidden <ins> so the slot leaves AdSense's
 * candidate pool entirely — otherwise the next *visible* push (the leaderboard)
 * would grab this 0-width slot in DOM order and still throw.
 *
 * Sizes are fixed (display:inline-block;width;height) with no data-ad-format —
 * i.e. dedicated fixed units, mirroring the pasted 728x90 leaderboard markup.
 * Distinct unit id per box (ids centralised in lib/ads.ts) so AdSense doesn't
 * unfill duplicates.
 */
import { AD_CLIENT as PUB, AD_SLOTS } from '../../lib/ads';
interface Props {
  side?: 'left' | 'right';
}
const { side = 'left' } = Astro.props;
---
{side === 'left' ? (
  <aside
    class="hidden xl:flex xl:flex-col xl:items-center xl:flex-shrink-0 xl:w-[300px]"
    aria-label="Sponsored"
    data-rail="left"
  >
    <!-- 160x600 skyscraper (matches speedtest.net stnext_skyscraper) -->
    <ins
      class="adsbygoogle ad-fixed"
      style="display:inline-block;width:160px;height:600px"
      data-ad-client={PUB}
      data-ad-slot={AD_SLOTS.leftSkyscraper}></ins>
    <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>
  </aside>
) : (
  <aside
    class="hidden xl:flex xl:flex-col xl:items-center xl:gap-12 xl:flex-shrink-0 xl:w-[300px]"
    aria-label="Sponsored"
    data-rail="right"
  >
    <!-- Top: 300x250 rectangle (matches speedtest.net stnext_top_rectangle) -->
    <ins
      class="adsbygoogle ad-fixed"
      style="display:inline-block;width:300px;height:250px"
      data-ad-client={PUB}
      data-ad-slot={AD_SLOTS.rightSquareTop}></ins>
    <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>

    <!-- Bottom: 300x250 rectangle (matches speedtest.net stnext_bottom_rectangle) -->
    <ins
      class="adsbygoogle ad-fixed"
      style="display:inline-block;width:300px;height:250px"
      data-ad-client={PUB}
      data-ad-slot={AD_SLOTS.rightSquareBottom}></ins>
    <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>
  </aside>
)}

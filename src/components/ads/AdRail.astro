---
/**
 * One side rail = a SINGLE fixed 160×600 skyscraper, shown only on xl+
 * (mobile/tablet never render the rails — they collapse to the in-content ad
 * instead). Sticky so it stays beside the tool as the user scrolls (works now
 * that <body> uses overflow-x: clip, not hidden).
 *
 * Why fixed 160×600 (not full-width responsive): a fixed slim tower centered in
 * the wider 280px rail leaves whitespace on both sides and reads as a small,
 * separate, intentional unit — the "contained ad island" look (cf. Speedtest /
 * Ziff Davis) — instead of a 280px-wide responsive blob that fills the rail
 * edge-to-edge. A muted "Advertisement" microlabel reinforces the separation.
 * Trade-off: 160×600 has lower demand than responsive, so to change the size or
 * go back to responsive, edit this one file. Slot id lives in lib/ads.ts.
 *
 * Loading: the <ins> keeps its own inline push({}) right after it. AdSense fills
 * statusless <ins> in DOM order, so an inline push immediately after it targets
 * THIS slot. Don't reorder into a lazy/observer scheme — a bare push() can't
 * target a specific slot, so out-of-DOM-order lazy fills would misalign.
 *
 * Mobile/tablet (< xl): the rail <aside> is display:none, so the rail <ins> has
 * zero width. Pushing it makes AdSense throw `No slot size for availableWidth=0`
 * (a Best-Practices console-error fail). The inline guard below only push()es at
 * xl+; below xl it instead strips the `adsbygoogle` class off the hidden <ins> so
 * the slot leaves AdSense's candidate pool entirely — otherwise the next *visible*
 * push (the banner) would grab this 0-width slot in DOM order and still throw.
 *
 * Each rail uses its own distinct ad unit (per AdSense best practice — reusing
 * one unit id across boxes makes AdSense unfill the duplicates).
 */
import { AD_CLIENT as PUB, AD_SLOTS } from '../../lib/ads';
interface Props {
  side?: 'left' | 'right';
}
const { side = 'left' } = Astro.props;

// One distinct ad unit per rail (ids centralised in lib/ads.ts).
const SLOTS = {
  left: AD_SLOTS.railLeftTop,
  right: AD_SLOTS.railRightTop,
} as const;
const slot = SLOTS[side];
---
<aside
  class="hidden xl:flex xl:flex-col xl:items-center xl:flex-shrink-0 xl:w-[280px] xl:sticky xl:top-20 xl:self-start"
  aria-label="Sponsored"
  data-rail={side}
>
  <span class="font-label text-[10px] font-medium uppercase tracking-widest text-outline mb-2 select-none">Advertisement</span>
  <!-- Fixed 160×600 skyscraper, centered in the 280px rail (whitespace flanks it). -->
  <ins
    class="adsbygoogle"
    style="display:inline-block;width:160px;height:600px"
    data-ad-client={PUB}
    data-ad-slot={slot}></ins>
  <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>
</aside>

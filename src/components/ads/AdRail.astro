---
/**
 * One side rail = TWO stacked ad units, shown only on xl+ (mobile/tablet never
 * render the rails — they collapse to the in-content ad instead). Sticky so the
 * pair stays beside the tool as the user scrolls (works now that <body> uses
 * overflow-x: clip, not hidden).
 *
 * Loading: each <ins> keeps its own inline push({}) right after it — the proven
 * pattern from the old single-rail markup. AdSense fills statusless <ins> in DOM
 * order, so an inline push immediately after each one always targets THAT slot
 * (every earlier slot already got its push from its own preceding script). Don't
 * reorder these into a lazy/observer scheme — a bare push() can't target a
 * specific slot, so out-of-DOM-order lazy fills would misalign.
 *
 * Mobile/tablet (< xl): the rail <aside> is display:none, so each rail <ins> has
 * zero width. Pushing it makes AdSense throw `No slot size for availableWidth=0`
 * (a Best-Practices console-error fail). The inline guard below only push()es at
 * xl+; below xl it instead strips the `adsbygoogle` class off the hidden <ins> so
 * the slot leaves AdSense's candidate pool entirely — otherwise the next *visible*
 * push would grab this 0-width slot in DOM order and still throw.
 *
 * Slots (data-ad-format="auto" + full-width-responsive, so each adapts to the
 * 280px rail): each of the four rail boxes is its own distinct square ad unit
 * (per AdSense best practice — reusing one unit ID across boxes makes AdSense
 * unfill the duplicates).
 */
import { AD_CLIENT as PUB, AD_PLACEMENTS } from '../../lib/ads';
interface Props {
  side?: 'left' | 'right';
}
const { side = 'left' } = Astro.props as Props;

// One distinct square ad unit per rail box (ids centralised in lib/ads.ts).
const SLOTS = {
  left: { top: AD_PLACEMENTS.railLeftTop.slot, bottom: AD_PLACEMENTS.railLeftBottom.slot },
  right: { top: AD_PLACEMENTS.railRightTop.slot, bottom: AD_PLACEMENTS.railRightBottom.slot },
} as const;
const slot = SLOTS[side];
---
<aside
  class="hidden xl:flex xl:flex-col xl:gap-4 xl:flex-shrink-0 xl:w-[280px] xl:sticky xl:top-20 xl:self-start"
  aria-label="Sponsored"
  data-rail={side}
>
  <!-- Top: square -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-format="auto"
    data-full-width-responsive="true"
    data-ad-client={PUB}
    data-ad-slot={slot.top}></ins>
  <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>

  <!-- Bottom: square -->
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-format="auto"
    data-full-width-responsive="true"
    data-ad-client={PUB}
    data-ad-slot={slot.bottom}></ins>
  <script is:inline>(function(){var i=document.currentScript.previousElementSibling;if(window.matchMedia('(min-width:1280px)').matches){(adsbygoogle=window.adsbygoogle||[]).push({});}else if(i){i.classList.remove('adsbygoogle');}})();</script>
</aside>

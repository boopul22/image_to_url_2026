---
/**
 * Client-side image compressor. Re-encodes PNG/JPG/WebP at adjustable quality
 * and shows before/after sizes. Output format defaults to same-as-input when
 * 'match' is chosen, or forced to JPG/WebP for extra savings.
 */
---
<div class="w-full max-w-2xl mx-auto">
  <input type="file" id="icomp-input" accept="image/png,image/jpeg,image/webp,.png,.jpg,.jpeg,.webp" multiple class="hidden" />
  <div class="bg-white border-2 border-on-background border-b-0 px-4 py-3 flex items-center justify-between gap-3 flex-wrap">
    <div class="flex items-center gap-2 min-w-0">
      <span class="material-symbols-outlined text-rose-600 text-lg flex-shrink-0" style="font-variation-settings: 'FILL' 1;">lock</span>
      <div class="min-w-0">
        <p class="text-xs font-bold uppercase tracking-wider text-on-background">100% in your browser</p>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <label for="icomp-format" class="text-xs font-bold uppercase tracking-wider text-on-background">Format</label>
      <select id="icomp-format" class="border-2 border-on-background bg-white text-xs font-bold uppercase px-2 py-1">
        <option value="match">Match source</option>
        <option value="image/jpeg">JPG</option>
        <option value="image/webp">WebP</option>
      </select>
      <label for="icomp-quality" class="text-xs font-bold uppercase tracking-wider text-on-background ml-2">Quality</label>
      <input type="range" id="icomp-quality" min="30" max="100" value="80" class="w-20 sm:w-28 accent-rose-600" />
      <span id="icomp-quality-val" class="text-xs font-mono font-bold w-8 text-right">80</span>
    </div>
  </div>
  <div id="icomp-panel" class="bg-white border-2 border-dashed border-on-background overflow-hidden transition-colors">
    <div id="icomp-state-idle" class="px-6 py-12 sm:px-10 sm:py-16">
      <div id="icomp-drop" class="flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
        <span class="material-symbols-outlined text-on-background text-4xl sm:text-5xl">compress</span>
        <div class="text-center">
          <p class="text-on-background font-semibold text-sm sm:text-base font-headline uppercase tracking-wider">Drop images here or click to browse</p>
          <p class="text-xs sm:text-sm text-on-surface-variant mt-2">PNG · JPG · WebP — multi-select OK</p>
        </div>
      </div>
      <div id="icomp-progress" class="hidden mt-6">
        <div class="h-2.5 sm:h-2 bg-surface-variant overflow-hidden rounded-full">
          <div id="icomp-progress-fill" class="h-full bg-rose-600 transition-all duration-300 rounded-full" style="width: 0%"></div>
        </div>
        <p id="icomp-progress-text" class="text-xs text-center mt-2 font-mono text-on-surface-variant">Compressing…</p>
      </div>
    </div>
    <div id="icomp-state-results" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
        <span class="font-bold text-secondary text-sm sm:text-lg" id="icomp-results-heading">Compressed</span>
        <button id="icomp-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">Compress more</button>
      </div>
      <div id="icomp-results-list" class="flex flex-col gap-2 max-h-96 overflow-auto"></div>
    </div>
    <div id="icomp-state-error" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-symbols-outlined text-error text-lg sm:text-xl">error</span>
        <span class="font-bold text-error text-sm sm:text-lg">Failed</span>
        <button id="icomp-error-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline">Try again</button>
      </div>
      <p id="icomp-error-text" class="text-xs sm:text-sm text-on-surface-variant"></p>
    </div>
  </div>
</div>

<script>
  const input = document.getElementById('icomp-input') as HTMLInputElement;
  const drop = document.getElementById('icomp-drop') as HTMLDivElement;
  const panel = document.getElementById('icomp-panel') as HTMLDivElement;
  const stateIdle = document.getElementById('icomp-state-idle') as HTMLDivElement;
  const stateResults = document.getElementById('icomp-state-results') as HTMLDivElement;
  const stateError = document.getElementById('icomp-state-error') as HTMLDivElement;
  const progress = document.getElementById('icomp-progress') as HTMLDivElement;
  const progressFill = document.getElementById('icomp-progress-fill') as HTMLDivElement;
  const progressText = document.getElementById('icomp-progress-text') as HTMLParagraphElement;
  const resultsList = document.getElementById('icomp-results-list') as HTMLDivElement;
  const resultsHeading = document.getElementById('icomp-results-heading') as HTMLSpanElement;
  const resetBtn = document.getElementById('icomp-reset') as HTMLButtonElement;
  const errorReset = document.getElementById('icomp-error-reset') as HTMLButtonElement;
  const errorText = document.getElementById('icomp-error-text') as HTMLParagraphElement;
  const qualityInput = document.getElementById('icomp-quality') as HTMLInputElement;
  const qualityVal = document.getElementById('icomp-quality-val') as HTMLSpanElement;
  const formatSel = document.getElementById('icomp-format') as HTMLSelectElement;

  qualityInput.addEventListener('input', () => { qualityVal.textContent = qualityInput.value; });

  function showState(n: 'idle' | 'results' | 'error') {
    stateIdle.classList.toggle('hidden', n !== 'idle');
    stateResults.classList.toggle('hidden', n !== 'results');
    stateError.classList.toggle('hidden', n !== 'error');
  }
  drop.addEventListener('click', () => input.click());
  ['dragenter','dragover'].forEach(ev => panel.addEventListener(ev, e => { e.preventDefault(); panel.classList.add('border-rose-600','bg-rose-50'); }));
  ['dragleave','drop'].forEach(ev => panel.addEventListener(ev, e => { e.preventDefault(); panel.classList.remove('border-rose-600','bg-rose-50'); }));
  panel.addEventListener('drop', e => { const f = (e as DragEvent).dataTransfer?.files; if (f && f.length) handleFiles(f); });
  input.addEventListener('change', () => { if (input.files && input.files.length) handleFiles(input.files); });
  resetBtn.addEventListener('click', () => { resultsList.innerHTML = ''; input.value = ''; showState('idle'); progress.classList.add('hidden'); progressFill.style.width = '0%'; });
  errorReset.addEventListener('click', () => { showState('idle'); progress.classList.add('hidden'); progressFill.style.width = '0%'; });

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / 1024 / 1024).toFixed(2)} MB`;
  }

  function compressFile(file: File, mime: string, quality: number): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onerror = () => reject(new Error('Could not read file'));
      reader.onload = () => {
        const img = new Image();
        img.onerror = () => reject(new Error('Could not decode'));
        img.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = img.naturalWidth; canvas.height = img.naturalHeight;
          const ctx = canvas.getContext('2d');
          if (!ctx) return reject(new Error('Canvas unavailable'));
          if (mime === 'image/jpeg') { ctx.fillStyle = '#fff'; ctx.fillRect(0,0,canvas.width,canvas.height); }
          ctx.drawImage(img, 0, 0);
          canvas.toBlob(b => b ? resolve(b) : reject(new Error('Encoding failed')), mime, mime === 'image/png' ? undefined : quality);
        };
        img.src = reader.result as string;
      };
      reader.readAsDataURL(file);
    });
  }

  function extFor(mime: string): string { return mime === 'image/jpeg' ? 'jpg' : mime === 'image/webp' ? 'webp' : 'png'; }

  function makeRow(name: string, origSize: number, blob: Blob): HTMLDivElement {
    const row = document.createElement('div');
    row.className = 'border-2 border-on-background bg-white p-3 flex items-center gap-3';
    const url = URL.createObjectURL(blob);
    const baseName = name.replace(/\.[^.]+$/, '') + '-compressed.' + extFor(blob.type);
    const thumb = document.createElement('img'); thumb.src = url; thumb.alt = ''; thumb.className = 'w-12 h-12 object-cover border-2 border-on-background flex-shrink-0';
    const meta = document.createElement('div'); meta.className = 'flex-1 min-w-0';
    const nameEl = document.createElement('p'); nameEl.className = 'text-xs font-bold truncate'; nameEl.textContent = baseName;
    const savedPct = Math.max(0, Math.round((1 - blob.size / origSize) * 100));
    const sizeEl = document.createElement('p'); sizeEl.className = 'text-[11px] text-on-surface-variant';
    sizeEl.textContent = `${fmtBytes(origSize)} → ${fmtBytes(blob.size)} (${savedPct}% smaller)`;
    meta.appendChild(nameEl); meta.appendChild(sizeEl);
    const dl = document.createElement('a'); dl.href = url; dl.download = baseName;
    dl.className = 'bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wide flex-shrink-0'; dl.textContent = 'Download';
    row.appendChild(thumb); row.appendChild(meta); row.appendChild(dl);
    return row;
  }

  async function handleFiles(fileList: FileList) {
    const files = Array.from(fileList);
    if (!files.length) return;
    progress.classList.remove('hidden'); progressFill.style.width = '0%';
    resultsList.innerHTML = '';
    const quality = Number(qualityInput.value) / 100;
    const formatChoice = formatSel.value;
    let done = 0, success = 0, totalOrig = 0, totalNew = 0;
    for (const file of files) {
      progressText.textContent = `Compressing ${done + 1} / ${files.length} — ${file.name}`;
      const outMime = formatChoice === 'match' ? (file.type || 'image/jpeg') : formatChoice;
      try {
        const blob = await compressFile(file, outMime, quality);
        totalOrig += file.size; totalNew += blob.size;
        resultsList.appendChild(makeRow(file.name, file.size, blob));
        success++;
      } catch (err: any) {
        const row = document.createElement('div');
        row.className = 'border-2 border-error bg-white p-3 text-xs';
        row.textContent = `${file.name} — ${err?.message || 'failed'}`;
        resultsList.appendChild(row);
      }
      done++; progressFill.style.width = `${Math.round((done / files.length) * 100)}%`;
    }
    if (success === 0) { showState('error'); errorText.textContent = 'Could not compress any file.'; return; }
    const savedPct = totalOrig ? Math.round((1 - totalNew / totalOrig) * 100) : 0;
    resultsHeading.textContent = `Compressed ${success} — saved ${savedPct}%`;
    showState('results');
  }
</script>

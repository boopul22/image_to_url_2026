---
import SharePanel from './SharePanel.astro';
import { localizedUrl } from '../i18n/landing/registry';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';
import type { PageKey } from '../i18n/landing/slugs';
// Global share surface, rendered once in Layout.astro so it exists on EVERY page.
//
// Flow:
//   - shareGoRandom(url): the uploaders' "Get Link" handler navigates to a RANDOM
//     landing page with ?u=<url>.
//   - On the destination, this component reads ?u= on load and MOUNTS the share
//     panel into that page's existing ad-rail center column ([data-share-mount],
//     present in ImageUploader + ToolAdSurround). That way the panel is flanked by
//     the page's OWN already-filling side ads — no duplicate ad slots, no fragile
//     dynamic ad fills. Then it strips ?u= from the URL.
//   - revealShareDest(url): in-place reveal fallback (same mount logic) if ever
//     called without navigation.
//
// Destinations are computed SERVER-SIDE in the visitor's locale via localizedUrl()
// and curated toward higher-CPC pages for RPM. Every curated page has an uploader
// or converter widget, so [data-share-mount] always exists there.

const locale: Locale = ((Astro.locals as any).locale as Locale) ?? defaultLocale;

const DEST_KEYS: PageKey[] = [
  'image-hosting-for-ebay',
  'image-hosting-for-shopify',
  'image-hosting-for-wordpress',
  'image-hosting-for-notion',
  'image-hosting-for-email-signatures',
  'image-hosting-for-newsletters',
  'image-hosting-for-google-forms',
  'image-hosting-for-google-sheets',
  'image-hosting-for-github-readme',
  'image-hosting-for-discord',
  'image-hosting-for-forums',
  'jpg-to-pdf',
  'png-to-pdf',
  'heic-to-pdf',
  'image-compressor',
  'image-resizer',
  'png-to-webp',
  'jpg-to-webp',
  'permanent-image-hosting',
  'free-image-hosting',
];
const destURLs = DEST_KEYS.map((k) => localizedUrl(k, locale));
---

<!-- Hidden host for the panel until a ?u= reveal moves it into [data-share-mount]. -->
<div id="share-dest" hidden class="w-full">
  <SharePanel />
</div>

<!-- Server-computed, locale-correct random destinations for the routing helper. -->
<script is:inline define:vars={{ destURLs }}>
  window.__shareDestPages = destURLs;
</script>

<script>
  import { getValidUrl } from '../lib/share-url';

  const destEl = document.getElementById('share-dest');
  const w = window as any;
  if (destEl) {
    const dest: HTMLElement = destEl;
    let mounted = false;

    function doReveal(u: string) {
      // Move the panel into the page's ad-rail center column so the page's own
      // (already-filling) side ads flank it. Fall back to just below the header.
      if (!mounted) {
        mounted = true;
        const mount = document.querySelector('[data-share-mount]');
        if (mount) {
          mount.prepend(dest);
        } else {
          const header = document.querySelector('header, nav');
          if (header) header.insertAdjacentElement('afterend', dest);
        }
      }
      dest.hidden = false;
      if (typeof w.showSharePanel === 'function') w.showSharePanel(u);
    }

    // In-place reveal (no navigation) — kept for flexibility.
    w.revealShareDest = (raw: string) => {
      const u = getValidUrl(raw);
      if (u) doReveal(u);
    };

    // "Get Link" → navigate to a random landing page carrying ?u=.
    w.shareGoRandom = (raw: string) => {
      const u = getValidUrl(raw);
      if (!u) return;
      const here = location.pathname.replace(/\/$/, '');
      const pages = ((w.__shareDestPages as string[]) || []).filter(
        (p) => p && p.replace(/\/$/, '') !== here,
      );
      const target = pages.length
        ? pages[Math.floor(Math.random() * pages.length)]
        : '/share';
      location.href = target + '?u=' + encodeURIComponent(u);
    };

    // Redirected visitor: auto-reveal on a valid ?u=, then clean the URL.
    const fromQuery = getValidUrl(new URLSearchParams(location.search).get('u'));
    if (fromQuery) {
      doReveal(fromQuery);
      try {
        const url = new URL(location.href);
        url.searchParams.delete('u');
        history.replaceState({}, '', url.pathname + url.search + url.hash);
      } catch { /* ignore */ }
    }
  }
</script>

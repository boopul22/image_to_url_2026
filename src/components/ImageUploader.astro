---
/**
 * Reusable image uploader widget.
 * Embeds the drag-and-drop upload panel with progress, success, and error states.
 * Uses unique IDs via a generated suffix to allow multiple instances (though typically one per page).
 *
 * Visual: soft "drop card" per the design mockup — a padded gray shell wrapping a
 * white dashed drop area with a floating action island (auto-delete + Browse).
 * The soft radii/shadows come from the scoped `.soft-uploader` layer in global.css;
 * the rest of the site stays brutalist.
 */
---

<!-- Tool-area ads: left + right 160x600 skyscrapers flank the uploader on lg+,
     with a 90px horizontal banner above. The wrapper breaks out of its parent's
     max-w-5xl constraint at lg+ via left-1/2/-translate-x-1/2 so all three
     columns + gaps fit (~1040px) inside an lg:max-w-6xl frame. -->
<div class="w-full mb-8 sm:mb-10 lg:relative lg:left-1/2 lg:-translate-x-1/2 lg:w-screen lg:max-w-6xl lg:px-6">
  <div class="w-full lg:flex lg:items-start lg:justify-center lg:gap-6">
    <!-- Left skyscraper -->
    <aside class="hidden lg:block lg:flex-shrink-0 lg:w-[160px] lg:h-[600px] lg:overflow-hidden lg:sticky lg:top-20 lg:self-start" aria-label="Sponsored">
      <ins
        class="adsbygoogle"
        style="display:inline-block;width:160px;height:600px"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="1115981593"
      ></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>

    <!-- Center column: top horizontal banner + uploader widget + trust signals -->
    <div class="w-full lg:flex-1 lg:max-w-2xl lg:min-w-0">
      <!-- Top responsive banner — full-width-responsive lets AdSense pick the best size per device -->
      <div class="w-full max-w-2xl mx-auto mb-4">
        <ins
          class="adsbygoogle"
          style="display:block"
          data-ad-client="ca-pub-7803867089582138"
          data-ad-slot="8598885796"
          data-ad-format="auto"
          data-full-width-responsive="true"
        ></ins>
        <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <div class="soft-uploader w-full max-w-xl sm:max-w-2xl mx-auto">
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" multiple class="hidden" />

        <!-- Soft drop card: padded gray shell -->
        <div class="su-card su-inner-shadow bg-surface-container p-2 border border-outline-variant/40">
          <!-- Drop area -->
          <div
            id="upload-panel"
            class="su-drop relative bg-white border border-dashed border-outline-variant overflow-hidden transition-all duration-300"
          >
            <!-- State: idle / uploading -->
            <div id="state-idle" class="relative min-h-[320px]">
              <div id="drop-zone" class="group absolute inset-0 flex flex-col items-center justify-center gap-4 px-6 pb-24 cursor-pointer" role="button" tabindex="0">
                <span class="material-symbols-outlined text-on-surface-variant/30 group-hover:text-rose-500 group-hover:scale-110 transition-all duration-300 text-5xl sm:text-6xl" id="upload-icon">cloud_upload</span>
                <div class="text-center">
                  <p class="text-on-surface-variant font-medium text-sm sm:text-base transition-opacity duration-300 group-hover:opacity-70" id="upload-text">Drop files to upload</p>
                  <p class="text-xs sm:text-sm text-on-surface-variant/70 mt-1" id="upload-subtext">JPG, PNG, WebP, GIF, SVG &mdash; Max 10MB</p>
                </div>
                <div id="progress-bar" class="su-progress hidden w-full max-w-xs h-2 bg-surface-variant overflow-hidden">
                  <div id="progress-fill" class="su-progress h-full bg-rose-600 transition-all duration-300" style="width: 0%"></div>
                </div>
                <div class="sr-only" id="upload-btn">Select File</div>
              </div>

              <!-- Floating action island: auto-delete + Browse -->
              <div class="su-island su-soft-shadow absolute bottom-5 left-1/2 -translate-x-1/2 z-10 bg-white border border-outline-variant/30 flex items-center gap-2 p-2 w-[92%] max-w-[380px]">
                <div class="su-control flex items-center gap-2 bg-surface-container-low px-3 py-2 flex-1 min-w-0 hover:bg-surface-container transition-colors">
                  <span class="material-symbols-outlined text-rose-600 text-base flex-shrink-0" style="font-variation-settings: 'FILL' 1;">schedule</span>
                  <div class="relative flex-1 min-w-0">
                    <select
                      id="expires-in"
                      aria-label="Auto-delete after"
                      aria-describedby="expires-in-hint"
                      class="su-control appearance-none w-full bg-transparent text-xs font-semibold text-on-surface pr-5 outline-none cursor-pointer"
                    >
                      <option value="7d">Delete in 7 days</option>
                      <option value="1h">Delete in 1 hour</option>
                      <option value="24h">Delete in 24 hours</option>
                      <option value="30d">Delete in 30 days</option>
                      <option value="never">Never delete</option>
                    </select>
                    <span class="material-symbols-outlined absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant/60 text-base pointer-events-none">expand_more</span>
                  </div>
                </div>
                <button
                  type="button"
                  id="browse-btn"
                  class="su-btn bg-rose-600 hover:bg-rose-700 text-white text-xs font-semibold px-5 py-2.5 transition-colors whitespace-nowrap active:scale-95 flex-shrink-0"
                  style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);"
                >
                  Browse
                </button>
              </div>
            </div>

            <!-- State: success -->
            <div id="state-success" class="p-4 sm:p-6 hidden">
              <div class="flex items-center gap-3 mb-4">
                <span class="material-symbols-outlined text-rose-600 text-lg sm:text-xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                <span class="font-bold text-on-surface text-sm sm:text-lg">Uploaded!</span>
                <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Upload another
                </button>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <input type="text" id="result-url" readonly class="su-control flex-1 min-w-0 bg-surface-container-low border border-outline-variant px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-500" />
                <button id="copy-btn" class="su-btn bg-rose-600 hover:bg-rose-700 text-white font-semibold text-sm py-3 px-6 transition-colors active:scale-95 flex-shrink-0" style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);">
                  Get Link
                </button>
              </div>
              <!-- ExtractPics cross-promo CTA -->
              <a href="https://www.extractpics.com/" target="_blank" rel="noopener" data-track-click="extractpics-cta" class="flex items-center gap-3 mt-4 pt-4 border-t border-outline-variant/40 hover:opacity-90 transition-opacity group">
                <span class="su-control flex-shrink-0 inline-flex items-center justify-center w-9 h-9 bg-rose-50 text-rose-600">
                  <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">image_search</span>
                </span>
                <div class="flex-1 min-w-0">
                  <span class="text-xs sm:text-sm font-bold text-on-background">Need images from a website?</span>
                  <p class="text-xs text-on-surface-variant mt-0.5">ExtractPics — grab every image from any URL, free</p>
                </div>
                <span class="su-btn flex-shrink-0 inline-flex items-center gap-1 bg-rose-600 text-white px-3 py-2 font-bold text-xs group-hover:translate-x-0.5 transition-transform">
                  Try it <span class="material-symbols-outlined text-sm">open_in_new</span>
                </span>
              </a>
            </div>

            <!-- State: batch success -->
            <div id="state-batch" class="p-4 sm:p-6 hidden">
              <div class="flex items-center gap-3 mb-4">
                <span class="material-symbols-outlined text-rose-600 text-lg sm:text-xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                <span class="font-bold text-on-surface text-sm sm:text-lg" id="batch-heading">Uploaded 0 files</span>
                <button id="batch-another" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Upload more
                </button>
              </div>
              <div id="batch-list" class="flex flex-col gap-2 max-h-80 overflow-auto"></div>
              <button id="batch-copy-all" class="su-btn mt-3 w-full bg-rose-600 hover:bg-rose-700 text-white font-semibold text-sm py-3 px-6 transition-colors active:scale-95" style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);">
                Copy all URLs
              </button>
            </div>

            <!-- State: error -->
            <div id="state-error" class="p-4 sm:p-6 hidden">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-error flex-shrink-0 text-2xl">error</span>
                <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">Upload failed</span>
                <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Try again
                </button>
                <a id="error-login" href="/api/auth/login" class="hidden text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Login
                </a>
              </div>
              <!-- Sign in CTA for limit errors -->
              <a href="/api/auth/login" id="error-signin" class="hidden items-center gap-2 mt-3 pt-3 border-t border-outline-variant/40 text-on-background hover:opacity-80 transition-opacity group">
                <span class="material-symbols-outlined text-base text-primary">login</span>
                <span class="text-xs sm:text-sm font-bold">Sign in to get more uploads</span>
                <span class="material-symbols-outlined text-sm text-primary group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Auto-delete hint + help, below the card -->
        <div class="mt-3 flex items-center justify-center gap-1.5 text-center">
          <p id="expires-in-hint" class="text-xs text-on-surface-variant">Auto-deletes in 7 days</p>
          <button
            type="button"
            id="expires-in-help"
            aria-label="What does auto-delete do?"
            aria-expanded="false"
            aria-controls="expires-in-help-panel"
            class="su-control inline-flex items-center justify-center w-5 h-5 border border-outline-variant text-[10px] font-bold text-on-surface-variant hover:bg-rose-600 hover:text-white hover:border-rose-600 transition-colors"
          >?</button>
        </div>
        <div
          id="expires-in-warning"
          class="su-control hidden mt-2 bg-rose-50 border border-rose-200 px-4 py-2.5 text-xs font-semibold text-rose-700 text-center"
          role="status"
        >
          <p id="expires-in-warning-text"></p>
        </div>
        <div
          id="expires-in-help-panel"
          class="su-control hidden mt-2 bg-surface-container-low border border-outline-variant/40 px-4 py-3 text-xs text-on-surface-variant leading-snug text-center"
          role="region"
          aria-labelledby="expires-in-help"
        >
          Your image is auto-deleted after 7 days by default. Pick a longer window to keep it around, or a shorter one to wipe it sooner. Logged-out uploads max out at 24 hours regardless.
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap justify-center gap-4 sm:gap-8 mt-5 sm:mt-6 text-xs sm:text-sm text-on-surface-variant font-label font-bold uppercase tracking-wider">
          <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">rocket_launch</span> CDN</span>
          <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">lock</span> SSL</span>
          <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">link</span> Permanent</span>
          <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">flash_on</span> Instant</span>
        </div>

        <!-- Mobile/tablet in-content ad — fills the slot gap where desktop has skyscrapers. -->
        <div class="lg:hidden w-full max-w-2xl mx-auto mt-6">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client="ca-pub-7803867089582138"
            data-ad-slot="7769825756"
            data-ad-format="auto"
            data-full-width-responsive="true"
          ></ins>
          <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      </div><!-- /soft-uploader -->
    </div><!-- /center column -->

    <!-- Right skyscraper -->
    <aside class="hidden lg:block lg:flex-shrink-0 lg:w-[160px] lg:h-[600px] lg:overflow-hidden lg:sticky lg:top-20 lg:self-start" aria-label="Sponsored">
      <ins
        class="adsbygoogle"
        style="display:inline-block;width:160px;height:600px"
        data-ad-client="ca-pub-7803867089582138"
        data-ad-slot="3200025356"
      ></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
  </div><!-- /flex wrapper -->
</div><!-- /ad-wrapped outer -->

<script>
  // Ad-blocker detection — analytics only, NEVER blocks or degrades uploads.
  // Shared with HomePage.astro so both uploaders report the same signal.

  // Cached login check shared between the auto-delete gate and the batch-upload gate.
  let isLoggedIn: boolean | null = null;
  async function fetchLoggedIn(): Promise<boolean> {
    if (isLoggedIn !== null) return isLoggedIn;
    try {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      const data = await res.json();
      isLoggedIn = !!(data && data.user);
    } catch {
      isLoggedIn = false;
    }
    return isLoggedIn;
  }

  const expiresInSel = document.getElementById('expires-in') as HTMLSelectElement | null;
  const expiresInHint = document.getElementById('expires-in-hint');
  const expiresWarnEl = document.getElementById('expires-in-warning');
  const expiresWarnText = document.getElementById('expires-in-warning-text');
  const EXPIRY_HINTS: Record<string, string> = {
    never: 'Never auto-deleted',
    '1h': 'Auto-deletes in 1 hour',
    '24h': 'Auto-deletes in 24 hours',
    '7d': 'Auto-deletes in 7 days',
    '30d': 'Auto-deletes in 30 days',
  };
  const WARN_LABEL: Record<string, string> = {
    '1h': '1 hour',
    '24h': '24 hours',
    '7d': '7 days',
    '30d': '30 days',
  };

  function refreshExpiresWarning(value: string) {
    if (expiresInHint) {
      expiresInHint.textContent = EXPIRY_HINTS[value] || EXPIRY_HINTS['7d'];
    }
    if (!expiresWarnEl || !expiresWarnText) return;
    const label = WARN_LABEL[value];
    if (!label) {
      expiresWarnEl.classList.add('hidden');
      expiresWarnText.textContent = '';
    } else {
      expiresWarnText.textContent = `Deletes in ${label} — pick a different duration above ↑`;
      expiresWarnEl.classList.remove('hidden');
    }
  }

  if (expiresInSel) {
    expiresInSel.addEventListener('change', () => refreshExpiresWarning(expiresInSel.value));
    refreshExpiresWarning(expiresInSel.value);
  }

  const expiresHelpBtn = document.getElementById('expires-in-help');
  const expiresHelpPanel = document.getElementById('expires-in-help-panel');
  if (expiresHelpBtn && expiresHelpPanel) {
    expiresHelpBtn.addEventListener('click', () => {
      const expanded = expiresHelpBtn.getAttribute('aria-expanded') === 'true';
      expiresHelpBtn.setAttribute('aria-expanded', String(!expanded));
      expiresHelpPanel.classList.toggle('hidden');
    });
  }

  const panel = document.getElementById('upload-panel')!;
  const dropZone = document.getElementById('drop-zone')!;
  const browseBtn = document.getElementById('browse-btn');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadIcon = document.getElementById('upload-icon')!;
  const uploadText = document.getElementById('upload-text')!;
  const uploadSubtext = document.getElementById('upload-subtext')!;
  const uploadBtn = document.getElementById('upload-btn')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressFill = document.getElementById('progress-fill')!;
  const stateIdle = document.getElementById('state-idle')!;
  const stateSuccess = document.getElementById('state-success')!;
  const stateBatch = document.getElementById('state-batch')!;
  const stateError = document.getElementById('state-error')!;
  const batchHeading = document.getElementById('batch-heading')!;
  const batchList = document.getElementById('batch-list')!;
  const batchCopyAll = document.getElementById('batch-copy-all')!;
  const batchAnother = document.getElementById('batch-another')!;
  const resultUrl = document.getElementById('result-url') as HTMLInputElement;
  const copyBtn = document.getElementById('copy-btn')!;
  const uploadAnother = document.getElementById('upload-another')!;
  const errorRetry = document.getElementById('error-retry')!;
  const errorLogin = document.getElementById('error-login')!;
  const errorText = document.getElementById('error-text')!;
  const errorSignin = document.getElementById('error-signin')!;
  const errorPromo = document.getElementById('error-promo');

  function showState(state: 'idle' | 'success' | 'batch' | 'error') {
    stateIdle.classList.toggle('hidden', state !== 'idle');
    stateSuccess.classList.toggle('hidden', state !== 'success');
    stateBatch.classList.toggle('hidden', state !== 'batch');
    stateError.classList.toggle('hidden', state !== 'error');
  }

  function resetIdle() {
    showState('idle');
    progressBar.classList.add('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'cloud_upload';
    uploadText.textContent = 'Drop files to upload';
    uploadSubtext.textContent = 'JPG, PNG, WebP, GIF, SVG — up to 10 MB';
    uploadBtn.textContent = 'Select File';
    fileInput.value = '';
    errorSignin.classList.add('hidden');
    errorSignin.classList.remove('flex');
    errorPromo?.classList.add('hidden');
    errorPromo?.classList.remove('flex');
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  function showLoginError() {
    errorRetry.classList.add('hidden');
    errorLogin.classList.remove('hidden');
  }

  function showRetryError() {
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });
  browseBtn?.addEventListener('click', () => fileInput.click());

  panel.addEventListener('dragover', (e) => {
    e.preventDefault();
    panel.classList.add('!border-rose-400', '!bg-rose-50');
  });
  panel.addEventListener('dragleave', (e) => {
    if (!panel.contains(e.relatedTarget as Node)) {
      panel.classList.remove('!border-rose-400', '!bg-rose-50');
    }
  });
  panel.addEventListener('drop', (e) => {
    e.preventDefault();
    panel.classList.remove('!border-rose-400', '!bg-rose-50');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) handleFiles(files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) handleFiles(fileInput.files);
  });

  async function handleFiles(files: FileList) {
    // Ad-block gate covers both single and batch paths in one place.
    if (!(await (window as any).__adblockGate?.check())) {
      fileInput.value = '';
      return;
    }
    if (files.length === 1) {
      uploadFile(files[0]);
      return;
    }
    // Batch path — require login
    const loggedIn = await fetchLoggedIn();
    if (!loggedIn) {
      showState('error');
      errorText.textContent = 'Sign in to upload multiple images at once.';
      errorSignin.classList.remove('hidden');
      errorSignin.classList.add('flex');
      showLoginError();
      fileInput.value = '';
      return;
    }
    uploadBatch(Array.from(files));
  }

  async function uploadBatch(files: File[]) {
    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'hourglass_top';
    uploadText.textContent = `Uploading 0 / ${files.length}`;
    uploadSubtext.textContent = 'Batch upload in progress…';
    uploadBtn.textContent = 'Uploading...';

    batchList.innerHTML = '';
    const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
    const ab = '0'; // gated in handleFiles
    const results: { name: string; url: string }[] = [];
    const failures: { name: string; error: string }[] = [];

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      uploadText.textContent = `Uploading ${i + 1} / ${files.length}`;
      uploadSubtext.textContent = file.name;
      try {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('adblock', ab);
        if (expiresInEl) formData.append('expires_in', expiresInEl.value);
        const response = await fetch('/api/upload', { method: 'POST', body: formData });
        const data = await response.json();
        if (!response.ok || data.error) throw new Error(data.error || 'Upload failed');
        results.push({ name: file.name, url: data.data.url });
      } catch (err: any) {
        failures.push({ name: file.name, error: err.message || 'Upload failed' });
      }
      progressFill.style.width = `${Math.round(((i + 1) / files.length) * 100)}%`;
    }

    if (results.length === 0) {
      showState('error');
      errorText.textContent = failures[0]?.error || 'All uploads failed';
      return;
    }

    batchHeading.textContent =
      failures.length > 0
        ? `Uploaded ${results.length} / ${files.length} (${failures.length} failed)`
        : `Uploaded ${results.length} files`;

    for (const r of results) {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      const input = document.createElement('input');
      input.type = 'text';
      input.readOnly = true;
      input.value = r.url;
      input.className = 'su-control flex-1 min-w-0 bg-surface-container-low border border-outline-variant px-3 py-2 text-xs font-mono text-on-surface focus:outline-none focus:border-rose-500';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = 'Copy';
      btn.className = 'su-btn bg-white hover:bg-rose-600 hover:text-white text-on-surface font-bold text-xs py-2 px-3 border border-outline-variant transition-colors flex-shrink-0';
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(r.url);
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
      row.appendChild(input);
      row.appendChild(btn);
      batchList.appendChild(row);
    }

    showState('batch');
  }

  batchCopyAll.addEventListener('click', () => {
    const urls = Array.from(batchList.querySelectorAll('input')).map((i) => (i as HTMLInputElement).value).join('\n');
    navigator.clipboard.writeText(urls);
    (batchCopyAll as HTMLButtonElement).textContent = 'Copied!';
    setTimeout(() => { (batchCopyAll as HTMLButtonElement).textContent = 'Copy all URLs'; }, 2000);
  });

  batchAnother.addEventListener('click', resetIdle);

  copyBtn.addEventListener('click', () => {
    // "Get Link" — no copy here; send the user to the share screen, which owns
    // copying (plus more formats + QR).
    window.location.href = '/share?u=' + encodeURIComponent(resultUrl.value);
  });



  uploadAnother.addEventListener('click', resetIdle);
  errorRetry.addEventListener('click', resetIdle);

  async function uploadFile(file: File) {
    // "Never" requires a signed-in account; server clamps anon to 24h otherwise.
    if (expiresInSel?.value === 'never') {
      const loggedIn = await fetchLoggedIn();
      if (!loggedIn) {
        showState('error');
        errorText.textContent = 'Sign in to upload images that never expire.';
        errorSignin.classList.remove('hidden');
        errorSignin.classList.add('flex');
        showLoginError();
        fileInput.value = '';
        return;
      }
    }

    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'hourglass_top';
    uploadText.textContent = `Uploading ${file.name}`;
    uploadSubtext.textContent = `${(file.size / 1024).toFixed(0)} KB · ${file.type.split('/')[1]?.toUpperCase() || 'FILE'}`;
    uploadBtn.textContent = 'Uploading...';

    const ab = '0'; // gated in handleFiles

    // Minimum perceived upload time — instant completion was driving
    // users to bounce before they registered that anything happened.
    const MIN_UPLOAD_MS = 5000;
    const startedAt = Date.now();

    // Time-based progress that walks toward 95% over MIN_UPLOAD_MS so the
    // bar feels alive regardless of how fast the real request finishes.
    const progressInterval = setInterval(() => {
      const elapsed = Date.now() - startedAt;
      const target = Math.min(95, (elapsed / MIN_UPLOAD_MS) * 95);
      progressFill.style.width = `${target}%`;
    }, 100);

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('adblock', ab);
      const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
      if (expiresInEl) formData.append('expires_in', expiresInEl.value);

      const response = await fetch('/api/upload', { method: 'POST', body: formData });
      const data = await response.json();

      if (!response.ok || data.error) {
        clearInterval(progressInterval);
        throw new Error(data.error || 'Upload failed');
      }

      const remaining = MIN_UPLOAD_MS - (Date.now() - startedAt);
      if (remaining > 0) {
        await new Promise((r) => setTimeout(r, remaining));
      }

      clearInterval(progressInterval);
      progressFill.style.width = '100%';
      setTimeout(() => {
        showState('success');
        resultUrl.value = data.data.url;
      }, 300);

    } catch (err: any) {
      clearInterval(progressInterval);
      showState('error');
      errorText.textContent = err.message || 'Upload failed';
      const isLimit = (err.message || '').toLowerCase().includes('limit');
      errorSignin.classList.toggle('hidden', !isLimit);
      errorSignin.classList.toggle('flex', isLimit);
      errorPromo?.classList.toggle('hidden', !isLimit);
      errorPromo?.classList.toggle('flex', isLimit);
      if (isLimit) showLoginError();
      else showRetryError();
    }
  }

  // Click tracking for cross-promo CTA
  document.querySelectorAll<HTMLAnchorElement>('[data-track-click]').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.sendBeacon('/api/track/click', JSON.stringify({
        linkId: el.dataset.trackClick,
        page: window.location.pathname,
      }));
    });
  });
</script>

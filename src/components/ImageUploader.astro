---
/**
 * Reusable image uploader widget.
 * Embeds the drag-and-drop upload panel with progress, success, and error states.
 * Uses unique IDs via a generated suffix to allow multiple instances (though typically one per page).
 */
---

<div class="w-full max-w-xl sm:max-w-2xl mx-auto mb-8 sm:mb-10">
  <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml" multiple class="hidden" />
  <div class="bg-white border-2 border-on-background border-b-0 px-4 py-3 flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span class="material-symbols-outlined text-rose-600 text-lg flex-shrink-0" style="font-variation-settings: 'FILL' 1;">timer</span>
      <div class="min-w-0">
        <label for="expires-in" class="block text-xs font-bold uppercase tracking-wider text-on-background">
          Auto-delete
          <button
            type="button"
            id="expires-in-help"
            aria-label="What does auto-delete do?"
            title="Privacy control: pick how long your image stays online before it is permanently wiped from our servers. Logged-out uploads max out at 24 hours."
            class="inline-flex items-center justify-center w-4 h-4 ml-1 border border-on-background text-[10px] font-bold align-middle hover:bg-rose-600 hover:text-white hover:border-rose-600 transition-colors"
          >?</button>
        </label>
        <p id="expires-in-hint" class="text-[11px] leading-tight text-on-surface-variant">Never auto-deleted</p>
      </div>
    </div>
    <select
      id="expires-in"
      aria-describedby="expires-in-hint"
      class="bg-white border-2 border-on-background px-3 py-2 text-xs font-bold uppercase tracking-wider focus:outline-none focus:border-rose-600 flex-shrink-0"
    >
      <option value="never">Never</option>
      <option value="1h">1 hour</option>
      <option value="24h">24 hours</option>
      <option value="7d">7 days</option>
      <option value="30d">30 days</option>
    </select>
  </div>
  <div
    id="upload-panel"
    class="bg-white border-2 border-dashed border-on-background overflow-hidden transition-colors"
  >
    <!-- State: idle / uploading -->
    <div id="state-idle" class="px-6 py-12 sm:px-10 sm:py-16">
      <div id="drop-zone" class="flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
        <span class="material-symbols-outlined text-on-background text-4xl sm:text-5xl" id="upload-icon">add_photo_alternate</span>
        <div class="text-center">
          <p class="text-on-background font-semibold text-sm sm:text-base font-headline uppercase tracking-wider" id="upload-text">Drop image here or click to browse</p>
          <p class="text-xs sm:text-sm text-on-surface-variant mt-2" id="upload-subtext">JPG, PNG, WebP, GIF, SVG &mdash; Max 10MB</p>
        </div>
        <div class="sr-only" id="upload-btn">Select File</div>
      </div>
      <div id="progress-bar" class="hidden mt-6 h-2.5 sm:h-2 bg-surface-variant overflow-hidden rounded-full">
        <div id="progress-fill" class="h-full bg-primary transition-all duration-300 rounded-full" style="width: 0%"></div>
      </div>
    </div>

    <!-- State: success -->
    <div id="state-success" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
        <span class="font-bold text-secondary text-sm sm:text-lg">Uploaded!</span>
        <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
          Upload another
        </button>
      </div>
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" id="result-url" readonly class="flex-1 min-w-0 bg-white border-2 border-on-background px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-600" />
        <button id="copy-btn" class="bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide flex-shrink-0">
          Copy
        </button>
      </div>
      <!-- YouTube channel support CTA -->
      <a href="https://www.youtube.com/channel/UCsZteVHTWUZKmOf1xBkeVzA/?sub_confirmation=1" target="_blank" rel="noopener" data-track-click="youtube-cta" class="flex items-center gap-3 mt-3 pt-3 border-t-2 border-on-background/10 hover:opacity-90 transition-opacity group">
        <svg class="flex-shrink-0 w-6 h-6 text-[#FF0000]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <div class="flex-1 min-w-0">
          <span class="text-xs sm:text-sm font-bold text-on-background">Enjoy this free tool? Please support us 🙏</span>
          <p class="text-xs text-on-surface-variant mt-0.5">GROOVE songs that lift your mood</p>
        </div>
        <span class="flex-shrink-0 inline-flex items-center gap-1 bg-[#FF0000] text-white border-2 border-on-background px-3 py-2 font-bold text-xs uppercase tracking-wider group-hover:translate-x-0.5 transition-transform">
          Subscribe <span class="material-symbols-outlined text-sm">open_in_new</span>
        </span>
      </a>
    </div>

    <!-- State: batch success -->
    <div id="state-batch" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
        <span class="font-bold text-secondary text-sm sm:text-lg" id="batch-heading">Uploaded 0 files</span>
        <button id="batch-another" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
          Upload more
        </button>
      </div>
      <div id="batch-list" class="flex flex-col gap-2 max-h-80 overflow-auto"></div>
      <button id="batch-copy-all" class="mt-3 w-full bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide">
        Copy all URLs
      </button>
    </div>

    <!-- State: error -->
    <div id="state-error" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-error flex-shrink-0 text-2xl">error</span>
        <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">Upload failed</span>
        <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
          TRY AGAIN
        </button>
      </div>
      <!-- Sign in CTA for limit errors -->
      <a href="/api/auth/login" id="error-signin" class="hidden items-center gap-2 mt-3 pt-3 border-t-2 border-on-background/10 text-on-background hover:opacity-80 transition-opacity group">
        <span class="material-symbols-outlined text-base text-primary">login</span>
        <span class="text-xs sm:text-sm font-bold">Sign in to get more uploads</span>
        <span class="material-symbols-outlined text-sm text-primary group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
      </a>
    </div>
  </div>

  <!-- Hire-me pitch modal (shown after copy, max 1x / 24h) -->
  <div
    id="pitch-modal"
    class="hidden fixed inset-0 z-50 items-center justify-center p-4 bg-neutral-900/60"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pitch-heading"
  >
    <div class="relative w-full max-w-lg bg-white border-2 border-neutral-900 brutal-shadow">
      <button
        id="pitch-close"
        type="button"
        aria-label="Close"
        class="absolute top-0 right-0 w-10 h-10 flex items-center justify-center border-l-2 border-b-2 border-neutral-900 bg-white hover:bg-rose-600 hover:text-white transition-colors"
      >
        <span class="material-symbols-outlined text-xl">close</span>
      </button>
      <div class="border-b-2 border-neutral-900 px-5 py-4 pr-14">
        <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-rose-600 border-2 border-neutral-900 bg-white px-2 py-1 mb-3">01 &middot; From the dev</span>
        <h2 id="pitch-heading" class="font-headline font-semibold uppercase tracking-tight text-2xl sm:text-3xl leading-[0.95] text-on-background">
          Like this tool?<br/>I build sites too.
        </h2>
      </div>
      <div class="px-5 py-4 border-b-2 border-neutral-900 text-sm text-on-surface-variant leading-relaxed">
        <p class="mb-3">I built this image host solo — fast, SEO-ready, Cloudflare-native. Your website can look and perform the same.</p>
        <ul class="space-y-2">
          <li class="flex gap-2"><span class="material-symbols-outlined text-rose-600 text-base flex-shrink-0" style="font-variation-settings: 'FILL' 1;">bolt</span><span><b class="text-on-background">Hand-coded, not WordPress.</b> Loads in under a second.</span></li>
          <li class="flex gap-2"><span class="material-symbols-outlined text-rose-600 text-base flex-shrink-0" style="font-variation-settings: 'FILL' 1;">search</span><span><b class="text-on-background">Built for Google + AI search.</b> Schema, sitemaps, the works.</span></li>
          <li class="flex gap-2"><span class="material-symbols-outlined text-rose-600 text-base flex-shrink-0" style="font-variation-settings: 'FILL' 1;">payments</span><span><b class="text-on-background">Fair pricing.</b> One dev, no agency markup.</span></li>
        </ul>
      </div>
      <form
        id="pitch-form"
        action="https://formsubmit.co/blog.boopul@gmail.com"
        method="POST"
        class="px-5 py-4"
      >
        <input type="hidden" name="_subject" value="New website lead from imagetourl.cloud" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://imagetourl.cloud/?contacted=1" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
        <label for="pitch-email" class="block text-xs font-bold uppercase tracking-wider text-on-background mb-2">Your email &mdash; I reply within a day</label>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            id="pitch-email"
            name="email"
            required
            placeholder="you@domain.com"
            class="flex-1 min-w-0 bg-white border-2 border-neutral-900 px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-600"
          />
          <button
            type="submit"
            id="pitch-submit"
            class="bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide flex-shrink-0"
          >
            Get a quote
          </button>
        </div>
        <p class="text-[11px] text-on-surface-variant mt-2 uppercase tracking-wider">No spam. No sales call. Just one dev replying.</p>
      </form>
    </div>
  </div>

  <!-- Trust signals -->
  <div class="flex flex-wrap justify-center gap-4 sm:gap-8 mt-5 sm:mt-6 text-xs sm:text-sm text-on-surface-variant font-label font-bold uppercase tracking-wider">
    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">rocket_launch</span> CDN</span>
    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">lock</span> SSL</span>
    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">link</span> Permanent</span>
    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-base sm:text-lg" style="font-variation-settings: 'FILL' 1;">flash_on</span> Instant</span>
  </div>
</div>

<script>
  const expiresInSel = document.getElementById('expires-in') as HTMLSelectElement | null;
  const expiresInHint = document.getElementById('expires-in-hint');
  const EXPIRY_HINTS: Record<string, string> = {
    never: 'Never auto-deleted',
    '1h': 'Auto-deletes in 1 hour',
    '24h': 'Auto-deletes in 24 hours',
    '7d': 'Auto-deletes in 7 days',
    '30d': 'Auto-deletes in 30 days',
  };
  if (expiresInSel && expiresInHint) {
    expiresInSel.addEventListener('change', () => {
      expiresInHint.textContent = EXPIRY_HINTS[expiresInSel.value] || EXPIRY_HINTS.never;
    });
  }

  const panel = document.getElementById('upload-panel')!;
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadIcon = document.getElementById('upload-icon')!;
  const uploadText = document.getElementById('upload-text')!;
  const uploadSubtext = document.getElementById('upload-subtext')!;
  const uploadBtn = document.getElementById('upload-btn')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressFill = document.getElementById('progress-fill')!;
  const stateIdle = document.getElementById('state-idle')!;
  const stateSuccess = document.getElementById('state-success')!;
  const stateBatch = document.getElementById('state-batch')!;
  const stateError = document.getElementById('state-error')!;
  const batchHeading = document.getElementById('batch-heading')!;
  const batchList = document.getElementById('batch-list')!;
  const batchCopyAll = document.getElementById('batch-copy-all')!;
  const batchAnother = document.getElementById('batch-another')!;
  const resultUrl = document.getElementById('result-url') as HTMLInputElement;
  const copyBtn = document.getElementById('copy-btn')!;
  const uploadAnother = document.getElementById('upload-another')!;
  const errorRetry = document.getElementById('error-retry')!;
  const errorText = document.getElementById('error-text')!;
  const errorSignin = document.getElementById('error-signin')!;
  const errorPromo = document.getElementById('error-promo')!;

  function showState(state: 'idle' | 'success' | 'batch' | 'error') {
    stateIdle.classList.toggle('hidden', state !== 'idle');
    stateSuccess.classList.toggle('hidden', state !== 'success');
    stateBatch.classList.toggle('hidden', state !== 'batch');
    stateError.classList.toggle('hidden', state !== 'error');
  }

  function resetIdle() {
    showState('idle');
    progressBar.classList.add('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'upload_file';
    uploadText.textContent = 'Click to upload or drag & drop';
    uploadSubtext.textContent = 'JPG, PNG, WebP, GIF, SVG — up to 10 MB';
    uploadBtn.textContent = 'Select File';
    fileInput.value = '';
    errorSignin.classList.add('hidden');
    errorSignin.classList.remove('flex');
    errorPromo.classList.add('hidden');
    errorPromo.classList.remove('flex');
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });

  panel.addEventListener('dragover', (e) => {
    e.preventDefault();
    panel.classList.add('!border-primary', '!bg-primary-fixed/30');
  });
  panel.addEventListener('dragleave', (e) => {
    if (!panel.contains(e.relatedTarget as Node)) {
      panel.classList.remove('!border-primary', '!bg-primary-fixed/30');
    }
  });
  panel.addEventListener('drop', (e) => {
    e.preventDefault();
    panel.classList.remove('!border-primary', '!bg-primary-fixed/30');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) handleFiles(files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) handleFiles(fileInput.files);
  });

  async function handleFiles(files: FileList) {
    if (files.length === 1) {
      uploadFile(files[0]);
      return;
    }
    // Batch path — require login
    let loggedIn = false;
    try {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      const data = await res.json();
      loggedIn = !!(data && data.user);
    } catch {}
    if (!loggedIn) {
      showState('error');
      errorText.textContent = 'Sign in to upload multiple images at once.';
      errorSignin.classList.remove('hidden');
      errorSignin.classList.add('flex');
      fileInput.value = '';
      return;
    }
    uploadBatch(Array.from(files));
  }

  async function uploadBatch(files: File[]) {
    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'hourglass_top';
    uploadText.textContent = `Uploading 0 / ${files.length}`;
    uploadSubtext.textContent = 'Batch upload in progress…';
    uploadBtn.textContent = 'Uploading...';

    batchList.innerHTML = '';
    const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
    const results: { name: string; url: string }[] = [];
    const failures: { name: string; error: string }[] = [];

    for (let i = 0; i < files.length; i++) {
      const file = files[i];
      uploadText.textContent = `Uploading ${i + 1} / ${files.length}`;
      uploadSubtext.textContent = file.name;
      try {
        const formData = new FormData();
        formData.append('file', file);
        if (expiresInEl) formData.append('expires_in', expiresInEl.value);
        const response = await fetch('/api/upload', { method: 'POST', body: formData });
        const data = await response.json();
        if (!response.ok || data.error) throw new Error(data.error || 'Upload failed');
        results.push({ name: file.name, url: data.data.url });
      } catch (err: any) {
        failures.push({ name: file.name, error: err.message || 'Upload failed' });
      }
      progressFill.style.width = `${Math.round(((i + 1) / files.length) * 100)}%`;
    }

    if (results.length === 0) {
      showState('error');
      errorText.textContent = failures[0]?.error || 'All uploads failed';
      return;
    }

    batchHeading.textContent =
      failures.length > 0
        ? `Uploaded ${results.length} / ${files.length} (${failures.length} failed)`
        : `Uploaded ${results.length} files`;

    for (const r of results) {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      const input = document.createElement('input');
      input.type = 'text';
      input.readOnly = true;
      input.value = r.url;
      input.className = 'flex-1 min-w-0 bg-white border-2 border-on-background px-3 py-2 text-xs font-mono text-on-surface focus:outline-none focus:border-rose-600';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = 'Copy';
      btn.className = 'bg-white hover:bg-rose-600 hover:text-white text-on-background font-bold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wider transition-colors flex-shrink-0';
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(r.url);
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
      row.appendChild(input);
      row.appendChild(btn);
      batchList.appendChild(row);
    }

    showState('batch');
  }

  batchCopyAll.addEventListener('click', () => {
    const urls = Array.from(batchList.querySelectorAll('input')).map((i) => (i as HTMLInputElement).value).join('\n');
    navigator.clipboard.writeText(urls);
    (batchCopyAll as HTMLButtonElement).textContent = 'Copied!';
    setTimeout(() => { (batchCopyAll as HTMLButtonElement).textContent = 'Copy all URLs'; }, 2000);
    maybeShowPitch();
  });

  batchAnother.addEventListener('click', resetIdle);

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(resultUrl.value);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
    maybeShowPitch();
  });

  // Hire-me pitch modal — show at most once per 24 hours after a copy
  const pitchModal = document.getElementById('pitch-modal')!;
  const pitchClose = document.getElementById('pitch-close')!;
  const pitchForm = document.getElementById('pitch-form') as HTMLFormElement | null;
  const PITCH_KEY = 'pitch-modal-last-shown';
  const DAY_MS = 24 * 60 * 60 * 1000;

  function openPitch() {
    pitchModal.classList.remove('hidden');
    pitchModal.classList.add('flex');
    try { localStorage.setItem(PITCH_KEY, String(Date.now())); } catch {}
    const email = document.getElementById('pitch-email') as HTMLInputElement | null;
    setTimeout(() => email?.focus(), 50);
  }
  function closePitch() {
    pitchModal.classList.add('hidden');
    pitchModal.classList.remove('flex');
  }
  function maybeShowPitch() {
    let last = 0;
    try { last = Number(localStorage.getItem(PITCH_KEY) || '0'); } catch {}
    if (Date.now() - last < DAY_MS) return;
    // Small delay so the "Copied!" feedback is visible first
    setTimeout(openPitch, 450);
  }
  pitchClose.addEventListener('click', closePitch);
  pitchModal.addEventListener('click', (e) => {
    if (e.target === pitchModal) closePitch();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !pitchModal.classList.contains('hidden')) closePitch();
  });
  pitchForm?.addEventListener('submit', () => {
    const btn = document.getElementById('pitch-submit') as HTMLButtonElement | null;
    if (btn) { btn.textContent = 'Sending…'; btn.disabled = true; }
  });

  uploadAnother.addEventListener('click', resetIdle);
  errorRetry.addEventListener('click', resetIdle);

  async function uploadFile(file: File) {
    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.textContent = 'hourglass_top';
    uploadText.textContent = `Uploading ${file.name}`;
    uploadSubtext.textContent = `${(file.size / 1024).toFixed(0)} KB · ${file.type.split('/')[1]?.toUpperCase() || 'FILE'}`;
    uploadBtn.textContent = 'Uploading...';

    let progress = 0;
    const progressInterval = setInterval(() => {
      progress = Math.min(progress + Math.random() * 15, 90);
      progressFill.style.width = `${progress}%`;
    }, 200);

    try {
      const formData = new FormData();
      formData.append('file', file);
      const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
      if (expiresInEl) formData.append('expires_in', expiresInEl.value);

      const response = await fetch('/api/upload', { method: 'POST', body: formData });
      const data = await response.json();

      clearInterval(progressInterval);

      if (!response.ok || data.error) {
        throw new Error(data.error || 'Upload failed');
      }

      progressFill.style.width = '100%';
      setTimeout(() => {
        showState('success');
        resultUrl.value = data.data.url;
      }, 300);

    } catch (err: any) {
      clearInterval(progressInterval);
      showState('error');
      errorText.textContent = err.message || 'Upload failed';
      const isLimit = (err.message || '').toLowerCase().includes('limit');
      errorSignin.classList.toggle('hidden', !isLimit);
      errorSignin.classList.toggle('flex', isLimit);
      errorPromo.classList.toggle('hidden', !isLimit);
      errorPromo.classList.toggle('flex', isLimit);
    }
  }

  // Click tracking for YouTube CTA
  document.querySelectorAll<HTMLAnchorElement>('[data-track-click]').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.sendBeacon('/api/track/click', JSON.stringify({
        linkId: el.dataset.trackClick,
        page: window.location.pathname,
      }));
    });
  });
</script>

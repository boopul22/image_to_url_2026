---
import Icon from './Icon.astro';
/**
 * Reusable image uploader widget.
 * Embeds the drag-and-drop upload panel with progress, success, and error states.
 * Uses unique IDs via a generated suffix to allow multiple instances (though typically one per page).
 *
 * Visual: soft "drop card" per the design mockup — a padded gray shell wrapping a
 * white dashed drop area with a floating action island (auto-delete + Browse).
 * The soft radii/shadows come from the scoped `.soft-uploader` layer in global.css;
 * the rest of the site stays brutalist.
 */
import AdRail from './ads/AdRail.astro';
import { AD_CLIENT, AD_SLOTS } from '../lib/ads';
---

<!-- Tool-area ads: left + right 160x600 skyscrapers flank the uploader on lg+,
     with a 90px horizontal banner above. The wrapper breaks out of its parent's
     max-w-5xl constraint at lg+ via left-1/2/-translate-x-1/2 so all three
     columns + gaps fit (~1040px) inside an lg:max-w-6xl frame. -->
<div class="w-full mb-8 sm:mb-10 xl:relative xl:left-1/2 xl:-translate-x-1/2 xl:w-screen xl:max-w-7xl xl:px-6">
  <div class="w-full xl:flex xl:items-start xl:justify-center xl:gap-6">
    <!-- Left rail — two stacked responsive ad units (vertical + square) -->
    <AdRail side="left" />

    <!-- Center column: uploader widget + trust signals. -->
    <div class="w-full xl:flex-1 xl:max-w-2xl xl:min-w-0">
      <div class="soft-uploader w-full max-w-xl sm:max-w-2xl mx-auto">
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml,audio/mpeg,.mp3" multiple class="hidden" />

        <!-- Soft drop card: padded gray shell -->
        <div class="su-card su-inner-shadow bg-surface-container p-2 border border-outline-variant/40">
          <!-- Drop area -->
          <div
            id="upload-panel"
            class="su-drop relative bg-white border border-dashed border-outline-variant overflow-hidden transition-all duration-300"
          >
            <!-- State: idle / uploading -->
            <div id="state-idle" class="relative min-h-[320px]">
              <div id="drop-zone" class="group absolute inset-0 flex flex-col items-center justify-center gap-4 px-6 pb-24 cursor-pointer" role="button" tabindex="0">
                <Icon name="cloud_upload" class="text-on-surface-variant/30 group-hover:text-rose-500 group-hover:scale-110 transition-all duration-300 text-5xl sm:text-6xl" id="upload-icon" />
                <div class="text-center">
                  <p class="text-on-surface-variant font-medium text-sm sm:text-base transition-opacity duration-300 group-hover:opacity-70" id="upload-text">Drop files to upload</p>
                  <p class="text-[11px] sm:text-xs text-on-surface-variant/80 mt-1" id="upload-subtext">JPG, PNG, WebP, GIF, SVG, MP3 &mdash; Max 50MB</p>
                </div>
                <div id="progress-bar" class="su-progress hidden w-full max-w-xs h-2 bg-surface-variant overflow-hidden">
                  <div id="progress-fill" class="su-progress h-full bg-rose-600 transition-all duration-300" style="width: 0%"></div>
                </div>
                <div class="sr-only" id="upload-btn">Select File</div>
              </div>

              <!-- Floating action island: auto-delete + Browse -->
              <div class="su-island su-soft-shadow absolute bottom-5 left-1/2 -translate-x-1/2 z-10 bg-white border border-outline-variant/30 flex items-center gap-2 p-2 w-[92%] max-w-[380px]">
                <div class="su-control flex items-center gap-2 bg-surface-container-low px-3 py-2 flex-1 min-w-0 hover:bg-surface-container transition-colors">
                  <Icon name="schedule" class="text-rose-600 text-base flex-shrink-0" fill />
                  <div class="relative flex-1 min-w-0">
                    <select
                      id="expires-in"
                      aria-label="Auto-delete after"
                      aria-describedby="expires-in-hint"
                      class="su-control appearance-none w-full bg-transparent text-xs font-semibold text-on-surface pr-5 outline-none cursor-pointer"
                    >
                      <option value="auto">Auto-expire</option>
                      <option value="never">Never delete</option>
                    </select>
                    <Icon name="expand_more" class="absolute right-0 top-1/2 -translate-y-1/2 text-on-surface-variant/60 text-base pointer-events-none" />
                  </div>
                </div>
                <button
                  type="button"
                  id="browse-btn"
                  class="su-btn bg-rose-600 hover:bg-rose-700 text-white text-xs font-semibold px-5 py-2.5 transition-colors whitespace-nowrap active:scale-95 flex-shrink-0"
                  style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);"
                >
                  Browse
                </button>
              </div>
            </div>

            <!-- State: success -->
            <div id="state-success" class="p-4 sm:p-6 hidden">
              <div class="flex items-center gap-3 mb-4">
                <Icon name="check_circle" class="text-rose-600 text-lg sm:text-xl" fill />
                <span class="font-bold text-on-surface text-sm sm:text-lg">Uploaded!</span>
                <button id="upload-another" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Upload another
                </button>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
                <input type="text" id="result-url" readonly class="su-control flex-1 min-w-0 bg-surface-container-low border border-outline-variant px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-500" />
                <button id="copy-btn" class="su-btn bg-rose-600 hover:bg-rose-700 text-white font-semibold text-sm py-3 px-6 transition-colors active:scale-95 flex-shrink-0" style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);">
                  Get Link
                </button>
              </div>
              <!-- Guest-only heads-up: anonymous uploads auto-expire. Revealed by JS
                   only when /api/me reports no signed-in user. The sign-in action is
                   a bordered pill (not an inline link) so the recovery path reads as
                   actionable without shouting. -->
              <div id="guest-expiry-note" class="hidden mt-4 pt-3 border-t border-outline-variant/40 flex flex-wrap items-center gap-x-2 gap-y-2 text-xs text-on-surface-variant">
                <Icon name="schedule" class="text-rose-500 text-base flex-shrink-0" fill />
                <span class="flex-1 min-w-[12rem]">
                  <span class="font-semibold text-on-surface">Heads up —</span> guest uploads auto-expire in ~2 weeks.
                </span>
                <a href="/api/auth/login" class="su-control inline-flex items-center gap-1.5 border border-outline-variant bg-surface-container-low text-primary font-semibold px-3 py-1.5 hover:bg-rose-50 hover:border-rose-300 transition-colors flex-shrink-0 group">
                  Sign in to keep it forever
                  <Icon name="arrow_forward" class="text-sm group-hover:translate-x-0.5 transition-transform" />
                </a>
              </div>
            </div>

            <!-- Bulk uploads (>1 file) no longer render an in-page list here —
                 they navigate to the multi-image /share screen (rich list + ad
                 rails). Single uploads use #state-success below. -->

            <!-- State: error -->
            <div id="state-error" class="p-4 sm:p-6 hidden">
              <div class="flex items-center gap-3">
                <Icon name="error" class="text-error flex-shrink-0 text-2xl" />
                <span class="font-bold text-on-error-container text-sm sm:text-base flex-1 min-w-0" id="error-text">Upload failed</span>
                <button id="error-retry" class="text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Try again
                </button>
                <a id="error-login" href="/api/auth/login" class="hidden text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">
                  Login
                </a>
              </div>
              <!-- Sign in CTA for limit errors — solid button (same vocabulary as
                   Browse/Get Link) since it's the primary recovery action. -->
              <a href="/api/auth/login" id="error-signin" class="hidden w-fit items-center gap-2 mt-4 su-btn bg-rose-600 hover:bg-rose-700 text-white text-xs sm:text-sm font-semibold px-4 py-2.5 transition-colors active:scale-95 group" style="box-shadow: 0 4px 14px rgb(225 29 72 / 0.30);">
                <Icon name="login" class="text-base" />
                <span>Sign in to get more uploads</span>
                <Icon name="arrow_forward" class="text-sm group-hover:translate-x-0.5 transition-transform" />
              </a>
            </div>
          </div>
        </div>

        <!-- Expiry notice: one quiet footnote line. Default behavior + permanent-link
             hint inline; the full explanation lives behind the "?" toggle. -->
        <div class="mt-3 w-full max-w-md mx-auto">
          <p class="flex items-center justify-center flex-wrap gap-x-1.5 gap-y-1 text-xs text-on-surface-variant text-center">
            <Icon name="schedule" class="text-rose-500 text-sm" fill />
            <span id="expires-in-hint" class="font-medium text-on-surface">Auto-expires in ~2 weeks</span>
            <span class="text-on-surface-variant/40">·</span>
            <a href="/api/auth/login" class="font-semibold text-primary hover:underline underline-offset-2">Sign in</a>
            <span>for permanent links</span>
            <!-- Quota chip: hidden until the visitor shows intent (hover/focus/touch
                 on the drop panel) so cold pageviews never pay the /api/me query. -->
            <span id="quota-chip" class="hidden items-center gap-x-1.5">
              <span class="text-on-surface-variant/40">·</span>
              <span id="quota-chip-text" class="font-medium"></span>
            </span>
            <button
              type="button"
              id="expires-in-help"
              aria-label="What does auto-delete do?"
              aria-expanded="false"
              aria-controls="expires-in-help-panel"
              class="su-control tap-target inline-flex items-center justify-center w-[16px] h-[16px] rounded-full border border-outline-variant text-[10px] font-bold text-on-surface-variant hover:bg-rose-600 hover:text-white hover:border-rose-600 transition-colors flex-shrink-0"
            >?</button>
          </p>

          <div
            id="expires-in-help-panel"
            class="su-control hidden mt-2 bg-surface-container-low border border-outline-variant/40 px-4 py-3 text-xs text-on-surface-variant leading-relaxed text-left"
            role="region"
            aria-labelledby="expires-in-help"
          >
            Auto-expire images are cleared at the start of each month, so you always get at least about two weeks. Choose "Never delete" (sign-in required) for a permanent link that never breaks.
          </div>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap justify-center gap-4 sm:gap-8 mt-5 sm:mt-6 text-xs sm:text-sm text-on-surface-variant font-label font-bold uppercase tracking-wider">
          <span class="flex items-center gap-1.5"><Icon name="rocket_launch" class="text-primary text-base sm:text-lg" fill /> CDN</span>
          <span class="flex items-center gap-1.5"><Icon name="lock" class="text-primary text-base sm:text-lg" fill /> SSL</span>
          <span class="flex items-center gap-1.5"><Icon name="link" class="text-primary text-base sm:text-lg" fill /> Permanent</span>
          <span class="flex items-center gap-1.5"><Icon name="flash_on" class="text-primary text-base sm:text-lg" fill /> Instant</span>
        </div>

      </div><!-- /soft-uploader -->
    </div><!-- /center column -->

    <!-- Right rail — two stacked responsive square ad units -->
    <AdRail side="right" />
  </div><!-- /flex wrapper -->

  <!-- Mobile/tablet in-content Multiplex — fills the slot gap where desktop has
       rails. Kept LAST in DOM (after both rails) so its lazy fill can't steal an
       earlier eager rail's push. Below the fold → lazy-loaded by the observer. -->
  <div class="xl:hidden w-full max-w-2xl mx-auto mt-6">
    <div class="ad-reserve">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-format="autorelaxed"
        data-ad-client={AD_CLIENT}
        data-ad-slot={AD_SLOTS.inContent}
        data-ad-lazy></ins>
    </div>
  </div>
</div><!-- /ad-wrapped outer -->

<script>
  import { ic_cloud_upload, ic_hourglass_top } from '../data/icon-svgs';
  // Ad-blocker detection — analytics only, NEVER blocks or degrades uploads.
  // Shared with HomePage.astro so both uploaders report the same signal.

  // Cached /api/me payload — shared by the never-expire login gate and the
  // bulk-upload quota pre-slice. One fetch per page; the server 429 is the real
  // backstop, so a slightly stale `remaining` only costs an extra "skipped" label.
  let mePromise: Promise<any> | null = null;
  function fetchMe(): Promise<any> {
    if (!mePromise) {
      mePromise = fetch('/api/me', { credentials: 'same-origin' })
        .then((r) => r.json())
        .catch(() => ({ user: null, upload: null }));
    }
    return mePromise;
  }
  async function fetchLoggedIn(): Promise<boolean> {
    return !!(await fetchMe()).user;
  }

  const expiresInSel = document.getElementById('expires-in') as HTMLSelectElement | null;
  const expiresInHint = document.getElementById('expires-in-hint');
  const EXPIRY_HINTS: Record<string, string> = {
    auto: 'Auto-expires in ~2 weeks',
    never: 'Permanent — never deleted',
  };

  function refreshExpiresHint(value: string) {
    if (expiresInHint) {
      expiresInHint.textContent = EXPIRY_HINTS[value] || EXPIRY_HINTS.auto;
    }
  }

  if (expiresInSel) {
    expiresInSel.addEventListener('change', () => refreshExpiresHint(expiresInSel.value));
    refreshExpiresHint(expiresInSel.value);
  }

  const expiresHelpBtn = document.getElementById('expires-in-help');
  const expiresHelpPanel = document.getElementById('expires-in-help-panel');
  if (expiresHelpBtn && expiresHelpPanel) {
    expiresHelpBtn.addEventListener('click', () => {
      const expanded = expiresHelpBtn.getAttribute('aria-expanded') === 'true';
      expiresHelpBtn.setAttribute('aria-expanded', String(!expanded));
      expiresHelpPanel.classList.toggle('hidden');
    });
  }

  const panel = document.getElementById('upload-panel')!;
  const dropZone = document.getElementById('drop-zone')!;
  const browseBtn = document.getElementById('browse-btn');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadIcon = document.getElementById('upload-icon')!;
  const uploadText = document.getElementById('upload-text')!;
  const uploadSubtext = document.getElementById('upload-subtext')!;
  const uploadBtn = document.getElementById('upload-btn')!;
  const progressBar = document.getElementById('progress-bar')!;
  const progressFill = document.getElementById('progress-fill')!;
  const stateIdle = document.getElementById('state-idle')!;
  const stateSuccess = document.getElementById('state-success')!;
  const stateError = document.getElementById('state-error')!;
  const resultUrl = document.getElementById('result-url') as HTMLInputElement;
  const copyBtn = document.getElementById('copy-btn')!;
  const uploadAnother = document.getElementById('upload-another')!;
  const errorRetry = document.getElementById('error-retry')!;
  const errorLogin = document.getElementById('error-login')!;
  const errorText = document.getElementById('error-text')!;
  const errorSignin = document.getElementById('error-signin')!;
  const errorPromo = document.getElementById('error-promo');
  const guestExpiryNote = document.getElementById('guest-expiry-note');

  function showState(state: 'idle' | 'success' | 'error') {
    stateIdle.classList.toggle('hidden', state !== 'idle');
    stateSuccess.classList.toggle('hidden', state !== 'success');
    stateError.classList.toggle('hidden', state !== 'error');
    if (state === 'success') {
      refreshQuotaChip(); // server just deducted — refetch, then reveal
      revealGuestExpiryNote();
    } else {
      guestExpiryNote?.classList.add('hidden');
    }
  }

  // Show the "your image auto-deletes" heads-up only to guests. Uses the cached
  // /api/me payload, so it costs no extra request; a null user means anonymous.
  async function revealGuestExpiryNote() {
    if (!guestExpiryNote) return;
    const isGuest = !(await fetchMe()).user;
    guestExpiryNote.classList.toggle('hidden', !isGuest);
  }

  // ---- Proactive quota chip (footnote line) ----
  // State honesty without taxing cold pageviews: the /api/me fetch fires on the
  // visitor's first intent signal (hover/focus/touch on the drop panel), not on
  // load. Guests see "N of 100 uploads left today", users "N of 150 credits
  // left"; ≤20% remaining turns amber via the --color-warning token.
  const quotaChip = document.getElementById('quota-chip');
  const quotaChipText = document.getElementById('quota-chip-text');

  function renderQuotaChip(me: any) {
    if (!quotaChip || !quotaChipText) return;
    const u = me?.upload;
    if (!u || typeof u.remaining !== 'number' || typeof u.limit !== 'number') return;
    if (u.unit === 'credits') {
      quotaChipText.textContent = `${u.remaining} of ${u.limit} credits left`;
      quotaChipText.title = '≈1 credit per MB';
    } else {
      quotaChipText.textContent = `${u.remaining} of ${u.limit} uploads left today`;
    }
    const low = u.remaining <= u.limit * 0.2;
    quotaChipText.classList.toggle('text-warning', low);
    quotaChipText.classList.toggle('text-on-surface', !low);
    quotaChip.classList.remove('hidden');
    quotaChip.classList.add('inline-flex');
  }

  let quotaLoaded = false;
  async function loadQuotaChip() {
    if (quotaLoaded) return;
    quotaLoaded = true;
    renderQuotaChip(await fetchMe());
  }

  async function refreshQuotaChip() {
    quotaLoaded = true;
    mePromise = null; // balance changed server-side — bust the cache
    renderQuotaChip(await fetchMe());
  }

  (['pointerenter', 'focusin', 'touchstart'] as const).forEach((ev) =>
    panel.addEventListener(ev, loadQuotaChip, { once: true, passive: true }),
  );

  // Destination the Get Link button navigates to; set by both the single and
  // bulk upload paths (bulk carries multiple u= params + skipped count).
  let shareHref = '';

  function resetIdle() {
    showState('idle');
    shareHref = '';
    progressBar.classList.add('hidden');
    progressFill.style.width = '0%';
    uploadIcon.innerHTML = ic_cloud_upload;
    uploadText.textContent = 'Drop files to upload';
    uploadSubtext.textContent = 'JPG, PNG, WebP, GIF, SVG, MP3 — up to 50 MB';
    uploadBtn.textContent = 'Select File';
    fileInput.value = '';
    errorSignin.classList.add('hidden');
    errorSignin.classList.remove('flex');
    errorPromo?.classList.add('hidden');
    errorPromo?.classList.remove('flex');
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  function showLoginError() {
    errorRetry.classList.add('hidden');
    errorLogin.classList.remove('hidden');
  }

  function showRetryError() {
    errorLogin.classList.add('hidden');
    errorRetry.classList.remove('hidden');
  }

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); fileInput.click(); }
  });
  browseBtn?.addEventListener('click', () => fileInput.click());

  panel.addEventListener('dragover', (e) => {
    e.preventDefault();
    panel.classList.add('!border-rose-400', '!bg-rose-50');
  });
  panel.addEventListener('dragleave', (e) => {
    if (!panel.contains(e.relatedTarget as Node)) {
      panel.classList.remove('!border-rose-400', '!bg-rose-50');
    }
  });
  panel.addEventListener('drop', (e) => {
    e.preventDefault();
    panel.classList.remove('!border-rose-400', '!bg-rose-50');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) handleFiles(files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) handleFiles(fileInput.files);
  });

  // Mount + resolve the email opt-in gate (locks uploads for legacy signed-in
  // users until they consent; no-op for guests / already-opted-in users).
  (window as any).emailOptInGate?.init(panel.closest('.soft-uploader'));

  async function handleFiles(files: FileList) {
    // Email opt-in gate: legacy signed-in users must consent before uploading.
    // Fails open (never locks guests or on error).
    await (window as any).emailOptInGate?.ready;
    if ((window as any).emailOptInGate?.isLocked?.()) {
      (window as any).emailOptInGate.flash();
      fileInput.value = '';
      return;
    }
    // Ad-block gate covers both single and batch paths in one place.
    if (!(await (window as any).__adblockGate?.check())) {
      fileInput.value = '';
      return;
    }
    if (files.length === 1) {
      uploadFile(files[0]);
      return;
    }
    // Bulk path — open to everyone. Guests spend a daily upload count (5), users
    // spend size-priced credits; uploadBatch pre-slices to what the allowance covers.
    uploadBatch(Array.from(files));
  }

  const MAX_BATCH = 25; // hard cap on files per batch, whatever the allowance
  // Credits an upload costs — must match creditCost() in src/lib/upload-limits.ts.
  const creditCost = (bytes: number) => Math.max(1, Math.round(bytes / (1024 * 1024)));

  async function uploadBatch(files: File[]) {
    // Pre-slice to what the caller's allowance covers so we don't fire doomed
    // requests. The server still enforces per file (429), so a stale/unknown
    // remaining just means a few extra fast rejections handled below.
    const usage = (await fetchMe())?.upload;
    const unit = usage?.unit;
    const remaining = typeof usage?.remaining === 'number' ? usage.remaining : Infinity;

    if (remaining <= 0) {
      // Nothing left today — mirror the single-file 429 UX (limit copy + sign-in).
      showState('error');
      const resetIn = usage?.resetIn;
      errorText.textContent = unit === 'credits'
        ? (resetIn ? `You're out of upload credits for today. They refill in about ${resetIn}.` : "You're out of upload credits for today.")
        : (resetIn ? `You've reached your daily upload limit. It resets in about ${resetIn}.` : "You've reached your daily upload limit.");
      errorSignin.classList.remove('hidden');
      errorSignin.classList.add('flex');
      showLoginError();
      fileInput.value = '';
      return;
    }

    // Credits: greedily pack files while their cumulative cost fits the balance
    // (a too-big file is skipped but smaller later ones can still go). Uploads
    // (guests): slice by count. Both respect MAX_BATCH.
    let toUpload: File[];
    if (unit === 'credits' && Number.isFinite(remaining)) {
      toUpload = [];
      let spent = 0;
      for (const f of files) {
        if (toUpload.length >= MAX_BATCH) break;
        const c = creditCost(f.size);
        if (spent + c > remaining) continue;
        spent += c;
        toUpload.push(f);
      }
    } else {
      toUpload = files.slice(0, Math.min(files.length, MAX_BATCH, remaining));
    }

    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.innerHTML = ic_hourglass_top;
    uploadText.textContent = `Uploading 0 / ${toUpload.length}`;
    uploadSubtext.textContent = 'Bulk upload in progress…';
    uploadBtn.textContent = 'Uploading...';

    const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
    const ab = '0'; // gated in handleFiles
    const results: { name: string; url: string }[] = [];
    const failures: { name: string; error: string }[] = [];

    for (let i = 0; i < toUpload.length; i++) {
      const file = toUpload[i];
      uploadText.textContent = `Uploading ${i + 1} / ${toUpload.length}`;
      uploadSubtext.textContent = file.name;
      try {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('adblock', ab);
        if (expiresInEl) formData.append('expires_in', expiresInEl.value);
        const response = await fetch('/api/upload', { method: 'POST', body: formData });
        const data = await response.json();
        if (!response.ok || data.error) {
          // 429 backstop: a race pushed the count over between /api/me and now.
          // Stop — every remaining file would 429 too; they'll be reported as skipped.
          if (response.status === 429) { failures.push({ name: file.name, error: data.error || 'Daily limit reached' }); break; }
          throw new Error(data.error || 'Upload failed');
        }
        results.push({ name: file.name, url: data.data.url });
      } catch (err: any) {
        failures.push({ name: file.name, error: err.message || 'Upload failed' });
      }
      progressFill.style.width = `${Math.round(((i + 1) / toUpload.length) * 100)}%`;
    }

    if (results.length === 0) {
      showState('error');
      errorText.textContent = failures[0]?.error || 'All uploads failed';
      return;
    }

    // Everything selected minus what actually got hosted (over-quota, over
    // MAX_BATCH, or per-file failures) is reported as "skipped" on /share.
    const skipped = files.length - results.length;

    // Land on the success panel; /share opens only when Get Link is clicked.
    if (results.length === 1 && skipped === 0) {
      shareHref = '/share?u=' + encodeURIComponent(results[0].url);
      resultUrl.value = results[0].url;
    } else {
      const params = new URLSearchParams();
      for (const r of results) params.append('u', r.url);
      if (skipped > 0) params.set('skipped', String(skipped));
      shareHref = '/share?' + params.toString();
      resultUrl.value = skipped > 0
        ? `${results.length} images uploaded · ${skipped} skipped`
        : `${results.length} images uploaded`;
    }
    progressFill.style.width = '100%';
    showState('success');
  }

  copyBtn.addEventListener('click', () => {
    // "Get Link" — send the user to the /share screen, which owns the rich share
    // widget (URL, copy, formats, QR, watermark) + ad rails.
    window.location.href = shareHref || '/share?u=' + encodeURIComponent(resultUrl.value);
  });



  uploadAnother.addEventListener('click', resetIdle);
  errorRetry.addEventListener('click', resetIdle);

  async function uploadFile(file: File) {
    // "Never" requires a signed-in account; server clamps anon to 24h otherwise.
    if (expiresInSel?.value === 'never') {
      const loggedIn = await fetchLoggedIn();
      if (!loggedIn) {
        showState('error');
        errorText.textContent = 'Sign in to upload images that never expire.';
        errorSignin.classList.remove('hidden');
        errorSignin.classList.add('flex');
        showLoginError();
        fileInput.value = '';
        return;
      }
    }

    showState('idle');
    progressBar.classList.remove('hidden');
    progressFill.style.width = '0%';
    uploadIcon.innerHTML = ic_hourglass_top;
    uploadText.textContent = `Uploading ${file.name}`;
    uploadSubtext.textContent = `${(file.size / 1024).toFixed(0)} KB · ${file.type.split('/')[1]?.toUpperCase() || 'FILE'}`;
    uploadBtn.textContent = 'Uploading...';

    const ab = '0'; // gated in handleFiles

    // Minimum perceived upload time — instant completion was driving
    // users to bounce before they registered that anything happened.
    const MIN_UPLOAD_MS = 5000;
    const startedAt = Date.now();

    // Time-based progress that walks toward 95% over MIN_UPLOAD_MS so the
    // bar feels alive regardless of how fast the real request finishes.
    const progressInterval = setInterval(() => {
      const elapsed = Date.now() - startedAt;
      const target = Math.min(95, (elapsed / MIN_UPLOAD_MS) * 95);
      progressFill.style.width = `${target}%`;
    }, 100);

    try {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('adblock', ab);
      const expiresInEl = document.getElementById('expires-in') as HTMLSelectElement | null;
      if (expiresInEl) formData.append('expires_in', expiresInEl.value);

      const response = await fetch('/api/upload', { method: 'POST', body: formData });
      const data = await response.json();

      if (!response.ok || data.error) {
        clearInterval(progressInterval);
        throw new Error(data.error || 'Upload failed');
      }

      const remaining = MIN_UPLOAD_MS - (Date.now() - startedAt);
      if (remaining > 0) {
        await new Promise((r) => setTimeout(r, remaining));
      }

      clearInterval(progressInterval);
      progressFill.style.width = '100%';
      setTimeout(() => {
        showState('success');
        resultUrl.value = data.data.url;
        shareHref = '/share?u=' + encodeURIComponent(data.data.url);
      }, 300);

    } catch (err: any) {
      clearInterval(progressInterval);
      showState('error');
      errorText.textContent = err.message || 'Upload failed';
      const msg = (err.message || '').toLowerCase();
      const isLimit = msg.includes('limit') || msg.includes('credit');
      errorSignin.classList.toggle('hidden', !isLimit);
      errorSignin.classList.toggle('flex', isLimit);
      errorPromo?.classList.toggle('hidden', !isLimit);
      errorPromo?.classList.toggle('flex', isLimit);
      if (isLimit) showLoginError();
      else showRetryError();
    }
  }

  // Click tracking for cross-promo CTA
  document.querySelectorAll<HTMLAnchorElement>('[data-track-click]').forEach((el) => {
    el.addEventListener('click', () => {
      navigator.sendBeacon('/api/track/click', JSON.stringify({
        linkId: el.dataset.trackClick,
        page: window.location.pathname,
      }));
    });
  });
</script>

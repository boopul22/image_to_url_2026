---
/**
 * Client-side HEIC/HEIF → JPG converter.
 * heic2any is dynamically imported on first interaction so the WASM payload
 * never touches the initial bundle. Conversion happens in the browser only;
 * the optional "Host this JPG" button is the single point of network egress.
 */
---

<div class="w-full max-w-2xl mx-auto">
  <input
    type="file"
    id="heic-input"
    accept=".heic,.heif,image/heic,image/heif"
    multiple
    class="hidden"
  />

  <!-- Quality + privacy strip -->
  <div class="bg-white border-2 border-on-background border-b-0 px-4 py-3 flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span class="material-symbols-outlined text-rose-600 text-lg flex-shrink-0" style="font-variation-settings: 'FILL' 1;">lock</span>
      <div class="min-w-0">
        <p class="text-xs font-bold uppercase tracking-wider text-on-background">100% in your browser</p>
        <p class="text-[11px] leading-tight text-on-surface-variant">Files never leave your device</p>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <label for="heic-quality" class="text-xs font-bold uppercase tracking-wider text-on-background">Quality</label>
      <input
        type="range"
        id="heic-quality"
        min="60"
        max="100"
        value="92"
        class="w-20 sm:w-28 accent-rose-600"
      />
      <span id="heic-quality-val" class="text-xs font-mono font-bold w-8 text-right">92</span>
    </div>
  </div>

  <!-- Drop zone -->
  <div
    id="heic-panel"
    class="bg-white border-2 border-dashed border-on-background overflow-hidden transition-colors"
  >
    <div id="heic-state-idle" class="px-6 py-12 sm:px-10 sm:py-16">
      <div id="heic-drop" class="flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
        <span class="material-symbols-outlined text-on-background text-4xl sm:text-5xl">photo_camera_back</span>
        <div class="text-center">
          <p class="text-on-background font-semibold text-sm sm:text-base font-headline uppercase tracking-wider">Drop HEIC files here or click to browse</p>
          <p class="text-xs sm:text-sm text-on-surface-variant mt-2">From your iPhone / iPad — multi-select OK</p>
        </div>
      </div>
      <div id="heic-progress" class="hidden mt-6">
        <div class="h-2.5 sm:h-2 bg-surface-variant overflow-hidden rounded-full">
          <div id="heic-progress-fill" class="h-full bg-rose-600 transition-all duration-300 rounded-full" style="width: 0%"></div>
        </div>
        <p id="heic-progress-text" class="text-xs text-center mt-2 font-mono text-on-surface-variant">Loading converter…</p>
      </div>
    </div>

    <!-- Results -->
    <div id="heic-state-results" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
        <span class="font-bold text-secondary text-sm sm:text-lg" id="heic-results-heading">Converted 0 files</span>
        <button id="heic-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">
          Convert more
        </button>
      </div>
      <div id="heic-results-list" class="flex flex-col gap-2 max-h-96 overflow-auto"></div>
    </div>

    <!-- Error -->
    <div id="heic-state-error" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-symbols-outlined text-error text-lg sm:text-xl">error</span>
        <span class="font-bold text-error text-sm sm:text-lg">Conversion failed</span>
        <button id="heic-error-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline">Try again</button>
      </div>
      <p id="heic-error-text" class="text-xs sm:text-sm text-on-surface-variant"></p>
    </div>
  </div>
</div>

<script>
  type Heic2Any = (opts: { blob: Blob; toType?: string; quality?: number }) => Promise<Blob | Blob[]>;

  const input = document.getElementById('heic-input') as HTMLInputElement;
  const drop = document.getElementById('heic-drop') as HTMLDivElement;
  const panel = document.getElementById('heic-panel') as HTMLDivElement;
  const stateIdle = document.getElementById('heic-state-idle') as HTMLDivElement;
  const stateResults = document.getElementById('heic-state-results') as HTMLDivElement;
  const stateError = document.getElementById('heic-state-error') as HTMLDivElement;
  const progress = document.getElementById('heic-progress') as HTMLDivElement;
  const progressFill = document.getElementById('heic-progress-fill') as HTMLDivElement;
  const progressText = document.getElementById('heic-progress-text') as HTMLParagraphElement;
  const resultsList = document.getElementById('heic-results-list') as HTMLDivElement;
  const resultsHeading = document.getElementById('heic-results-heading') as HTMLSpanElement;
  const resetBtn = document.getElementById('heic-reset') as HTMLButtonElement;
  const errorReset = document.getElementById('heic-error-reset') as HTMLButtonElement;
  const errorText = document.getElementById('heic-error-text') as HTMLParagraphElement;
  const qualityInput = document.getElementById('heic-quality') as HTMLInputElement;
  const qualityVal = document.getElementById('heic-quality-val') as HTMLSpanElement;

  let heic2any: Heic2Any | null = null;

  qualityInput.addEventListener('input', () => {
    qualityVal.textContent = qualityInput.value;
  });

  function showState(name: 'idle' | 'results' | 'error') {
    stateIdle.classList.toggle('hidden', name !== 'idle');
    stateResults.classList.toggle('hidden', name !== 'results');
    stateError.classList.toggle('hidden', name !== 'error');
  }

  async function ensureLib(): Promise<Heic2Any> {
    if (heic2any) return heic2any;
    progressText.textContent = 'Loading converter…';
    const mod = await import('heic2any');
    heic2any = (mod.default || mod) as Heic2Any;
    return heic2any;
  }

  drop.addEventListener('click', () => input.click());
  drop.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      input.click();
    }
  });

  ['dragenter', 'dragover'].forEach((ev) => {
    panel.addEventListener(ev, (e) => {
      e.preventDefault();
      panel.classList.add('border-rose-600', 'bg-rose-50');
    });
  });
  ['dragleave', 'drop'].forEach((ev) => {
    panel.addEventListener(ev, (e) => {
      e.preventDefault();
      panel.classList.remove('border-rose-600', 'bg-rose-50');
    });
  });
  panel.addEventListener('drop', (e) => {
    const files = (e as DragEvent).dataTransfer?.files;
    if (files && files.length) handleFiles(files);
  });
  input.addEventListener('change', () => {
    if (input.files && input.files.length) handleFiles(input.files);
  });

  resetBtn.addEventListener('click', () => {
    resultsList.innerHTML = '';
    input.value = '';
    showState('idle');
    progress.classList.add('hidden');
    progressFill.style.width = '0%';
  });
  errorReset.addEventListener('click', () => {
    showState('idle');
    progress.classList.add('hidden');
    progressFill.style.width = '0%';
  });

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / 1024 / 1024).toFixed(2)} MB`;
  }

  function makeRow(name: string, blob: Blob): HTMLDivElement {
    const row = document.createElement('div');
    row.className = 'border-2 border-on-background bg-white p-3 flex items-center gap-3';

    const url = URL.createObjectURL(blob);
    const baseName = name.replace(/\.(heic|heif)$/i, '.jpg');

    const thumb = document.createElement('img');
    thumb.src = url;
    thumb.alt = '';
    thumb.className = 'w-12 h-12 object-cover border-2 border-on-background flex-shrink-0';

    const meta = document.createElement('div');
    meta.className = 'flex-1 min-w-0';
    const nameEl = document.createElement('p');
    nameEl.className = 'text-xs font-bold truncate';
    nameEl.textContent = baseName;
    const sizeEl = document.createElement('p');
    sizeEl.className = 'text-[11px] text-on-surface-variant';
    sizeEl.textContent = fmtBytes(blob.size);
    meta.appendChild(nameEl);
    meta.appendChild(sizeEl);

    const dl = document.createElement('a');
    dl.href = url;
    dl.download = baseName;
    dl.className = 'bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wide flex-shrink-0';
    dl.textContent = 'Download';

    const host = document.createElement('button');
    host.className = 'border-2 border-on-background bg-white hover:bg-on-background hover:text-white font-headline font-semibold text-xs py-2 px-3 uppercase tracking-wide flex-shrink-0';
    host.textContent = 'Get URL';
    host.addEventListener('click', async () => {
      host.disabled = true;
      host.textContent = 'Hosting…';
      try {
        const fd = new FormData();
        fd.append('file', new File([blob], baseName, { type: 'image/jpeg' }));
        const res = await fetch('/api/upload', { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok || data.error) throw new Error(data.error || 'Upload failed');
        const hosted = data.data.url as string;
        host.remove();
        const urlInput = document.createElement('input');
        urlInput.type = 'text';
        urlInput.readOnly = true;
        urlInput.value = hosted;
        urlInput.className = 'flex-1 min-w-0 bg-white border-2 border-on-background px-2 py-2 text-xs font-mono';
        urlInput.addEventListener('focus', () => urlInput.select());
        const copy = document.createElement('button');
        copy.className = 'bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wide flex-shrink-0';
        copy.textContent = 'Copy';
        copy.addEventListener('click', async () => {
          await navigator.clipboard.writeText(hosted);
          copy.textContent = 'Copied!';
          setTimeout(() => (copy.textContent = 'Copy'), 1200);
        });
        row.appendChild(urlInput);
        row.appendChild(copy);
      } catch (err: any) {
        host.disabled = false;
        host.textContent = 'Retry';
        const note = document.createElement('span');
        note.className = 'text-[11px] text-error';
        note.textContent = err.message || 'Failed';
        row.appendChild(note);
      }
    });

    row.appendChild(thumb);
    row.appendChild(meta);
    row.appendChild(dl);
    row.appendChild(host);
    return row;
  }

  async function handleFiles(fileList: FileList) {
    const files = Array.from(fileList);
    if (!files.length) return;

    progress.classList.remove('hidden');
    progressFill.style.width = '0%';
    progressText.textContent = 'Loading converter…';

    let lib: Heic2Any;
    try {
      lib = await ensureLib();
    } catch (err: any) {
      showState('error');
      errorText.textContent = 'Could not load the converter library. Check your connection and try again.';
      return;
    }

    resultsList.innerHTML = '';
    const quality = Number(qualityInput.value) / 100;
    let done = 0;
    let success = 0;

    for (const file of files) {
      progressText.textContent = `Converting ${done + 1} / ${files.length} — ${file.name}`;
      try {
        const out = await lib({ blob: file, toType: 'image/jpeg', quality });
        const blob = Array.isArray(out) ? out[0] : out;
        resultsList.appendChild(makeRow(file.name, blob));
        success++;
      } catch (err) {
        const row = document.createElement('div');
        row.className = 'border-2 border-error bg-white p-3 text-xs';
        row.textContent = `${file.name} — failed (not a valid HEIC?)`;
        resultsList.appendChild(row);
      }
      done++;
      progressFill.style.width = `${Math.round((done / files.length) * 100)}%`;
    }

    if (success === 0) {
      showState('error');
      errorText.textContent = 'None of the files could be converted. Make sure they are valid HEIC/HEIF images.';
      return;
    }

    resultsHeading.textContent = `Converted ${success} file${success === 1 ? '' : 's'}`;
    showState('results');
  }
</script>

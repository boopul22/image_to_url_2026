---
import Icon from './Icon.astro';
/**
 * Client-side image resizer with linked width/height inputs, preset target
 * sizes, quality control, optional format conversion, and a live "source
 * → output" dimension readout. Decoding uses createImageBitmap so EXIF
 * orientation is baked into the pixels.
 */
---
<div class="soft-uploader w-full max-w-2xl mx-auto">
  <input type="file" id="irsz-input" accept="image/png,image/jpeg,image/webp,.png,.jpg,.jpeg,.webp" multiple class="hidden" />

  <div class="su-card su-inner-shadow bg-surface-container p-2 border border-outline-variant/40">
  <!-- Privacy strip -->
  <div class="su-control bg-white border border-outline-variant/40 mb-2 px-4 py-3 flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <Icon name="lock" class="text-rose-600 text-lg flex-shrink-0" fill />
      <div class="min-w-0">
        <p class="text-xs font-bold uppercase tracking-wider text-on-background">100% in your browser</p>
        <p class="text-[11px] leading-tight text-on-surface-variant">Files never leave your device</p>
      </div>
    </div>
    <span id="irsz-source-dims" class="su-control hidden text-[11px] font-mono font-bold text-on-background bg-tertiary-fixed border border-outline-variant px-2 py-1"></span>
  </div>

  <!-- Controls -->
  <div id="irsz-controls" class="su-control bg-white border border-outline-variant/40 mb-2 p-4 flex flex-col gap-3">
    <!-- Width + Height row with lock between -->
    <div class="flex items-end gap-2 flex-wrap">
      <div class="flex-1 min-w-[7rem]">
        <label for="irsz-w" class="block text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-1">Width (px)</label>
        <input id="irsz-w" type="number" min="1" max="20000" placeholder="auto" class="su-control w-full border border-outline-variant bg-white text-sm font-mono font-bold px-3 py-2" />
      </div>
      <button
        id="irsz-lock"
        type="button"
        aria-pressed="true"
        title="Lock aspect ratio"
        class="su-btn border border-outline-variant bg-rose-600 text-white flex items-center justify-center w-10 h-10 mb-0 transition-colors"
      >
        <Icon name="lock" class="text-lg" fill id="irsz-lock-icon" />
      </button>
      <div class="flex-1 min-w-[7rem]">
        <label for="irsz-h" class="block text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-1">Height (px)</label>
        <input id="irsz-h" type="number" min="1" max="20000" placeholder="auto" class="su-control w-full border border-outline-variant bg-white text-sm font-mono font-bold px-3 py-2" />
      </div>
    </div>

    <!-- Percent slider as an alternative -->
    <div class="flex items-center gap-3 flex-wrap">
      <label for="irsz-pct" class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant flex-shrink-0">Or scale</label>
      <input id="irsz-pct" type="range" min="5" max="200" value="100" class="flex-1 min-w-[8rem] accent-rose-600" disabled />
      <span id="irsz-pct-val" class="text-xs font-mono font-bold w-12 text-right">100%</span>
    </div>

    <!-- Preset chips -->
    <div class="flex flex-wrap gap-1.5">
      <span class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant self-center mr-1">Presets</span>
      <button data-preset="1920x1080" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">1080p</button>
      <button data-preset="2560x1440" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">1440p</button>
      <button data-preset="3840x2160" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">4K</button>
      <button data-preset="1080x1080" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">IG&nbsp;square</button>
      <button data-preset="1080x1350" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">IG&nbsp;portrait</button>
      <button data-preset="1200x630" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">OG&nbsp;card</button>
      <button data-preset="1500x500" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">Twitter&nbsp;banner</button>
      <button data-preset="800x800" class="irsz-chip su-btn border border-outline-variant bg-white hover:bg-tertiary-fixed text-[11px] font-mono font-bold px-2 py-1">800×800</button>
    </div>

    <!-- Format + quality row -->
    <div class="flex items-center gap-2 flex-wrap">
      <label for="irsz-format" class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant">Output</label>
      <select id="irsz-format" class="su-control border border-outline-variant bg-white text-xs font-bold uppercase px-2 py-1">
        <option value="match">Match source</option>
        <option value="image/jpeg">JPG</option>
        <option value="image/png">PNG</option>
        <option value="image/webp">WebP</option>
      </select>
      <label for="irsz-quality" class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant ml-2">Quality</label>
      <input type="range" id="irsz-quality" min="50" max="100" value="92" class="w-24 sm:w-32 accent-rose-600" />
      <span id="irsz-quality-val" class="text-xs font-mono font-bold w-9 text-right">92</span>
    </div>

    <!-- Output dimension preview -->
    <p id="irsz-preview-line" class="text-xs font-mono text-on-surface-variant hidden"></p>
  </div>

  <!-- Drop zone / states -->
  <div id="irsz-panel" class="su-drop bg-white border border-dashed border-outline-variant overflow-hidden transition-all duration-300">
    <div id="irsz-state-idle" class="px-6 py-12 sm:px-10 sm:py-16">
      <div id="irsz-drop" class="group flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
        <Icon name="aspect_ratio" class="text-on-surface-variant/40 group-hover:text-rose-500 group-hover:scale-110 transition-all duration-300 text-4xl sm:text-5xl" />
        <div class="text-center">
          <p class="text-on-background font-semibold text-sm sm:text-base font-headline uppercase tracking-wider">Drop images here or click to browse</p>
          <p class="text-xs sm:text-sm text-on-surface-variant mt-2">PNG · JPG · WebP — multi-select OK</p>
        </div>
      </div>
      <div id="irsz-progress" class="hidden mt-6">
        <div class="su-progress h-2.5 sm:h-2 bg-surface-variant overflow-hidden rounded-full">
          <div id="irsz-progress-fill" class="su-progress h-full bg-rose-600 transition-all duration-300 rounded-full" style="width: 0%"></div>
        </div>
        <p id="irsz-progress-text" class="text-xs text-center mt-2 font-mono text-on-surface-variant">Resizing…</p>
      </div>
    </div>

    <div id="irsz-state-results" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <Icon name="check_circle" class="text-secondary text-lg sm:text-xl" />
        <span class="font-bold text-secondary text-sm sm:text-lg" id="irsz-results-heading">Resized</span>
        <button id="irsz-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline flex-shrink-0">Resize more</button>
      </div>
      <div id="irsz-results-list" class="flex flex-col gap-2 max-h-96 overflow-auto"></div>
    </div>

    <div id="irsz-state-error" class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <Icon name="error" class="text-error text-lg sm:text-xl" />
        <span class="font-bold text-error text-sm sm:text-lg">Resize failed</span>
        <button id="irsz-error-reset" class="ml-auto text-primary font-bold text-xs sm:text-sm hover:underline">Try again</button>
      </div>
      <p id="irsz-error-text" class="text-xs sm:text-sm text-error"></p>
    </div>
  </div>
  </div>
</div>

<script>
  import { ic_lock, ic_lock_open } from '../data/icon-svgs';
  const input = document.getElementById('irsz-input') as HTMLInputElement;
  const drop = document.getElementById('irsz-drop') as HTMLDivElement;
  const panel = document.getElementById('irsz-panel') as HTMLDivElement;
  const stateIdle = document.getElementById('irsz-state-idle') as HTMLDivElement;
  const stateResults = document.getElementById('irsz-state-results') as HTMLDivElement;
  const stateError = document.getElementById('irsz-state-error') as HTMLDivElement;
  const progress = document.getElementById('irsz-progress') as HTMLDivElement;
  const progressFill = document.getElementById('irsz-progress-fill') as HTMLDivElement;
  const progressText = document.getElementById('irsz-progress-text') as HTMLParagraphElement;
  const resultsList = document.getElementById('irsz-results-list') as HTMLDivElement;
  const resultsHeading = document.getElementById('irsz-results-heading') as HTMLSpanElement;
  const resetBtn = document.getElementById('irsz-reset') as HTMLButtonElement;
  const errorReset = document.getElementById('irsz-error-reset') as HTMLButtonElement;
  const errorText = document.getElementById('irsz-error-text') as HTMLParagraphElement;
  const wInput = document.getElementById('irsz-w') as HTMLInputElement;
  const hInput = document.getElementById('irsz-h') as HTMLInputElement;
  const lockBtn = document.getElementById('irsz-lock') as HTMLButtonElement;
  const lockIcon = document.getElementById('irsz-lock-icon') as HTMLSpanElement;
  const pctInput = document.getElementById('irsz-pct') as HTMLInputElement;
  const pctVal = document.getElementById('irsz-pct-val') as HTMLSpanElement;
  const qualityInput = document.getElementById('irsz-quality') as HTMLInputElement;
  const qualityVal = document.getElementById('irsz-quality-val') as HTMLSpanElement;
  const formatSel = document.getElementById('irsz-format') as HTMLSelectElement;
  const previewLine = document.getElementById('irsz-preview-line') as HTMLParagraphElement;
  const sourceDimsEl = document.getElementById('irsz-source-dims') as HTMLSpanElement;
  const chipBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.irsz-chip'));

  let locked = true;
  let srcW = 0;
  let srcH = 0;
  let suppress = false;

  function showState(n: 'idle' | 'results' | 'error') {
    stateIdle.classList.toggle('hidden', n !== 'idle');
    stateResults.classList.toggle('hidden', n !== 'results');
    stateError.classList.toggle('hidden', n !== 'error');
  }

  function fmtBytes(n: number): string {
    if (n < 1024) return `${n} B`;
    if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
    return `${(n / 1024 / 1024).toFixed(2)} MB`;
  }

  function updateLockUi() {
    lockIcon.innerHTML = locked ? ic_lock : ic_lock_open;
    lockBtn.setAttribute('aria-pressed', String(locked));
    lockBtn.classList.toggle('bg-rose-600', locked);
    lockBtn.classList.toggle('text-white', locked);
    lockBtn.classList.toggle('bg-white', !locked);
    lockBtn.classList.toggle('text-on-background', !locked);
  }

  function targetDims(): { w: number; h: number } | null {
    if (!srcW || !srcH) {
      const w = Math.max(0, Math.floor(Number(wInput.value) || 0));
      const h = Math.max(0, Math.floor(Number(hInput.value) || 0));
      if (w > 0 && h > 0) return { w, h };
      return null;
    }
    const wRaw = wInput.value.trim();
    const hRaw = hInput.value.trim();
    let w = wRaw ? Math.max(1, Math.floor(Number(wRaw))) : 0;
    let h = hRaw ? Math.max(1, Math.floor(Number(hRaw))) : 0;
    if (w && !h) h = Math.max(1, Math.round(srcH * (w / srcW)));
    else if (h && !w) w = Math.max(1, Math.round(srcW * (h / srcH)));
    else if (!w && !h) { w = srcW; h = srcH; }
    return { w, h };
  }

  function updatePreviewLine() {
    if (!srcW) { previewLine.classList.add('hidden'); return; }
    const t = targetDims();
    if (!t) { previewLine.classList.add('hidden'); return; }
    previewLine.classList.remove('hidden');
    const pctW = ((t.w / srcW) * 100).toFixed(0);
    previewLine.textContent = `Source ${srcW}×${srcH} → Output ${t.w}×${t.h} (${pctW}%)`;
  }

  function syncFromWidth() {
    if (suppress) return;
    suppress = true;
    if (locked && srcW && wInput.value) {
      const w = Math.max(1, Math.floor(Number(wInput.value)));
      hInput.value = String(Math.max(1, Math.round(srcH * (w / srcW))));
    }
    if (srcW && wInput.value) {
      pctInput.value = String(Math.min(200, Math.max(5, Math.round((Number(wInput.value) / srcW) * 100))));
      pctVal.textContent = `${pctInput.value}%`;
    }
    updatePreviewLine();
    suppress = false;
  }
  function syncFromHeight() {
    if (suppress) return;
    suppress = true;
    if (locked && srcH && hInput.value) {
      const h = Math.max(1, Math.floor(Number(hInput.value)));
      wInput.value = String(Math.max(1, Math.round(srcW * (h / srcH))));
    }
    if (srcH && hInput.value) {
      pctInput.value = String(Math.min(200, Math.max(5, Math.round((Number(hInput.value) / srcH) * 100))));
      pctVal.textContent = `${pctInput.value}%`;
    }
    updatePreviewLine();
    suppress = false;
  }
  function syncFromPercent() {
    if (suppress) return;
    if (!srcW || !srcH) return;
    suppress = true;
    const pct = Number(pctInput.value);
    pctVal.textContent = `${pct}%`;
    wInput.value = String(Math.max(1, Math.round((srcW * pct) / 100)));
    hInput.value = String(Math.max(1, Math.round((srcH * pct) / 100)));
    updatePreviewLine();
    suppress = false;
  }

  wInput.addEventListener('input', syncFromWidth);
  hInput.addEventListener('input', syncFromHeight);
  pctInput.addEventListener('input', syncFromPercent);
  qualityInput.addEventListener('input', () => { qualityVal.textContent = qualityInput.value; });

  lockBtn.addEventListener('click', () => {
    locked = !locked;
    updateLockUi();
    if (locked) syncFromWidth();
  });

  chipBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const preset = btn.dataset.preset || '';
      const m = preset.match(/^(\d+)x(\d+)$/);
      if (!m) return;
      suppress = true;
      wInput.value = m[1];
      hInput.value = m[2];
      suppress = false;
      updatePreviewLine();
      if (srcW) {
        const pct = Math.min(200, Math.max(5, Math.round((Number(m[1]) / srcW) * 100)));
        pctInput.value = String(pct);
        pctVal.textContent = `${pct}%`;
      }
    });
  });

  drop.addEventListener('click', () => input.click());
  drop.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); }
  });
  ['dragenter', 'dragover'].forEach((ev) => panel.addEventListener(ev, (e) => {
    e.preventDefault();
    panel.classList.add('border-rose-600', 'bg-rose-50');
  }));
  ['dragleave', 'drop'].forEach((ev) => panel.addEventListener(ev, (e) => {
    e.preventDefault();
    panel.classList.remove('border-rose-600', 'bg-rose-50');
  }));
  panel.addEventListener('drop', (e) => {
    const files = (e as DragEvent).dataTransfer?.files;
    if (files && files.length) handleFiles(files);
  });
  input.addEventListener('change', () => {
    if (input.files && input.files.length) handleFiles(input.files);
  });
  resetBtn.addEventListener('click', () => {
    resultsList.innerHTML = '';
    input.value = '';
    showState('idle');
    progress.classList.add('hidden');
    progressFill.style.width = '0%';
  });
  errorReset.addEventListener('click', () => {
    showState('idle');
    progress.classList.add('hidden');
    progressFill.style.width = '0%';
  });

  async function decodeFirst(file: File): Promise<{ source: CanvasImageSource; w: number; h: number; close: () => void }> {
    try {
      const bitmap = await createImageBitmap(file, { imageOrientation: 'from-image' });
      return { source: bitmap, w: bitmap.width, h: bitmap.height, close: () => bitmap.close() };
    } catch {
      const img = await new Promise<HTMLImageElement>((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = () => reject(new Error('Could not read file'));
        reader.onload = () => {
          const i = new Image();
          i.onerror = () => reject(new Error('Could not decode'));
          i.onload = () => resolve(i);
          i.src = reader.result as string;
        };
        reader.readAsDataURL(file);
      });
      return { source: img, w: img.naturalWidth, h: img.naturalHeight, close: () => {} };
    }
  }

  async function resizeOne(file: File, w: number, h: number): Promise<{ blob: Blob; w: number; h: number; mime: string }> {
    const dec = await decodeFirst(file);
    const canvas = document.createElement('canvas');
    canvas.width = w; canvas.height = h;
    const ctx = canvas.getContext('2d');
    if (!ctx) { dec.close(); throw new Error('Canvas unavailable'); }
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = 'high';
    const fmt = formatSel.value;
    const outMime = fmt === 'match' ? (file.type || 'image/jpeg') : fmt;
    if (outMime === 'image/jpeg') { ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, w, h); }
    ctx.drawImage(dec.source, 0, 0, w, h);
    dec.close();
    const quality = Number(qualityInput.value) / 100;
    return new Promise((resolve, reject) => {
      canvas.toBlob(
        (blob) => blob ? resolve({ blob, w, h, mime: outMime }) : reject(new Error('Encoding failed')),
        outMime,
        outMime === 'image/png' ? undefined : quality,
      );
    });
  }

  function extFor(mime: string): string {
    return mime === 'image/jpeg' ? 'jpg' : mime === 'image/webp' ? 'webp' : 'png';
  }

  function makeRow(name: string, src: File, res: { blob: Blob; w: number; h: number; mime: string }): HTMLDivElement {
    const row = document.createElement('div');
    row.className = 'su-control border border-outline-variant bg-white p-3 flex items-center gap-3';
    const url = URL.createObjectURL(res.blob);
    const baseName = name.replace(/\.[^.]+$/, '') + `-${res.w}x${res.h}.${extFor(res.mime)}`;
    const thumb = document.createElement('img');
    thumb.src = url; thumb.alt = '';
    thumb.className = 'w-12 h-12 object-contain bg-surface-variant/30 su-control border border-outline-variant flex-shrink-0';
    const meta = document.createElement('div'); meta.className = 'flex-1 min-w-0';
    const nameEl = document.createElement('p'); nameEl.className = 'text-xs font-bold truncate'; nameEl.textContent = baseName;
    const sizeEl = document.createElement('p'); sizeEl.className = 'text-[11px] text-on-surface-variant font-mono';
    sizeEl.textContent = `${res.w} × ${res.h} · ${fmtBytes(res.blob.size)} · was ${fmtBytes(src.size)}`;
    meta.appendChild(nameEl); meta.appendChild(sizeEl);
    const dl = document.createElement('a'); dl.href = url; dl.download = baseName;
    dl.className = 'su-btn bg-rose-600 hover:bg-rose-700 text-white font-semibold text-xs py-2 px-3 flex-shrink-0';
    dl.textContent = 'Download';
    row.appendChild(thumb); row.appendChild(meta); row.appendChild(dl);
    return row;
  }

  async function handleFiles(fileList: FileList) {
    const files = Array.from(fileList);
    if (!files.length) return;

    // Use the first file's dimensions to seed the inputs/preview.
    try {
      const first = await decodeFirst(files[0]);
      srcW = first.w; srcH = first.h;
      first.close();
      sourceDimsEl.textContent = `Source ${srcW}×${srcH}`;
      sourceDimsEl.classList.remove('hidden');
      pctInput.disabled = false;
      if (!wInput.value && !hInput.value) {
        // Default to 50% scale if nothing chosen yet
        suppress = true;
        wInput.value = String(Math.max(1, Math.round(srcW * 0.5)));
        hInput.value = String(Math.max(1, Math.round(srcH * 0.5)));
        pctInput.value = '50';
        pctVal.textContent = '50%';
        suppress = false;
      } else {
        syncFromWidth();
      }
      updatePreviewLine();
    } catch (err: any) {
      showState('error');
      errorText.textContent = err?.message || 'Could not decode the first image.';
      return;
    }

    const t = targetDims();
    if (!t || t.w < 1 || t.h < 1) {
      showState('error');
      errorText.textContent = 'Enter a width or height first.';
      return;
    }

    progress.classList.remove('hidden');
    progressFill.style.width = '0%';
    progressText.textContent = `Resizing 1 / ${files.length}…`;
    resultsList.innerHTML = '';
    let done = 0, success = 0;

    for (const file of files) {
      progressText.textContent = `Resizing ${done + 1} / ${files.length} — ${file.name}`;
      try {
        // For each file, recompute aspect-correct dims when locked.
        let tw = t.w, th = t.h;
        if (locked) {
          const dec = await decodeFirst(file);
          if (wInput.value && !hInput.value) {
            tw = Math.max(1, Math.floor(Number(wInput.value)));
            th = Math.max(1, Math.round(dec.h * (tw / dec.w)));
          } else if (hInput.value && !wInput.value) {
            th = Math.max(1, Math.floor(Number(hInput.value)));
            tw = Math.max(1, Math.round(dec.w * (th / dec.h)));
          }
          dec.close();
        }
        const res = await resizeOne(file, tw, th);
        resultsList.appendChild(makeRow(file.name, file, res));
        success++;
      } catch (err: any) {
        const row = document.createElement('div');
        row.className = 'border border-error bg-white p-3 text-xs';
        row.textContent = `${file.name} — ${err?.message || 'failed'}`;
        resultsList.appendChild(row);
      }
      done++;
      progressFill.style.width = `${Math.round((done / files.length) * 100)}%`;
    }

    if (success === 0) { showState('error'); errorText.textContent = 'Could not resize any file.'; return; }
    resultsHeading.textContent = `Resized ${success} file${success === 1 ? '' : 's'}`;
    showState('results');
  }

  updateLockUi();
</script>

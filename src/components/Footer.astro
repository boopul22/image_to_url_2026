---
import { t } from '../i18n/utils';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { getNavGroups } from '../lib/nav-links';
import { localizedUrl } from '../i18n/landing/registry';

const locale: Locale = Astro.locals.locale ?? defaultLocale;
const nav = getNavGroups(locale);

function localePath(path: string): string {
  return `/${locale}${path}`;
}

const colHead = "font-headline font-semibold text-xs uppercase tracking-wider text-white mb-4";
const subHead = "font-headline text-[11px] uppercase tracking-wider text-neutral-500 mt-4 mb-2";
const linkClass = "text-xs text-neutral-400 hover:text-white transition-colors py-0.5 block";
---

<footer class="bg-neutral-900 text-neutral-400 pt-12 pb-8 border-t-4 border-rose-600" style="padding-bottom: max(2rem, env(safe-area-inset-bottom));">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-12 gap-x-6 gap-y-10">

      <!-- Brand + Newsletter + Socials -->
      <div class="col-span-2 md:col-span-4 lg:col-span-3">
        <div class="font-headline font-semibold text-base uppercase tracking-tighter text-white mb-3 flex items-center gap-2">
          <span class="material-symbols-outlined text-rose-600 text-xl" style="font-variation-settings: 'FILL' 1;">cloud_done</span>
          ImageToURL
        </div>
        <p class="text-xs text-neutral-400 leading-relaxed max-w-xs mb-5">{t(locale, 'footer.tagline')}</p>

        <span class={colHead}>{t(locale, 'footer.stayUpdated')}</span>
        <div class="flex flex-col sm:flex-row gap-2 mb-5 max-w-sm">
          <input
            type="email"
            placeholder={t(locale, 'footer.emailPlaceholder')}
            class="flex-1 bg-neutral-800 border-2 border-neutral-700 text-white placeholder:text-neutral-500 px-3 py-2 text-xs focus:border-rose-600 focus:outline-none"
          />
          <button class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-2 font-headline font-semibold text-xs uppercase tracking-wide transition-colors">
            {t(locale, 'footer.join')}
          </button>
        </div>

        <div class="flex items-center gap-3">
          <a href="https://github.com/boopul22" target="_blank" rel="noopener" aria-label="GitHub" class="text-neutral-400 hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          </a>
          <a href="https://www.instagram.com/bipul.skill" target="_blank" rel="noopener" aria-label="Instagram" class="text-neutral-400 hover:text-white transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://bipul.online/" target="_blank" rel="noopener" aria-label="Personal Website" class="text-xs text-neutral-400 hover:text-white transition-colors">bipul.online</a>
        </div>
      </div>

      <!-- Tools column: Convert + Format + Utilities -->
      <div class="col-span-1 md:col-span-2 lg:col-span-3">
        <span class={colHead}>{t(locale, 'footer.tools')}</span>

        <span class="block font-headline text-[11px] uppercase tracking-wider text-neutral-500 mb-2">URL Uploaders</span>
        <div class="columns-2 gap-x-4">
          {nav.convert.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>Format Convert</span>
        <div class="columns-2 gap-x-4">
          {nav.formatConvert.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>Utilities</span>
        <div class="columns-2 gap-x-4">
          {nav.utilities.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>
      </div>

      <!-- Popular: Features + Use Cases -->
      <div class="col-span-1 md:col-span-2 lg:col-span-3">
        <span class={colHead}>Popular</span>

        <span class="block font-headline text-[11px] uppercase tracking-wider text-neutral-500 mb-2">Features</span>
        <div class="columns-2 gap-x-4">
          {nav.features.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>Use Cases</span>
        <div class="columns-2 gap-x-4">
          {nav.useCases.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>
      </div>

      <!-- Learn: Compare + API + Answers + Guides -->
      <div class="col-span-1 md:col-span-2 lg:col-span-2">
        <span class={colHead}>Learn</span>

        <span class="block font-headline text-[11px] uppercase tracking-wider text-neutral-500 mb-2">Guides</span>
        <div class="columns-2 gap-x-4">
          {nav.guides.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>Answers</span>
        <div class="columns-2 gap-x-4">
          {nav.answers.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>Compare</span>
        <div class="columns-2 gap-x-4">
          {nav.compare.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>

        <span class={subHead}>API</span>
        <div class="columns-2 gap-x-4">
          {nav.api.map((i) => (<a href={i.href} class={linkClass}>{i.name}</a>))}
        </div>
      </div>

      <!-- Company: pages + our tools -->
      <div class="col-span-1 md:col-span-2 lg:col-span-1">
        <span class={colHead}>{t(locale, 'footer.resources')}</span>
        <a href={localePath('/privacy')} class={linkClass}>{t(locale, 'footer.privacy')}</a>
        <a href={localePath('/terms')} class={linkClass}>{t(locale, 'footer.terms')}</a>
        <a href={localePath('/docs')} class={linkClass}>{t(locale, 'footer.docs')}</a>
        <a href={localizedUrl('about', locale)} class={linkClass}>{t(locale, 'footer.about')}</a>
        <a href={localizedUrl('contact', locale)} class={linkClass}>{t(locale, 'footer.contact')}</a>
        <a href={localePath('/blog')} class={linkClass}>{t(locale, 'footer.blog')}</a>
        <a href={localizedUrl('content-guidelines', locale)} class={linkClass}>Content Guidelines</a>

        <span class={subHead}>Our Tools</span>
        <a href={localePath('/')} class={linkClass + " flex items-center gap-1.5"}>
          <span class="material-symbols-outlined text-rose-600 text-sm">cloud_upload</span>
          ImageToURL
        </a>
        <a href={localizedUrl('heic-to-jpg', locale)} class={linkClass + " flex items-center gap-1.5"}>
          <span class="material-symbols-outlined text-rose-600 text-sm">photo_camera_back</span>
          HEIC to JPG
        </a>
        <a href="https://extractpics.com/?ref=imagetourl" target="_blank" rel="noopener" class={linkClass + " flex items-center gap-1.5"}>
          <span class="material-symbols-outlined text-rose-600 text-sm">travel_explore</span>
          ExtractPics
        </a>
        <a href="https://dailymeditationguide.com/?ref=imagetourl" target="_blank" rel="noopener" class={linkClass + " flex items-center gap-1.5"}>
          <span class="material-symbols-outlined text-rose-600 text-sm">self_improvement</span>
          Daily Meditation
        </a>
      </div>
    </div>

    <div class="mt-10 pt-5 border-t border-neutral-800 flex flex-col sm:flex-row justify-between gap-2 text-xs text-neutral-500">
      <p>{t(locale, 'footer.copyright', { year: String(new Date().getFullYear()) })}</p>
      <p>Built with care · Hosted on Cloudflare</p>
    </div>
  </div>
</footer>

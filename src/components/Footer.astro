---
import { t } from '../i18n/utils';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function localePath(path: string): string {
  return `/${locale}${path}`;
}
---

<footer class="bg-surface-container border-t-2 border-on-background" style="padding-bottom: env(safe-area-inset-bottom);">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 sm:gap-8 w-full px-4 sm:px-8 py-10 sm:py-12 max-w-7xl mx-auto">
    <div>
      <div class="text-xl font-black font-headline text-on-background mb-4">ImageToURL</div>
      <p class="font-body font-medium text-on-surface-variant mb-6">{t(locale, 'footer.tagline')}</p>
      <div class="flex gap-3">
        <a href="#" class="w-11 h-11 border-2 border-on-background flex items-center justify-center hover:bg-primary hover:text-white active:bg-primary active:text-white transition-colors">
          <span class="material-symbols-outlined text-lg">share</span>
        </a>
        <a href="#" class="w-11 h-11 border-2 border-on-background flex items-center justify-center hover:bg-primary hover:text-white active:bg-primary active:text-white transition-colors">
          <span class="material-symbols-outlined text-lg">public</span>
        </a>
      </div>
    </div>
    <div class="flex flex-col gap-4">
      <span class="font-label uppercase tracking-widest text-xs font-bold text-on-background">{t(locale, 'footer.tools')}</span>
      <a href="/free-image-hosting" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.freeHosting')}</a>
      <a href="/image-url-generator" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.urlGenerator')}</a>
      <a href="/bulk-image-upload" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.bulkUpload')}</a>
      <a href="/png-to-url" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">PNG to URL</a>
      <a href="/photo-to-url" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">Photo to URL</a>
    </div>
    <div class="flex flex-col gap-4">
      <span class="font-label uppercase tracking-widest text-xs font-bold text-on-background">{t(locale, 'footer.resources')}</span>
      <a href={localePath('/privacy')} class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.privacy')}</a>
      <a href={localePath('/terms')} class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.terms')}</a>
      <a href={localePath('/docs')} class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.docs')}</a>
      <a href="/about" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.about')}</a>
      <a href="/contact" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.contact')}</a>
      <a href={localePath('/blog')} class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1">{t(locale, 'footer.blog')}</a>
    </div>
    <div class="flex flex-col gap-4">
      <span class="font-label uppercase tracking-widest text-xs font-bold text-on-background">Our Tools</span>
      <a href="/" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">cloud_upload</span>
        ImageToURL
      </a>
      <a href="https://extractpics.com/?ref=imagetourl" target="_blank" rel="noopener" class="text-outline hover:text-on-background active:text-on-background underline decoration-2 font-medium transition-colors py-1 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">travel_explore</span>
        ExtractPics
        <span class="material-symbols-outlined text-xs text-outline">open_in_new</span>
      </a>
    </div>
    <div class="flex flex-col gap-3">
      <span class="font-label uppercase tracking-widest text-xs font-bold text-on-background">{t(locale, 'footer.stayUpdated')}</span>
      <div class="flex flex-col sm:flex-row gap-2 mt-2 sm:relative">
        <input type="email" placeholder={t(locale, 'footer.emailPlaceholder')} class="w-full bg-white border-2 border-on-background px-4 py-3 sm:py-2 sm:pr-20 focus:ring-0 focus:border-primary focus:outline-none text-base sm:text-sm" />
        <button class="sm:absolute sm:right-2 sm:top-2 sm:bottom-2 bg-primary text-on-primary px-4 py-3 sm:py-0 sm:px-3 font-bold text-sm sm:text-xs uppercase active:scale-95 transition-transform">{t(locale, 'footer.join')}</button>
      </div>
      <p class="text-xs text-on-surface-variant mt-4">{t(locale, 'footer.copyright', { year: String(new Date().getFullYear()) })}</p>
    </div>
  </div>
</footer>

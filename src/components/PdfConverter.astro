---
/**
 * Client-side image → PDF converter. Uses jsPDF, dynamically imported so the
 * library (~40KB gzipped) never enters the initial bundle. Accepts PNG, JPG,
 * or HEIC (routed through heic2any first). One image per page, auto-sized to
 * A4 with a small margin.
 */
export interface Props {
  /** source format ids allowed in the accept list */
  from: 'png' | 'jpg' | 'heic' | 'any';
  idPrefix?: string;
}
const { from, idPrefix = 'pdf' } = Astro.props;

const acceptMap = {
  png: '.png,image/png',
  jpg: '.jpg,.jpeg,image/jpeg',
  heic: '.heic,.heif,image/heic,image/heif',
  any: '.png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp',
};
const accept = acceptMap[from];
const fromLabel = { png: 'PNG', jpg: 'JPG', heic: 'HEIC', any: 'image' }[from];
---

<div class="w-full max-w-2xl mx-auto" data-pdf-root={idPrefix} data-pdf-from={from}>
  <input type="file" id={`${idPrefix}-input`} accept={accept} multiple class="hidden" />

  <div class="bg-white border-2 border-on-background border-b-0 px-4 py-3 flex items-center justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span class="material-symbols-outlined text-rose-600 text-lg flex-shrink-0" style="font-variation-settings: 'FILL' 1;">lock</span>
      <div class="min-w-0">
        <p class="text-xs font-bold uppercase tracking-wider text-on-background">100% in your browser</p>
        <p class="text-[11px] leading-tight text-on-surface-variant">Files never leave your device</p>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <label class="text-xs font-bold uppercase tracking-wider text-on-background flex items-center gap-1">
        <input type="checkbox" id={`${idPrefix}-merge`} checked class="accent-rose-600" />
        Merge into one PDF
      </label>
    </div>
  </div>

  <div id={`${idPrefix}-panel`} class="bg-white border-2 border-dashed border-on-background overflow-hidden transition-colors">
    <div id={`${idPrefix}-state-idle`} class="px-6 py-12 sm:px-10 sm:py-16">
      <div id={`${idPrefix}-drop`} class="flex flex-col items-center gap-3 cursor-pointer" role="button" tabindex="0">
        <span class="material-symbols-outlined text-on-background text-4xl sm:text-5xl">picture_as_pdf</span>
        <div class="text-center">
          <p class="text-on-background font-semibold text-sm sm:text-base font-headline uppercase tracking-wider">Drop {fromLabel} files here or click to browse</p>
          <p class="text-xs sm:text-sm text-on-surface-variant mt-2">One image per page — A4 auto-fit</p>
        </div>
      </div>
      <div id={`${idPrefix}-progress`} class="hidden mt-6">
        <div class="h-2.5 sm:h-2 bg-surface-variant overflow-hidden rounded-full">
          <div id={`${idPrefix}-progress-fill`} class="h-full bg-rose-600 transition-all duration-300 rounded-full" style="width: 0%"></div>
        </div>
        <p id={`${idPrefix}-progress-text`} class="text-xs text-center mt-2 font-mono text-on-surface-variant">Preparing…</p>
      </div>
    </div>

    <div id={`${idPrefix}-state-results`} class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-secondary text-lg sm:text-xl">check_circle</span>
        <span class="font-bold text-secondary text-sm sm:text-lg" id={`${idPrefix}-results-heading`}>Ready</span>
        <button id={`${idPrefix}-reset`} class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline flex-shrink-0">Convert more</button>
      </div>
      <div id={`${idPrefix}-results-list`} class="flex flex-col gap-2 max-h-96 overflow-auto"></div>
    </div>

    <div id={`${idPrefix}-state-error`} class="p-4 sm:p-6 hidden">
      <div class="flex items-center gap-3 mb-3">
        <span class="material-symbols-outlined text-error text-lg sm:text-xl">error</span>
        <span class="font-bold text-error text-sm sm:text-lg">Conversion failed</span>
        <button id={`${idPrefix}-error-reset`} class="ml-auto text-primary font-bold text-xs sm:text-sm uppercase tracking-wider hover:underline">Try again</button>
      </div>
      <p id={`${idPrefix}-error-text`} class="text-xs sm:text-sm text-on-surface-variant"></p>
    </div>
  </div>
</div>

<script>
  function initPdfConverter(root: HTMLElement) {
    const idPrefix = root.getAttribute('data-pdf-root') || 'pdf';
    const fromFormat = root.getAttribute('data-pdf-from') || 'any';

    const byId = <T extends HTMLElement>(id: string) => document.getElementById(`${idPrefix}-${id}`) as T;
    const input = byId<HTMLInputElement>('input');
    const drop = byId<HTMLDivElement>('drop');
    const panel = byId<HTMLDivElement>('panel');
    const stateIdle = byId<HTMLDivElement>('state-idle');
    const stateResults = byId<HTMLDivElement>('state-results');
    const stateError = byId<HTMLDivElement>('state-error');
    const progress = byId<HTMLDivElement>('progress');
    const progressFill = byId<HTMLDivElement>('progress-fill');
    const progressText = byId<HTMLParagraphElement>('progress-text');
    const resultsList = byId<HTMLDivElement>('results-list');
    const resultsHeading = byId<HTMLSpanElement>('results-heading');
    const resetBtn = byId<HTMLButtonElement>('reset');
    const errorReset = byId<HTMLButtonElement>('error-reset');
    const errorText = byId<HTMLParagraphElement>('error-text');
    const mergeBox = byId<HTMLInputElement>('merge');
    if (!input || !drop || !panel) return;

    let jsPDFCtor: any = null;
    let heic2any: any = null;

    async function ensureJsPdf(): Promise<any> {
      if (jsPDFCtor) return jsPDFCtor;
      progressText.textContent = 'Loading PDF engine…';
      const mod: any = await import('jspdf');
      jsPDFCtor = mod.jsPDF || mod.default || mod;
      return jsPDFCtor;
    }
    async function ensureHeic(): Promise<any> {
      if (heic2any) return heic2any;
      progressText.textContent = 'Loading HEIC decoder…';
      const mod: any = await import('heic2any');
      heic2any = mod.default || mod;
      return heic2any;
    }

    function showState(name: 'idle' | 'results' | 'error') {
      stateIdle.classList.toggle('hidden', name !== 'idle');
      stateResults.classList.toggle('hidden', name !== 'results');
      stateError.classList.toggle('hidden', name !== 'error');
    }

    drop.addEventListener('click', () => input.click());
    drop.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); }
    });
    ['dragenter', 'dragover'].forEach((ev) => {
      panel.addEventListener(ev, (e) => { e.preventDefault(); panel.classList.add('border-rose-600', 'bg-rose-50'); });
    });
    ['dragleave', 'drop'].forEach((ev) => {
      panel.addEventListener(ev, (e) => { e.preventDefault(); panel.classList.remove('border-rose-600', 'bg-rose-50'); });
    });
    panel.addEventListener('drop', (e) => {
      const files = (e as DragEvent).dataTransfer?.files;
      if (files && files.length) handleFiles(files);
    });
    input.addEventListener('change', () => {
      if (input.files && input.files.length) handleFiles(input.files);
    });
    resetBtn.addEventListener('click', () => {
      resultsList.innerHTML = ''; input.value = '';
      showState('idle'); progress.classList.add('hidden'); progressFill.style.width = '0%';
    });
    errorReset.addEventListener('click', () => {
      showState('idle'); progress.classList.add('hidden'); progressFill.style.width = '0%';
    });

    function fmtBytes(n: number): string {
      if (n < 1024) return `${n} B`;
      if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
      return `${(n / 1024 / 1024).toFixed(2)} MB`;
    }

    function imageDataUrl(file: Blob): Promise<{ dataUrl: string; width: number; height: number; mime: string }> {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = () => reject(new Error('Could not read file'));
        reader.onload = () => {
          const dataUrl = reader.result as string;
          const img = new Image();
          img.onerror = () => reject(new Error('Browser could not decode'));
          img.onload = () => resolve({ dataUrl, width: img.naturalWidth, height: img.naturalHeight, mime: dataUrl.substring(5, dataUrl.indexOf(';')) });
          img.src = dataUrl;
        };
        reader.readAsDataURL(file);
      });
    }

    async function prepareBlob(file: File): Promise<Blob> {
      // HEIC source → convert to JPEG first
      if (fromFormat === 'heic' || /\.hei[cf]$/i.test(file.name) || file.type === 'image/heic' || file.type === 'image/heif') {
        const lib = await ensureHeic();
        const out = await lib({ blob: file, toType: 'image/jpeg', quality: 0.92 });
        return Array.isArray(out) ? out[0] : out;
      }
      return file;
    }

    function makePdfRow(name: string, blob: Blob): HTMLDivElement {
      const row = document.createElement('div');
      row.className = 'border-2 border-on-background bg-white p-3 flex items-center gap-3';
      const url = URL.createObjectURL(blob);
      const meta = document.createElement('div');
      meta.className = 'flex-1 min-w-0';
      const nameEl = document.createElement('p');
      nameEl.className = 'text-xs font-bold truncate'; nameEl.textContent = name;
      const sizeEl = document.createElement('p');
      sizeEl.className = 'text-[11px] text-on-surface-variant'; sizeEl.textContent = fmtBytes(blob.size);
      meta.appendChild(nameEl); meta.appendChild(sizeEl);
      const dl = document.createElement('a');
      dl.href = url; dl.download = name;
      dl.className = 'bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wide flex-shrink-0';
      dl.textContent = 'Download';
      const host = document.createElement('button');
      host.className = 'border-2 border-on-background bg-white hover:bg-on-background hover:text-white font-headline font-semibold text-xs py-2 px-3 uppercase tracking-wide flex-shrink-0';
      host.textContent = 'Get URL';
      host.addEventListener('click', async () => {
        host.disabled = true; host.textContent = 'Hosting…';
        try {
          const fd = new FormData();
          fd.append('file', new File([blob], name, { type: 'application/pdf' }));
          const res = await fetch('/api/upload', { method: 'POST', body: fd });
          const data = await res.json();
          if (!res.ok || data.error) throw new Error(data.error || 'Upload failed');
          const hosted = data.data.url as string;
          host.remove();
          const inp = document.createElement('input');
          inp.type = 'text'; inp.readOnly = true; inp.value = hosted;
          inp.className = 'flex-1 min-w-0 bg-white border-2 border-on-background px-2 py-2 text-xs font-mono';
          inp.addEventListener('focus', () => inp.select());
          const copy = document.createElement('button');
          copy.className = 'bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-xs py-2 px-3 border-2 border-on-background uppercase tracking-wide flex-shrink-0';
          copy.textContent = 'Copy';
          copy.addEventListener('click', async () => {
            await navigator.clipboard.writeText(hosted);
            copy.textContent = 'Copied!';
            setTimeout(() => (copy.textContent = 'Copy'), 1200);
          });
          row.appendChild(inp); row.appendChild(copy);
        } catch (err: any) {
          host.disabled = false; host.textContent = 'Retry';
          const note = document.createElement('span');
          note.className = 'text-[11px] text-error';
          note.textContent = err.message || 'Failed';
          row.appendChild(note);
        }
      });
      row.appendChild(meta); row.appendChild(dl); row.appendChild(host);
      return row;
    }

    function addImageToPdf(pdf: any, imageInfo: { dataUrl: string; width: number; height: number; mime: string }, firstPage: boolean) {
      const pageW = pdf.internal.pageSize.getWidth();
      const pageH = pdf.internal.pageSize.getHeight();
      const margin = 10;
      const maxW = pageW - margin * 2;
      const maxH = pageH - margin * 2;
      const ratio = Math.min(maxW / imageInfo.width, maxH / imageInfo.height);
      const w = imageInfo.width * ratio;
      const h = imageInfo.height * ratio;
      const x = (pageW - w) / 2;
      const y = (pageH - h) / 2;
      if (!firstPage) pdf.addPage();
      const format = imageInfo.mime === 'image/png' ? 'PNG' : 'JPEG';
      pdf.addImage(imageInfo.dataUrl, format, x, y, w, h, undefined, 'FAST');
    }

    async function handleFiles(fileList: FileList) {
      const files = Array.from(fileList);
      if (!files.length) return;
      progress.classList.remove('hidden');
      progressFill.style.width = '0%';
      progressText.textContent = 'Preparing…';
      resultsList.innerHTML = '';

      let JsPDF: any;
      try { JsPDF = await ensureJsPdf(); }
      catch { showState('error'); errorText.textContent = 'Could not load the PDF engine.'; return; }

      const merge = mergeBox?.checked ?? true;
      let success = 0;

      if (merge) {
        const pdf = new JsPDF({ unit: 'mm', format: 'a4' });
        for (let i = 0; i < files.length; i++) {
          const file = files[i];
          progressText.textContent = `Processing ${i + 1} / ${files.length} — ${file.name}`;
          try {
            const blob = await prepareBlob(file);
            const info = await imageDataUrl(blob);
            addImageToPdf(pdf, info, i === 0);
            success++;
          } catch (err: any) {
            const row = document.createElement('div');
            row.className = 'border-2 border-error bg-white p-3 text-xs';
            row.textContent = `${file.name} — ${err?.message || 'failed'}`;
            resultsList.appendChild(row);
          }
          progressFill.style.width = `${Math.round(((i + 1) / files.length) * 100)}%`;
        }
        if (success > 0) {
          const blob = pdf.output('blob') as Blob;
          const name = files.length === 1 ? files[0].name.replace(/\.[^.]+$/, '') + '.pdf' : 'merged-' + Date.now() + '.pdf';
          resultsList.appendChild(makePdfRow(name, blob));
        }
      } else {
        for (let i = 0; i < files.length; i++) {
          const file = files[i];
          progressText.textContent = `Processing ${i + 1} / ${files.length} — ${file.name}`;
          try {
            const blob = await prepareBlob(file);
            const info = await imageDataUrl(blob);
            const pdf = new JsPDF({ unit: 'mm', format: 'a4' });
            addImageToPdf(pdf, info, true);
            const outBlob = pdf.output('blob') as Blob;
            const name = file.name.replace(/\.[^.]+$/, '') + '.pdf';
            resultsList.appendChild(makePdfRow(name, outBlob));
            success++;
          } catch (err: any) {
            const row = document.createElement('div');
            row.className = 'border-2 border-error bg-white p-3 text-xs';
            row.textContent = `${file.name} — ${err?.message || 'failed'}`;
            resultsList.appendChild(row);
          }
          progressFill.style.width = `${Math.round(((i + 1) / files.length) * 100)}%`;
        }
      }

      if (success === 0) {
        showState('error'); errorText.textContent = 'None of the files could be converted.'; return;
      }
      resultsHeading.textContent = `Ready — ${success} image${success === 1 ? '' : 's'} in PDF`;
      showState('results');
    }
  }

  document.querySelectorAll<HTMLElement>('[data-pdf-root]').forEach(initPdfConverter);
</script>

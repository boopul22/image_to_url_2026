---
import { t, stripLocalePrefix } from '../i18n/utils';
import { locales, localeLabels, defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { getNavGroups } from '../lib/nav-links';

const { activePage = "home" } = Astro.props;
const user = Astro.locals.user;
const locale: Locale = Astro.locals.locale ?? defaultLocale;
const basePath = stripLocalePrefix(Astro.url.pathname);

// Root-level English-only pages have no locale variants — hide language switcher
const hasLocalePrefix = Astro.url.pathname !== basePath;
const isLocalizable = hasLocalePrefix || Astro.url.pathname === '/';

function localePath(path: string, loc: Locale = locale): string {
  return `/${loc}${path}`;
}

const navLinks = [
  { name: t(locale, 'nav.home'), href: localePath('/'), id: "home", icon: "home" },
  { name: t(locale, 'nav.features'), href: localePath('/features'), id: "features", icon: "auto_awesome" },
  { name: t(locale, 'nav.blog'), href: localePath('/blog'), id: "blog", icon: "article" },
];

const toolsDropdown = getNavGroups(locale);
---

<nav class="sticky top-0 z-40 bg-[#fcfcfc]/95 backdrop-blur-sm border-b border-neutral-200 transition-all duration-300" style="padding-left: env(safe-area-inset-left); padding-right: env(safe-area-inset-right);">
  <div class="flex justify-between items-center w-full px-4 sm:px-6 h-14 max-w-6xl mx-auto lg:grid lg:grid-cols-[1fr_auto_1fr]">
    <a href={localePath('/')} class="text-[15px] font-semibold font-headline tracking-tighter uppercase text-on-background flex items-center gap-1.5 flex-shrink-0 lg:justify-self-start">
      <span class="material-symbols-outlined text-rose-600 text-lg" style="font-variation-settings: 'FILL' 1;">cloud_done</span>
      ImageToURL
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-5 xl:gap-6 lg:justify-self-center">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[13px] font-headline font-medium uppercase tracking-wide transition-colors duration-200",
            activePage === link.id
              ? "text-on-background"
              : "text-neutral-500 hover:text-on-background",
          ]}
        >
          {link.name}
        </a>
      ))}

      <!-- Tools Dropdown -->
      <div class="relative" id="tools-switcher-desktop">
        <button
          id="tools-btn-desktop"
          class="flex items-center gap-1 text-[13px] font-headline font-medium uppercase tracking-wide transition-colors duration-200 text-neutral-500 hover:text-on-background"
          aria-expanded="false"
        >
          {t(locale, 'nav.tools')}
          <span class="material-symbols-outlined text-sm">expand_more</span>
        </button>
        <div id="tools-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 bg-surface border-2 border-on-background hard-shadow overflow-hidden z-50 min-w-[560px]">
          <div class="grid grid-cols-3 gap-0 divide-x-2 divide-on-background">
            <!-- Convert Column -->
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">{t(locale, 'nav.convert')}</span>
              {toolsDropdown.convert.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
                  {item.name}
                </a>
              ))}
            </div>
            <!-- Features Column -->
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">{t(locale, 'nav.featuresLabel')}</span>
              {toolsDropdown.features.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
                  {item.name}
                </a>
              ))}
            </div>
            <!-- Use Cases Column -->
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">Use Cases</span>
              {toolsDropdown.useCases.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
                  {item.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Tools Dropdown (our products) -->
      <div class="relative" id="our-tools-switcher-desktop">
        <button
          id="our-tools-btn-desktop"
          class="flex items-center gap-1 text-[13px] font-headline font-medium uppercase tracking-wide transition-colors duration-200 text-neutral-500 hover:text-on-background"
          aria-expanded="false"
        >
          Tools
          <span class="material-symbols-outlined text-sm">expand_more</span>
        </button>
        <div id="our-tools-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 bg-surface border-2 border-on-background hard-shadow overflow-hidden z-50 min-w-[260px]">
          <div class="p-3">
            {toolsDropdown.tools.map((item) => (
              <a
                href={item.href}
                {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
                class="flex items-center gap-2 px-2 py-2 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded"
              >
                <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
                {item.name}
                {item.external && <span class="material-symbols-outlined text-[10px] text-outline ml-auto">open_in_new</span>}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop Right Actions -->
    <div class="hidden lg:flex items-center gap-4 lg:justify-self-end">
      <!-- Language Switcher (desktop) — hidden on English-only pages -->
      {isLocalizable && (
      <div class="relative" id="lang-switcher-desktop">
        <button
          id="lang-btn-desktop"
          class="flex items-center gap-1 text-[13px] font-headline font-medium uppercase tracking-wide text-neutral-500 hover:text-on-background transition-colors"
          aria-label="Change language"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-sm">translate</span>
          {localeLabels[locale]}
          <span class="material-symbols-outlined text-sm">expand_more</span>
        </button>
        <div id="lang-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 bg-surface border-2 border-on-background hard-shadow z-50 w-[360px] max-h-[min(70vh,480px)] overflow-y-auto grid grid-cols-2">
          {locales.map((loc) => (
            <a
              href={`/${loc}${basePath}`}
              class:list={[
                "block px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors truncate",
                loc === locale ? "text-on-background font-bold bg-primary" : "text-on-surface",
              ]}
            >
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>
      )}

      <div id="auth-slot-desktop" data-signed-in={user ? 'true' : 'false'}>
      {user ? (
        <div class="relative" id="profile-switcher-desktop">
          <button
            id="profile-btn-desktop"
            class="flex items-center gap-2 text-[13px] font-headline font-medium uppercase tracking-wide text-on-background hover:text-rose-600 transition-colors"
            aria-label="Profile menu"
            aria-expanded="false"
          >
            <img
              src={user.avatarUrl}
              alt={user.name}
              class="w-6 h-6 border border-neutral-300 object-cover"
              width="24"
              height="24"
              referrerpolicy="no-referrer"
            />
            <span>{user.name}</span>
            <span class="material-symbols-outlined text-sm">expand_more</span>
          </button>
          <div id="profile-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 bg-white border border-neutral-200 shadow-lg overflow-hidden z-50 min-w-[180px]">
            <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors">
              <span class="material-symbols-outlined text-base text-neutral-500">dashboard</span>
              Dashboard
            </a>
            {user.role === 'admin' && (
              <a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-rose-600 hover:bg-neutral-50 transition-colors">
                <span class="material-symbols-outlined text-base">admin_panel_settings</span>
                {t(locale, 'nav.admin')}
              </a>
            )}
            <div class="border-t border-neutral-200"></div>
            <a href="/api/auth/logout" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-neutral-500 hover:text-on-background hover:bg-neutral-50 transition-colors">
              <span class="material-symbols-outlined text-base">logout</span>
              {t(locale, 'nav.signOut')}
            </a>
          </div>
        </div>
      ) : (
        <a
          href="/api/auth/login"
          class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-1.5 font-headline text-[12px] font-semibold uppercase tracking-wide flex items-center gap-1.5 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          {t(locale, 'nav.signIn')}
        </a>
      )}
      </div>
    </div>

    <!-- Mobile Menu Button (only element on right side on mobile) -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden w-9 h-9 flex items-center justify-center text-on-background hover:bg-neutral-100 transition-colors"
      aria-label={t(locale, 'nav.toggleMenu')}
      aria-expanded="false"
    >
      <span class="material-symbols-outlined text-xl" id="menu-icon">menu</span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu-transition lg:hidden border-t border-neutral-200 bg-background">
    <div class="flex flex-col px-4 py-3 gap-1" style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 transition-colors flex items-center gap-3",
            activePage === link.id
              ? "text-on-background bg-primary border-2 border-on-background font-bold"
              : "text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest",
          ]}
        >
          <span class="material-symbols-outlined text-base">{link.icon}</span>
          {link.name}
        </a>
      ))}

      <div class="h-px bg-outline-variant my-2"></div>

      <!-- Tools Dropdown (mobile) -->
      <div class="relative" id="tools-switcher-mobile">
        <button
          id="tools-btn-mobile"
          class="flex items-center gap-3 w-full py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors font-label uppercase tracking-wider text-xs font-bold text-outline"
          aria-label="Tools"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-base">build</span>
          {t(locale, 'nav.tools')}
          <span class="material-symbols-outlined text-sm ml-auto" id="tools-chevron-mobile">expand_more</span>
        </button>
        <div id="tools-dropdown-mobile" class="hidden mx-4 mb-1 bg-surface-container border-2 border-on-background overflow-hidden">
          <div class="px-3 pt-3 pb-1">
            <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline">{t(locale, 'nav.convert')}</span>
          </div>
          {toolsDropdown.convert.map((item) => (
            <a href={item.href} class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors">
              <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
              {item.name}
            </a>
          ))}
          <div class="px-3 pt-3 pb-1">
            <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline">{t(locale, 'nav.featuresLabel')}</span>
          </div>
          {toolsDropdown.features.map((item) => (
            <a href={item.href} class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors">
              <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
              {item.name}
            </a>
          ))}
          <div class="px-3 pt-3 pb-1">
            <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline">Use Cases</span>
          </div>
          {toolsDropdown.useCases.map((item) => (
            <a href={item.href} class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors">
              <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
              {item.name}
            </a>
          ))}
        </div>
      </div>

      <!-- Tools Dropdown (mobile, real products) -->
      <div class="relative" id="our-tools-switcher-mobile">
        <button
          id="our-tools-btn-mobile"
          class="flex items-center gap-3 w-full py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors font-label uppercase tracking-wider text-xs font-bold text-outline"
          aria-label="Tools"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-base">build</span>
          Tools
          <span class="material-symbols-outlined text-sm ml-auto" id="our-tools-chevron-mobile">expand_more</span>
        </button>
        <div id="our-tools-dropdown-mobile" class="hidden mx-4 mb-1 bg-surface-container border-2 border-on-background overflow-hidden">
          {toolsDropdown.tools.map((item) => (
            <a
              href={item.href}
              {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
              class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors"
            >
              <span class="material-symbols-outlined text-primary text-base">{item.icon}</span>
              {item.name}
              {item.external && <span class="material-symbols-outlined text-[10px] text-outline ml-auto">open_in_new</span>}
            </a>
          ))}
        </div>
      </div>

      <div class="h-px bg-outline-variant my-2"></div>

      <!-- Language Switcher (inside mobile menu) — hidden on English-only pages -->
      {isLocalizable && (
      <div class="relative" id="lang-switcher-mobile">
        <button
          id="lang-btn-mobile"
          class="flex items-center gap-3 w-full py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors font-label uppercase tracking-wider text-xs font-bold text-outline"
          aria-label="Change language"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-base">translate</span>
          {localeLabels[locale]}
          <span class="material-symbols-outlined text-sm ml-auto">expand_more</span>
        </button>
        <div id="lang-dropdown-mobile" class="hidden mx-4 mb-1 bg-surface-container border-2 border-on-background max-h-[50vh] overflow-y-auto grid grid-cols-2">
          {locales.map((loc) => (
            <a
              href={`/${loc}${basePath}`}
              class:list={[
                "block px-3 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors truncate",
                loc === locale ? "text-on-background font-bold bg-primary" : "text-on-surface",
              ]}
            >
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>
      )}

      <div id="auth-slot-mobile" data-signed-in={user ? 'true' : 'false'}>
      {user ? (
        <>
          <div class="h-px bg-outline-variant my-1"></div>
          <a href="/dashboard" class="flex items-center gap-3 py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
            <img
              src={user.avatarUrl}
              alt={user.name}
              class="w-7 h-7 border-2 border-on-background object-cover"
              width="28"
              height="28"
              referrerpolicy="no-referrer"
            />
            <span class="font-label text-xs font-bold text-on-background">{user.name}</span>
          </a>
          {user.role === 'admin' && (
            <a href="/admin" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-error hover:bg-error-container active:bg-error-container transition-colors flex items-center gap-3">
              <span class="material-symbols-outlined text-base">admin_panel_settings</span>
              {t(locale, 'nav.admin')}
            </a>
          )}
          <a href="/api/auth/logout" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors flex items-center gap-3">
            <span class="material-symbols-outlined text-base">logout</span>
            {t(locale, 'nav.signOut')}
          </a>
        </>
      ) : (
        <a
          href="/api/auth/login"
          class="flex items-center justify-center gap-2 mx-2 mt-1 bg-primary text-on-primary py-3.5 border-2 border-on-background hard-shadow font-label uppercase tracking-wider text-xs font-bold active:scale-[0.98] transition-transform"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          {t(locale, 'nav.signIn')}
        </a>
      )}
      </div>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  function closeMobileMenu() {
    mobileMenu?.classList.remove('open');
    if (menuIcon) menuIcon.textContent = 'menu';
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu!.classList.contains('open');
    if (isOpen) {
      closeMobileMenu();
    } else {
      mobileMenu!.classList.add('open');
      menuIcon!.textContent = 'close';
      menuBtn!.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu when a nav link is tapped
  mobileMenu?.querySelectorAll('a[href]:not([id*="lang"])').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Desktop language switcher
  const langBtnDesktop = document.getElementById('lang-btn-desktop');
  const langDropdownDesktop = document.getElementById('lang-dropdown-desktop');

  langBtnDesktop?.addEventListener('click', () => {
    const isOpen = !langDropdownDesktop!.classList.contains('hidden');
    langDropdownDesktop!.classList.toggle('hidden');
    langBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    // Close tools dropdown when opening lang
    toolsDropdownDesktop?.classList.add('hidden');
    toolsBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Desktop tools dropdown
  const toolsBtnDesktop = document.getElementById('tools-btn-desktop');
  const toolsDropdownDesktop = document.getElementById('tools-dropdown-desktop');

  toolsBtnDesktop?.addEventListener('click', () => {
    const isOpen = !toolsDropdownDesktop!.classList.contains('hidden');
    toolsDropdownDesktop!.classList.toggle('hidden');
    toolsBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    // Close other dropdowns when opening solutions
    langDropdownDesktop?.classList.add('hidden');
    langBtnDesktop?.setAttribute('aria-expanded', 'false');
    ourToolsDropdownDesktop?.classList.add('hidden');
    ourToolsBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Desktop our-tools dropdown (real products)
  const ourToolsBtnDesktop = document.getElementById('our-tools-btn-desktop');
  const ourToolsDropdownDesktop = document.getElementById('our-tools-dropdown-desktop');

  ourToolsBtnDesktop?.addEventListener('click', () => {
    const isOpen = !ourToolsDropdownDesktop!.classList.contains('hidden');
    ourToolsDropdownDesktop!.classList.toggle('hidden');
    ourToolsBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    toolsDropdownDesktop?.classList.add('hidden');
    toolsBtnDesktop?.setAttribute('aria-expanded', 'false');
    langDropdownDesktop?.classList.add('hidden');
    langBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Desktop profile dropdown
  const profileBtnDesktop = document.getElementById('profile-btn-desktop');
  const profileDropdownDesktop = document.getElementById('profile-dropdown-desktop');

  profileBtnDesktop?.addEventListener('click', () => {
    const isOpen = !profileDropdownDesktop!.classList.contains('hidden');
    profileDropdownDesktop!.classList.toggle('hidden');
    profileBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    langDropdownDesktop?.classList.add('hidden');
    langBtnDesktop?.setAttribute('aria-expanded', 'false');
    toolsDropdownDesktop?.classList.add('hidden');
    toolsBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Close all desktop dropdowns on outside click
  document.addEventListener('click', (e) => {
    const langSwitcher = document.getElementById('lang-switcher-desktop');
    const toolsSwitcher = document.getElementById('tools-switcher-desktop');
    const profileSwitcher = document.getElementById('profile-switcher-desktop');
    if (langSwitcher && !langSwitcher.contains(e.target as Node)) {
      langDropdownDesktop?.classList.add('hidden');
      langBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
    if (toolsSwitcher && !toolsSwitcher.contains(e.target as Node)) {
      toolsDropdownDesktop?.classList.add('hidden');
      toolsBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
    const ourToolsSwitcher = document.getElementById('our-tools-switcher-desktop');
    if (ourToolsSwitcher && !ourToolsSwitcher.contains(e.target as Node)) {
      ourToolsDropdownDesktop?.classList.add('hidden');
      ourToolsBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
    if (profileSwitcher && !profileSwitcher.contains(e.target as Node)) {
      profileDropdownDesktop?.classList.add('hidden');
      profileBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
  });

  // Mobile language switcher (inline expand)
  const langBtnMobile = document.getElementById('lang-btn-mobile');
  const langDropdownMobile = document.getElementById('lang-dropdown-mobile');

  langBtnMobile?.addEventListener('click', () => {
    const isOpen = !langDropdownMobile!.classList.contains('hidden');
    langDropdownMobile!.classList.toggle('hidden');
    langBtnMobile!.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile tools dropdown (inline expand)
  const toolsBtnMobile = document.getElementById('tools-btn-mobile');
  const toolsDropdownMobile = document.getElementById('tools-dropdown-mobile');
  const toolsChevronMobile = document.getElementById('tools-chevron-mobile');

  toolsBtnMobile?.addEventListener('click', () => {
    const isOpen = !toolsDropdownMobile!.classList.contains('hidden');
    toolsDropdownMobile!.classList.toggle('hidden');
    toolsBtnMobile!.setAttribute('aria-expanded', String(!isOpen));
    if (toolsChevronMobile) {
      toolsChevronMobile.style.transform = isOpen ? '' : 'rotate(180deg)';
    }
  });

  // Mobile our-tools dropdown
  const ourToolsBtnMobile = document.getElementById('our-tools-btn-mobile');
  const ourToolsDropdownMobile = document.getElementById('our-tools-dropdown-mobile');
  const ourToolsChevronMobile = document.getElementById('our-tools-chevron-mobile');

  ourToolsBtnMobile?.addEventListener('click', () => {
    const isOpen = !ourToolsDropdownMobile!.classList.contains('hidden');
    ourToolsDropdownMobile!.classList.toggle('hidden');
    ourToolsBtnMobile!.setAttribute('aria-expanded', String(!isOpen));
    if (ourToolsChevronMobile) {
      ourToolsChevronMobile.style.transform = isOpen ? '' : 'rotate(180deg)';
    }
  });

  // Auth nav hydration — fixes signed-out flash on prerendered/CDN-cached pages.
  // Server may render the signed-out state (no cookies at build time, or anonymous
  // CDN cache hit). If a real session exists, swap the auth slots to the profile UI.
  (async () => {
    const desktop = document.getElementById('auth-slot-desktop');
    const mobile = document.getElementById('auth-slot-mobile');
    if (!desktop || desktop.dataset.signedIn === 'true') return;

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    let user: { name: string; avatarUrl: string; role: 'user' | 'admin' } | null = null;
    try {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      if (!res.ok) return;
      user = (await res.json()).user;
    } catch {
      return;
    }
    if (!user) return;

    const name = escapeHtml(user.name);
    const avatar = escapeHtml(user.avatarUrl);
    const isAdmin = user.role === 'admin';

    desktop.innerHTML = `
      <div class="relative" id="profile-switcher-desktop">
        <button id="profile-btn-desktop" class="flex items-center gap-2 text-[13px] font-headline font-medium uppercase tracking-wide text-on-background hover:text-rose-600 transition-colors" aria-label="Profile menu" aria-expanded="false">
          <img src="${avatar}" alt="${name}" class="w-6 h-6 border border-neutral-300 object-cover" width="24" height="24" referrerpolicy="no-referrer" />
          <span>${name}</span>
          <span class="material-symbols-outlined text-sm">expand_more</span>
        </button>
        <div id="profile-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 bg-white border border-neutral-200 shadow-lg overflow-hidden z-50 min-w-[180px]">
          <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors">
            <span class="material-symbols-outlined text-base text-neutral-500">dashboard</span>Dashboard
          </a>
          ${isAdmin ? `<a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-rose-600 hover:bg-neutral-50 transition-colors"><span class="material-symbols-outlined text-base">admin_panel_settings</span>Admin</a>` : ''}
          <div class="border-t border-neutral-200"></div>
          <a href="/api/auth/logout" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-neutral-500 hover:text-on-background hover:bg-neutral-50 transition-colors">
            <span class="material-symbols-outlined text-base">logout</span>Sign out
          </a>
        </div>
      </div>
    `;

    if (mobile) {
      mobile.innerHTML = `
        <div class="h-px bg-outline-variant my-1"></div>
        <a href="/dashboard" class="flex items-center gap-3 py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
          <img src="${avatar}" alt="${name}" class="w-7 h-7 border-2 border-on-background object-cover" width="28" height="28" referrerpolicy="no-referrer" />
          <span class="font-label text-xs font-bold text-on-background">${name}</span>
        </a>
        ${isAdmin ? `<a href="/admin" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-error hover:bg-error-container active:bg-error-container transition-colors flex items-center gap-3"><span class="material-symbols-outlined text-base">admin_panel_settings</span>Admin</a>` : ''}
        <a href="/api/auth/logout" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors flex items-center gap-3">
          <span class="material-symbols-outlined text-base">logout</span>Sign out
        </a>
      `;
    }

    // Re-wire the desktop profile dropdown toggle for the freshly injected DOM
    const newProfileBtn = document.getElementById('profile-btn-desktop');
    const newProfileDropdown = document.getElementById('profile-dropdown-desktop');
    newProfileBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      newProfileDropdown?.classList.toggle('hidden');
      const open = !newProfileDropdown?.classList.contains('hidden');
      newProfileBtn?.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', (e) => {
      const sw = document.getElementById('profile-switcher-desktop');
      if (sw && !sw.contains(e.target as Node)) {
        newProfileDropdown?.classList.add('hidden');
        newProfileBtn?.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>

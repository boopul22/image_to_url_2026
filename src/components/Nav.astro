---
const { activePage = "home" } = Astro.props;
const user = Astro.locals.user;

const navLinks = [
  { name: "Home", href: "/", id: "home" },
  { name: "Features", href: "/features", id: "features" },
  { name: "Pricing", href: "/pricing", id: "pricing" },
  { name: "API", href: "/docs", id: "api" },
  { name: "Blog", href: "/blog", id: "blog" },
];
---

<nav class="sticky top-0 z-40 bg-background/80 backdrop-blur-md border-b-2 border-on-background transition-all duration-300">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
    <a href="/" class="text-2xl font-black font-headline text-on-background flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">cloud_done</span>
      ImageToURL
    </a>
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-label uppercase tracking-wider text-xs font-bold transition-all duration-200",
            activePage === link.id
              ? "text-primary border-b-2 border-primary pb-1"
              : "text-outline hover:text-on-background hover:-translate-y-0.5",
          ]}
        >
          {link.name}
        </a>
      ))}
    </div>

    {user ? (
      <div class="flex items-center gap-3">
        <img
          src={user.avatarUrl}
          alt={user.name}
          class="w-8 h-8 rounded-full border-2 border-on-background object-cover"
          referrerpolicy="no-referrer"
        />
        <span class="font-label text-xs font-bold text-on-background hidden sm:inline">{user.name}</span>
        <a
          href="/api/auth/logout"
          class="text-outline hover:text-on-background font-label text-xs font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-all duration-200"
        >
          Sign Out
        </a>
      </div>
    ) : (
      <a
        href="/api/auth/login"
        class="bg-primary text-on-primary px-6 py-2 rounded-lg border-2 border-on-background hard-shadow hard-shadow-hover active:scale-95 duration-100 font-label uppercase tracking-wider text-xs font-bold flex items-center gap-2"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        Sign In
      </a>
    )}
  </div>
</nav>

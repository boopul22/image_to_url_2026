---
import { t, stripLocalePrefix } from '../i18n/utils';
import { locales, localeLabels, defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const { activePage = "home" } = Astro.props;
const user = Astro.locals.user;
const locale: Locale = Astro.locals.locale ?? defaultLocale;
const basePath = stripLocalePrefix(Astro.url.pathname);

function localePath(path: string, loc: Locale = locale): string {
  if (loc === defaultLocale) return path;
  return `/${loc}${path}`;
}

const navLinks = [
  { name: t(locale, 'nav.home'), href: localePath('/'), id: "home" },
  { name: t(locale, 'nav.features'), href: localePath('/features'), id: "features" },
  { name: t(locale, 'nav.pricing'), href: localePath('/pricing'), id: "pricing" },
  { name: t(locale, 'nav.api'), href: localePath('/docs'), id: "api" },
  { name: t(locale, 'nav.blog'), href: localePath('/blog'), id: "blog" },
];
---

<nav class="sticky top-0 z-40 bg-background/80 backdrop-blur-md border-b-2 border-on-background transition-all duration-300">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
    <a href={localePath('/')} class="text-2xl font-black font-headline text-on-background flex items-center gap-2">
      <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">cloud_done</span>
      ImageToURL
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-label uppercase tracking-wider text-xs font-bold transition-all duration-200",
            activePage === link.id
              ? "text-primary border-b-2 border-primary pb-1"
              : "text-outline hover:text-on-background hover:-translate-y-0.5",
          ]}
        >
          {link.name}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <!-- Language Switcher -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          class="flex items-center gap-1 px-2 py-1 rounded-lg border border-outline-variant hover:bg-surface-container-highest transition-colors text-xs font-bold font-label uppercase tracking-wider"
          aria-label="Change language"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-sm">translate</span>
          <span>{localeLabels[locale]}</span>
          <span class="material-symbols-outlined text-sm">expand_more</span>
        </button>
        <div id="lang-dropdown" class="hidden absolute right-0 top-full mt-2 bg-surface border-2 border-on-background rounded-lg hard-shadow overflow-hidden z-50 min-w-[140px]">
          {locales.map((loc) => (
            <a
              href={loc === defaultLocale ? basePath : `/${loc}${basePath}`}
              class:list={[
                "block px-4 py-2 text-sm font-medium hover:bg-surface-container-highest transition-colors",
                loc === locale ? "text-primary font-bold bg-primary-fixed" : "text-on-surface",
              ]}
            >
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>

      {user ? (
        <>
          <a href="/dashboard" class="flex items-center gap-2 hover:-translate-y-0.5 transition-all duration-200">
            <img
              src={user.avatarUrl}
              alt={user.name}
              class="w-8 h-8 rounded-full border-2 border-on-background object-cover"
              width="32"
              height="32"
              referrerpolicy="no-referrer"
            />
            <span class="font-label text-xs font-bold text-on-background hidden sm:inline">{user.name}</span>
          </a>
          {user.role === 'admin' && (
            <a
              href="/admin"
              class="text-error font-label text-xs font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-all duration-200 hidden sm:inline"
            >
              {t(locale, 'nav.admin')}
            </a>
          )}
          <a
            href="/api/auth/logout"
            class="text-outline hover:text-on-background font-label text-xs font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-all duration-200 hidden sm:inline"
          >
            {t(locale, 'nav.signOut')}
          </a>
        </>
      ) : (
        <a
          href="/api/auth/login"
          class="bg-primary text-on-primary px-6 py-2 rounded-lg border-2 border-on-background hard-shadow hard-shadow-hover active:scale-95 duration-100 font-label uppercase tracking-wider text-xs font-bold flex items-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          {t(locale, 'nav.signIn')}
        </a>
      )}

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg border-2 border-on-background hover:bg-surface-container-highest transition-colors"
        aria-label={t(locale, 'nav.toggleMenu')}
        aria-expanded="false"
      >
        <span class="material-symbols-outlined text-xl" id="menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t-2 border-on-background bg-background/95 backdrop-blur-md">
    <div class="flex flex-col px-6 py-4 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-label uppercase tracking-wider text-xs font-bold py-3 px-4 rounded-lg transition-colors",
            activePage === link.id
              ? "text-primary bg-primary-fixed"
              : "text-outline hover:text-on-background hover:bg-surface-container-highest",
          ]}
        >
          {link.name}
        </a>
      ))}
      {user && (
        <>
          {user.role === 'admin' && (
            <a href="/admin" class="font-label uppercase tracking-wider text-xs font-bold py-3 px-4 rounded-lg text-error hover:bg-error-container transition-colors sm:hidden">
              {t(locale, 'nav.admin')}
            </a>
          )}
          <a href="/api/auth/logout" class="font-label uppercase tracking-wider text-xs font-bold py-3 px-4 rounded-lg text-outline hover:text-on-background hover:bg-surface-container-highest transition-colors sm:hidden">
            {t(locale, 'nav.signOut')}
          </a>
        </>
      )}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu!.classList.contains('hidden');
    mobileMenu!.classList.toggle('hidden');
    menuIcon!.textContent = isOpen ? 'menu' : 'close';
    menuBtn!.setAttribute('aria-expanded', String(!isOpen));
  });

  // Language switcher toggle
  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');

  langBtn?.addEventListener('click', () => {
    const isOpen = !langDropdown!.classList.contains('hidden');
    langDropdown!.classList.toggle('hidden');
    langBtn!.setAttribute('aria-expanded', String(!isOpen));
  });

  document.addEventListener('click', (e) => {
    const switcher = document.getElementById('lang-switcher');
    if (switcher && !switcher.contains(e.target as Node)) {
      langDropdown!.classList.add('hidden');
      langBtn!.setAttribute('aria-expanded', 'false');
    }
  });
</script>

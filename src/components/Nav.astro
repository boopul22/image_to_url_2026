---
import Icon from './Icon.astro';
import { t, stripLocalePrefix } from '../i18n/utils';
import { locales, localeLabels, defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { getNavGroups } from '../lib/nav-links';
import { resolveSlug, localizedUrl } from '../i18n/landing/registry';

const { activePage = "home", blogLocaleSlugs = null } = Astro.props as { activePage?: string; blogLocaleSlugs?: Record<string, string> | null };
const user = Astro.locals.user;
const locale: Locale = Astro.locals.locale ?? defaultLocale;
const basePath = stripLocalePrefix(Astro.url.pathname);

// Always show the language switcher — even on English-only root pages, users
// should be able to jump to a localized experience (their locale's homepage).
const hasLocalePrefix = Astro.url.pathname !== basePath;
const isLocalizable = true;

// If the current URL is a translated landing page, resolve its pageKey so we
// can generate per-locale translated slugs for the language switcher.
// e.g. on /hi/convert-png-to-url the user clicks "French" → /fr/convertir-png-en-url
const currentSlug = basePath.replace(/^\/+|\/+$/g, '');
const currentPageKey = currentSlug ? resolveSlug(locale, currentSlug) : null;

// Detect English-only root pages (/png-to-jpg, /image-compressor, /guides/*, etc.)
// — anything without a locale prefix that isn't in the landing registry.
const isEnglishOnlyRoot = !hasLocalePrefix && Astro.url.pathname !== '/' && !currentPageKey;

function langSwitchHref(loc: Locale): string {
  // Blog post? Use the per-locale translated slug directly (one hop, not two).
  if (blogLocaleSlugs && blogLocaleSlugs[loc]) return `/${loc}/blog/${blogLocaleSlugs[loc]}`;
  // Landing page in the slug registry? Use its translated slug. localizedUrl()
  // emits the trailing slash so the switcher href matches the page's canonical
  // and hreflang URLs — otherwise the crawler follows the no-slash form and
  // flags every localized page for "hreflang has no self/return link".
  if (currentPageKey) return localizedUrl(currentPageKey, loc);
  // English-only page with no translated variant → keep the user on the same
  // URL. Clicking is effectively a no-op instead of dumping them on a locale
  // homepage. When translations land, this falls through to currentPageKey.
  if (isEnglishOnlyRoot) return Astro.url.pathname;
  // Fallback: same path under the new locale prefix.
  return `/${loc}${basePath}`;
}

// For English-only pages, flag the switcher visually so users understand the
// page isn't translated yet (the href does nothing on click).
const currentLocaleOnlyHint = isEnglishOnlyRoot;

function localePath(path: string, loc: Locale = locale): string {
  return `/${loc}${path}`;
}

// Top-level links kept lean: the logo is the Home link, so Home is dropped here.
// Features + Blog stay; the former SEO "Solutions" mega-menu lives in the footer.
const navLinks = [
  { name: t(locale, 'nav.features'), href: localePath('/features'), id: "features", icon: "auto_awesome" },
  { name: t(locale, 'nav.blog'), href: localePath('/blog'), id: "blog", icon: "article" },
];

const toolsDropdown = getNavGroups(locale);
---

<nav class="sticky top-0 z-40 bg-[#fcfcfc]/95 backdrop-blur-sm border-b border-neutral-200 transition-all duration-300" style="padding-left: env(safe-area-inset-left); padding-right: env(safe-area-inset-right);">
  <div class="flex justify-between items-center w-full px-4 sm:px-6 h-14 max-w-6xl mx-auto lg:grid lg:grid-cols-[1fr_auto_1fr]">
    <a href={localePath('/')} class="text-[15px] font-semibold font-headline tracking-tighter uppercase text-on-background flex items-center gap-1.5 flex-shrink-0 lg:justify-self-start">
      <Icon name="cloud_done" class="text-rose-600 text-lg" fill />
      ImageToURL
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-5 xl:gap-6 lg:justify-self-center">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[13px] font-headline font-medium uppercase tracking-wide transition-colors duration-200",
            activePage === link.id
              ? "text-on-background"
              : "text-neutral-500 hover:text-on-background",
          ]}
        >
          {link.name}
        </a>
      ))}

      <!-- Tools Dropdown (our products) -->
      <div class="relative" id="our-tools-switcher-desktop">
        <button
          id="our-tools-btn-desktop"
          class="flex items-center gap-1 text-[13px] font-headline font-medium uppercase tracking-wide transition-colors duration-200 text-neutral-500 hover:text-on-background"
          aria-expanded="false"
        >
          Tools
          <Icon name="expand_more" class="text-sm" />
        </button>
        <div id="our-tools-dropdown-desktop" class="hidden fixed top-16 right-[calc((100vw-min(100vw,72rem))/2+1.5rem)] rounded-xl bg-surface border border-outline-variant/40 hard-shadow overflow-hidden z-50 w-[780px] max-w-[calc(100vw-2rem)] max-h-[80vh] overflow-y-auto">
          <div class="grid grid-cols-3 gap-0 divide-x divide-outline-variant/40">
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">{t(locale, 'nav.convert')}</span>
              {toolsDropdown.convert.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <Icon name={item.icon} class="text-primary text-base" />
                  {item.name}
                </a>
              ))}
            </div>
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">Format Converters</span>
              {toolsDropdown.formatConvert.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <Icon name={item.icon} class="text-primary text-base" />
                  {item.name}
                </a>
              ))}
            </div>
            <div class="p-4">
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mb-3">Utilities</span>
              {toolsDropdown.utilities.map((item) => (
                <a href={item.href} class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded">
                  <Icon name={item.icon} class="text-primary text-base" />
                  {item.name}
                </a>
              ))}
              {toolsDropdown.tools.length > 0 && (
                <Fragment>
                  <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline block mt-4 mb-3">Partner Tools</span>
                  {toolsDropdown.tools.map((item) => (
                    <a
                      href={item.href}
                      {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
                      class="flex items-center gap-2 px-2 py-1.5 text-sm font-medium hover:bg-surface-container-highest transition-colors rounded"
                    >
                      <Icon name={item.icon} class="text-primary text-base" />
                      {item.name}
                      {item.external && <Icon name="open_in_new" class="text-[10px] text-outline ml-auto" />}
                    </a>
                  ))}
                </Fragment>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop Right Actions -->
    <div class="hidden lg:flex items-center gap-2.5 lg:justify-self-end">
      <!-- Compact language switcher — a globe icon (signed-OUT only). Signed-in
           users get the language grid inside the profile menu below, so this is
           the anonymous visitor's switcher and keeps the top bar tidy. -->
      {isLocalizable && !user && (
      <div class="relative" id="lang-switcher-desktop">
        <button
          id="lang-btn-desktop"
          class="flex items-center justify-center w-9 h-9 text-neutral-500 hover:text-on-background hover:bg-neutral-100 transition-colors"
          aria-label="Change language"
          aria-expanded="false"
          title={localeLabels[locale]}
        >
          <Icon name="translate" class="text-lg" />
        </button>
        <div id="lang-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 rounded-xl bg-surface border border-outline-variant/40 hard-shadow z-50 w-[360px] max-w-[calc(100vw-2rem)] max-h-[min(70vh,480px)] overflow-y-auto grid grid-cols-2">
          {locales.map((loc) => (
            <a
              href={langSwitchHref(loc)}
              class:list={[
                "block px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors truncate",
                loc === locale ? "text-on-background font-bold bg-primary" : "text-on-surface",
              ]}
            >
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>
      )}

      <div id="auth-slot-desktop" data-signed-in={user ? 'true' : 'false'} class="flex items-center gap-2.5">
      {user ? (
        <Fragment>
        <!-- Credits chip — filled by the deferred /api/me hydration (same fetch
             that already runs for auth state), so the server render costs no
             extra D1 query. Hidden until the balance is known. -->
        <a
          href="/dashboard"
          id="nav-credits-chip"
          class="hidden items-center gap-1.5 border border-outline-variant/60 bg-surface-container-low px-2.5 py-1 text-[12px] font-semibold text-on-surface hover:border-rose-300 hover:bg-rose-50 transition-colors"
          title="Keep-forever saves left today — refills every 24h (temporary uploads are free & unlimited)"
        >
          <Icon name="toll" class="text-sm text-primary" fill />
          <span id="nav-credits-num">—</span><span class="text-on-surface-variant font-normal" id="nav-credits-cap"></span>
        </a>
        <div class="relative" id="profile-switcher-desktop">
          <button
            id="profile-btn-desktop"
            class="flex items-center gap-1.5 hover:opacity-80 transition-opacity"
            aria-label="Profile menu"
            aria-expanded="false"
          >
            <img
              src={user.avatarUrl}
              alt={user.name}
              class="w-7 h-7 rounded-full border border-neutral-300 object-cover"
              width="28"
              height="28"
              referrerpolicy="no-referrer"
            />
            <Icon name="expand_more" class="text-sm text-neutral-500" />
          </button>
          <div id="profile-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 rounded-xl bg-white border border-neutral-200 shadow-lg overflow-hidden z-50 w-[248px]">
            <!-- Identity header — name moved off the top bar into here. -->
            <div class="flex items-center gap-2.5 px-4 py-3 border-b border-neutral-200">
              <img src={user.avatarUrl} alt={user.name} class="w-8 h-8 rounded-full border border-neutral-300 object-cover" width="32" height="32" referrerpolicy="no-referrer" />
              <span class="text-[13px] font-semibold text-on-background truncate">{user.name}</span>
            </div>
            <!-- Credits detail — number, progress bar, refill time. Filled with
                 the chip; stays hidden if the balance fetch fails. -->
            <div id="nav-credits-panel" class="hidden px-4 py-3 border-b border-neutral-200">
              <div class="flex items-center justify-between text-[12px] font-medium text-on-surface">
                <span class="text-neutral-500">Keep-forever saves</span>
                <span><span id="nav-credits-panel-num" class="font-bold">—</span><span class="text-neutral-500" id="nav-credits-panel-cap"></span></span>
              </div>
              <div class="mt-2 h-1 bg-neutral-100 overflow-hidden">
                <div id="nav-credits-panel-bar" class="h-full bg-rose-600 transition-[width] duration-300" style="width:0%"></div>
              </div>
              <p id="nav-credits-panel-refill" class="text-[11px] text-neutral-500 mt-1.5"></p>
            </div>
            <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors">
              <Icon name="dashboard" class="text-base text-neutral-500" />
              Dashboard
            </a>
            {isLocalizable && (
              <div class="border-t border-neutral-200">
                <button id="profile-lang-btn" class="w-full flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors" aria-expanded="false" aria-controls="profile-lang-grid">
                  <Icon name="translate" class="text-base text-neutral-500" />
                  Language
                  <span class="ml-auto flex items-center gap-1 text-neutral-500 text-[12px]">{localeLabels[locale]}<Icon name="expand_more" class="text-sm transition-transform" id="profile-lang-chevron" /></span>
                </button>
                <div id="profile-lang-grid" class="hidden max-h-56 overflow-y-auto grid grid-cols-2 border-t border-neutral-100 bg-neutral-50/60">
                  {locales.map((loc) => (
                    <a
                      href={langSwitchHref(loc)}
                      class:list={[
                        "block px-3 py-2 text-[13px] font-medium hover:bg-white transition-colors truncate",
                        loc === locale ? "text-on-background font-bold bg-primary" : "text-on-surface",
                      ]}
                    >
                      {localeLabels[loc]}
                    </a>
                  ))}
                </div>
              </div>
            )}
            {user.role === 'admin' && (
              <a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-rose-600 hover:bg-neutral-50 transition-colors border-t border-neutral-200">
                <Icon name="admin_panel_settings" class="text-base" />
                {t(locale, 'nav.admin')}
              </a>
            )}
            <div class="border-t border-neutral-200"></div>
            <a href="/api/auth/logout" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-neutral-500 hover:text-on-background hover:bg-neutral-50 transition-colors">
              <Icon name="logout" class="text-base" />
              {t(locale, 'nav.signOut')}
            </a>
          </div>
        </div>
        </Fragment>
      ) : (
        <a
          href="/api/auth/login"
          class="bg-rose-600 hover:bg-rose-700 text-white px-4 py-1.5 font-headline text-[12px] font-semibold uppercase tracking-wide flex items-center gap-1.5 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          {t(locale, 'nav.signIn')}
        </a>
      )}
      </div>
    </div>

    <!-- Mobile Menu Button (only element on right side on mobile) -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden w-9 h-9 flex items-center justify-center text-on-background hover:bg-neutral-100 transition-colors"
      aria-label={t(locale, 'nav.toggleMenu')}
      aria-expanded="false"
    >
      <Icon name="menu" class="text-xl" id="menu-icon" />
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu-transition lg:hidden border-t border-neutral-200 bg-background">
    <div class="flex flex-col px-4 py-3 gap-1" style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 transition-colors flex items-center gap-3",
            activePage === link.id
              ? "text-on-background bg-primary border border-outline-variant/40 rounded-lg font-bold"
              : "text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest",
          ]}
        >
          <Icon name={link.icon} class="text-base" />
          {link.name}
        </a>
      ))}

      <div class="h-px bg-outline-variant my-2"></div>

      <!-- Tools Dropdown (mobile, real products) -->
      <div class="relative" id="our-tools-switcher-mobile">
        <button
          id="our-tools-btn-mobile"
          class="flex items-center gap-3 w-full py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors font-label uppercase tracking-wider text-xs font-bold text-outline"
          aria-label="Tools"
          aria-expanded="false"
        >
          <Icon name="build" class="text-base" />
          Tools
          <Icon name="expand_more" class="text-sm ml-auto" id="our-tools-chevron-mobile" />
        </button>
        <div id="our-tools-dropdown-mobile" class="hidden mx-4 mb-1 rounded-xl bg-surface-container border border-outline-variant/40 overflow-hidden max-h-[70vh] overflow-y-auto">
          {([
            ['nav.convert', toolsDropdown.convert],
            ['Format Converters', toolsDropdown.formatConvert],
            ['Utilities', toolsDropdown.utilities],
            ['Partner Tools', toolsDropdown.tools],
          ] as const).filter(([, items]) => items.length > 0).map(([label, items]) => (
            <>
              <div class="px-3 pt-3 pb-1">
                <span class="font-label uppercase tracking-widest text-[10px] font-bold text-outline">
                  {label.startsWith('nav.') ? t(locale, label) : label}
                </span>
              </div>
              {items.map((item) => (
                <a
                  href={item.href}
                  {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
                  class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors"
                >
                  <Icon name={item.icon} class="text-primary text-base" />
                  {item.name}
                  {item.external && <Icon name="open_in_new" class="text-[10px] text-outline ml-auto" />}
                </a>
              ))}
            </>
          ))}
        </div>
      </div>

      <div class="h-px bg-outline-variant my-2"></div>

      <!-- Language Switcher (inside mobile menu) — hidden on English-only pages -->
      {isLocalizable && (
      <div class="relative" id="lang-switcher-mobile">
        <button
          id="lang-btn-mobile"
          class="flex items-center gap-3 w-full py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors font-label uppercase tracking-wider text-xs font-bold text-outline"
          aria-label="Change language"
          aria-expanded="false"
        >
          <Icon name="translate" class="text-base" />
          {localeLabels[locale]}
          <Icon name="expand_more" class="text-sm ml-auto" />
        </button>
        <div id="lang-dropdown-mobile" class="hidden mx-4 mb-1 rounded-xl bg-surface-container border border-outline-variant/40 max-h-[50vh] overflow-y-auto grid grid-cols-2">
          {locales.map((loc) => (
            <a
              href={langSwitchHref(loc)}
              class:list={[
                "block px-3 py-2.5 text-sm font-medium hover:bg-surface-container-highest transition-colors truncate",
                loc === locale ? "text-on-background font-bold bg-primary" : "text-on-surface",
              ]}
            >
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>
      )}

      <div id="auth-slot-mobile" data-signed-in={user ? 'true' : 'false'}>
      {user ? (
        <>
          <div class="h-px bg-outline-variant my-1"></div>
          <a href="/dashboard" class="flex items-center gap-3 py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
            <img
              src={user.avatarUrl}
              alt={user.name}
              class="w-7 h-7 rounded-full border border-outline-variant/40 object-cover"
              width="28"
              height="28"
              referrerpolicy="no-referrer"
            />
            <span class="font-label text-xs font-bold text-on-background">{user.name}</span>
          </a>
          <!-- Credits row — filled by the deferred /api/me hydration; hidden until known. -->
          <a href="/dashboard" id="nav-credits-mobile" class="hidden mx-4 mb-2 px-3 py-2.5 border border-outline-variant/40 bg-surface-container-low hover:bg-surface-container transition-colors">
            <span class="flex items-center justify-between text-xs font-medium text-on-surface">
              <span class="flex items-center gap-1.5 text-on-surface-variant"><Icon name="toll" class="text-sm text-primary" fill /> Keep-forever saves</span>
              <span><span id="nav-credits-mobile-num" class="font-bold">—</span><span class="text-on-surface-variant" id="nav-credits-mobile-cap"></span></span>
            </span>
            <span class="block mt-2 h-1 bg-surface-container-highest overflow-hidden">
              <span id="nav-credits-mobile-bar" class="block h-full bg-rose-600 transition-[width] duration-300" style="width:0%"></span>
            </span>
            <span id="nav-credits-mobile-refill" class="block text-[11px] text-on-surface-variant mt-1.5"></span>
          </a>
          {user.role === 'admin' && (
            <a href="/admin" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-error hover:bg-error-container active:bg-error-container transition-colors flex items-center gap-3">
              <Icon name="admin_panel_settings" class="text-base" />
              {t(locale, 'nav.admin')}
            </a>
          )}
          <a href="/api/auth/logout" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors flex items-center gap-3">
            <Icon name="logout" class="text-base" />
            {t(locale, 'nav.signOut')}
          </a>
        </>
      ) : (
        <a
          href="/api/auth/login"
          class="flex items-center justify-center gap-2 mx-2 mt-1 rounded-lg bg-primary text-on-primary py-3.5 border border-outline-variant/40 hard-shadow font-label uppercase tracking-wider text-xs font-bold active:scale-[0.98] transition-transform"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
          </svg>
          {t(locale, 'nav.signIn')}
        </a>
      )}
      </div>
    </div>
  </div>
</nav>

<script>
  import { ic_menu, ic_close, ic_expand_more, ic_dashboard, ic_admin_panel_settings, ic_logout, ic_toll, ic_translate } from '../data/icon-svgs';
  const icon = (inner: string, cls = '', id = '') => `<svg class="ms-icon ${cls}"${id ? ` id="${id}"` : ''} viewBox="0 -960 960 960">${inner}</svg>`;
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  function closeMobileMenu() {
    mobileMenu?.classList.remove('open');
    if (menuIcon) menuIcon.innerHTML = ic_menu;
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu!.classList.contains('open');
    if (isOpen) {
      closeMobileMenu();
    } else {
      mobileMenu!.classList.add('open');
      menuIcon!.innerHTML = ic_close;
      menuBtn!.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu when a nav link is tapped
  mobileMenu?.querySelectorAll('a[href]:not([id*="lang"])').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Desktop language switcher
  const langBtnDesktop = document.getElementById('lang-btn-desktop');
  const langDropdownDesktop = document.getElementById('lang-dropdown-desktop');

  langBtnDesktop?.addEventListener('click', () => {
    const isOpen = !langDropdownDesktop!.classList.contains('hidden');
    langDropdownDesktop!.classList.toggle('hidden');
    langBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    // Close the tools dropdown when opening lang
    ourToolsDropdownDesktop?.classList.add('hidden');
    ourToolsBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Desktop tools dropdown (real products)
  const ourToolsBtnDesktop = document.getElementById('our-tools-btn-desktop');
  const ourToolsDropdownDesktop = document.getElementById('our-tools-dropdown-desktop');

  ourToolsBtnDesktop?.addEventListener('click', () => {
    const isOpen = !ourToolsDropdownDesktop!.classList.contains('hidden');
    ourToolsDropdownDesktop!.classList.toggle('hidden');
    ourToolsBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    langDropdownDesktop?.classList.add('hidden');
    langBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // Desktop profile dropdown
  const profileBtnDesktop = document.getElementById('profile-btn-desktop');
  const profileDropdownDesktop = document.getElementById('profile-dropdown-desktop');

  profileBtnDesktop?.addEventListener('click', () => {
    const isOpen = !profileDropdownDesktop!.classList.contains('hidden');
    profileDropdownDesktop!.classList.toggle('hidden');
    profileBtnDesktop!.setAttribute('aria-expanded', String(!isOpen));
    langDropdownDesktop?.classList.add('hidden');
    langBtnDesktop?.setAttribute('aria-expanded', 'false');
    ourToolsDropdownDesktop?.classList.add('hidden');
    ourToolsBtnDesktop?.setAttribute('aria-expanded', 'false');
  });

  // The "Language" row inside the profile menu expands an inline locale grid.
  // Idempotent + re-callable so it works for both the SSR-signed-in DOM and the
  // JS-hydrated profile menu (data-wired guards against double-binding).
  function wireProfileLang() {
    const btn = document.getElementById('profile-lang-btn');
    const grid = document.getElementById('profile-lang-grid');
    const chev = document.getElementById('profile-lang-chevron');
    if (!btn || !grid || (btn as HTMLElement).dataset.wired) return;
    (btn as HTMLElement).dataset.wired = '1';
    btn.addEventListener('click', (e) => {
      e.stopPropagation(); // don't let the outside-click handler close the menu
      const nowHidden = grid.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!nowHidden));
      if (chev) chev.style.transform = nowHidden ? '' : 'rotate(180deg)';
    });
  }
  wireProfileLang();

  // Close all desktop dropdowns on outside click
  document.addEventListener('click', (e) => {
    const langSwitcher = document.getElementById('lang-switcher-desktop');
    const profileSwitcher = document.getElementById('profile-switcher-desktop');
    if (langSwitcher && !langSwitcher.contains(e.target as Node)) {
      langDropdownDesktop?.classList.add('hidden');
      langBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
    const ourToolsSwitcher = document.getElementById('our-tools-switcher-desktop');
    if (ourToolsSwitcher && !ourToolsSwitcher.contains(e.target as Node)) {
      ourToolsDropdownDesktop?.classList.add('hidden');
      ourToolsBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
    if (profileSwitcher && !profileSwitcher.contains(e.target as Node)) {
      profileDropdownDesktop?.classList.add('hidden');
      profileBtnDesktop?.setAttribute('aria-expanded', 'false');
    }
  });

  // Mobile language switcher (inline expand)
  const langBtnMobile = document.getElementById('lang-btn-mobile');
  const langDropdownMobile = document.getElementById('lang-dropdown-mobile');

  langBtnMobile?.addEventListener('click', () => {
    const isOpen = !langDropdownMobile!.classList.contains('hidden');
    langDropdownMobile!.classList.toggle('hidden');
    langBtnMobile!.setAttribute('aria-expanded', String(!isOpen));
  });

  // Mobile tools dropdown (inline expand)
  const ourToolsBtnMobile = document.getElementById('our-tools-btn-mobile');
  const ourToolsDropdownMobile = document.getElementById('our-tools-dropdown-mobile');
  const ourToolsChevronMobile = document.getElementById('our-tools-chevron-mobile');

  ourToolsBtnMobile?.addEventListener('click', () => {
    const isOpen = !ourToolsDropdownMobile!.classList.contains('hidden');
    ourToolsDropdownMobile!.classList.toggle('hidden');
    ourToolsBtnMobile!.setAttribute('aria-expanded', String(!isOpen));
    if (ourToolsChevronMobile) {
      ourToolsChevronMobile.style.transform = isOpen ? '' : 'rotate(180deg)';
    }
  });

  // Auth nav hydration — fixes signed-out flash on prerendered/CDN-cached pages.
  // Server may render the signed-out state (no cookies at build time, or anonymous
  // CDN cache hit). If a real session exists, swap the auth slots to the profile UI.
  //
  // Deferred off the critical path: the /api/me fetch is not render-blocking, so
  // we wait for idle to avoid competing with LCP resources.
  // Fill the nav credits chip + dropdown panel + mobile row from the /api/me
  // `upload` payload. Signed-in users get a daily allowance of permanent uploads
  // (temporary uploads are free & unlimited); everything stays hidden when the
  // balance is unknown (fetch failed / guest scope).
  const fillCredits = (upload: any) => {
    if (!upload || upload.unit !== 'credits' || typeof upload.remaining !== 'number' || typeof upload.limit !== 'number') return;
    const low = upload.remaining <= upload.limit * 0.2;
    const pct = Math.max(0, Math.min(100, (upload.remaining / upload.limit) * 100));
    const refill = upload.resetIn ? `Refills in ~${upload.resetIn}` : 'Refills every 24h';

    const chip = document.getElementById('nav-credits-chip');
    const num = document.getElementById('nav-credits-num');
    const cap = document.getElementById('nav-credits-cap');
    if (chip && num && cap) {
      num.textContent = String(upload.remaining);
      cap.textContent = `/${upload.limit}`;
      num.classList.toggle('text-warning', low);
      chip.classList.remove('hidden');
      chip.classList.add('flex');
    }

    const setPanel = (prefix: string) => {
      const panel = document.getElementById(prefix);
      const pnum = document.getElementById(`${prefix}-num`);
      const pcap = document.getElementById(`${prefix}-cap`);
      const bar = document.getElementById(`${prefix}-bar`);
      const prefill = document.getElementById(`${prefix}-refill`);
      if (!panel || !pnum || !pcap || !bar || !prefill) return;
      pnum.textContent = String(upload.remaining);
      pcap.textContent = `/${upload.limit}`;
      pnum.classList.toggle('text-warning', low);
      bar.style.width = `${pct}%`;
      bar.classList.toggle('bg-warning', low);
      bar.classList.toggle('bg-rose-600', !low);
      prefill.textContent = refill;
      panel.classList.remove('hidden');
      panel.classList.add('block');
    };
    setPanel('nav-credits-panel');
    setPanel('nav-credits-mobile');
  };

  const hydrateAuth = async () => {
    const desktop = document.getElementById('auth-slot-desktop');
    const mobile = document.getElementById('auth-slot-mobile');
    if (!desktop) return;

    // Skip /api/me entirely when the has_session hint cookie is missing.
    // The real session cookie is HttpOnly; this non-sensitive hint lets us
    // avoid the fetch for anonymous visitors (most landing-page traffic).
    if (!/(?:^|;\s*)has_session=1(?:;|$)/.test(document.cookie)) return;

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));

    let user: { name: string; avatarUrl: string; role: 'user' | 'admin' } | null = null;
    let upload: any = null;
    try {
      const res = await fetch('/api/me', {
        credentials: 'same-origin',
        priority: 'low',
      } as RequestInit);
      if (!res.ok) return;
      const me = await res.json();
      user = me.user;
      upload = me.upload;
    } catch {
      return;
    }
    if (!user) return;

    // Server already rendered the signed-in UI (SSR page) — the hidden credits
    // elements are in the DOM; just fill them and stop.
    if (desktop.dataset.signedIn === 'true') {
      fillCredits(upload);
      return;
    }

    const name = escapeHtml(user.name);
    const avatar = escapeHtml(user.avatarUrl);
    const isAdmin = user.role === 'admin';

    // Language grid for the profile menu: clone the anon locale panel that the
    // signed-out SSR already rendered (correct per-locale hrefs, current locale
    // flagged). currentLangLabel is read off the flagged option.
    const anonLangGrid = document.getElementById('lang-dropdown-desktop');
    const langGridHtml = anonLangGrid ? anonLangGrid.innerHTML : '';
    const currentLangLabel = anonLangGrid?.querySelector('a.font-bold')?.textContent?.trim() || '';
    const langSection = langGridHtml
      ? `<div class="border-t border-neutral-200">
          <button id="profile-lang-btn" class="w-full flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors" aria-expanded="false" aria-controls="profile-lang-grid">
            ${icon(ic_translate, 'text-base text-neutral-500')}Language
            <span class="ml-auto flex items-center gap-1 text-neutral-500 text-[12px]">${escapeHtml(currentLangLabel)}${icon(ic_expand_more, 'text-sm transition-transform', 'profile-lang-chevron')}</span>
          </button>
          <div id="profile-lang-grid" class="hidden max-h-56 overflow-y-auto grid grid-cols-2 border-t border-neutral-100 bg-neutral-50/60">${langGridHtml}</div>
        </div>`
      : '';

    desktop.innerHTML = `
      <a href="/dashboard" id="nav-credits-chip" class="hidden items-center gap-1.5 border border-outline-variant/60 bg-surface-container-low px-2.5 py-1 text-[12px] font-semibold text-on-surface hover:border-rose-300 hover:bg-rose-50 transition-colors" title="Keep-forever saves left today — refills every 24h (temporary uploads are free & unlimited)">
        ${icon(ic_toll, 'text-sm text-primary')}
        <span id="nav-credits-num">—</span><span class="text-on-surface-variant font-normal" id="nav-credits-cap"></span>
      </a>
      <div class="relative" id="profile-switcher-desktop">
        <button id="profile-btn-desktop" class="flex items-center gap-1.5 hover:opacity-80 transition-opacity" aria-label="Profile menu" aria-expanded="false">
          <img src="${avatar}" alt="${name}" class="w-7 h-7 rounded-full border border-neutral-300 object-cover" width="28" height="28" referrerpolicy="no-referrer" />
          ${icon(ic_expand_more, 'text-sm text-neutral-500')}
        </button>
        <div id="profile-dropdown-desktop" class="hidden absolute right-0 top-full mt-2 rounded-xl bg-white border border-neutral-200 shadow-lg overflow-hidden z-50 w-[248px]">
          <div class="flex items-center gap-2.5 px-4 py-3 border-b border-neutral-200">
            <img src="${avatar}" alt="${name}" class="w-8 h-8 rounded-full border border-neutral-300 object-cover" width="32" height="32" referrerpolicy="no-referrer" />
            <span class="text-[13px] font-semibold text-on-background truncate">${name}</span>
          </div>
          <div id="nav-credits-panel" class="hidden px-4 py-3 border-b border-neutral-200">
            <div class="flex items-center justify-between text-[12px] font-medium text-on-surface">
              <span class="text-neutral-500">Keep-forever saves</span>
              <span><span id="nav-credits-panel-num" class="font-bold">—</span><span class="text-neutral-500" id="nav-credits-panel-cap"></span></span>
            </div>
            <div class="mt-2 h-1 bg-neutral-100 overflow-hidden">
              <div id="nav-credits-panel-bar" class="h-full bg-rose-600 transition-[width] duration-300" style="width:0%"></div>
            </div>
            <p id="nav-credits-panel-refill" class="text-[11px] text-neutral-500 mt-1.5"></p>
          </div>
          <a href="/dashboard" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-on-background hover:bg-neutral-50 transition-colors">
            ${icon(ic_dashboard, 'text-base text-neutral-500')}Dashboard
          </a>
          ${langSection}
          ${isAdmin ? `<a href="/admin" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-rose-600 hover:bg-neutral-50 transition-colors border-t border-neutral-200">${icon(ic_admin_panel_settings, 'text-base')}Admin</a>` : ''}
          <div class="border-t border-neutral-200"></div>
          <a href="/api/auth/logout" class="flex items-center gap-2 px-4 py-2.5 text-[13px] font-medium text-neutral-500 hover:text-on-background hover:bg-neutral-50 transition-colors">
            ${icon(ic_logout, 'text-base')}Sign out
          </a>
        </div>
      </div>
    `;

    // Language now lives in the profile menu — retire the standalone globe.
    document.getElementById('lang-switcher-desktop')?.remove();

    if (mobile) {
      mobile.innerHTML = `
        <div class="h-px bg-outline-variant my-1"></div>
        <a href="/dashboard" class="flex items-center gap-3 py-3.5 px-4 hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
          <img src="${avatar}" alt="${name}" class="w-7 h-7 rounded-full border border-outline-variant/40 object-cover" width="28" height="28" referrerpolicy="no-referrer" />
          <span class="font-label text-xs font-bold text-on-background">${name}</span>
        </a>
        <a href="/dashboard" id="nav-credits-mobile" class="hidden mx-4 mb-2 px-3 py-2.5 border border-outline-variant/40 bg-surface-container-low hover:bg-surface-container transition-colors">
          <span class="flex items-center justify-between text-xs font-medium text-on-surface">
            <span class="flex items-center gap-1.5 text-on-surface-variant">${icon(ic_toll, 'text-sm text-primary')} Keep-forever saves</span>
            <span><span id="nav-credits-mobile-num" class="font-bold">—</span><span class="text-on-surface-variant" id="nav-credits-mobile-cap"></span></span>
          </span>
          <span class="block mt-2 h-1 bg-surface-container-highest overflow-hidden">
            <span id="nav-credits-mobile-bar" class="block h-full bg-rose-600 transition-[width] duration-300" style="width:0%"></span>
          </span>
          <span id="nav-credits-mobile-refill" class="block text-[11px] text-on-surface-variant mt-1.5"></span>
        </a>
        ${isAdmin ? `<a href="/admin" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-error hover:bg-error-container active:bg-error-container transition-colors flex items-center gap-3">${icon(ic_admin_panel_settings, 'text-base')}Admin</a>` : ''}
        <a href="/api/auth/logout" class="font-label uppercase tracking-wider text-xs font-bold py-3.5 px-4 text-outline hover:text-on-background hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors flex items-center gap-3">
          ${icon(ic_logout, 'text-base')}Sign out
        </a>
      `;
    }

    // Fill the freshly injected credits elements from the same /api/me payload.
    fillCredits(upload);
    // Wire the profile menu's inline Language expander (freshly injected DOM).
    wireProfileLang();

    // Re-wire the desktop profile dropdown toggle for the freshly injected DOM
    const newProfileBtn = document.getElementById('profile-btn-desktop');
    const newProfileDropdown = document.getElementById('profile-dropdown-desktop');
    newProfileBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      newProfileDropdown?.classList.toggle('hidden');
      const open = !newProfileDropdown?.classList.contains('hidden');
      newProfileBtn?.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', (e) => {
      const sw = document.getElementById('profile-switcher-desktop');
      if (sw && !sw.contains(e.target as Node)) {
        newProfileDropdown?.classList.add('hidden');
        newProfileBtn?.setAttribute('aria-expanded', 'false');
      }
    });
  };

  type IdleCallback = (cb: () => void, opts?: { timeout?: number }) => number;
  const idle: IdleCallback =
    (window as unknown as { requestIdleCallback?: IdleCallback }).requestIdleCallback
    ?? ((cb: () => void) => setTimeout(cb, 1500) as unknown as number);
  idle(() => { void hydrateAuth(); }, { timeout: 2000 });
</script>

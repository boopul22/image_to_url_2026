---
import Icon from '../../components/Icon.astro';
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ImageUploader from '../../components/ImageUploader.astro';
import HeicConverter from '../../components/HeicConverter.astro';
import HeicPngConverter from '../../components/HeicPngConverter.astro';
import CanvasConverter from '../../components/CanvasConverter.astro';
import PdfConverter from '../../components/PdfConverter.astro';
import ImageCompressor from '../../components/ImageCompressor.astro';
import ImageResizer from '../../components/ImageResizer.astro';
import Base64Encoder from '../../components/Base64Encoder.astro';
import Base64Decoder from '../../components/Base64Decoder.astro';
import FaviconGenerator from '../../components/FaviconGenerator.astro';
import ToolAdFrame from '../../components/ads/ToolAdFrame.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { locales, defaultLocale, type Locale } from '../../i18n/config';
import { PAGE_KEYS, SLUGS, getSlug, localizedUrl, hreflangPairs, isPageKey, type PageKey } from '../../i18n/landing/registry';
import type { LandingContentMap, LandingContent } from '../../i18n/landing/types';
import { relatedFor } from '../../lib/related-links';

// Widget map: which custom converter/utility component to render per pageKey.
// Pages not in this map fall back to the generic <ImageUploader>.
type WidgetSpec =
  | { kind: 'none' }
  | { kind: 'uploader' }
  | { kind: 'heic-to-jpg' }
  | { kind: 'heic-to-png' }
  | { kind: 'pdf'; from: 'png' | 'jpg' | 'heic' }
  | { kind: 'canvas'; from: 'png' | 'jpg' | 'webp' | 'gif' | 'bmp' | 'avif' | 'jfif' | 'tiff' | 'image'; to: 'png' | 'jpg' | 'webp'; idPrefix: string; outExt?: string }
  | { kind: 'compressor' }
  | { kind: 'resizer' }
  | { kind: 'base64-encoder' }
  | { kind: 'base64-decoder' }
  | { kind: 'favicon' };

const WIDGETS: Partial<Record<PageKey, WidgetSpec>> = {
  // Cluster A — format-pair converters
  'heic-to-jpg':  { kind: 'heic-to-jpg' },
  'heic-to-png':  { kind: 'heic-to-png' },
  'heic-to-pdf':  { kind: 'pdf', from: 'heic' },
  'png-to-jpg':   { kind: 'canvas', from: 'png',  to: 'jpg',  idPrefix: 'png2jpg' },
  'jpg-to-png':   { kind: 'canvas', from: 'jpg',  to: 'png',  idPrefix: 'jpg2png' },
  'webp-to-jpg':  { kind: 'canvas', from: 'webp', to: 'jpg',  idPrefix: 'webp2jpg' },
  'webp-to-png':  { kind: 'canvas', from: 'webp', to: 'png',  idPrefix: 'webp2png' },
  'png-to-webp':  { kind: 'canvas', from: 'png',  to: 'webp', idPrefix: 'png2webp' },
  'jpg-to-webp':  { kind: 'canvas', from: 'jpg',  to: 'webp', idPrefix: 'jpg2webp' },
  'png-to-pdf':   { kind: 'pdf', from: 'png' },
  'jpg-to-pdf':   { kind: 'pdf', from: 'jpg' },
  // Cluster G — new "to JPG" converters (any/jpeg/jfif/avif/tiff → jpg)
  'convert-to-jpg': { kind: 'canvas', from: 'image', to: 'jpg', idPrefix: 'any2jpg' },
  'jpeg-to-jpg':    { kind: 'canvas', from: 'jpg',   to: 'jpg', idPrefix: 'jpeg2jpg' },
  'jfif-to-jpg':    { kind: 'canvas', from: 'jfif',  to: 'jpg', idPrefix: 'jfif2jpg' },
  'jpg-to-jpeg':    { kind: 'canvas', from: 'jpg',   to: 'jpg', idPrefix: 'jpg2jpeg', outExt: 'jpeg' },
  'avif-to-jpg':    { kind: 'canvas', from: 'avif',  to: 'jpg', idPrefix: 'avif2jpg' },
  'tiff-to-jpg':    { kind: 'canvas', from: 'tiff',  to: 'jpg', idPrefix: 'tiff2jpg' },
  // Cluster B — utilities
  'image-compressor': { kind: 'compressor' },
  'image-resizer':    { kind: 'resizer' },
  'image-to-base64':  { kind: 'base64-encoder' },
  'base64-to-image':  { kind: 'base64-decoder' },
  'favicon-generator': { kind: 'favicon' },
  // Informational / policy pages — no upload widget on these.
  'about':               { kind: 'none' },
  'contact':             { kind: 'none' },
  'content-guidelines':  { kind: 'none' },
};

// Eager-load all landing content modules at build time. Each module exports
// `content: Record<Locale, LandingContent>`.
const modules = import.meta.glob<{ content: LandingContentMap }>(
  '../../i18n/landing/*.ts',
  { eager: true },
);

function contentFor(pageKey: PageKey): LandingContentMap | null {
  const path = `../../i18n/landing/${pageKey}.ts`;
  return modules[path]?.content ?? null;
}

export function getStaticPaths() {
  const paths: { params: { locale: Locale; slug: string } }[] = [];
  for (const pageKey of PAGE_KEYS) {
    for (const locale of locales) {
      const slug = SLUGS[pageKey][locale] ?? SLUGS[pageKey][defaultLocale];
      if (!slug) continue;
      paths.push({ params: { locale, slug } });
    }
  }
  return paths;
}

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const slug = String(Astro.params.slug ?? '');

// Reverse-resolve slug to pageKey for this locale
let pageKey: PageKey | null = null;
for (const key of PAGE_KEYS) {
  if (getSlug(key, locale) === slug) { pageKey = key; break; }
}
if (!pageKey) return Astro.redirect('/' + locale + '/');

const map = contentFor(pageKey);
if (!map) return Astro.redirect('/' + locale + '/');
const c: LandingContent = map[locale] ?? map[defaultLocale];

const pageUrl = `https://imagetourl.cloud/${locale}/${slug}`;
const alternates = hreflangPairs(pageKey);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: c.schemaName,
  url: pageUrl,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: c.schemaDescription,
  inLanguage: locale,
  provider: { '@id': 'https://imagetourl.cloud/#organization' },
  // Freshness signals — only emitted for pages that declare them in content.
  ...(c.datePublished ? { datePublished: c.datePublished } : {}),
  ...(c.dateModified ? { dateModified: c.dateModified } : {}),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: locale,
  mainEntity: c.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Note: BreadcrumbList JSON-LD is emitted by Layout.astro (autoBreadcrumbs),
// so we don't add one here to avoid a duplicate.

// HowTo rich result — opt-in per page via content.howToSchema.
const howToSchema = c.howToSchema
  ? {
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      name: c.howTitle,
      inLanguage: locale,
      step: c.steps.map((s, i) => ({
        '@type': 'HowToStep',
        position: i + 1,
        name: s.title,
        text: s.body,
      })),
    }
  : null;

const schemas = [schema, faqSchema, ...(howToSchema ? [howToSchema] : [])];

// Resolve related internal links. Hand-authored content links win; otherwise
// every registered landing page gets a localized internal-linking fallback.
const relatedSource = c.related?.length
  ? c.related
  : relatedFor(pageKey).map(r => ({
      pageKey: r.pageKey,
      label: contentFor(r.pageKey)?.[locale]?.schemaName ?? r.title,
    }));
const relatedLinks = relatedSource
  .filter(r => isPageKey(r.pageKey))
  .map(r => ({ href: localizedUrl(r.pageKey as PageKey, locale), label: r.label }));

const homeHref = `/${locale}/`;
const widget: WidgetSpec = WIDGETS[pageKey] ?? { kind: 'uploader' };
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  ogTitleEn={`${map[defaultLocale].h1Pre} ${map[defaultLocale].h1Highlight}`}
  schema={schemas}
  hreflangAlternates={alternates}
>
  <Nav />

  <main>
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
      {widget.kind === 'uploader' && <ToolAdFrame><ImageUploader /></ToolAdFrame>}
      {widget.kind === 'heic-to-jpg' && <ToolAdFrame><HeicConverter /></ToolAdFrame>}
      {widget.kind === 'heic-to-png' && <ToolAdFrame><HeicPngConverter /></ToolAdFrame>}
      {widget.kind === 'pdf' && <ToolAdFrame><PdfConverter from={widget.from} idPrefix={`pdf-${widget.from}-${locale}`} /></ToolAdFrame>}
      {widget.kind === 'canvas' && <ToolAdFrame><CanvasConverter from={widget.from} to={widget.to} idPrefix={`${widget.idPrefix}-${locale}`} outExtOverride={widget.outExt} /></ToolAdFrame>}
      {widget.kind === 'compressor' && <ToolAdFrame><ImageCompressor /></ToolAdFrame>}
      {widget.kind === 'resizer' && <ToolAdFrame><ImageResizer /></ToolAdFrame>}
      {widget.kind === 'base64-encoder' && <ToolAdFrame><Base64Encoder /></ToolAdFrame>}
      {widget.kind === 'base64-decoder' && <ToolAdFrame><Base64Decoder /></ToolAdFrame>}
      {widget.kind === 'favicon' && <ToolAdFrame><FaviconGenerator /></ToolAdFrame>}

      <header class="mb-5 sm:mb-8 reveal">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-outline-variant/40">{c.badge}</span>
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
          {c.h1Pre} <span class="italic text-primary">{c.h1Highlight}</span>
        </h1>
        <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
          {c.intro}
        </p>
      </header>

      {c.specs && c.specs.length > 0 && (
        <section class="mb-6 sm:mb-10 reveal" aria-label={c.specsTitle ?? 'At a glance'}>
          {c.specsTitle && <h2 class="sr-only">{c.specsTitle}</h2>}
          <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-px bg-outline-variant/40 border border-outline-variant/40 rounded-xl overflow-hidden">
            {c.specs.map(s => (
              <div class="bg-surface-container-low p-3 sm:p-4">
                <dt class="font-label text-[0.65rem] sm:text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-1">{s.label}</dt>
                <dd class="font-headline font-black text-sm sm:text-base text-on-background">{s.value}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <AdSlot placement="leaderTop" class="mb-6 sm:mb-10" />
    </div>

    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.howTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          {c.steps.map((step, i) => (
            <div class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed'][i % 3]} border border-outline-variant/40 p-4 sm:p-5 rounded-xl hard-shadow reveal`}>
              <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border border-outline-variant/40 rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">{i + 1}</div>
              <h3 class="text-base sm:text-lg font-black font-headline mb-2">{step.title}</h3>
              <p class="font-body text-on-surface-variant">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <AdSlot placement="contentMidA" class="max-w-5xl mx-auto px-3 sm:px-6 mt-8 sm:mt-12" />

    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.whyTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          {c.whyItems.map((item, i) => (
            <div class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed', 'bg-surface-variant'][i % 4]} border border-outline-variant/40 p-4 sm:p-5 rounded-xl hard-shadow reveal`}>
              <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border border-outline-variant/40 rounded-lg flex items-center justify-center mb-3 sm:mb-4">
                <Icon name="bolt" class="text-primary text-lg sm:text-xl" />
              </div>
              <h3 class="text-base sm:text-lg font-black font-headline mb-2">{item.title}</h3>
              <p class="font-body text-on-surface-variant">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {c.comparisonColumns && c.comparisonColumns.length > 0 && c.comparisonRows && c.comparisonRows.length > 0 && (
      <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
        <div class="max-w-5xl mx-auto px-3 sm:px-6">
          <div class="flex items-baseline gap-4 mb-3 sm:mb-4 reveal">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.comparisonTitle ?? 'How it compares'}</h2>
            <div class="h-1 flex-grow bg-on-background opacity-10"></div>
          </div>
          {c.comparisonIntro && (
            <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed mb-5 sm:mb-8 reveal">{c.comparisonIntro}</p>
          )}
          <div class="overflow-x-auto reveal border border-outline-variant/40 rounded-xl">
            <table class="w-full text-left border-collapse text-sm">
              <thead>
                <tr class="bg-on-surface text-surface">
                  {c.comparisonColumns.map((col, i) => (
                    <th scope="col" class={`p-3 font-headline font-black whitespace-nowrap ${i === 0 ? '' : 'text-center'}`}>{col}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {c.comparisonRows.map((row, ri) => (
                  <tr class={ri % 2 === 0 ? 'bg-surface' : 'bg-surface-container-low'}>
                    {row.cells.map((cell, ci) => (
                      ci === 0
                        ? <th scope="row" class="p-3 font-headline font-bold text-on-background border-t border-outline-variant/40 whitespace-nowrap">{cell}</th>
                        : <td class="p-3 text-center text-on-surface-variant border-t border-outline-variant/40">{cell}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    {c.sections && c.sections.length > 0 && (
      <section class="py-8 sm:py-12">
        <div class="max-w-3xl mx-auto px-3 sm:px-6 space-y-6 sm:space-y-8">
          {c.sections.map(sec => (
            <div class="reveal">
              <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-3">{sec.heading}</h2>
              <p class="font-body text-on-surface-variant leading-relaxed">{sec.body}</p>
            </div>
          ))}
          {c.sections.length >= 2 && <AdSlot placement="articleMidA" />}
        </div>
      </section>
    )}

    {c.useCasesTitle && c.useCases && c.useCases.length > 0 && (
      <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
        <div class="max-w-5xl mx-auto px-3 sm:px-6">
          <div class="flex items-baseline gap-4 mb-3 sm:mb-4 reveal">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.useCasesTitle}</h2>
            <div class="h-1 flex-grow bg-on-background opacity-10"></div>
          </div>
          {c.useCasesIntro && (
            <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed mb-5 sm:mb-8 reveal">{c.useCasesIntro}</p>
          )}
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
            {c.useCases.map((item, i) => (
              <div class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed'][i % 3]} border border-outline-variant/40 p-4 sm:p-5 rounded-xl hard-shadow reveal`}>
                <h3 class="text-base sm:text-lg font-black font-headline mb-2">{item.title}</h3>
                <p class="font-body text-on-surface-variant">{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.faqTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        {c.faqIntro && <p class="text-sm sm:text-base text-on-surface-variant mb-5 sm:mb-8 reveal">{c.faqIntro}</p>}
        <div class="space-y-4 reveal">
          {c.faqs.map((f, i) => (
            <details class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed', 'bg-surface-variant'][i % 4]} border border-outline-variant/40 rounded-xl hard-shadow group`}>
              <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between gap-3">
                <h3 class="m-0 font-black font-headline text-sm sm:text-base">{f.q}</h3>
                <Icon name="expand_more" class="text-primary transition-transform group-open:rotate-180" />
              </summary>
              <div class="px-4 sm:px-5 pb-4 sm:pb-5">
                <p class="font-body text-on-surface-variant">{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {relatedLinks.length > 0 && (
      <section class="py-8 sm:py-12">
        <div class="max-w-5xl mx-auto px-3 sm:px-6">
          <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.relatedTitle ?? 'More image to URL tools'}</h2>
            <div class="h-1 flex-grow bg-on-background opacity-10"></div>
          </div>
          <div class="flex flex-wrap gap-2 sm:gap-3 reveal">
            {relatedLinks.map(l => (
              <a href={l.href} class="inline-flex items-center gap-1.5 bg-surface-container-low border border-outline-variant/40 rounded-xl px-3 py-2 font-label text-xs sm:text-sm font-bold text-on-background hover:text-primary hover:-translate-y-0.5 transition-all hard-shadow">
                <Icon name="arrow_forward" class="text-base text-primary" />
                {l.label}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <AdSlot placement="bottomMultiplex" class="max-w-5xl mx-auto px-3 sm:px-6 mb-8 sm:mb-12" />

    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="reveal">
          <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border border-outline-variant/40 hard-shadow text-center">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">{c.ctaTitle}</h2>
            <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">{c.ctaBody}</p>
            <a href={homeHref} class="inline-block bg-primary text-on-primary px-6 py-3 border border-outline-variant/40 font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
              {c.ctaButton}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

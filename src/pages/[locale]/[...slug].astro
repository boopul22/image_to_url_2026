---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ImageUploader from '../../components/ImageUploader.astro';
import HeicConverter from '../../components/HeicConverter.astro';
import HeicPngConverter from '../../components/HeicPngConverter.astro';
import CanvasConverter from '../../components/CanvasConverter.astro';
import PdfConverter from '../../components/PdfConverter.astro';
import ImageCompressor from '../../components/ImageCompressor.astro';
import ImageResizer from '../../components/ImageResizer.astro';
import { locales, defaultLocale, type Locale } from '../../i18n/config';
import { PAGE_KEYS, SLUGS, getSlug, localizedUrl, hreflangPairs, type PageKey } from '../../i18n/landing/registry';
import type { LandingContentMap, LandingContent } from '../../i18n/landing/types';

// Widget map: which custom converter/utility component to render per pageKey.
// Pages not in this map fall back to the generic <ImageUploader>.
type WidgetSpec =
  | { kind: 'none' }
  | { kind: 'uploader' }
  | { kind: 'heic-to-jpg' }
  | { kind: 'heic-to-png' }
  | { kind: 'pdf'; from: 'png' | 'jpg' | 'heic' }
  | { kind: 'canvas'; from: 'png' | 'jpg' | 'webp'; to: 'png' | 'jpg' | 'webp'; idPrefix: string }
  | { kind: 'compressor' }
  | { kind: 'resizer' };

const WIDGETS: Partial<Record<PageKey, WidgetSpec>> = {
  // Cluster A — format-pair converters
  'heic-to-jpg':  { kind: 'heic-to-jpg' },
  'heic-to-png':  { kind: 'heic-to-png' },
  'heic-to-pdf':  { kind: 'pdf', from: 'heic' },
  'png-to-jpg':   { kind: 'canvas', from: 'png',  to: 'jpg',  idPrefix: 'png2jpg' },
  'jpg-to-png':   { kind: 'canvas', from: 'jpg',  to: 'png',  idPrefix: 'jpg2png' },
  'webp-to-jpg':  { kind: 'canvas', from: 'webp', to: 'jpg',  idPrefix: 'webp2jpg' },
  'webp-to-png':  { kind: 'canvas', from: 'webp', to: 'png',  idPrefix: 'webp2png' },
  'png-to-webp':  { kind: 'canvas', from: 'png',  to: 'webp', idPrefix: 'png2webp' },
  'jpg-to-webp':  { kind: 'canvas', from: 'jpg',  to: 'webp', idPrefix: 'jpg2webp' },
  'png-to-pdf':   { kind: 'pdf', from: 'png' },
  'jpg-to-pdf':   { kind: 'pdf', from: 'jpg' },
  // Cluster B — utilities
  'image-compressor': { kind: 'compressor' },
  'image-resizer':    { kind: 'resizer' },
  // image-to-base64, base64-to-image, favicon-generator have no shared widget —
  // they use inline scripts and render fine without a widget component.
  // Informational / policy pages — no upload widget on these.
  'about':               { kind: 'none' },
  'contact':             { kind: 'none' },
  'content-guidelines':  { kind: 'none' },
};

// Eager-load all landing content modules at build time. Each module exports
// `content: Record<Locale, LandingContent>`.
const modules = import.meta.glob<{ content: LandingContentMap }>(
  '../../i18n/landing/*.ts',
  { eager: true },
);

function contentFor(pageKey: PageKey): LandingContentMap | null {
  const path = `../../i18n/landing/${pageKey}.ts`;
  return modules[path]?.content ?? null;
}

export function getStaticPaths() {
  const paths: { params: { locale: Locale; slug: string } }[] = [];
  for (const pageKey of PAGE_KEYS) {
    for (const locale of locales) {
      const slug = SLUGS[pageKey][locale] ?? SLUGS[pageKey][defaultLocale];
      if (!slug) continue;
      paths.push({ params: { locale, slug } });
    }
  }
  return paths;
}

const locale = (Astro.params.locale ?? defaultLocale) as Locale;
const slug = String(Astro.params.slug ?? '');

// Reverse-resolve slug to pageKey for this locale
let pageKey: PageKey | null = null;
for (const key of PAGE_KEYS) {
  if (getSlug(key, locale) === slug) { pageKey = key; break; }
}
if (!pageKey) return Astro.redirect('/' + locale + '/');

const map = contentFor(pageKey);
if (!map) return Astro.redirect('/' + locale + '/');
const c: LandingContent = map[locale] ?? map[defaultLocale];

const pageUrl = `https://imagetourl.cloud/${locale}/${slug}`;
const alternates = hreflangPairs(pageKey);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: c.schemaName,
  url: pageUrl,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: c.schemaDescription,
  inLanguage: locale,
  provider: { '@id': 'https://imagetourl.cloud/#organization' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: locale,
  mainEntity: c.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const homeHref = `/${locale}/`;
const widget: WidgetSpec = WIDGETS[pageKey] ?? { kind: 'uploader' };
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  schema={[schema, faqSchema]}
  hreflangAlternates={alternates}
>
  <Nav />

  <main>
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
      {widget.kind === 'uploader' && <ImageUploader />}
      {widget.kind === 'heic-to-jpg' && <HeicConverter />}
      {widget.kind === 'heic-to-png' && <HeicPngConverter />}
      {widget.kind === 'pdf' && <PdfConverter from={widget.from} idPrefix={`pdf-${widget.from}-${locale}`} />}
      {widget.kind === 'canvas' && <CanvasConverter from={widget.from} to={widget.to} idPrefix={`${widget.idPrefix}-${locale}`} />}
      {widget.kind === 'compressor' && <ImageCompressor />}
      {widget.kind === 'resizer' && <ImageResizer />}

      <header class="mb-5 sm:mb-8 reveal">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">{c.badge}</span>
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
          {c.h1Pre} <span class="italic text-primary">{c.h1Highlight}</span>
        </h1>
        <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
          {c.intro}
        </p>
      </header>
    </div>

    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.howTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          {c.steps.map((step, i) => (
            <div class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed'][i % 3]} border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal`}>
              <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">{i + 1}</div>
              <h3 class="text-base sm:text-lg font-black font-headline mb-2">{step.title}</h3>
              <p class="font-body text-on-surface-variant">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.whyTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          {c.whyItems.map((item, i) => (
            <div class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed', 'bg-surface-variant'][i % 4]} border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal`}>
              <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
                <span class="material-symbols-outlined text-primary text-lg sm:text-xl">bolt</span>
              </div>
              <h3 class="text-base sm:text-lg font-black font-headline mb-2">{item.title}</h3>
              <p class="font-body text-on-surface-variant">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">{c.faqTitle}</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="space-y-4 reveal">
          {c.faqs.map((f, i) => (
            <details class={`${['bg-secondary-container', 'bg-tertiary-fixed', 'bg-primary-fixed', 'bg-surface-variant'][i % 4]} border-2 border-on-background rounded-xl hard-shadow group`}>
              <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between gap-3">
                <span>{f.q}</span>
                <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              <div class="px-4 sm:px-5 pb-4 sm:pb-5">
                <p class="font-body text-on-surface-variant">{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="reveal">
          <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">{c.ctaTitle}</h2>
            <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">{c.ctaBody}</p>
            <a href={homeHref} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
              {c.ctaButton}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

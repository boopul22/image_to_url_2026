---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current upload route
POST /api/upload

# Status
Website uploader only.
Public bearer-token REST access is not live yet.

# Current limits
Guest uploads:     100 files per rolling 24 hours
Signed-in uploads: 150 credits per day (about 1 credit per MB)
Max file size:     10 MB

# Current storage behavior
Guest links auto-expire at monthly cleanup.
Signed-in uploads can use "Never delete" before upload.`;
---
<DevApiPage
  title="Image Hosting REST API — Current Status"
  slug="image-hosting-rest-api"
  metaDescription="Current ImageToURL REST status: website uploads are live; public bearer-token REST uploads, metadata, delete, list, and webhooks are not live yet."
  h1Pre="Image Hosting REST API"
  h1Highlight="not public yet."
  intro="The current upload route powers the ImageToURL website uploader and is guarded for same-site browser requests. Public REST access with bearer tokens, metadata, list, delete, and webhook endpoints is not live today."
  lang="bash"
  langLabel="REST"
  codeSnippet={code}
  whys={[
    { title: "Honest current status", body: "Website uploads are live. Public REST automation is roadmap and should not be wired into production systems yet." },
    { title: "Clear limits", body: "The live uploader enforces 5 guest uploads/day, 25 signed-in uploads/day, and 10 MB per file." },
    { title: "Predictable storage", body: "Guest links auto-expire at monthly cleanup; signed-in users can choose keep-forever links before uploading." },
    { title: "Simple path forward", body: "Use the dashboard and web uploader today. Contact us if you need higher limits or programmatic access." }
  ]}
  faqs={[
    { q: "Is there an OpenAPI spec?", a: "No public OpenAPI spec is live today." },
    { q: "Do you support webhooks?", a: "No public webhook feature is live today." },
    { q: "Presigned URLs for direct browser upload?", a: "No. Use the ImageToURL website uploader today." },
    { q: "Batch upload in one request?", a: "No public batch REST endpoint is live. Use the bulk-upload UI." },
    { q: "Do you return responsive image variants?", a: "No public REST variant response is live. Use the site tools before uploading or the image route helpers used by the website." },
    { q: "Delete via public URL?", a: "No. Signed-in users can delete their own uploads from the dashboard." },
    { q: "Idempotency keys?", a: "Not applicable until public REST uploads are opened." },
    { q: "SDK roadmap?", a: "SDKs are not live today. The website uploader is the supported production path." }
  ]}
  relatedSlugs={[
    { href: "/image-upload-api/", title: "Quick Start", body: "30-second upload example." },
    { href: "/image-hosting-api-python/", title: "Python", body: "Python client snippet." },
    { href: "/image-hosting-api-nodejs/", title: "Node.js", body: "Node snippet." }
  ]}
/>

---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public Make.com HTTP uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Upload via Make (Integromat) — Current Status"
  slug="image-upload-make"
  metaDescription="Current Make.com upload status for ImageToURL. Public HTTP/API uploads are not live yet; use the website uploader today."
  h1Pre="Make image upload"
  h1Highlight="not public yet."
  intro="Make.com automation is not live yet because public API-key uploads are not open. Use the website uploader today, or contact us if your workflow needs automation access."
  lang="bash"
  langLabel="Make HTTP"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "Make automation is roadmap", body: "HTTP-module uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 50 MB file cap." },
    { title: "Contact for automation", body: "If you need Make for forms, drives, or support intake, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I use Make today?", a: "No. Public HTTP/API uploads are not live yet; use the website uploader." },
    { q: "How would file attachment work later?", a: "Make's multipart/form-data body can send a File-type bundle once public API-key uploads are available." },
    { q: "Extract the response URL for next step?", a: "That will be documented when public upload automation launches. The website uploader already returns a URL you can copy manually." },
    { q: "What's 'Core' vs 'Pro' Make plan?", a: "Core: 10k ops/mo for $9. Pro: 10k with 2× faster execution and priority support. For image-upload workflows, Core is usually fine." },
    { q: "Error handling?", a: "Make has error routes, but ImageToURL public upload automation is not live today." },
    { q: "Iterator for bulk uploads?", a: "Not available today through a public ImageToURL endpoint." },
    { q: "Is the API key visible in scenarios?", a: "Make stores connection values encrypted. Do not add an ImageToURL upload key today, because public API-key uploads are not live yet. If automation opens later, store credentials in encrypted connections." },
    { q: "Works with Make's Custom Apps?", a: "Yes — build a Custom App that wraps the ImageToURL endpoint if you reuse it across many scenarios. Removes boilerplate." }
  ]}
  relatedSlugs={[
    { href: "/image-upload-zapier/", title: "Zapier", body: "Zapier alternative." },
    { href: "/image-upload-n8n/", title: "n8n", body: "Self-hosted." },
    { href: "/image-upload-api/", title: "API overview", body: "Underlying endpoint." }
  ]}
/>

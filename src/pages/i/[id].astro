---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getDB } from '../../lib/db';

const { id } = Astro.params;

if (!id || !/^[a-z0-9]{4,16}$/i.test(id)) {
  return new Response(null, { status: 404 });
}

function nowSqlUtc(): string {
  return new Date().toISOString().replace('T', ' ').slice(0, 19);
}

const db = getDB(Astro.locals);
const row = await db
  .prepare(
    `SELECT id, r2_key, url, filename, mime_type, size_bytes, expires_at, deleted_at, created_at
     FROM images WHERE id = ?`,
  )
  .bind(id)
  .first<{
    id: string;
    r2_key: string;
    url: string;
    filename: string;
    mime_type: string;
    size_bytes: number;
    expires_at: string | null;
    deleted_at: string | null;
    created_at: string;
  }>();

if (!row || row.deleted_at || (row.expires_at && row.expires_at <= nowSqlUtc())) {
  return new Response(null, { status: 404 });
}

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=300, stale-while-revalidate=86400');

const rawUrl = row.url;
const shareUrl = new URL(Astro.url.pathname, Astro.site).href;
const filename = row.filename || 'image';
const sizeKb = Math.max(1, Math.round(row.size_bytes / 1024));
const uploadedAt = new Date(row.created_at + 'Z').toISOString().slice(0, 10);
const ext = (row.mime_type.split('/')[1] || 'img').toUpperCase();
---

<Layout
  title={`${filename} — Hosted on ImageToURL`}
  description="Image hosted free on ImageToURL. Upload your own — no signup, no watermark, permanent CDN hosting."
  ogImage={rawUrl}
  ogType="article"
  noindex={true}
  noHreflang={true}
>
  <Nav />

  <main class="px-4 sm:px-6 py-8 sm:py-12">
    <div class="max-w-3xl mx-auto">
      <!-- Image display -->
      <div class="bg-white border-2 border-on-background brutal-shadow p-3 sm:p-4">
        <img
          src={rawUrl}
          alt={filename}
          class="block w-full h-auto max-h-[70vh] object-contain bg-surface-variant"
          loading="eager"
        />
      </div>

      <!-- Metadata bar -->
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-mono text-on-surface-variant">
        <span class="font-bold text-on-background truncate max-w-[60%]">{filename}</span>
        <span>{ext}</span>
        <span>{sizeKb} KB</span>
        <span>{uploadedAt}</span>
      </div>

      <!-- Share/copy controls -->
      <section class="mt-6 bg-white border-2 border-on-background brutal-shadow p-4 sm:p-6">
        <h2 class="font-headline font-semibold text-sm uppercase tracking-wider text-on-background mb-3">
          Share this image
        </h2>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="share-url"
            readonly
            value={shareUrl}
            class="flex-1 min-w-0 bg-white border-2 border-on-background px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-600"
          />
          <button
            id="copy-share-btn"
            type="button"
            class="bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide flex-shrink-0"
          >
            Copy share link
          </button>
        </div>
        <p class="mt-2 text-xs text-on-surface-variant">Paste this anywhere — Reddit, blogs, forums, Discord.</p>

        <button
          id="toggle-direct"
          type="button"
          class="mt-4 text-xs font-bold uppercase tracking-wider text-on-surface-variant hover:text-rose-600"
          aria-expanded="false"
          aria-controls="direct-row"
        >
          + Need a direct image URL for &lt;img src&gt;?
        </button>

        <div id="direct-row" class="hidden mt-3 flex-col sm:flex-row gap-3">
          <input
            type="text"
            id="direct-url"
            readonly
            value={rawUrl}
            class="flex-1 min-w-0 bg-white border-2 border-on-background px-4 py-3 text-sm font-mono text-on-surface focus:outline-none focus:border-rose-600"
          />
          <button
            id="copy-direct-btn"
            type="button"
            class="bg-white hover:bg-surface-variant text-on-background font-headline font-semibold text-sm py-3 px-6 border-2 border-on-background brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide flex-shrink-0"
          >
            Copy direct URL
          </button>
        </div>
      </section>

      <!-- CTA back to homepage -->
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 bg-rose-600 hover:bg-rose-700 text-white font-headline font-semibold text-sm py-3 px-6 border-2 border-neutral-900 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide"
      >
        <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">cloud_upload</span>
        Upload your own on ImageToURL
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const shareInput = document.getElementById('share-url') as HTMLInputElement | null;
  const directInput = document.getElementById('direct-url') as HTMLInputElement | null;
  const copyShareBtn = document.getElementById('copy-share-btn') as HTMLButtonElement | null;
  const copyDirectBtn = document.getElementById('copy-direct-btn') as HTMLButtonElement | null;
  const toggleDirect = document.getElementById('toggle-direct') as HTMLButtonElement | null;
  const directRow = document.getElementById('direct-row') as HTMLDivElement | null;

  function wireCopy(btn: HTMLButtonElement | null, input: HTMLInputElement | null, originalLabel: string) {
    if (!btn || !input) return;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(input.value);
      } catch {
        input.select();
        document.execCommand('copy');
      }
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = originalLabel; }, 2000);
    });
  }

  wireCopy(copyShareBtn, shareInput, 'Copy share link');
  wireCopy(copyDirectBtn, directInput, 'Copy direct URL');

  if (toggleDirect && directRow) {
    toggleDirect.addEventListener('click', () => {
      const isHidden = directRow.classList.contains('hidden');
      directRow.classList.toggle('hidden');
      directRow.classList.toggle('flex');
      toggleDirect.setAttribute('aria-expanded', String(isHidden));
    });
  }
</script>

---
import Icon from '../components/Icon.astro';
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// No CDN caching — always fresh, private user data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
---

<Layout title="Dashboard - ImageToURL" noindex={true}>
  <Nav activePage="dashboard" />

  <main class="pt-6 sm:pt-8 pb-16 sm:pb-24 px-4 sm:px-6 max-w-5xl mx-auto space-y-8 sm:space-y-12">
    <!-- Account Card -->
    <section class="bg-surface border border-outline-variant/40 p-5 sm:p-8 hard-shadow flex flex-col md:flex-row items-center gap-6 sm:gap-8">
      <img
        src={user.avatarUrl}
        alt={user.name}
        class="w-20 h-20 rounded-full border-4 border-on-surface object-cover"
        referrerpolicy="no-referrer"
      />
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-lg sm:text-xl font-headline italic font-black text-on-surface">{user.name}</h1>
        <p class="text-on-surface-variant font-body">{user.email}</p>
      </div>
      <div class="flex items-center gap-3">
        <span class:list={[
          "px-4 py-1 border border-outline-variant/40 rounded-full font-label text-xs font-bold uppercase tracking-wider",
          user.role === 'admin' ? 'bg-error text-on-error' : 'bg-secondary-fixed text-on-secondary-fixed',
        ]}>
          {user.role}
        </span>
      </div>
    </section>

    <!-- Overview Stats. Icon color semantics: near-black (secondary) for neutral
         counts, amber (warning) for urgency, rose (primary) reserved for the
         actionable spend metric (Credits). Every tile reserves the subtitle line
         so the big numbers baseline-align across the row. -->
    <section class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <div class="bg-surface border border-outline-variant/40 p-4 sm:p-5 hard-shadow">
        <div class="flex items-center gap-2 text-on-surface-variant mb-1">
          <Icon name="photo_library" class="text-secondary text-lg" />
          <span class="font-label text-[10px] font-bold uppercase tracking-wider">Images</span>
        </div>
        <p id="stat-total" class="text-2xl sm:text-3xl font-headline italic font-black text-on-surface">—</p>
        <p class="text-[11px] text-on-surface-variant mt-0.5 min-h-4">&nbsp;</p>
      </div>
      <div class="bg-surface border border-outline-variant/40 p-4 sm:p-5 hard-shadow">
        <div class="flex items-center gap-2 text-on-surface-variant mb-1">
          <Icon name="database" class="text-secondary text-lg" />
          <span class="font-label text-[10px] font-bold uppercase tracking-wider">Storage</span>
        </div>
        <p id="stat-storage" class="text-2xl sm:text-3xl font-headline italic font-black text-on-surface">—</p>
        <p class="text-[11px] text-on-surface-variant mt-0.5 min-h-4">&nbsp;</p>
      </div>
      <div class="bg-surface border border-outline-variant/40 p-4 sm:p-5 hard-shadow">
        <div class="flex items-center gap-2 text-on-surface-variant mb-1">
          <Icon name="schedule" class="text-warning text-lg" />
          <span class="font-label text-[10px] font-bold uppercase tracking-wider">Expiring Soon</span>
        </div>
        <p id="stat-expiring" class="text-2xl sm:text-3xl font-headline italic font-black text-on-surface">—</p>
        <p id="stat-expiring-sub" class="text-[11px] text-on-surface-variant mt-0.5 min-h-4">&nbsp;</p>
      </div>
      <div class="bg-surface border border-outline-variant/40 p-4 sm:p-5 hard-shadow">
        <div class="flex items-center gap-2 text-on-surface-variant mb-1">
          <Icon name="toll" class="text-primary text-lg" />
          <span class="font-label text-[10px] font-bold uppercase tracking-wider">Keep-forever</span>
        </div>
        <p id="stat-credits" class="text-2xl sm:text-3xl font-headline italic font-black text-on-surface">—</p>
        <div class="mt-2 h-1 bg-surface-container-highest overflow-hidden">
          <div id="stat-credits-bar" class="h-full bg-rose-600 transition-[width] duration-300" style="width:0%"></div>
        </div>
        <p id="stat-credits-sub" class="text-[11px] text-on-surface-variant mt-1 min-h-4"></p>
      </div>
    </section>

    <!-- Images Section -->
    <section>
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <h2 class="text-2xl font-headline italic font-black text-on-surface flex items-center gap-3">
          <Icon name="photo_library" class="text-secondary" />
          Your Images
        </h2>
        <div class="flex items-center gap-2">
          <div class="relative flex-1 sm:flex-none">
            <Icon name="search" class="absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant/60 text-lg pointer-events-none" />
            <input
              id="search-input"
              type="search"
              placeholder="Search by filename"
              class="w-full sm:w-56 bg-surface border border-outline-variant/40 pl-10 pr-3 py-2 font-body text-sm focus:outline-none focus:border-primary"
            />
          </div>
          <select
            id="sort-select"
            class="bg-surface border border-outline-variant/40 px-3 py-2 font-body text-sm focus:outline-none focus:border-primary cursor-pointer"
          >
            <option value="newest">Newest</option>
            <option value="oldest">Oldest</option>
            <option value="largest">Largest</option>
            <option value="smallest">Smallest</option>
            <option value="name">Name (A–Z)</option>
          </select>
        </div>
      </div>

      <!-- Selection Toolbar -->
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <button
          id="select-toggle"
          class="bg-surface border border-outline-variant/40 px-4 py-2 font-label text-xs font-bold uppercase tracking-wider hard-shadow hover:-translate-y-0.5 transition-all"
        >
          Select
        </button>
        <div id="bulk-bar" class="hidden flex-wrap items-center gap-3">
          <button id="select-all" class="font-label text-xs font-bold uppercase tracking-wider text-primary hover:-translate-y-0.5 transition-all">
            Select all
          </button>
          <button id="select-none" class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant hover:-translate-y-0.5 transition-all">
            Clear
          </button>
          <span id="selection-count" class="font-label text-xs font-bold uppercase tracking-wider text-on-surface-variant">0 selected</span>
          <button
            id="bulk-delete-btn"
            disabled
            class="bg-error text-on-error px-4 py-2 border border-outline-variant/40 font-label text-xs font-bold uppercase tracking-wider hard-shadow hover:-translate-y-0.5 transition-all disabled:opacity-40 disabled:cursor-not-allowed disabled:translate-y-0 flex items-center gap-2"
          >
            <Icon name="delete" class="text-sm" />
            Delete Selected
          </button>
        </div>
      </div>

      <div id="images-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <div class="col-span-full text-center text-outline py-12">
          <Icon name="hourglass_empty" class="text-4xl mb-2" />
          <p class="font-label text-xs uppercase">Loading images...</p>
        </div>
      </div>
      <div id="load-more-wrapper" class="hidden mt-8 text-center">
        <button id="load-more-btn" class="bg-surface border border-outline-variant/40 px-8 py-3 font-label text-xs font-bold uppercase tracking-wider hard-shadow hover:-translate-y-1 transition-all">
          Load More
        </button>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  import { ic_image, ic_delete } from '../data/icon-svgs';
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function formatBytes(bytes: number): string {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
  }

  function formatExpiry(iso: string): string {
    const ms = new Date(iso.replace(' ', 'T') + 'Z').getTime() - Date.now();
    if (ms <= 0) return 'soon';
    const m = Math.round(ms / 60000);
    if (m < 60) return `in ${m}m`;
    const h = Math.round(m / 60);
    if (h < 48) return `in ${h}h`;
    return `in ${Math.round(h / 24)}d`;
  }

  // Expiry line on a card: within 7 days it becomes an amber badge (urgency —
  // the --color-warning token); further out it stays a quiet gray line. Rose is
  // reserved for brand/actions, so it no longer paints every expiry as alarming.
  function renderExpiryChip(iso: string): string {
    const ms = new Date(iso.replace(' ', 'T') + 'Z').getTime() - Date.now();
    const label = `Expires ${formatExpiry(iso)}`;
    return ms <= 7 * 86400000
      ? `<p class="inline-flex w-fit items-center bg-warning-container text-warning text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5">${label}</p>`
      : `<p class="text-[10px] font-bold uppercase tracking-wider text-on-surface-variant">${label}</p>`;
  }

  // ---- Stats ----
  const statTotal = document.getElementById('stat-total')!;
  const statStorage = document.getElementById('stat-storage')!;
  const statExpiring = document.getElementById('stat-expiring')!;
  const statCredits = document.getElementById('stat-credits')!;
  const statCreditsSub = document.getElementById('stat-credits-sub')!;

  function renderStats(stats: { totalImages: number; totalBytes: number; expiringSoon: number; credits?: number; creditsCap?: number; refreshIn?: string } | undefined) {
    if (!stats) return;
    statTotal.textContent = String(stats.totalImages);
    statStorage.textContent = formatBytes(stats.totalBytes);
    statExpiring.textContent = String(stats.expiringSoon);
    // Urgency states use the amber --color-warning token: expiring count > 0,
    // and a credit balance at ≤20% of the daily cap. Swap (not stack) the color
    // utilities so two color classes never fight over the same element.
    const expiringUrgent = stats.expiringSoon > 0;
    statExpiring.classList.toggle('text-warning', expiringUrgent);
    statExpiring.classList.toggle('text-on-surface', !expiringUrgent);
    if (typeof stats.credits === 'number') {
      const cap = stats.creditsCap ?? 50;
      statCredits.textContent = `${stats.credits} / ${cap}`;
      statCreditsSub.textContent = stats.refreshIn ? `Refills in ~${stats.refreshIn}` : 'Keep-forever saves/day';
      const low = stats.credits <= cap * 0.2;
      statCredits.classList.toggle('text-warning', low);
      statCredits.classList.toggle('text-on-surface', !low);
      const bar = document.getElementById('stat-credits-bar');
      if (bar) {
        bar.style.width = `${Math.max(0, Math.min(100, (stats.credits / cap) * 100))}%`;
        bar.classList.toggle('bg-warning', low);
        bar.classList.toggle('bg-rose-600', !low);
      }
    }
  }

  // ---- Images state ----
  const imagesGrid = document.getElementById('images-grid')!;
  const loadMoreWrapper = document.getElementById('load-more-wrapper')!;
  const loadMoreBtn = document.getElementById('load-more-btn')!;
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;

  let currentPage = 1;
  let totalPages = 1;
  let allImages: any[] = [];
  let selectMode = false;
  const selected = new Set<string>();

  async function loadImages(page: number) {
    const params = new URLSearchParams({ page: String(page), sort: sortSelect.value });
    const q = searchInput.value.trim();
    if (q) params.set('search', q);

    const res = await fetch(`/api/dashboard/images?${params.toString()}`);
    const data = await res.json();

    if (page === 1) allImages = data.images || [];
    else allImages = [...allImages, ...(data.images || [])];

    currentPage = data.page || page;
    totalPages = data.totalPages || 1;
    renderStats(data.stats);
    renderImages();

    loadMoreWrapper.classList.toggle('hidden', currentPage >= totalPages);
  }

  function renderImages() {
    if (!allImages.length) {
      const q = searchInput.value.trim();
      const msg = q ? `No images match "${esc(q)}"` : 'No images uploaded yet';
      imagesGrid.innerHTML = `<div class="col-span-full text-center text-outline py-12"><svg class="ms-icon text-4xl mb-2" viewBox="0 -960 960 960">${ic_image}</svg><p class="font-label text-xs uppercase">${msg}</p></div>`;
      return;
    }
    imagesGrid.innerHTML = allImages.map((img: any) => {
      const isSel = selected.has(img.id);
      return `
      <div class="image-card bg-surface border ${isSel ? 'border-primary ring-2 ring-primary' : 'border-outline-variant/40'} overflow-hidden hard-shadow group relative" data-id="${esc(img.id)}">
        <div class="h-40 bg-surface-container-highest overflow-hidden relative cursor-pointer select-hit">
          <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          <label class="select-box absolute top-2 left-2 ${selectMode ? 'flex' : 'hidden'} items-center justify-center w-6 h-6 bg-surface/90 border border-outline-variant rounded cursor-pointer">
            <input type="checkbox" class="select-checkbox accent-primary w-4 h-4 cursor-pointer" data-id="${esc(img.id)}" ${isSel ? 'checked' : ''} />
          </label>
        </div>
        <div class="p-3 space-y-2">
          <p class="text-xs font-bold truncate" title="${esc(img.filename)}">${esc(img.filename)}</p>
          <p class="text-xs text-outline">${(img.size_bytes / 1024).toFixed(1)} KB · ${new Date(img.created_at).toLocaleDateString()}</p>
          ${img.expires_at ? renderExpiryChip(img.expires_at) : ''}
          <div class="flex gap-2">
            <button onclick="copyUrl('${esc(img.url)}')" class="flex-1 text-center py-2.5 border border-outline-variant/40 text-xs font-bold uppercase hover:bg-primary hover:text-on-primary active:bg-primary active:text-on-primary transition-colors">Copy URL</button>
            <button onclick="deleteImage('${esc(img.id)}')" class="py-2.5 px-3 border border-error text-error text-xs font-bold uppercase hover:bg-error hover:text-on-error active:bg-error active:text-on-error transition-colors">
              <svg class="ms-icon text-sm" viewBox="0 -960 960 960">${ic_delete}</svg>
            </button>
          </div>
        </div>
      </div>
    `;
    }).join('');

    // Wire up selection interactions on the freshly rendered cards.
    imagesGrid.querySelectorAll<HTMLInputElement>('.select-checkbox').forEach((cb) => {
      cb.addEventListener('change', () => toggleSelected(cb.dataset.id!, cb.checked));
      cb.addEventListener('click', (e) => e.stopPropagation());
    });
    if (selectMode) {
      imagesGrid.querySelectorAll<HTMLElement>('.select-hit').forEach((hit) => {
        hit.addEventListener('click', () => {
          const card = hit.closest('.image-card') as HTMLElement;
          const id = card?.dataset.id;
          if (id) toggleSelected(id, !selected.has(id));
        });
      });
    }
  }

  // ---- Selection ----
  const selectToggle = document.getElementById('select-toggle')!;
  const bulkBar = document.getElementById('bulk-bar')!;
  const selectionCount = document.getElementById('selection-count')!;
  const bulkDeleteBtn = document.getElementById('bulk-delete-btn') as HTMLButtonElement;

  function updateSelectionUI() {
    selectionCount.textContent = `${selected.size} selected`;
    bulkDeleteBtn.disabled = selected.size === 0;
  }

  function toggleSelected(id: string, on: boolean) {
    if (on) selected.add(id);
    else selected.delete(id);
    updateSelectionUI();
    renderImages();
  }

  selectToggle.addEventListener('click', () => {
    selectMode = !selectMode;
    selectToggle.classList.toggle('bg-primary', selectMode);
    selectToggle.classList.toggle('text-on-primary', selectMode);
    bulkBar.classList.toggle('hidden', !selectMode);
    bulkBar.classList.toggle('flex', selectMode);
    if (!selectMode) selected.clear();
    updateSelectionUI();
    renderImages();
  });

  document.getElementById('select-all')!.addEventListener('click', () => {
    allImages.forEach((img) => selected.add(img.id));
    updateSelectionUI();
    renderImages();
  });

  document.getElementById('select-none')!.addEventListener('click', () => {
    selected.clear();
    updateSelectionUI();
    renderImages();
  });

  bulkDeleteBtn.addEventListener('click', async () => {
    const ids = [...selected];
    if (!ids.length) return;
    if (!confirm(`Delete ${ids.length} image${ids.length === 1 ? '' : 's'} permanently? This cannot be undone.`)) return;

    bulkDeleteBtn.disabled = true;
    const res = await fetch('/api/dashboard/images', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids }),
    });
    if (res.ok) {
      selected.clear();
      updateSelectionUI();
      await loadImages(1);
    } else {
      bulkDeleteBtn.disabled = false;
      alert('Some images could not be deleted. Please try again.');
    }
  });

  // ---- Single image actions ----
  (window as any).copyUrl = (url: string) => navigator.clipboard.writeText(url);
  (window as any).deleteImage = async (id: string) => {
    if (!confirm('Delete this image permanently?')) return;
    await fetch('/api/dashboard/images', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    selected.delete(id);
    updateSelectionUI();
    loadImages(1);
  };

  // ---- Search + sort (debounced search) ----
  let searchTimer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => loadImages(1), 300);
  });
  sortSelect.addEventListener('change', () => loadImages(1));

  loadMoreBtn.addEventListener('click', () => loadImages(currentPage + 1));

  // Initial load
  loadImages(1);
</script>

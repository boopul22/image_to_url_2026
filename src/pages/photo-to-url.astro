---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Photo to URL Converter",
  "url": "https://imagetourl.cloud/photo-to-url",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Turn any photo into a shareable URL in seconds. Free photo hosting, no signup required.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can I upload photos from my phone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. Our uploader works on iPhone, Android, iPad, and all mobile browsers. Just tap the upload area to select from your photo library."
      }
    },
    {
      "@type": "Question",
      "name": "Will my photo quality be reduced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. We store and serve your photos in their original quality. No compression, no resizing, no watermarks."
      }
    },
    {
      "@type": "Question",
      "name": "How do I share my photo URL?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "After uploading, copy the generated URL and paste it anywhere — text messages, emails, social media posts, documents, or websites."
      }
    },
    {
      "@type": "Question",
      "name": "Are photo URLs permanent?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Once uploaded, your photo URL is permanent and will never expire. It's hosted on our global CDN for fast access worldwide."
      }
    },
    {
      "@type": "Question",
      "name": "Is this really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free. No signup required, no hidden fees, no premium upsells needed for basic photo sharing."
      }
    }
  ]
};
---

<Layout title="Photo to URL — Turn Any Photo into a Shareable Link | ImageToURL" description="Turn any photo into a shareable URL in seconds. Upload from phone or computer, get a permanent link instantly. Free photo hosting, no signup required." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-7xl mx-auto px-3 sm:px-6 pt-8 sm:pt-16">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-8 sm:mb-20 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Photo Sharing</span>
      <h1 class="text-3xl sm:text-6xl lg:text-8xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Photo to URL <span class="italic text-primary">in seconds.</span>
      </h1>
      <p class="text-base sm:text-xl lg:text-2xl font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Turn any photo into a shareable URL in seconds. Upload from your phone or computer, get a permanent link instantly — no signup, no fees, no hassle.
      </p>
    </header>
    </div>



    <!-- How It Works -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">1</div>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">add_photo_alternate</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Choose Your Photo</h3>
          <p class="font-body text-on-surface-variant">Select a photo from your phone, tablet, or computer. Drag & drop or tap to browse — works on any device.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">2</div>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">cloud_upload</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Instant Upload</h3>
          <p class="font-body text-on-surface-variant">Your photo uploads to our global CDN in under 3 seconds. A permanent, shareable URL is created automatically.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">3</div>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">send</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Share the Link</h3>
          <p class="font-body text-on-surface-variant">Copy your photo URL and share it via text, email, social media, or embed it in any website or document.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Why Use Photo to URL? -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Why Use Photo to URL?</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">phone_iphone</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Works on Every Device</h3>
          <p class="font-body text-on-surface-variant">Upload photos directly from your iPhone, Android, iPad, or desktop. Our interface adapts to any screen size.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">person_off</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">No Account Needed</h3>
          <p class="font-body text-on-surface-variant">Just open the page and upload. No registration, no email, no password. Share photos in under 10 seconds.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">all_inclusive</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Permanent Photo Links</h3>
          <p class="font-body text-on-surface-variant">Your photo URLs never expire. Share them today, access them years from now. Guaranteed permanence.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">photo_library</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">All Photo Formats</h3>
          <p class="font-body text-on-surface-variant">Upload JPG, PNG, WebP, or any common photo format. We handle them all with original quality preserved.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-8">
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">diversity_3</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Sharing with Friends & Family</h3>
          <p class="font-body text-on-surface-variant">Send photo links via WhatsApp, iMessage, or email. No file size limits, no compression from messaging apps.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">share</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Social Media Sharing</h3>
          <p class="font-body text-on-surface-variant">Create direct links for Instagram bios, Twitter posts, and Facebook groups. Your photos, your URLs.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">shopping_cart</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Online Marketplace Sellers</h3>
          <p class="font-body text-on-surface-variant">Add product photos to eBay, Craigslist, Facebook Marketplace, and classified ads with reliable URLs.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">flight</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Travel & Event Photos</h3>
          <p class="font-body text-on-surface-variant">Share vacation albums, wedding photos, and event snapshots as simple links anyone can access.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="space-y-4 reveal">
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-6 sm:p-8 cursor-pointer font-black font-headline text-lg sm:text-xl list-none flex items-center justify-between">
            Can I upload photos from my phone?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 sm:px-8 pb-6 sm:pb-8">
            <p class="font-body text-on-surface-variant">Absolutely. Our uploader works on iPhone, Android, iPad, and all mobile browsers. Just tap the upload area to select from your photo library.</p>
          </div>
        </details>
        <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-6 sm:p-8 cursor-pointer font-black font-headline text-lg sm:text-xl list-none flex items-center justify-between">
            Will my photo quality be reduced?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 sm:px-8 pb-6 sm:pb-8">
            <p class="font-body text-on-surface-variant">No. We store and serve your photos in their original quality. No compression, no resizing, no watermarks.</p>
          </div>
        </details>
        <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-6 sm:p-8 cursor-pointer font-black font-headline text-lg sm:text-xl list-none flex items-center justify-between">
            How do I share my photo URL?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 sm:px-8 pb-6 sm:pb-8">
            <p class="font-body text-on-surface-variant">After uploading, copy the generated URL and paste it anywhere — text messages, emails, social media posts, documents, or websites.</p>
          </div>
        </details>
        <details class="bg-surface-variant border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-6 sm:p-8 cursor-pointer font-black font-headline text-lg sm:text-xl list-none flex items-center justify-between">
            Are photo URLs permanent?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 sm:px-8 pb-6 sm:pb-8">
            <p class="font-body text-on-surface-variant">Yes. Once uploaded, your photo URL is permanent and will never expire. It's hosted on our global CDN for fast access worldwide.</p>
          </div>
        </details>
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-6 sm:p-8 cursor-pointer font-black font-headline text-lg sm:text-xl list-none flex items-center justify-between">
            Is this really free?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-6 sm:px-8 pb-6 sm:pb-8">
            <p class="font-body text-on-surface-variant">Yes, completely free. No signup required, no hidden fees, no premium upsells needed for basic photo sharing.</p>
          </div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-8">
        <a href="/screenshot-to-url" class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-lg sm:text-xl font-black font-headline mb-1">Screenshot to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Share screenshots as instant links</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-lg sm:text-xl font-black font-headline mb-1">Free Image Hosting</h3>
            <p class="font-body text-on-surface-variant text-sm">Host any image format for free</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/image-url-generator" class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-lg sm:text-xl font-black font-headline mb-1">Image URL Generator</h3>
            <p class="font-body text-on-surface-variant text-sm">Generate instant URLs for any image</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-8 sm:p-12 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Turn your photo into a shareable link</h2>
        <p class="font-body text-surface/70 mb-6 sm:mb-8 max-w-lg mx-auto">Upload any photo and get a permanent URL in seconds. No signup, no watermarks, no catch.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-8 py-4 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Photo Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public Python/API-key uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Hosting API — Python Status"
  slug="image-hosting-api-python"
  metaDescription="Current Python/API upload status for ImageToURL. Public API-key uploads are not live yet; use the website uploader today."
  h1Pre="Image hosting API"
  h1Highlight="not public yet."
  intro="The public Python upload flow is not live yet. The current upload endpoint powers the website uploader and rejects non-same-site automation requests."
  lang="text"
  langLabel="Python"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "Python automation is roadmap", body: "Scripts, notebooks, Airflow, and backend jobs need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 50 MB file cap." },
    { title: "Contact for automation", body: "If you need Python upload workflows, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I upload from Python today?", a: "No. Public Python/API-key uploads are not live yet; use the website uploader." },
    { q: "Can I upload from a BytesIO buffer instead of a file path?", a: "Not through a public ImageToURL API today. That pattern can work after API-key uploads are available." },
    { q: "Error handling?", a: "The live website uploader shows friendly errors for quota, file type, and size. Public Python error handling docs will come with API access." },
    { q: "How do I upload from a Pillow image?", a: "Use Pillow to resize or compress locally, then upload the final file through the website uploader today." },
    { q: "Rate limits from Python?", a: "Public Python uploads are not live yet. Website limits are 5 guest uploads and 25 signed-in uploads per rolling 24 hours." },
    { q: "Does it work in Jupyter / Colab?", a: "Not as a public upload API today. You can still upload manually through the website and paste the resulting URL into a notebook." },
    { q: "Parallelism — is it safe?", a: "No public bulk automation endpoint is live today. Use the website limits, or contact us if you need automation access." },
    { q: "Django ImageField integration?", a: "Not available today. A Django storage backend would need public API-key uploads first." }
  ]}
  relatedSlugs={[
    { href: "/image-hosting-api-nodejs/", title: "Node.js", body: "Node fetch / axios." },
    { href: "/image-hosting-api-curl/", title: "cURL", body: "Shell scripts." },
    { href: "/image-upload-api/", title: "Upload API overview", body: "Endpoint docs." }
  ]}
/>

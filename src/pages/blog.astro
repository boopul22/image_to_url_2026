---
// ISR — SSR + edge cache. SSG speed with background refresh on new posts.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getDB } from '../lib/db';
import { getPublishedPosts, getCategories } from '../lib/cms';

// ISR: Cache at CDN edge for 5 min, serve stale up to 1 hour while revalidating
Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=300, stale-while-revalidate=3600');
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');

const db = getDB(Astro.locals);
const { posts } = await getPublishedPosts(db, { limit: 50 });
const categories = await getCategories(db);

const featuredPost = posts.find((p) => p.featured);
const otherPosts = posts.filter((p) => p !== featuredPost);
---

<Layout title="Blog — Image Hosting Tutorials, Tips & Updates | ImageToURL" description="Read tutorials, product updates, and insights on image hosting, CDN optimization, REST APIs, and creative workflows from the ImageToURL team.">
  <Nav activePage="blog" />

  <main>
    <!-- Hero Section -->
    <section class="bg-surface-container py-24 px-6 overflow-hidden relative border-b-2 border-on-surface">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="inline-block px-4 py-1 bg-tertiary-fixed border-2 border-on-surface rounded-full mb-6 rotate-[-2deg]">
          <span class="font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed">Latest Perspectives</span>
        </div>
        <h1 class="font-headline italic text-6xl md:text-8xl font-black text-on-surface leading-tight tracking-tight mb-6">
          The ImageToURL<br />
          <span class="relative">
            Blog
            <svg class="absolute -bottom-2 left-0 w-full h-4 text-tertiary/30" preserveAspectRatio="none" viewBox="0 0 100 10">
              <path d="M0 5 Q 25 0 50 5 T 100 5" fill="none" stroke="currentColor" stroke-width="4"></path>
            </svg>
          </span>
        </h1>
        <p class="font-headline font-medium text-xl md:text-2xl text-on-surface-variant max-w-2xl leading-relaxed">
          Insights, tutorials, and stories from the intersection of cloud storage, creative workflows, and digital engineering.
        </p>
      </div>
      <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-20 pointer-events-none hidden lg:block">
        <span class="material-symbols-outlined text-[20rem] text-primary">draw</span>
      </div>
    </section>

    <!-- Search & Filter Bar -->
    <section class="max-w-7xl mx-auto px-6 -mt-8 relative z-20">
      <div class="bg-surface border-2 border-on-surface p-4 flex flex-col md:flex-row gap-4 items-center hard-shadow">
        <div class="flex-1 flex items-center gap-3 px-4 py-2 bg-surface-container-lowest border-2 border-on-surface w-full">
          <span class="material-symbols-outlined text-outline">search</span>
          <input type="text" placeholder="Search articles..." class="bg-transparent border-none focus:ring-0 focus:outline-none w-full font-body text-sm" />
        </div>
        <div class="flex gap-2 overflow-x-auto w-full md:w-auto pb-2 md:pb-0">
          <button class="px-4 py-2 rounded-full border-2 border-on-surface bg-secondary-fixed text-on-secondary-fixed font-label text-xs font-bold uppercase whitespace-nowrap">All Posts</button>
          {categories.map((cat) => (
            <button class="px-4 py-2 rounded-full border-2 border-on-surface bg-surface-container-highest text-on-surface-variant font-label text-xs font-bold uppercase whitespace-nowrap hover:bg-secondary-fixed transition-colors" data-category={cat.id}>
              {cat.name}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <!-- Featured Post -->
        {featuredPost && (
          <article class="lg:col-span-2 group">
            <a href={`/blog/${featuredPost.slug}`} class="block">
              <div class="bg-surface border-2 border-on-surface h-full overflow-hidden hard-shadow hard-shadow-hover transition-all duration-200">
                <div class="flex flex-col md:flex-row h-full">
                  <div class="w-full md:w-1/2 h-64 md:h-full relative overflow-hidden border-b-2 md:border-b-0 md:border-r-2 border-on-surface">
                    {featuredPost.coverImage && (
                      <img alt={featuredPost.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" src={featuredPost.coverImage} />
                    )}
                    <div class="absolute top-4 left-4">
                      <span class="px-3 py-1 bg-primary text-on-primary border-2 border-on-surface font-label text-[10px] font-bold uppercase tracking-widest">Featured</span>
                    </div>
                  </div>
                  <div class="p-8 flex flex-col justify-between flex-1">
                    <div>
                      <span class={`font-label text-xs font-bold uppercase text-${featuredPost.categoryColor || 'primary'} tracking-widest mb-4 block`}>{featuredPost.categoryName || 'Uncategorized'}</span>
                      <h2 class="font-headline text-3xl md:text-4xl font-black text-on-surface mb-4 group-hover:text-primary transition-colors">{featuredPost.title}</h2>
                      <p class="font-body text-on-surface-variant mb-6 leading-relaxed">{featuredPost.excerpt}</p>
                    </div>
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full border-2 border-on-surface bg-tertiary-fixed p-0.5 overflow-hidden">
                          <img alt={featuredPost.authorName} class="w-full h-full object-cover rounded-full" loading="lazy" decoding="async" src={featuredPost.authorAvatar} />
                        </div>
                        <span class="font-label text-xs font-bold text-on-surface">{featuredPost.authorName}</span>
                      </div>
                      <span class="font-label text-xs font-black uppercase text-primary flex items-center gap-1">
                        Read More <span class="material-symbols-outlined text-sm">arrow_forward</span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          </article>
        )}

        <!-- Other Posts -->
        {otherPosts.map((post, i) => {
          const isWide = i === otherPosts.length - 1 && otherPosts.length % 3 === 0;
          return (
            <article class:list={["group", { "lg:col-span-2": isWide }]}>
              <a href={`/blog/${post.slug}`} class="block h-full">
                <div class:list={[
                  "bg-surface border-2 border-on-surface h-full flex hard-shadow hard-shadow-hover transition-all duration-200",
                  isWide ? "flex-col md:flex-row" : "flex-col",
                ]}>
                  {isWide ? (
                    <>
                      <div class="p-8 flex flex-col justify-center flex-1">
                        <span class={`font-label text-xs font-bold uppercase text-${post.categoryColor || 'primary'} tracking-widest mb-4 block`}>{post.categoryName || 'Uncategorized'}</span>
                        <h3 class="font-headline text-3xl font-black text-on-surface mb-4 group-hover:text-primary transition-colors">{post.title}</h3>
                        <p class="font-body text-on-surface-variant mb-6 leading-relaxed">{post.excerpt}</p>
                        <span class="font-label text-xs font-black uppercase text-primary flex items-center gap-1">
                          Read More <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </span>
                      </div>
                      <div class={`w-full md:w-2/5 h-64 md:h-auto border-t-2 md:border-t-0 md:border-l-2 border-on-surface flex items-center justify-center relative overflow-hidden ${post.iconBg || 'bg-surface-container-highest'}`}>
                        {post.coverImage ? (
                          <img alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" src={post.coverImage} />
                        ) : (
                          <>
                            <span class="material-symbols-outlined text-[12rem] text-primary/10 absolute rotate-12">auto_fix_high</span>
                            <div class="text-center p-6 relative z-10">
                              <span class="material-symbols-outlined text-6xl text-primary mb-4">{post.iconFallback || 'article'}</span>
                              <div class="font-headline italic text-xl">{post.categoryName || 'Uncategorized'}</div>
                            </div>
                          </>
                        )}
                      </div>
                    </>
                  ) : (
                    <>
                      <div class={`h-48 relative border-b-2 border-on-surface overflow-hidden ${!post.coverImage ? (post.iconBg || 'bg-surface-container-highest') + ' flex items-center justify-center' : ''}`}>
                        {post.coverImage ? (
                          <img alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" src={post.coverImage} />
                        ) : (
                          <div class="relative z-10 flex flex-col items-center">
                            <span class="material-symbols-outlined text-6xl text-on-surface/20">{post.iconFallback || 'article'}</span>
                            <span class="font-headline text-lg italic mt-2">{post.categoryName || 'Uncategorized'}</span>
                          </div>
                        )}
                      </div>
                      <div class="p-6 flex flex-col flex-1">
                        <span class={`font-label text-xs font-bold uppercase text-${post.categoryColor || 'primary'} tracking-widest mb-3 block`}>{post.categoryName || 'Uncategorized'}</span>
                        <h3 class="font-headline text-2xl font-black text-on-surface mb-4 group-hover:text-primary transition-colors">{post.title}</h3>
                        <p class="font-body text-sm text-on-surface-variant mb-6 flex-1">{post.excerpt}</p>
                        <span class="font-label text-xs font-black uppercase text-primary flex items-center gap-1 mt-auto">
                          Read More <span class="material-symbols-outlined text-sm">arrow_forward</span>
                        </span>
                      </div>
                    </>
                  )}
                </div>
              </a>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Newsletter Section -->
    <section class="max-w-7xl mx-auto px-6 mb-24">
      <div class="bg-surface-container border-2 border-on-surface p-12 text-center relative overflow-hidden rounded-lg hard-shadow">
        <div class="relative z-10">
          <h2 class="font-headline italic text-4xl font-black text-on-surface mb-4">Stay Curated</h2>
          <p class="font-headline text-xl text-on-surface-variant mb-8 max-w-xl mx-auto">Get our monthly digest of creative insights and technical deep-dives delivered to your inbox.</p>
          <form class="flex flex-col md:flex-row gap-4 max-w-lg mx-auto">
            <input type="email" placeholder="your@email.com" class="flex-1 bg-surface border-2 border-on-surface px-6 py-3 font-body focus:ring-2 focus:ring-primary focus:outline-none" />
            <button type="submit" class="bg-primary text-on-primary px-8 py-3 border-2 border-on-surface font-label uppercase tracking-wider text-xs font-bold hover:-translate-y-1 transition-transform hard-shadow">Subscribe</button>
          </form>
        </div>
        <span class="material-symbols-outlined text-8xl text-primary/10 absolute -bottom-8 -left-8 -rotate-12">mail</span>
        <span class="material-symbols-outlined text-8xl text-secondary/10 absolute -top-8 -right-8 rotate-12">rocket</span>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Permanent Image Hosting - ImageToURL",
  "description": "Image URLs that never expire or break. Upload once, share forever. Free permanent image hosting.",
  "url": "https://imagetourl.cloud/permanent-image-hosting",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does \"image to URL permanent\" actually mean here?",
      "acceptedAnswer": { "@type": "Answer", "text": "It means the URL we generate for your image keeps working forever. There is no expiration timer, no inactivity sweep, and no plan to migrate URLs. The same link you copy today will still load the image years from now." }
    },
    {
      "@type": "Question",
      "name": "Do image URLs on ImageToURL really never expire?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Once you upload an image, the URL is permanent. There are no expiration dates, no auto-deletion after inactivity, and no time-based limits. Your link works forever." }
    },
    {
      "@type": "Question",
      "name": "Why do other image hosts delete images?",
      "acceptedAnswer": { "@type": "Answer", "text": "Many free image hosts delete images after periods of inactivity, change their terms of service, or shut down entirely. Imgur purged millions of images in 2023. Discord made CDN links expire. We built ImageToURL specifically to solve this problem." }
    },
    {
      "@type": "Question",
      "name": "Can I use permanent image URLs in documentation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Permanent URLs are ideal for technical documentation, README files, wiki pages, and knowledge bases where broken images cause confusion and reduce trust." }
    },
    {
      "@type": "Question",
      "name": "What happens if ImageToURL shuts down?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our infrastructure is built on enterprise-grade cloud storage designed for 99.999999999% durability. We are committed to long-term operation and have no plans to sunset the service." }
    },
    {
      "@type": "Question",
      "name": "Is there a limit on how many permanent images I can host?",
      "acceptedAnswer": { "@type": "Answer", "text": "There are no limits on the number of images you can host. Upload as many as you need — every single one gets a permanent, shareable URL." }
    }
  ]
};
---

<Layout title="Image to URL Permanent — Hosting That Never Expires | ImageToURL" description="Permanent image to URL hosting. Upload once, share forever. Image links that never expire, never break, and never disappear. Free, no signup." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Permanent Links</span>
      <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image to URL, <span class="italic text-primary">permanent and forever.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload once, share forever. Your image to URL link is permanent. It will not expire, will not break, and will not disappear when you forget about it. End link rot for good.
      </p>
    </header>
    </div>



    <!-- The Link Rot Problem -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">The Link Rot Problem</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">delete_forever</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Imgur Deletes Images</h3>
          <p class="font-body text-on-surface-variant">In 2023, Imgur purged millions of older and anonymous images. Countless forum posts, tutorials, and documentation lost their visuals overnight.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">timer_off</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Discord Links Expire</h3>
          <p class="font-body text-on-surface-variant">Discord CDN URLs now include expiring authentication tokens. Images shared via Discord links stop working after a set period, breaking embedded content across the web.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">compress</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Social Media Compresses</h3>
          <p class="font-body text-on-surface-variant">Twitter, Facebook, and Instagram all compress uploaded images aggressively. Your carefully crafted visuals lose quality every time they are re-shared.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">power_off</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Free Hosts Shut Down</h3>
          <p class="font-body text-on-surface-variant">Photobucket, TinyPic, and countless others have shut down or changed their terms. Years of embedded images lost when a host decides to pivot or close.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Our Permanence Guarantee -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Our Permanence Guarantee</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">all_inclusive</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">No Expiration Dates</h3>
          <p class="font-body text-on-surface-variant">Your URLs have no time limits. No 30-day, 90-day, or 1-year expirations. Once generated, a link works permanently.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">cloud_done</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Enterprise-Grade Storage</h3>
          <p class="font-body text-on-surface-variant">Images are stored on infrastructure designed for 99.999999999% durability. Your data is replicated and protected against hardware failures.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">high_quality</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Original Quality Preserved</h3>
          <p class="font-body text-on-surface-variant">No compression, no re-encoding, no quality degradation. Your image is served at the exact same quality you uploaded it — forever.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">verified</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Stable URL Structure</h3>
          <p class="font-body text-on-surface-variant">Our URL format never changes. No migrations, no domain switches, no path restructuring. The link you get today will work identically in 10 years.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">description</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Documentation</h3>
          <p class="font-body text-on-surface-variant text-sm">Technical docs, README files, and wikis need images that load reliably for years. Permanent links keep your docs intact.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">palette</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Portfolios</h3>
          <p class="font-body text-on-surface-variant text-sm">Your creative work deserves permanent visibility. Host portfolio images that stay online no matter what happens to other platforms.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">inventory</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Archived Content</h3>
          <p class="font-body text-on-surface-variant text-sm">Forum posts, blog archives, and historical content keep their images intact. No more broken image icons on older pages.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">gavel</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Legal Records</h3>
          <p class="font-body text-on-surface-variant text-sm">Evidence photos, compliance records, and legal documentation need URLs that never change or disappear.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="max-w-3xl reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>What does "image to URL permanent" actually mean here?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">It means the URL we generate for your image keeps working forever. There is no expiration timer, no inactivity sweep, and no plan to migrate URLs. The same link you copy today will still load the image years from now.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Do image URLs on ImageToURL really never expire?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. Once you upload an image, the URL is permanent. There are no expiration dates, no auto-deletion after inactivity, and no time-based limits. Your link works forever.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Why do other image hosts delete images?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Many free image hosts delete images after periods of inactivity, change their terms of service, or shut down entirely. Imgur purged millions of images in 2023. Discord made CDN links expire. We built ImageToURL specifically to solve this problem.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I use permanent image URLs in documentation?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. Permanent URLs are ideal for technical documentation, README files, wiki pages, and knowledge bases where broken images cause confusion and reduce trust.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>What happens if ImageToURL shuts down?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Our infrastructure is built on enterprise-grade cloud storage designed for 99.999999999% durability. We are committed to long-term operation and have no plans to sunset the service.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Is there a limit on how many permanent images I can host?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">There are no limits on the number of images you can host. Upload as many as you need — every single one gets a permanent, shareable URL.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image format for free</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/free-image-cdn" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image CDN</h3>
            <p class="text-sm text-on-surface-variant">Global CDN delivery for your images</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/direct-image-link" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Direct Image Links</h3>
            <p class="text-sm text-on-surface-variant">Clean, hotlinkable URLs without gallery pages</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">Upload images that last forever</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">No expiration dates. No link rot. Get permanent image URLs in seconds.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

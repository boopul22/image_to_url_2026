---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ImageToURL — Image Hosting for Notion",
  "url": "https://imagetourl.cloud/image-hosting-for-notion",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Permanent image URLs for Notion pages. Notion's built-in image URLs expire — use ImageToURL for reliable hosting."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why do images break on published Notion pages?",
      "acceptedAnswer": { "@type": "Answer", "text": "Notion uses temporary signed URLs for images stored in its workspace. These URLs contain authentication tokens that expire after a period. When the token expires, the image stops loading on published pages, shared links, and embedded Notion content. External hosting with permanent URLs solves this completely." }
    },
    {
      "@type": "Question",
      "name": "How do I use an external image in Notion?",
      "acceptedAnswer": { "@type": "Answer", "text": "Upload your image to ImageToURL, copy the permanent URL, then in Notion type /image, select 'Embed link', and paste the URL. The image will load from ImageToURL's CDN and never expire, even on published Notion pages." }
    },
    {
      "@type": "Question",
      "name": "Will externally hosted images work in Notion's API?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. When you use an external image URL in Notion, the API returns the URL as type 'external' instead of type 'file'. External URLs are stable and permanent, making them reliable for integrations, automations, and any tool that reads Notion content via the API." }
    },
    {
      "@type": "Question",
      "name": "Do ImageToURL images work in Notion templates?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. When someone duplicates a Notion template that contains externally hosted images, the image URLs carry over perfectly. Unlike Notion-hosted images which can break after duplication, ImageToURL links always resolve correctly for every copy of the template." }
    },
    {
      "@type": "Question",
      "name": "Can I use this for a Notion website built with Super or Fruition?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Notion website builders like Super, Fruition, and Potion all benefit from externally hosted images. Since these tools render your Notion pages as websites, having permanent image URLs ensures your site's images never break due to Notion's expiring internal URLs." }
    }
  ]
};
---

<Layout title="Image Hosting for Notion Pages — Permanent URLs | ImageToURL" description="Notion's built-in image URLs expire on published pages. Use ImageToURL for permanent image URLs that never break in your Notion workspace." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Notion Users</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image Hosting for Notion <span class="italic text-primary">that never breaks.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Notion's internal image URLs expire on published pages and shared links. Upload to ImageToURL and get permanent image links that work everywhere Notion does.
      </p>
    </header>
    </div>



    <!-- The Notion Image Problem -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">The Notion Image Problem</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">timer_off</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">URLs Expire Silently</h3>
          <p class="font-body text-on-surface-variant">Notion generates temporary signed URLs for uploaded images. These tokens expire without warning, leaving blank spaces where your images used to be. You often do not notice until someone reports it.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">public</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Published Pages Break</h3>
          <p class="font-body text-on-surface-variant">When you publish a Notion page to the web, images that looked fine in your workspace can stop loading for visitors. The published page serves expired image URLs to anyone viewing it.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">share</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Shared Links Fail</h3>
          <p class="font-body text-on-surface-variant">Sharing a Notion page link with a client or colleague works initially, but the images on that page can expire before they get around to viewing it, making your content look broken.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">lock</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Internal-Only URLs</h3>
          <p class="font-body text-on-surface-variant">Notion's image URLs are authenticated to your workspace. They cannot be reliably used in external tools, integrations, or other platforms that read from your Notion content via API.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- How to Fix It -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How to Fix It</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">01</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">upload</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Your Image</h3>
          <p class="font-body text-on-surface-variant">Drag and drop your image above or click to browse. We support JPG, PNG, WebP, GIF, and SVG with no quality loss.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">02</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">content_copy</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Copy the Permanent URL</h3>
          <p class="font-body text-on-surface-variant">Your image gets a permanent URL instantly. Click to copy it to your clipboard. This URL will never expire or change.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">03</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">add_photo_alternate</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Embed in Notion</h3>
          <p class="font-body text-on-surface-variant">In Notion, type <code class="bg-on-background/10 px-1 rounded text-sm">/image</code>, choose "Embed link", and paste the URL. Your image loads from ImageToURL and never expires.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">public</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Published Pages</h3>
          <p class="font-body text-on-surface-variant text-sm">Keep images loading reliably on Notion pages published to the web. No more expired images for your visitors.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">groups</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Team Wikis</h3>
          <p class="font-body text-on-surface-variant text-sm">Diagrams, screenshots, and reference images in your team wiki stay visible for every team member, every time.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">web</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Portfolio Sites</h3>
          <p class="font-body text-on-surface-variant text-sm">Building a portfolio with Notion, Super, or Fruition? External images ensure your work samples always display correctly.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">description</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Documentation</h3>
          <p class="font-body text-on-surface-variant text-sm">Product docs, SOPs, and knowledge bases with images that load reliably for anyone with access to your Notion workspace.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Why do images break on published Notion pages?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Notion uses temporary signed URLs for images stored in its workspace. These URLs contain authentication tokens that expire after a period. When the token expires, the image stops loading on published pages, shared links, and embedded Notion content. External hosting with permanent URLs solves this completely.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>How do I use an external image in Notion?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Upload your image to ImageToURL, copy the permanent URL, then in Notion type /image, select "Embed link", and paste the URL. The image will load from ImageToURL's CDN and never expire, even on published Notion pages.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Will externally hosted images work in Notion's API?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. When you use an external image URL in Notion, the API returns the URL as type "external" instead of type "file". External URLs are stable and permanent, making them reliable for integrations, automations, and any tool that reads Notion content via the API.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Do ImageToURL images work in Notion templates?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. When someone duplicates a Notion template that contains externally hosted images, the image URLs carry over perfectly. Unlike Notion-hosted images which can break after duplication, ImageToURL links always resolve correctly for every copy of the template.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I use this for a Notion website built with Super or Fruition?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. Notion website builders like Super, Fruition, and Potion all benefit from externally hosted images. Since these tools render your Notion pages as websites, having permanent image URLs ensures your site's images never break due to Notion's expiring internal URLs.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/image-hosting-for-github-readme" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">GitHub README Hosting</h3>
            <p class="text-sm text-on-surface-variant">Permanent images for Markdown docs</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-hosting-for-newsletters" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Newsletter Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Reliable images for email campaigns</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image for free with CDN delivery</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Fix your Notion images permanently</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload an image, get a permanent URL, embed it in Notion. No more expired images on published pages.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

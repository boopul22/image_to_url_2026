---
import Icon from '../components/Icon.astro';
// Thin SSR fallback for old /share?u= links/bookmarks. The share widget itself
// is now the GLOBAL ShareDestination (rendered in Layout on every page), which
// auto-reveals on a valid ?u= — so this page must NOT render its own SharePanel
// or side ads (that would duplicate the global one's DOM ids + ad slots).
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getValidUrl } from '../lib/share-url';

// Never cache at the CDN (per-?u=) and keep it out of the index.
Astro.response.headers.set('Cache-Control', 'private, no-store');

const url = getValidUrl(Astro.url.searchParams.get('u'));
---

<Layout title="Image URL Copied — ImageToURL" description="Your image URL is ready — copy it, grab the embed code, or scan the QR." noindex={true} noHreflang>
  <Nav />

  <main class="max-w-xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    {url ? (
      <!-- Valid link: the global ShareDestination reveals the rich widget above.
           This is the no-JS / pre-reveal graceful fallback. -->
      <div class="text-center py-6">
        <Icon name="check_circle" class="text-secondary text-4xl" fill />
        <h1 class="text-xl font-headline italic font-black text-on-surface mt-3">Your link is ready</h1>
        <p class="text-on-surface-variant mt-1 text-sm">Your image URL:</p>
        <a href={url} class="inline-block mt-2 break-all font-mono text-sm text-primary hover:underline">{url}</a>
        <div class="mt-6">
          <a href="/" class="font-label text-xs font-bold uppercase tracking-wider text-primary hover:underline">← Upload another image</a>
        </div>
      </div>
    ) : (
      <!-- Invalid / missing URL state -->
      <div class="text-center py-10">
        <Icon name="link_off" class="text-5xl text-outline" />
        <h1 class="text-xl font-headline italic font-black text-on-surface mt-3">No image URL</h1>
        <p class="text-on-surface-variant mt-1">This page opens after you copy an uploaded image link.</p>
        <a href="/" class="inline-block mt-5 bg-rose-600 text-white font-headline font-semibold text-sm py-3 px-6 border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide">Upload an image</a>
      </div>
    )}
  </main>

  <Footer />
</Layout>

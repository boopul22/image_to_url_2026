---
import Icon from '../components/Icon.astro';
// Standalone "URL copied" share screen. The uploaders' "Get Link" buttons send
// the user here with ?u=<image url>. The widget itself is SharePanel.astro,
// rendered SERVER-SIDE here (populated + visible, zero layout shift); only the QR
// canvas + copy/watermark handlers run on the client. The URL is validated on our
// own hosts (see lib/share-url.ts) before it's used as an <img src>, in snippets,
// and in the QR — guarding against reflected content / XSS.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ToolAdSurround from '../components/ToolAdSurround.astro';
import SharePanel from '../components/SharePanel.astro';
import SharePanelMulti from '../components/SharePanelMulti.astro';
import { getValidUrls } from '../lib/share-url';

// Never cache at the CDN (per-?u=) and keep it out of the index.
Astro.response.headers.set('Cache-Control', 'private, no-store');

// One image → ?u=<url>; a bulk upload → repeated ?u= params (+ &skipped=N for
// files that didn't fit the daily quota). Validate/dedupe every URL and cap the
// count (keeps the query string small and bounds the list).
const MAX_SHARE_URLS = 25;
const urls = getValidUrls(Astro.url.searchParams.getAll('u')).slice(0, MAX_SHARE_URLS);
const skipped = Number(Astro.url.searchParams.get('skipped')) || 0;
const single = urls.length === 1 ? urls[0] : undefined;
---

<Layout
  title="Image URL Copied — ImageToURL"
  description="Your image URL is ready. Copy it as a direct link, Markdown, HTML, or BBCode, scan the QR code, or upload another image. Guest links expire; signed-in links can be kept forever."
  noindex={true}
  noHreflang
  eagerAds
>
  <Nav />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    {urls.length > 0 ? (
      <Fragment>
        <!-- Valid link(s): the share panel renders populated + visible server-side,
             flanked by the tool ad rails. One URL → the rich single panel; several
             (a bulk upload) → the multi-image list. -->
        <ToolAdSurround>
          {single
            ? <SharePanel url={single} copyDelayMs={1500} />
            : <SharePanelMulti urls={urls} skipped={skipped} copyDelayMs={1500} />}
          <div class="max-w-xl mx-auto mt-6 text-center">
            <a href="/" class="font-label text-xs font-bold uppercase tracking-wider text-primary hover:underline">← Upload another image</a>
          </div>
        </ToolAdSurround>

        <!-- Publisher content (kept at the BOTTOM, below the share panel). This is
             real, useful guidance about the link the visitor just created — it turns
             /share from a bare "dead-end / Thank-You" screen into a content page, so
             the ad units above are valuable-inventory compliant (Google forbids ads
             on no-content screens). -->
        <section class="max-w-3xl mx-auto mt-14 sm:mt-16">
          <h2 class="text-2xl sm:text-3xl font-headline font-bold text-on-surface tracking-tight">Make the most of your image link</h2>
          <p class="text-on-surface-variant mt-3 leading-relaxed">
            Your image is now hosted on a fast global CDN and reachable from a single short
            URL. Here is how to use that link, where it works best, and how long it lasts.
          </p>

          <div class="grid sm:grid-cols-3 gap-4 mt-8">
            <div class="bg-surface border border-outline-variant/40 brutal-shadow p-5">
              <span class="inline-flex items-center justify-center w-10 h-10 bg-rose-50 text-rose-600 border border-outline-variant/40">
                <Icon name="link" class="text-xl" fill />
              </span>
              <h3 class="text-base font-bold text-on-surface mt-3">Four ready formats</h3>
              <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
                Copy the plain <strong>Direct URL</strong> for anywhere a link works, or grab the
                <strong>Markdown</strong>, <strong>HTML</strong>, or <strong>BBCode</strong> snippet to
                embed the image inline. The QR code carries the same link to a phone.
              </p>
            </div>
            <div class="bg-surface border border-outline-variant/40 brutal-shadow p-5">
              <span class="inline-flex items-center justify-center w-10 h-10 bg-rose-50 text-rose-600 border border-outline-variant/40">
                <Icon name="public" class="text-xl" fill />
              </span>
              <h3 class="text-base font-bold text-on-surface mt-3">Where it works</h3>
              <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
                Paste it into forum posts, GitHub READMEs and issues, Discord and Slack,
                marketplace listings, email signatures, support tickets, or anywhere that
                accepts an image URL but not a file upload.
              </p>
            </div>
            <div class="bg-surface border border-outline-variant/40 brutal-shadow p-5">
              <span class="inline-flex items-center justify-center w-10 h-10 bg-rose-50 text-rose-600 border border-outline-variant/40">
                <Icon name="schedule" class="text-xl" fill />
              </span>
              <h3 class="text-base font-bold text-on-surface mt-3">How long it lasts</h3>
              <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">
                Guest uploads stay live until the monthly cleanup, with at least about two weeks before removal. <a href="/" class="text-primary hover:underline">Sign in</a>
                before uploading to keep your links forever and manage every image from your
                dashboard.
              </p>
            </div>
          </div>

          <h2 class="text-xl sm:text-2xl font-headline font-bold text-on-surface tracking-tight mt-12">Common questions</h2>
          <div class="mt-4 divide-y divide-outline-variant/40 border-y border-outline-variant/40">
            <details class="group py-4">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-on-surface">
                <h3 class="m-0 font-semibold">Is the link free, and how long does it last?</h3>
                <Icon name="expand_more" class="text-xl text-on-surface-variant transition-transform group-open:rotate-180" />
              </summary>
              <p class="text-sm text-on-surface-variant mt-2 leading-relaxed">
                Hosting is free with no account required. Guest links auto-expire at the monthly cleanup, with at least about two weeks before removal; sign in before uploading and your links can stay forever.
              </p>
            </details>
            <details class="group py-4">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-on-surface">
                <h3 class="m-0 font-semibold">Can I share the image without the watermark?</h3>
                <Icon name="expand_more" class="text-xl text-on-surface-variant transition-transform group-open:rotate-180" />
              </summary>
              <p class="text-sm text-on-surface-variant mt-2 leading-relaxed">
                Yes. The panel above offers both a watermarked and a clean "No watermark" version
                of the link. Pick whichever you want before you copy it.
              </p>
            </details>
            <details class="group py-4">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-on-surface">
                <h3 class="m-0 font-semibold">Which image formats are supported?</h3>
                <Icon name="expand_more" class="text-xl text-on-surface-variant transition-transform group-open:rotate-180" />
              </summary>
              <p class="text-sm text-on-surface-variant mt-2 leading-relaxed">
                JPG, PNG, WebP, GIF, and SVG up to 50MB. Need a different format or a smaller file?
                Use one of the converters below first, then upload the result.
              </p>
            </details>
          </div>

          <h2 class="text-xl sm:text-2xl font-headline font-bold text-on-surface tracking-tight mt-12">Related tools</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-4">
            <a href="/en/image-compressor/" class="flex items-center gap-2 bg-surface border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all p-3 text-sm font-medium text-on-surface">
              <Icon name="compress" class="text-lg text-rose-600" /> Image compressor
            </a>
            <a href="/en/image-resizer/" class="flex items-center gap-2 bg-surface border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all p-3 text-sm font-medium text-on-surface">
              <Icon name="crop" class="text-lg text-rose-600" /> Image resizer
            </a>
            <a href="/en/heic-to-jpg/" class="flex items-center gap-2 bg-surface border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all p-3 text-sm font-medium text-on-surface">
              <Icon name="image" class="text-lg text-rose-600" /> HEIC to JPG
            </a>
            <a href="/en/favicon-generator/" class="flex items-center gap-2 bg-surface border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all p-3 text-sm font-medium text-on-surface">
              <Icon name="star" class="text-lg text-rose-600" /> Favicon generator
            </a>
          </div>
        </section>
      </Fragment>
    ) : (
      <!-- Invalid / missing URL state -->
      <div class="text-center py-10">
        <Icon name="link_off" class="text-5xl text-outline" />
        <h1 class="text-xl font-headline italic font-black text-on-surface mt-3">No image URL</h1>
        <p class="text-on-surface-variant mt-1">This page opens after you copy an uploaded image link.</p>
        <a href="/" class="inline-block mt-5 bg-rose-600 text-white font-headline font-semibold text-sm py-3 px-6 border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide">Upload an image</a>
      </div>
    )}
  </main>

  <Footer />
</Layout>

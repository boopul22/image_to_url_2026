---
import Icon from '../components/Icon.astro';
// Standalone "URL copied" share screen. The uploaders' "Get Link" buttons send
// the user here with ?u=<image url>. The widget itself is SharePanel.astro,
// rendered SERVER-SIDE here (populated + visible, zero layout shift); only the QR
// canvas + copy/watermark handlers run on the client. The URL is validated on our
// own hosts (see lib/share-url.ts) before it's used as an <img src>, in snippets,
// and in the QR — guarding against reflected content / XSS.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ToolAdSurround from '../components/ToolAdSurround.astro';
import SharePanel from '../components/SharePanel.astro';
import { getValidUrl } from '../lib/share-url';

// Never cache at the CDN (per-?u=) and keep it out of the index.
Astro.response.headers.set('Cache-Control', 'private, no-store');

const url = getValidUrl(Astro.url.searchParams.get('u')) ?? undefined;
---

<Layout
  title="Image URL Copied — ImageToURL"
  description="Your image URL is ready. Copy it as a direct link, Markdown, HTML, or BBCode, scan the QR code, or upload another image — free, permanent hosting with no account required."
  noindex={true}
  noHreflang
>
  <Nav />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
    {url ? (
      <!-- Valid link: SharePanel renders populated + visible server-side, flanked
           by the tool ad rails. -->
      <ToolAdSurround>
        <SharePanel url={url} />
        <div class="max-w-xl mx-auto mt-6 text-center">
          <a href="/" class="font-label text-xs font-bold uppercase tracking-wider text-primary hover:underline">← Upload another image</a>
        </div>
      </ToolAdSurround>
    ) : (
      <!-- Invalid / missing URL state -->
      <div class="text-center py-10">
        <Icon name="link_off" class="text-5xl text-outline" />
        <h1 class="text-xl font-headline italic font-black text-on-surface mt-3">No image URL</h1>
        <p class="text-on-surface-variant mt-1">This page opens after you copy an uploaded image link.</p>
        <a href="/" class="inline-block mt-5 bg-rose-600 text-white font-headline font-semibold text-sm py-3 px-6 border border-outline-variant/40 brutal-shadow brutal-shadow-hover transition-all uppercase tracking-wide">Upload an image</a>
      </div>
    )}
  </main>

  <Footer />
</Layout>

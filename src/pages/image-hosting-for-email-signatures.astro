---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ImageToURL — Image Hosting for Email Signatures",
  "url": "https://imagetourl.com/image-hosting-for-email-signatures",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Host logo and headshot images for email signatures with permanent, reliable URLs."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why do email signature images sometimes appear as broken?",
      "acceptedAnswer": { "@type": "Answer", "text": "Email signature images break when the hosting service expires the URL, blocks hotlinking, or goes offline. Free image hosts like Imgur often block email client requests. ImageToURL provides permanent, direct URLs with no hotlink restrictions, so your signature images always display." }
    },
    {
      "@type": "Question",
      "name": "What image size should I use for email signatures?",
      "acceptedAnswer": { "@type": "Answer", "text": "For logos, use 200-300 pixels wide. For headshots, 100-150 pixels works best. Keep file sizes under 100KB for fast loading. Use PNG for logos with transparency or JPEG for headshot photos. Always specify width and height in your HTML to prevent layout shifts." }
    },
    {
      "@type": "Question",
      "name": "Does this work with Gmail signatures?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Gmail fully supports external image URLs in signatures. Go to Gmail Settings > Signature, click the image icon, select 'Web Address (URL)', and paste your ImageToURL link. The image will display in every email you send." }
    },
    {
      "@type": "Question",
      "name": "Will my signature images show as attachments?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. When you use an externally hosted image URL (like from ImageToURL), the image is loaded from the web when the recipient opens the email. It does not get attached to the email as a file, keeping your emails lightweight and professional." }
    },
    {
      "@type": "Question",
      "name": "Can I use the same image URL for my entire team's email signatures?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Upload your company logo once and share the same URL with your entire team. Everyone uses the same link in their signature, and if you ever need to update the logo, you can upload a new version and update the single URL." }
    }
  ]
};
---

<Layout title="Image Hosting for Email Signatures — Permanent URLs | ImageToURL" description="Host logo and headshot images for email signatures with permanent, reliable URLs. Works with Gmail, Outlook, Apple Mail, and all major email clients." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-7xl mx-auto px-3 sm:px-6 pt-8 sm:pt-16">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-8 sm:mb-20 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Email Signatures</span>
      <h1 class="text-3xl sm:text-6xl lg:text-8xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image Hosting for Email <span class="italic text-primary">Signatures.</span>
      </h1>
      <p class="text-base sm:text-xl lg:text-2xl font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload your logo or headshot and get a permanent URL that works across every email client. No broken images, no attachments, no expiring links.
      </p>
    </header>
    </div>



    <!-- Why Use External Hosting -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Why Use External Image Hosting</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">check_circle</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Images Never Break</h3>
          <p class="font-body text-on-surface-variant">Your email signature logo and headshot display correctly every single time. Permanent URLs mean no more broken image icons embarrassing you in front of clients and prospects.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">attach_file_off</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">No File Attachments</h3>
          <p class="font-body text-on-surface-variant">Externally hosted images load from the web instead of being attached to every email. This keeps your messages lightweight, avoids spam filters, and prevents the annoying "image001.png" attachment.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">devices</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Works Across All Clients</h3>
          <p class="font-body text-on-surface-variant">ImageToURL links render correctly in Gmail, Outlook, Apple Mail, Yahoo Mail, Thunderbird, and every other major email client. One URL, universal compatibility.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">all_inclusive</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Permanent URLs</h3>
          <p class="font-body text-on-surface-variant">Your image URLs never expire. Set up your email signature once, and the images will continue working in every email you have ever sent and every email you will send in the future.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Works With -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Works With Every Email Client</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">mail</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Gmail</h3>
          <p class="font-body text-on-surface-variant text-sm">Paste your ImageToURL link in Gmail's signature settings under the image URL option. Works with personal and Google Workspace accounts.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">desktop_windows</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Outlook</h3>
          <p class="font-body text-on-surface-variant text-sm">Works with Outlook desktop, Outlook.com, and Microsoft 365. Insert your image URL in the signature editor for consistent display across platforms.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">phone_iphone</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Apple Mail</h3>
          <p class="font-body text-on-surface-variant text-sm">Add your logo or headshot to Apple Mail signatures on Mac, iPhone, and iPad. The URL loads your image on every device automatically.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">bolt</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Thunderbird</h3>
          <p class="font-body text-on-surface-variant text-sm">Use HTML signatures in Thunderbird with your ImageToURL link. The image loads from the web each time, keeping your signature current.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Tips -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Email Signature Image Tips</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-8">
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">aspect_ratio</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Optimal Sizes</h3>
          <p class="font-body text-on-surface-variant">Logos: 200-300px wide. Headshots: 100-150px. Banners: 600px max width. Always specify dimensions in your HTML to prevent layout shifts when the email loads.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">image</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Best Formats</h3>
          <p class="font-body text-on-surface-variant">Use PNG for logos with transparency. Use JPEG for headshot photos. Keep file sizes under 100KB for instant loading. Avoid SVG as some email clients do not support it.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">high_quality</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Retina Ready</h3>
          <p class="font-body text-on-surface-variant">Upload images at 2x the display size for crisp rendering on high-DPI screens. A 200px display logo should be uploaded as a 400px image with the width attribute set to 200.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Why do email signature images sometimes appear as broken?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Email signature images break when the hosting service expires the URL, blocks hotlinking, or goes offline. Free image hosts like Imgur often block email client requests. ImageToURL provides permanent, direct URLs with no hotlink restrictions, so your signature images always display.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>What image size should I use for email signatures?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">For logos, use 200-300 pixels wide. For headshots, 100-150 pixels works best. Keep file sizes under 100KB for fast loading. Use PNG for logos with transparency or JPEG for headshot photos. Always specify width and height in your HTML to prevent layout shifts.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Does this work with Gmail signatures?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. Gmail fully supports external image URLs in signatures. Go to Gmail Settings, then Signature, click the image icon, select "Web Address (URL)", and paste your ImageToURL link. The image will display in every email you send.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Will my signature images show as attachments?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">No. When you use an externally hosted image URL (like from ImageToURL), the image is loaded from the web when the recipient opens the email. It does not get attached to the email as a file, keeping your emails lightweight and professional.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I use the same image URL for my entire team?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. Upload your company logo once and share the same URL with your entire team. Everyone uses the same link in their signature, and if you ever need to update the logo, you can upload a new version and update the single URL.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/image-hosting-for-newsletters" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Newsletter Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Reliable image hosting for email campaigns</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image for free with global CDN</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-url-generator" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Image URL Generator</h3>
            <p class="text-sm text-on-surface-variant">Generate shareable URLs for any image</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-8 sm:p-12 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Professional email signatures start here</h2>
        <p class="font-body text-surface/70 mb-6 sm:mb-8 max-w-lg mx-auto">Upload your logo or headshot and get a permanent URL in seconds. Works with every email client.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-8 py-4 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

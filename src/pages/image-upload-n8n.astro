---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `// Current status
// Public n8n HTTP uploads are not live yet.
//
// The active /api/upload route is used by the ImageToURL website uploader
// and requires a same-site browser request from imagetourl.cloud.
//
// Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Upload via n8n — Current Status"
  slug="image-upload-n8n"
  metaDescription="Current n8n upload status for ImageToURL. Public HTTP/API uploads are not live yet; use the website uploader today."
  h1Pre="n8n image upload"
  h1Highlight="not public yet."
  intro="n8n automation is not live yet because public API-key uploads are not open. Use the website uploader today, or contact us if your workflow needs automation access."
  lang="javascript"
  langLabel="n8n HTTP"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "n8n automation is roadmap", body: "HTTP Request uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 10 MB file cap." },
    { title: "Contact for automation", body: "If you need n8n for self-hosted workflows, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I use n8n today?", a: "No. Public HTTP/API uploads are not live yet; use the website uploader." },
    { q: "Do I need n8n Pro?", a: "No — self-hosted Community Edition is free and covers this use case fully. Pro adds SSO, audit logs, and hosted service." },
    { q: "Where do I store the API key?", a: "Do not store an ImageToURL API key yet; public API-key uploads are not live. Once available, use encrypted n8n credentials." },
    { q: "How do I handle errors?", a: "n8n can branch on non-success responses, but ImageToURL public upload automation is not live today." },
    { q: "Rate-limit retries?", a: "Website upload limits are 5 guest uploads and 25 signed-in uploads per rolling 24 hours. Public automation limits will be documented when API access opens." },
    { q: "Webhook trigger -> upload flow?", a: "Not available today through a public ImageToURL endpoint." },
    { q: "Docker / Railway / Render deploy?", a: "All three have one-click n8n templates. Railway and Render free tiers run small n8n instances comfortably." },
    { q: "Can I trigger n8n from GitHub Actions?", a: "n8n can receive GitHub Actions webhooks, but ImageToURL public upload automation is not live today." }
  ]}
  relatedSlugs={[
    { href: "/image-upload-make/", title: "Make.com", body: "Hosted alternative." },
    { href: "/image-upload-zapier/", title: "Zapier", body: "Simplest no-code option." },
    { href: "/image-hosting-api-nodejs/", title: "Node.js", body: "For n8n Function nodes." }
  ]}
/>

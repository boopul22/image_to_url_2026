---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;
function lp(path: string): string { return `/${locale}${path}`; }

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Online Image Downloader",
  "url": "https://imagetourl.cloud/image-downloader",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Free online image downloader. Upload any image and get a permanent direct download URL instantly. No signup, no watermarks.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to download an image and get a direct URL",
  "totalTime": "PT10S",
  "step": [
    { "@type": "HowToStep", "name": "Upload your image", "text": "Drag your image into the uploader or click to browse. JPG, PNG, WebP, GIF, SVG — up to 10MB." },
    { "@type": "HowToStep", "name": "Get your permanent URL", "text": "Your image is instantly hosted on Cloudflare's CDN and assigned a permanent direct download link." },
    { "@type": "HowToStep", "name": "Download or share", "text": "Copy the direct image URL and paste it anywhere — download, embed, or share with anyone." }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I download an image and get a direct URL for free?",
      "acceptedAnswer": { "@type": "Answer", "text": "Upload your image using the uploader above. In seconds you get a permanent, direct image URL hosted on our CDN. No signup required — completely free." }
    },
    {
      "@type": "Question",
      "name": "Is this image downloader free?",
      "acceptedAnswer": { "@type": "Answer", "text": "Completely free. No subscription, no watermark, no ads. Just upload and get your direct download link instantly." }
    },
    {
      "@type": "Question",
      "name": "What image formats does the downloader support?",
      "acceptedAnswer": { "@type": "Answer", "text": "We support JPG, JPEG, PNG, WebP, GIF, and SVG. Upload any of these formats and receive a permanent CDN-hosted direct URL." }
    },
    {
      "@type": "Question",
      "name": "How long does the image download URL last?",
      "acceptedAnswer": { "@type": "Answer", "text": "Image URLs are permanent and never expire unless you set an auto-delete option at upload time. Your image stays hosted indefinitely." }
    },
    {
      "@type": "Question",
      "name": "Can I download images in HD quality?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We store and serve your image exactly as uploaded — no compression, no quality loss. HD images download at full resolution, every time." }
    },
    {
      "@type": "Question",
      "name": "What is the maximum image file size?",
      "acceptedAnswer": { "@type": "Answer", "text": "Free users can upload images up to 10MB per file, covering the vast majority of web and HD images." }
    },
    {
      "@type": "Question",
      "name": "Can I hotlink the downloaded image URL on other websites?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every image URL supports hotlinking — embed it directly in any website, forum, email, or app without restrictions." }
    }
  ]
};
---

<Layout title="Image Downloader — Download Any Image by URL, Free Online | ImageToURL" description="Free online image downloader. Upload any image file and get a permanent direct download URL instantly. Supports JPG, PNG, WebP, GIF. No signup required." schema={[schema, howToSchema, faqSchema]} noHreflang>
  <Nav />
  <main>
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
      <ImageUploader />
      <header class="mb-5 sm:mb-8 reveal">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Image Downloader</span>
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
          Download any image — get a <span class="italic text-primary">permanent direct URL, free.</span>
        </h1>
        <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
          Upload your image and get a permanent, direct download link in seconds. Works for JPG, PNG, WebP, GIF and more. No signup, no watermark — the fastest free online image downloader.
        </p>
      </header>
    </div>

    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">1</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Your Image</h3>
            <p class="font-body text-on-surface-variant">Drag & drop or click to select your image file. Supports JPG, PNG, WebP, GIF, and SVG up to 10MB.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">2</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Get Your Direct URL</h3>
            <p class="font-body text-on-surface-variant">Your image is uploaded to our global CDN instantly. A permanent, direct download URL is generated in under a second.</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">3</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Download or Share</h3>
            <p class="font-body text-on-surface-variant">Copy your direct link and use it anywhere — download it, embed it on any site, or share it with anyone worldwide.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Use ImageToURL -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why This Image Downloader?</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">link</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Permanent Direct Links</h3>
            <p class="font-body text-on-surface-variant">Every image gets a real direct URL — no redirect pages, no HTML wrappers. The link resolves to raw image bytes, exactly what you need to hotlink or download.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">rocket_launch</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Global CDN Speed</h3>
            <p class="font-body text-on-surface-variant">Powered by Cloudflare's edge network with servers in 300+ cities. Your image downloads in under 100ms from anywhere in the world.</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">hd</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Full HD Quality Preserved</h3>
            <p class="font-body text-on-surface-variant">We never compress or alter your image. Download in the exact same quality as uploaded — pixel-perfect, full resolution, every time.</p>
          </div>
          <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">no_accounts</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">No Signup Required</h3>
            <p class="font-body text-on-surface-variant">Zero friction. No account, no email, no credit card. Just upload your image and get your direct download link immediately.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">developer_mode</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Developers & Designers</h3>
            <p class="font-body text-on-surface-variant">Host mockups, diagrams, and assets with CDN-backed direct URLs for any HTML, CSS, or Markdown file.</p>
          </div>
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">storefront</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Online Sellers</h3>
            <p class="font-body text-on-surface-variant">Re-host product images with permanent URLs for eBay, Craigslist, and marketplace listings that won't break.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">forum</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Forum & Community Users</h3>
            <p class="font-body text-on-surface-variant">Share images on Reddit, Discord, and forums with direct links that embed inline instead of just showing a plain URL.</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">campaign</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Email & Newsletter Creators</h3>
            <p class="font-body text-on-surface-variant">Get reliable direct image URLs for newsletters and email campaigns — CDN-hosted images load fast in every email client.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="space-y-4 reveal">
          <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              How do I download an image and get a direct URL for free?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Upload your image using the uploader above. In seconds you get a permanent, direct image URL hosted on our CDN. No signup required — completely free.</p>
            </div>
          </details>
          <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              Is this image downloader free to use?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Completely free. No subscription, no watermark, no ads. Just upload and get your direct download link instantly.</p>
            </div>
          </details>
          <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              What image formats does the downloader support?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">We support JPG, JPEG, PNG, WebP, GIF, and SVG. Upload any of these formats and receive a permanent CDN-hosted direct URL.</p>
            </div>
          </details>
          <details class="bg-surface-variant border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              How long does the download URL last?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Image URLs are permanent and never expire unless you set an auto-delete option at upload time. Your image stays hosted indefinitely on our global CDN.</p>
            </div>
          </details>
          <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              Can I download images in HD / high resolution?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Yes. We store and serve your image exactly as uploaded — no compression, no quality loss. HD images download at full resolution, every time.</p>
            </div>
          </details>
          <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              What is the maximum image file size I can upload?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Free users can upload images up to 10MB per file, covering the vast majority of web and HD images including high-resolution JPGs and PNGs.</p>
            </div>
          </details>
          <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
            <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
              Can I hotlink the downloaded image URL on other websites?
              <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5">
              <p class="font-body text-on-surface-variant">Yes. Every image URL supports hotlinking — embed it directly in any website, forum, email, or app without restrictions.</p>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <a href="/image-extractor" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">Image Extractor</h3>
              <p class="font-body text-on-surface-variant text-sm">Extract images from any website URL</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
          <a href="/photo-downloader" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">Photo Downloader</h3>
              <p class="font-body text-on-surface-variant text-sm">Save any photo by link instantly</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
          <a href="/direct-image-link" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">Direct Image Link</h3>
              <p class="font-body text-on-surface-variant text-sm">Get a hotlinkable direct URL for any image</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="reveal">
          <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">Download your image and get a permanent URL now</h2>
            <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload any image and get a direct download link in seconds. No signup, no limits, no catch.</p>
            <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
              Upload Image Now
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

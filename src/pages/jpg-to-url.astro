---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "JPG to URL Converter",
  "url": "https://imagetourl.cloud/jpg-to-url",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Convert JPG and JPEG images to shareable URLs instantly. Fast, free, and permanent.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What's the maximum JPG file size I can upload?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Free users can upload JPG images up to 2MB. With a free account, the limit increases to 10MB — more than enough for most photos."
      }
    },
    {
      "@type": "Question",
      "name": "Does ImageToURL compress my JPG images?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Your JPG files are stored and served exactly as uploaded. We never re-compress or alter your image quality."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between JPG and JPEG?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no difference — JPG and JPEG are the same format. The shorter .jpg extension exists because older Windows systems required three-letter extensions. ImageToURL supports both."
      }
    },
    {
      "@type": "Question",
      "name": "Can I hotlink my JPG images on other websites?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every JPG upload generates a direct image URL that supports hotlinking. Embed it in any website, forum, or email without restrictions."
      }
    },
    {
      "@type": "Question",
      "name": "How fast are JPG images served?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your images are served from a global CDN with edge servers worldwide. Most users experience load times under 100ms regardless of location."
      }
    }
  ]
};
---

<Layout title="JPG to URL — Convert JPEG Images to Shareable Links | ImageToURL" description="Convert JPG and JPEG images to shareable URLs instantly. Universal compatibility, fast loading, and permanent direct links. Free, no signup required." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">JPG Converter</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Convert JPG to URL <span class="italic text-primary">fast and free.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload any JPG or JPEG image and get a permanent, shareable URL instantly. Universal compatibility, fast CDN delivery, and zero quality loss — all for free.
      </p>
    </header>
    </div>



    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">1</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Your JPG</h3>
          <p class="font-body text-on-surface-variant">Drag & drop or click to select your JPG or JPEG file. Supports high-resolution photos up to 10MB.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">2</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Get Your URL</h3>
          <p class="font-body text-on-surface-variant">Your JPG is uploaded to our global CDN instantly. A permanent, direct image URL is generated automatically.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">3</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Share Anywhere</h3>
          <p class="font-body text-on-surface-variant">Copy your URL and use it anywhere — blogs, emails, forums, social media, or embed it in your website.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Why JPG? -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why JPG?</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">devices</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Universal Compatibility</h3>
          <p class="font-body text-on-surface-variant">JPG is the most widely supported image format. Works everywhere — every browser, every device, every platform.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">compress</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Optimized File Size</h3>
          <p class="font-body text-on-surface-variant">JPG compression delivers excellent quality at smaller file sizes, meaning faster page loads and quicker sharing.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">photo_camera</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Perfect for Photos</h3>
          <p class="font-body text-on-surface-variant">JPG excels at handling photographic images with millions of colors and smooth gradients.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">email</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Email-Friendly</h3>
          <p class="font-body text-on-surface-variant">JPG images embed perfectly in email clients, newsletters, and email signatures without compatibility issues.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">edit_note</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Bloggers & Writers</h3>
          <p class="font-body text-on-surface-variant">Embed photos in blog posts, articles, and content management systems with permanent URLs.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">campaign</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Email Marketers</h3>
          <p class="font-body text-on-surface-variant">Host newsletter images and email signature photos with reliable, fast-loading URLs.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">groups</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Social Media Managers</h3>
          <p class="font-body text-on-surface-variant">Share product photos, event images, and promotional content as direct links.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">house</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Real Estate Agents</h3>
          <p class="font-body text-on-surface-variant">Host property listing photos for MLS, Zillow, and classified ad platforms.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="space-y-4 reveal">
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            What's the maximum JPG file size I can upload?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Free users can upload JPG images up to 2MB. With a free account, the limit increases to 10MB — more than enough for most photos.</p>
          </div>
        </details>
        <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Does ImageToURL compress my JPG images?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">No. Your JPG files are stored and served exactly as uploaded. We never re-compress or alter your image quality.</p>
          </div>
        </details>
        <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            What's the difference between JPG and JPEG?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">There is no difference — JPG and JPEG are the same format. The shorter .jpg extension exists because older Windows systems required three-letter extensions. ImageToURL supports both.</p>
          </div>
        </details>
        <details class="bg-surface-variant border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Can I hotlink my JPG images on other websites?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes. Every JPG upload generates a direct image URL that supports hotlinking. Embed it in any website, forum, or email without restrictions.</p>
          </div>
        </details>
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            How fast are JPG images served?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Your images are served from a global CDN with edge servers worldwide. Most users experience load times under 100ms regardless of location.</p>
          </div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <a href="/png-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">PNG to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Convert PNG images with transparency preserved</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/webp-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">WebP to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Convert modern WebP images to shareable links</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/bulk-image-upload" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">Bulk Image Upload</h3>
            <p class="font-body text-on-surface-variant text-sm">Upload multiple images at once</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Convert your JPG to a shareable URL</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload your photo and get a permanent link in seconds. No signup, no compression, no catch.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload JPG Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

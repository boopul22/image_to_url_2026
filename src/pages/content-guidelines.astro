---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;
function lp(path: string): string { return `/${locale}${path}`; }

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Content Guidelines - ImageToURL",
  "description": "Content guidelines and acceptable use policy for ImageToURL's free image hosting platform.",
  "url": "https://imagetourl.cloud/content-guidelines"
};
---

<Layout title="Content Guidelines - ImageToURL" description="Read ImageToURL's content guidelines. Learn what content is allowed and prohibited on our free image hosting platform." schema={schema} noHreflang>
  <Nav />

  <main class="max-w-5xl mx-auto px-3 sm:px-6 py-8 sm:py-16">
    <!-- Hero -->
    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Guidelines</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Content <span class="italic text-primary">Guidelines.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        ImageToURL is built for everyone. To keep it safe, we have clear rules about what can and cannot be hosted on our platform.
      </p>
    </header>

    <!-- Prohibited Content -->
    <section class="mb-10 sm:mb-24">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Prohibited Content</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 reveal">
        <div class="bg-error-container border-2 border-error p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-error rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-error text-2xl">block</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Adult &amp; Sexual Content</h3>
          <p class="font-body text-on-error-container text-sm">Pornographic, sexually explicit, or nudity-containing images are strictly prohibited. This includes both real and AI-generated content.</p>
        </div>
        <div class="bg-error-container border-2 border-error p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-error rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-error text-2xl">dangerous</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Violence &amp; Hate Speech</h3>
          <p class="font-body text-on-error-container text-sm">Graphic violence, gore, hate symbols, or content promoting discrimination based on race, gender, religion, or any protected characteristic.</p>
        </div>
        <div class="bg-error-container border-2 border-error p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-error rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-error text-2xl">gavel</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Illegal Content</h3>
          <p class="font-body text-on-error-container text-sm">Any content that violates local or international laws, including child exploitation material (CSAM), drug trafficking, or terrorism-related content.</p>
        </div>
        <div class="bg-error-container border-2 border-error p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-error rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-error text-2xl">copyright</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Copyright Violations</h3>
          <p class="font-body text-on-error-container text-sm">Images you don't own or have permission to use. Watermark removal, pirated content, and trademark infringement are all prohibited.</p>
        </div>
      </div>
    </section>

    <!-- Acceptable Content -->
    <section class="mb-10 sm:mb-24">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Acceptable Content</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 reveal">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-secondary text-2xl">business</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Business &amp; Professional</h3>
          <p class="font-body text-on-surface-variant text-sm">Product photos, company logos, marketing materials, presentations, infographics, and professional portfolio images.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-secondary text-2xl">school</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Educational &amp; Creative</h3>
          <p class="font-body text-on-surface-variant text-sm">Tutorials, diagrams, artwork, photography, illustrations, memes, and original creative works.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-secondary text-2xl">group</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Personal &amp; Social</h3>
          <p class="font-body text-on-surface-variant text-sm">Personal photos, screenshots, social media images, profile pictures, and everyday life photography.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <div class="w-14 h-14 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5">
            <span class="material-symbols-outlined text-secondary text-2xl">code</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-black font-headline mb-2">Web &amp; Technical</h3>
          <p class="font-body text-on-surface-variant text-sm">Website assets, app screenshots, UI mockups, code snippets as images, and technical documentation graphics.</p>
        </div>
      </div>
    </section>

    <!-- Content Moderation -->
    <section class="mb-10 sm:mb-24">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Content Moderation</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-10 rounded-xl hard-shadow max-w-3xl reveal">
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-white border-2 border-on-background rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-tertiary text-2xl">smart_toy</span>
          </div>
          <div>
            <h3 class="text-xl sm:text-2xl font-black font-headline mb-3">Automated AI-Powered Moderation</h3>
            <p class="font-body text-on-surface-variant mb-4">All uploaded images pass through our automated content moderation system. This AI-powered system scans images in real-time to detect prohibited content before it becomes publicly accessible.</p>
            <p class="font-body text-on-surface-variant">Flagged images are reviewed and removed promptly. Our moderation system is continuously updated to improve accuracy and minimize false positives.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Consequences -->
    <section class="mb-10 sm:mb-24">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Consequences of Violations</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 reveal">
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <span class="inline-block px-3 py-1 bg-white border-2 border-on-background rounded-full text-xs font-bold font-label uppercase tracking-widest mb-4">Tier 1</span>
          <h3 class="text-xl font-black font-headline mb-2">First Violation</h3>
          <p class="font-body text-on-surface-variant text-sm">Content is removed and a warning is issued. The offending image URL is permanently disabled.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow">
          <span class="inline-block px-3 py-1 bg-white border-2 border-on-background rounded-full text-xs font-bold font-label uppercase tracking-widest mb-4">Tier 2</span>
          <h3 class="text-xl font-black font-headline mb-2">Repeat Violations</h3>
          <p class="font-body text-on-surface-variant text-sm">Temporary account suspension and all uploaded content reviewed. Access restricted for a period determined by severity.</p>
        </div>
        <div class="bg-error-container border-2 border-error p-4 sm:p-5 rounded-xl hard-shadow">
          <span class="inline-block px-3 py-1 bg-white border-2 border-error rounded-full text-xs font-bold font-label uppercase tracking-widest mb-4 text-error">Tier 3</span>
          <h3 class="text-xl font-black font-headline mb-2">Severe Violations</h3>
          <p class="font-body text-on-error-container text-sm">Permanent ban, all content removed, and potential referral to law enforcement for illegal content such as CSAM.</p>
        </div>
      </div>
    </section>

    <!-- Report Violations -->
    <section class="mb-10 sm:mb-24">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Report a Violation</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="bg-surface border-2 border-on-background p-6 sm:p-10 rounded-xl hard-shadow max-w-3xl reveal">
        <p class="font-body text-on-surface-variant mb-4">If you encounter content that violates these guidelines, please report it immediately so we can take action.</p>
        <p class="font-body text-on-surface-variant mb-6">Send reports to <a href="mailto:blog.boopul@gmail.com" class="text-primary font-bold hover:underline">blog.boopul@gmail.com</a> with the following information:</p>
        <ul class="space-y-2 font-body text-on-surface-variant text-sm list-disc list-inside mb-6">
          <li>The URL of the offending image</li>
          <li>A description of the violation</li>
          <li>The guideline category it falls under</li>
          <li>Your contact information (optional)</li>
        </ul>
        <p class="font-body text-on-surface-variant text-sm">We review all reports within 24 hours and take swift action on confirmed violations.</p>
      </div>
    </section>

    <!-- Footer links + CTA -->
    <section class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline mb-4">Questions about our policies?</h2>
        <p class="text-surface/70 mb-8 max-w-lg mx-auto">Review our full legal documents for more information.</p>
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href={lp('/privacy')} class="inline-flex items-center gap-2 bg-surface text-on-surface px-6 py-3 border-2 border-on-background font-label text-xs font-bold uppercase tracking-wider hard-shadow-hover active:scale-95 transition-all">
            Privacy Policy
          </a>
          <a href={lp('/terms')} class="inline-flex items-center gap-2 bg-surface text-on-surface px-6 py-3 border-2 border-on-background font-label text-xs font-bold uppercase tracking-wider hard-shadow-hover active:scale-95 transition-all">
            Terms of Service
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-xs font-bold uppercase tracking-wider hard-shadow-hover active:scale-95 transition-all">
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

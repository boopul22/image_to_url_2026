---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PNG to URL Converter",
  "url": "https://imagetourl.cloud/png-to-url",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Convert PNG images to shareable URLs instantly with transparency preserved.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Does ImageToURL preserve PNG transparency?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we store your PNG files exactly as uploaded — no compression, no conversion, no quality loss. Transparency is fully preserved."
      }
    },
    {
      "@type": "Question",
      "name": "What's the maximum PNG file size?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Free users can upload PNGs up to 2MB. With a free account, the limit increases to 10MB."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get a direct link to my PNG?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every upload generates a direct image URL (ending in .png) that you can hotlink, embed, or share anywhere."
      }
    },
    {
      "@type": "Question",
      "name": "How long do PNG URLs last?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your image URLs are permanent and never expire. Once uploaded, your PNG is hosted indefinitely."
      }
    },
    {
      "@type": "Question",
      "name": "Is PNG to URL conversion free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Completely free. No signup required, no watermarks, no ads. Just upload and get your link."
      }
    }
  ]
};
---

<Layout title="PNG to URL — Convert PNG Images to Shareable Links | ImageToURL" description="Convert PNG images to shareable URLs instantly. Preserve transparency, lossless quality, and get permanent direct links. Free, no signup required." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">PNG Converter</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Convert PNG to URL <span class="italic text-primary">with transparency preserved.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload any PNG image and get a permanent, shareable URL in seconds. Transparency, lossless quality, and every pixel preserved — completely free.
      </p>
    </header>
    </div>



    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">1</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Your PNG</h3>
          <p class="font-body text-on-surface-variant">Drag & drop or click to select your PNG file. Supports transparent and high-resolution PNGs up to 10MB.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">2</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Get Your URL</h3>
          <p class="font-body text-on-surface-variant">Your PNG is uploaded to our global CDN instantly. A permanent, direct image URL is generated automatically.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-2xl sm:text-3xl font-black font-headline">3</div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Share Anywhere</h3>
          <p class="font-body text-on-surface-variant">Copy your URL and use it anywhere — HTML, Markdown, forums, emails, or social media.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Why PNG? -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why PNG?</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">layers</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Transparency Support</h3>
          <p class="font-body text-on-surface-variant">PNG is the gold standard for images with transparent backgrounds. Logos, icons, overlays — all preserved perfectly.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">high_quality</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Lossless Quality</h3>
          <p class="font-body text-on-surface-variant">Unlike JPG, PNG uses lossless compression. Your image quality is preserved pixel-for-pixel, exactly as uploaded.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">web</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Web Graphics Standard</h3>
          <p class="font-body text-on-surface-variant">PNG is universally supported across all browsers, devices, and platforms. The most reliable format for web graphics.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">print</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Print-Ready Resolution</h3>
          <p class="font-body text-on-surface-variant">High-resolution PNGs maintain sharp detail for both screen display and print-quality output.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">palette</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Web Designers</h3>
          <p class="font-body text-on-surface-variant">Host logos, icons, and UI assets with transparency intact for seamless website integration.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">description</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Documentation Writers</h3>
          <p class="font-body text-on-surface-variant">Embed crisp screenshots and diagrams in Markdown, Notion, and GitHub READMEs.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">storefront</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">E-Commerce Sellers</h3>
          <p class="font-body text-on-surface-variant">Product images with transparent backgrounds for eBay, Amazon, and Shopify listings.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">code</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Developers</h3>
          <p class="font-body text-on-surface-variant">Host interface mockups, architecture diagrams, and API documentation images.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="space-y-4 reveal">
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Does ImageToURL preserve PNG transparency?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes, we store your PNG files exactly as uploaded — no compression, no conversion, no quality loss. Transparency is fully preserved.</p>
          </div>
        </details>
        <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            What's the maximum PNG file size?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Free users can upload PNGs up to 2MB. With a free account, the limit increases to 10MB.</p>
          </div>
        </details>
        <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Can I get a direct link to my PNG?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes. Every upload generates a direct image URL (ending in .png) that you can hotlink, embed, or share anywhere.</p>
          </div>
        </details>
        <details class="bg-surface-variant border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            How long do PNG URLs last?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Your image URLs are permanent and never expire. Once uploaded, your PNG is hosted indefinitely.</p>
          </div>
        </details>
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Is PNG to URL conversion free?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Completely free. No signup required, no watermarks, no ads. Just upload and get your link.</p>
          </div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <a href="/jpg-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">JPG to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Convert JPEG photos to shareable links</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/gif-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">GIF to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Host animated GIFs with direct URLs</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">Free Image Hosting</h3>
            <p class="font-body text-on-surface-variant text-sm">Host any image format for free</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Convert your PNG to a shareable URL</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload your PNG and get a permanent link in seconds. No signup, no watermarks, no catch.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload PNG Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ImageToURL — Image URL Generator",
  "url": "https://imagetourl.cloud/image-url-generator",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Generate instant URLs for your images. Upload any image and get a permanent, shareable link in seconds.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};
---

<Layout title="Image URL Generator - Convert Images to URLs Instantly | ImageToURL" description="Generate instant URLs for your images with ImageToURL. Upload any image and get a permanent, shareable link in seconds. Perfect for developers, bloggers, and content creators." schema={schema} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">URL Generator</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image URL Generator <span class="italic text-primary">in seconds.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload any image and instantly convert it into a permanent, shareable URL. No software to install, no accounts to create — just fast, reliable link generation.
      </p>
    </header>
    </div>



    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">01</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">upload</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Your Image</h3>
          <p class="font-body text-on-surface-variant">Drag and drop your image or click to browse your files. We support JPG, PNG, WebP, GIF, and SVG formats.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">02</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">link</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Instant URL Generation</h3>
          <p class="font-body text-on-surface-variant">Your unique image URL is generated in milliseconds. No waiting, no processing queues — it is ready the moment your upload completes.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">03</span>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">share</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Copy & Share</h3>
          <p class="font-body text-on-surface-variant">Use your image URL anywhere on the web. Paste it in emails, embed it in websites, or share it on social media.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Features -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Features</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">bolt</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Instant Generation</h3>
          <p class="font-body text-on-surface-variant">URLs are ready in under a second. Our infrastructure processes your upload and generates a permanent link almost instantly.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">all_inclusive</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Permanent URLs</h3>
          <p class="font-body text-on-surface-variant">Links that never expire or break. Once generated, your image URL will work forever — no time limits, no expiration dates.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">dynamic_feed</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Bulk URL Generator</h3>
          <p class="font-body text-on-surface-variant">Need URLs for multiple images? Upload a batch and generate all your links at once. Perfect for large projects and media libraries.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">share</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Easy Sharing</h3>
          <p class="font-body text-on-surface-variant">Copy your URL with one click, grab an embed code, or share directly. Every URL works everywhere — websites, forums, messaging apps, and more.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">code</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Web Developers</h3>
          <p class="font-body text-on-surface-variant text-sm">Embed image URLs directly in your code, README files, or documentation.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">forum</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Forum Users</h3>
          <p class="font-body text-on-surface-variant text-sm">Share images on Reddit, Discord, Stack Overflow, and any forum that supports image links.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">thumb_up</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Social Media</h3>
          <p class="font-body text-on-surface-variant text-sm">Generate shareable image links for any social media platform or messaging app.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">edit_note</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Content Creators</h3>
          <p class="font-body text-on-surface-variant text-sm">Use image URLs in blogs, newsletters, email campaigns, and online publications.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image format for free with CDN delivery</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/bulk-image-upload" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Bulk Image Upload</h3>
            <p class="text-sm text-on-surface-variant">Upload multiple images and get all URLs at once</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/screenshot-to-url" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Screenshot to URL</h3>
            <p class="text-sm text-on-surface-variant">Share screenshots as links instantly</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Generate your first image URL</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload an image and get a permanent, shareable link in seconds. No signup required.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Get Started Free
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

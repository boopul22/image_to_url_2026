---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ImageToURL — Image Hosting for Forums",
  "url": "https://imagetourl.cloud/image-hosting-for-forums",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Host images for forum posts with BBCode and HTML support. Direct image links for phpBB, vBulletin, Reddit, and all forums."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is BBCode image hosting?",
      "acceptedAnswer": { "@type": "Answer", "text": "BBCode is a markup language used by many forums like phpBB and vBulletin. To embed an image, you wrap a direct image URL in [img] tags: [img]https://your-image-url[/img]. ImageToURL provides the direct image URLs needed for BBCode to work correctly." }
    },
    {
      "@type": "Question",
      "name": "Why do forum image hosts show ads or pop-ups?",
      "acceptedAnswer": { "@type": "Answer", "text": "Many free image hosting services generate revenue by showing ads on their image pages or injecting pop-ups when someone clicks an image link. ImageToURL provides clean, direct image links with zero ads, pop-ups, or interstitials. Your images are served directly without any intermediary pages." }
    },
    {
      "@type": "Question",
      "name": "Will my forum images stay online permanently?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. ImageToURL provides permanent hosting for all uploaded images. Forum threads can stay active for years, and your images will continue to display correctly for as long as the thread exists. There are no expiration dates or automatic deletion policies." }
    },
    {
      "@type": "Question",
      "name": "Does ImageToURL work with Reddit?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. While Reddit has its own image hosting, ImageToURL links work perfectly in Reddit posts and comments using Markdown syntax: ![description](https://your-image-url). This is especially useful for subreddits that allow direct image links and for commenting with images." }
    },
    {
      "@type": "Question",
      "name": "Can I upload screenshots from games and software?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. ImageToURL supports all common image formats including PNG (perfect for screenshots with text), JPEG (for photos), GIF (for animated content), and WebP. Upload your screenshots and get direct links ready to paste into any forum post." }
    }
  ]
};
---

<Layout title="Free Image Hosting for Forum Posts | ImageToURL" description="Host images for forum posts with BBCode and HTML support. Direct image links that work on phpBB, vBulletin, Reddit, and all forum platforms." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Forum Users</span>
      <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image Hosting for Forum <span class="italic text-primary">Posts.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload your images and get direct links ready for BBCode, HTML, and Markdown. No ads, no pop-ups, no expiring URLs. Just clean image hosting for any forum.
      </p>
    </header>
    </div>



    <!-- Why Forum Users Love Us -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why Forum Users Love ImageToURL</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">link</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Direct Image Links</h3>
          <p class="font-body text-on-surface-variant">Every upload gives you a clean, direct URL that points to the image file itself. No landing pages, no redirects. Paste it into any forum and the image displays inline immediately.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">code</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">BBCode and HTML Ready</h3>
          <p class="font-body text-on-surface-variant">Get your image URL formatted for any forum system. Works with BBCode [img] tags for phpBB and vBulletin, HTML img tags for modern forums, and Markdown syntax for Reddit and Discourse.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">block</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Zero Ads</h3>
          <p class="font-body text-on-surface-variant">No pop-ups, no interstitials, no banner ads, no sponsored content. Other image hosts force users to navigate through ads to see your image. ImageToURL serves images directly and cleanly.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">all_inclusive</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Permanent Hosting</h3>
          <p class="font-body text-on-surface-variant">Forum threads live for years. Your images will too. No auto-deletion after 90 days, no inactive account purges. Every image URL you create works forever.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Embed Code Examples -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Embed Code Examples</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <h3 class="text-base sm:text-lg font-black font-headline mb-4">BBCode</h3>
          <code class="block bg-on-background/10 p-4 rounded-lg font-mono text-sm break-all">[img]https://imagetourl.cloud/your-image.png[/img]</code>
          <p class="font-body text-on-surface-variant mt-4 text-sm">For phpBB, vBulletin, SMF, MyBB, and other traditional forum platforms that support BBCode markup.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <h3 class="text-base sm:text-lg font-black font-headline mb-4">HTML</h3>
          <code class="block bg-on-background/10 p-4 rounded-lg font-mono text-sm break-all">&lt;img src="https://imagetourl.cloud/your-image.png" alt="Description"&gt;</code>
          <p class="font-body text-on-surface-variant mt-4 text-sm">For forums that allow HTML in posts, custom signatures, and any web-based platform that renders standard HTML.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <h3 class="text-base sm:text-lg font-black font-headline mb-4">Markdown</h3>
          <code class="block bg-on-background/10 p-4 rounded-lg font-mono text-sm break-all">![Description](https://imagetourl.cloud/your-image.png)</code>
          <p class="font-body text-on-surface-variant mt-4 text-sm">For Reddit, Discourse, GitHub Discussions, and any modern forum or platform that uses Markdown formatting.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">forum</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">phpBB Forums</h3>
          <p class="font-body text-on-surface-variant text-sm">Upload images and paste BBCode [img] tags directly into phpBB posts and signatures for inline image display.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">chat</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">vBulletin</h3>
          <p class="font-body text-on-surface-variant text-sm">Direct image URLs work perfectly with vBulletin's BBCode image embedding. No hotlink restrictions or broken thumbnails.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">reddit</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Reddit</h3>
          <p class="font-body text-on-surface-variant text-sm">Share images in Reddit posts and comments using Markdown links. Permanent URLs that work across every subreddit.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">hub</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Discourse</h3>
          <p class="font-body text-on-surface-variant text-sm">Modern Discourse forums render ImageToURL links automatically as inline images. Works in posts, replies, and topic descriptions.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>What is BBCode image hosting?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">BBCode is a markup language used by many forums like phpBB and vBulletin. To embed an image, you wrap a direct image URL in [img] tags: [img]https://your-image-url[/img]. ImageToURL provides the direct image URLs needed for BBCode to work correctly.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Why do forum image hosts show ads or pop-ups?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Many free image hosting services generate revenue by showing ads on their image pages or injecting pop-ups when someone clicks an image link. ImageToURL provides clean, direct image links with zero ads, pop-ups, or interstitials. Your images are served directly without any intermediary pages.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Will my forum images stay online permanently?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. ImageToURL provides permanent hosting for all uploaded images. Forum threads can stay active for years, and your images will continue to display correctly for as long as the thread exists. There are no expiration dates or automatic deletion policies.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Does ImageToURL work with Reddit?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. While Reddit has its own image hosting, ImageToURL links work perfectly in Reddit posts and comments using Markdown syntax: ![description](https://your-image-url). This is especially useful for subreddits that allow direct image links and for commenting with images.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I upload screenshots from games and software?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. ImageToURL supports all common image formats including PNG (perfect for screenshots with text), JPEG (for photos), GIF (for animated content), and WebP. Upload your screenshots and get direct links ready to paste into any forum post.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/image-hosting-for-discord" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Discord Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Permanent embed links for Discord servers</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-hosting-for-ebay" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">eBay Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Product image URLs for eBay listings</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image for free with global CDN</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">Get your images forum-ready in seconds</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload an image, get a direct URL with BBCode, HTML, and Markdown embed codes. No ads, no signup.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

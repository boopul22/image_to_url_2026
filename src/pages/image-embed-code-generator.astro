---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Image Embed Code Generator - ImageToURL",
  "description": "Upload an image and get ready-to-use embed codes in HTML, BBCode, and Markdown. Free embed code generator.",
  "url": "https://imagetourl.cloud/image-embed-code-generator",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What embed code formats does ImageToURL generate?",
      "acceptedAnswer": { "@type": "Answer", "text": "ImageToURL generates embed codes in three formats: HTML (img tags for websites), BBCode (for forums like phpBB and vBulletin), and Markdown (for GitHub, GitLab, documentation sites, and note-taking apps)." }
    },
    {
      "@type": "Question",
      "name": "Can I customize the embed code?",
      "acceptedAnswer": { "@type": "Answer", "text": "The generated embed codes use your image URL with standard formatting. You can freely modify the generated code to add custom classes, alt text, dimensions, or styling before pasting it into your project." }
    },
    {
      "@type": "Question",
      "name": "Which forums support BBCode image embedding?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most traditional forums support BBCode, including phpBB, vBulletin, XenForo, Discourse, and many others. BBCode image tags use the [img] syntax that these platforms recognize and render as inline images." }
    },
    {
      "@type": "Question",
      "name": "Will the embedded image always work?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. ImageToURL provides permanent image URLs backed by a global CDN. Once embedded, your image will load reliably from any location. The URLs never expire, so your embedded images will continue working indefinitely." }
    },
    {
      "@type": "Question",
      "name": "Can I use the Markdown code in GitHub README files?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Our Markdown image syntax works perfectly in GitHub README files, GitLab wikis, Notion pages, Obsidian notes, and any other platform that renders Markdown." }
    }
  ]
};
---

<Layout title="Image Embed Code Generator — HTML, BBCode & Markdown | ImageToURL" description="Upload an image and get ready-to-use embed codes in HTML, BBCode, and Markdown. Free embed code generator for websites, forums, and documentation." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-7xl mx-auto px-3 sm:px-6 pt-8 sm:pt-16">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-8 sm:mb-20 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Embed Codes</span>
      <h1 class="text-3xl sm:text-6xl lg:text-8xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image Embed Code <span class="italic text-primary">Generator.</span>
      </h1>
      <p class="text-base sm:text-xl lg:text-2xl font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Upload an image and get instant embed codes in HTML, BBCode, and Markdown. Copy, paste, done. Ready for websites, forums, documentation, and more.
      </p>
    </header>
    </div>



    <!-- Supported Formats -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Supported Embed Formats</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">code</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">HTML</h3>
          <p class="font-body text-on-surface-variant mb-4">Standard img tags for any website, blog, or web application. Works with every browser and CMS.</p>
          <div class="bg-on-surface text-surface rounded-lg p-4 font-mono text-xs sm:text-sm overflow-x-auto">
            <code>&lt;img src="your-url" alt="Image"&gt;</code>
          </div>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">forum</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">BBCode</h3>
          <p class="font-body text-on-surface-variant mb-4">Forum-compatible image tags for phpBB, vBulletin, XenForo, Discourse, and other forum platforms.</p>
          <div class="bg-on-surface text-surface rounded-lg p-4 font-mono text-xs sm:text-sm overflow-x-auto">
            <code>[img]your-url[/img]</code>
          </div>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">edit_note</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Markdown</h3>
          <p class="font-body text-on-surface-variant mb-4">Markdown syntax for GitHub READMEs, GitLab wikis, Notion, Obsidian, and documentation sites.</p>
          <div class="bg-on-surface text-surface rounded-lg p-4 font-mono text-xs sm:text-sm overflow-x-auto">
            <code>![Image](your-url)</code>
          </div>
        </div>
      </div>
    </div>
    </section>

    <!-- How It Works -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">01</span>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">upload</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Upload Your Image</h3>
          <p class="font-body text-on-surface-variant">Drag and drop any image file or click to browse. We support JPG, PNG, WebP, GIF, and SVG formats.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">02</span>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">data_object</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Choose Your Format</h3>
          <p class="font-body text-on-surface-variant">Pick the embed code format you need: HTML for websites, BBCode for forums, or Markdown for docs and READMEs.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <span class="inline-block font-black font-headline text-4xl sm:text-5xl opacity-15 mb-3">03</span>
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">content_paste</span>
          </div>
          <h3 class="text-lg sm:text-2xl font-black font-headline mb-2">Copy & Paste</h3>
          <p class="font-body text-on-surface-variant">Click to copy the embed code to your clipboard, then paste it wherever you need it. The image displays inline automatically.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Code Examples -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Code Examples</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="space-y-5 sm:space-y-8 reveal">
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow">
          <h3 class="text-lg sm:text-xl font-black font-headline mb-4">HTML Embed</h3>
          <div class="bg-on-surface text-green-400 rounded-lg p-4 sm:p-6 font-mono text-xs sm:text-sm overflow-x-auto leading-relaxed">
            <div class="text-surface/50 mb-1">&lt;!-- Basic image embed --&gt;</div>
            <div>&lt;img src=<span class="text-amber-300">"https://imagetourl.cloud/i/abc123.png"</span> alt=<span class="text-amber-300">"My image"</span>&gt;</div>
            <div class="mt-4 text-surface/50">&lt;!-- With dimensions --&gt;</div>
            <div>&lt;img src=<span class="text-amber-300">"https://imagetourl.cloud/i/abc123.png"</span> alt=<span class="text-amber-300">"My image"</span> width=<span class="text-amber-300">"800"</span> height=<span class="text-amber-300">"600"</span>&gt;</div>
            <div class="mt-4 text-surface/50">&lt;!-- Responsive image --&gt;</div>
            <div>&lt;img src=<span class="text-amber-300">"https://imagetourl.cloud/i/abc123.png"</span> alt=<span class="text-amber-300">"My image"</span> style=<span class="text-amber-300">"max-width:100%;height:auto"</span>&gt;</div>
          </div>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow">
          <h3 class="text-lg sm:text-xl font-black font-headline mb-4">BBCode Embed</h3>
          <div class="bg-on-surface text-green-400 rounded-lg p-4 sm:p-6 font-mono text-xs sm:text-sm overflow-x-auto leading-relaxed">
            <div class="text-surface/50 mb-1">Basic forum image:</div>
            <div>[img]<span class="text-amber-300">https://imagetourl.cloud/i/abc123.png</span>[/img]</div>
            <div class="mt-4 text-surface/50">With size (supported on some forums):</div>
            <div>[img width=800]<span class="text-amber-300">https://imagetourl.cloud/i/abc123.png</span>[/img]</div>
          </div>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow">
          <h3 class="text-lg sm:text-xl font-black font-headline mb-4">Markdown Embed</h3>
          <div class="bg-on-surface text-green-400 rounded-lg p-4 sm:p-6 font-mono text-xs sm:text-sm overflow-x-auto leading-relaxed">
            <div class="text-surface/50 mb-1"># GitHub README / Documentation:</div>
            <div>![<span class="text-amber-300">Screenshot of feature</span>](<span class="text-amber-300">https://imagetourl.cloud/i/abc123.png</span>)</div>
            <div class="mt-4 text-surface/50"># With link wrapping:</div>
            <div>[![<span class="text-amber-300">Click to visit</span>](<span class="text-amber-300">https://imagetourl.cloud/i/abc123.png</span>)](<span class="text-amber-300">https://example.com</span>)</div>
          </div>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-8">
        <div class="bg-secondary-container border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">rss_feed</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Bloggers</h3>
          <p class="font-body text-on-surface-variant text-sm">Embed images in blog posts with proper HTML tags. Works with WordPress, Ghost, Hugo, and every blogging platform.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">forum</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Forum Users</h3>
          <p class="font-body text-on-surface-variant text-sm">Get BBCode image tags ready to paste into any forum post. Your images display inline without external links.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">terminal</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Developers</h3>
          <p class="font-body text-on-surface-variant text-sm">Markdown image syntax for README files, pull request descriptions, and project documentation on GitHub and GitLab.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-6 sm:p-8 rounded-xl hard-shadow reveal">
          <div class="w-14 sm:w-16 h-14 sm:h-16 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-5 sm:mb-6">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">menu_book</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Wiki Editors</h3>
          <p class="font-body text-on-surface-variant text-sm">Add images to wiki articles, knowledge bases, and collaborative documentation with the right embed format.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="max-w-3xl reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>What embed code formats does ImageToURL generate?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">ImageToURL generates embed codes in three formats: HTML (img tags for websites), BBCode (for forums like phpBB and vBulletin), and Markdown (for GitHub, GitLab, documentation sites, and note-taking apps).</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I customize the embed code?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">The generated embed codes use your image URL with standard formatting. You can freely modify the generated code to add custom classes, alt text, dimensions, or styling before pasting it into your project.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Which forums support BBCode image embedding?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Most traditional forums support BBCode, including phpBB, vBulletin, XenForo, Discourse, and many others. BBCode image tags use the [img] syntax that these platforms recognize and render as inline images.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Will the embedded image always work?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. ImageToURL provides permanent image URLs backed by a global CDN. Once embedded, your image will load reliably from any location. The URLs never expire, so your embedded images will continue working indefinitely.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I use the Markdown code in GitHub README files?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. Our Markdown image syntax works perfectly in GitHub README files, GitLab wikis, Notion pages, Obsidian notes, and any other platform that renders Markdown.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-10 sm:py-20">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-6 sm:mb-10 reveal">
        <h2 class="text-xl sm:text-4xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/direct-image-link" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Direct Image Links</h3>
            <p class="text-sm text-on-surface-variant">Clean, hotlinkable URLs for any image</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-url-generator" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Image URL Generator</h3>
            <p class="text-sm text-on-surface-variant">Generate shareable URLs for any image</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image format for free</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-10 sm:py-20 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-7xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-8 sm:p-12 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Generate your embed code now</h2>
        <p class="font-body text-surface/70 mb-6 sm:mb-8 max-w-lg mx-auto">Upload an image and get HTML, BBCode, or Markdown embed codes instantly. Free, no signup required.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-8 py-4 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

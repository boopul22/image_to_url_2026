---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public cURL/API-key uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Hosting API — cURL Status"
  slug="image-hosting-api-curl"
  metaDescription="Current cURL/API upload status for ImageToURL. Public API-key uploads are not live yet; use the website uploader today."
  h1Pre="Image hosting API"
  h1Highlight="not public yet."
  intro="The public cURL upload flow is not live yet. The current upload endpoint powers the website uploader and rejects non-same-site automation requests."
  lang="bash"
  langLabel="cURL"
  codeSnippet={code}
  whys={[
    { title: "Website path is live", body: "Use the main uploader today for guest links, signed-in keep-forever links, copy formats, and dashboard history." },
    { title: "Automation is roadmap", body: "cURL, CI, and shell uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 10 MB file cap." },
    { title: "Contact for access", body: "If automation is important for your workflow, contact us and we can review the request." }
  ]}
  faqs={[
    { q: "Can I upload with cURL today?", a: "No. Public API-key uploads are not live yet; use the website uploader." },
    { q: "Can I use this in GitHub Actions?", a: "Not reliably until public API-key access is enabled." },
    { q: "What are the live limits?", a: "Guests get 100 uploads per rolling 24 hours. Signed-in users get 150 credits per day (about 1 credit per MB). Max file size is 10 MB." },
    { q: "Can I bulk upload today?", a: "Use the website bulk uploader, not a public REST script." },
    { q: "How do I get higher limits?", a: "Contact us with your workflow and expected volume." },
    { q: "Will cURL docs return later?", a: "Yes, once public bearer-token upload access is live." }
  ]}
  relatedSlugs={[
    { href: "/image-hosting-api-python/", title: "Python", body: "Python snippet." },
    { href: "/image-upload-zapier/", title: "Zapier", body: "No-code integration." },
    { href: "/image-upload-api/", title: "API overview", body: "Full endpoint docs." }
  ]}
/>

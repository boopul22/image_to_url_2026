---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public API-key uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and accepts same-site browser requests from imagetourl.cloud.
#
# Use the web uploader today. Treat API-key upload examples as roadmap
# until public bearer-token access is enabled.`;
---
<DevApiPage
  title="Image Upload Endpoint — Current Status"
  slug="image-upload-api"
  metaDescription="Current ImageToURL upload endpoint status: website uploads are live; public API-key uploads are not live yet."
  h1Pre="Image Upload Endpoint"
  h1Highlight="website uploads are live; public API is roadmap."
  intro="ImageToURL currently supports uploads through the website uploader. The underlying /api/upload route is guarded for same-site browser requests, so public bearer-token uploads should not be treated as live production API access yet."
  lang="bash"
  langLabel="cURL"
  codeSnippet={code}
  whys={[
    { title: "Website uploader is live", body: "Use the main uploader today for guest links, signed-in keep-forever links, copy formats, and dashboard history." },
    { title: "Same response shape internally", body: "The website endpoint returns JSON with success, data.url, filename, size, mimetype, and created_at when uploads succeed." },
    { title: "Clear storage behavior", body: "Guest links auto-expire at the monthly cleanup. Signed-in users can choose \"Never delete\" before upload for links that stay live." },
    { title: "Cloudflare-backed CDN", body: "Uploaded files are served from a fast Cloudflare-backed path on imagetourl.cloud." }
  ]}
  faqs={[
    { q: "Do I need an API key?", a: "No public upload API key is available today. Signed-in website uploads use your normal session cookie." },
    { q: "What's the max file size?", a: "50 MB per upload." },
    { q: "Is there a rate limit?", a: "Guests get 100 uploads per rolling 24 hours. Signed-in users get 150 credits per day (about 1 credit per MB)." },
    { q: "How do I delete an upload?", a: "Signed-in users can delete their own uploads from the dashboard." },
    { q: "Supported formats?", a: "PNG, JPG, WebP, GIF, SVG, and MP3. Use the browser conversion tools first for HEIC, PDF, or format changes." },
    { q: "Does the endpoint return responsive variants?", a: "No. Use the image tools before upload or the /img route helpers used by the site." },
    { q: "CORS?", a: "POST uploads are restricted to same-site browser requests from imagetourl.cloud." },
    { q: "Webhooks on upload?", a: "No public webhook feature is live today." }
  ]}
  relatedSlugs={[
    { href: "/image-hosting-api-python/", title: "Python", body: "Python requests snippet." },
    { href: "/image-hosting-api-nodejs/", title: "Node.js", body: "Node fetch snippet." },
    { href: "/image-hosting-rest-api/", title: "REST API", body: "Full endpoint docs." }
  ]}
/>

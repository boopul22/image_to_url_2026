---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import Icon from '../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout
  title="Image Library"
  activePage="images"
  eyebrow="Media"
  heading="Image library"
  subtitle="Every uploaded asset across the platform."
>
  <label slot="actions" class="a-btn a-btn-primary cursor-pointer">
    <Icon name="upload" size={16} /> Upload
    <input type="file" accept="image/*" multiple class="hidden" id="admin-upload-input" />
  </label>

  <div class="flex items-center justify-between gap-3 mb-4">
    <p class="text-xs a-subtle" id="total-count">— assets</p>
    <p class="text-xs a-subtle hidden sm:flex items-center gap-1.5"><Icon name="upload-cloud" size={15} /> Drop files anywhere to upload</p>
  </div>

  <!-- drop zone wraps the grid -->
  <div id="drop-zone" class="rounded-[14px] transition-colors" style="outline: 2px dashed transparent; outline-offset: 4px;">
    <div id="images-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 sm:gap-4">
      <div class="col-span-full a-card a-card-pad text-center a-subtle"><p class="text-sm">Loading images…</p></div>
    </div>
  </div>

  <div id="pagination" class="flex justify-center items-center gap-1.5 pt-6"></div>
</AdminLayout>

<script>
  const ICON_LINK = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>';
  const ICON_COPY = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>';
  const ICON_TRASH = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>';
  const ICON_PLUS = '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s ?? '';
    return d.innerHTML;
  }

  let currentPage = 1;

  function showToast(message: string) {
    document.querySelector('.admin-toast')?.remove();
    const t = document.createElement('div');
    t.className = 'admin-toast';
    t.textContent = message;
    t.setAttribute('style', 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:var(--a-fg);color:#fff;padding:.65rem 1.1rem;border-radius:10px;font-size:.8125rem;font-weight:550;z-index:60;box-shadow:0 8px 24px rgba(0,0,0,.18);transition:opacity .3s');
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2000);
  }

  async function loadImages(page: number) {
    const res = await fetch(`/api/admin/images?page=${page}`);
    const data = await res.json();
    currentPage = page;
    document.getElementById('total-count')!.textContent = `${data.total.toLocaleString()} assets`;

    const grid = document.getElementById('images-grid')!;
    if (!data.images?.length) {
      grid.innerHTML = '<div class="col-span-full a-card a-card-pad text-center a-subtle"><p class="text-sm">No images yet</p></div>';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }

    grid.innerHTML = data.images.map((img: any) => `
      <div class="a-card overflow-hidden group">
        <div class="relative aspect-[4/3] overflow-hidden" style="background:var(--a-surface-2)">
          <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
          <span class="a-badge a-badge-solid" style="position:absolute;top:.5rem;right:.5rem;text-transform:uppercase">${esc((img.mime_type || '/').split('/')[1] || '?')}</span>
        </div>
        <div class="p-3.5">
          <p class="text-sm font-semibold truncate" style="color:var(--a-fg)" title="${esc(img.filename)}">${esc(img.filename)}</p>
          <div class="flex items-center justify-between text-[11px] a-subtle mt-1">
            <span>${new Date(img.created_at).toLocaleDateString()}</span>
            <span class="a-num">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</span>
          </div>
          <div class="flex items-center gap-1.5 mt-3">
            <a href="${esc(img.url)}" target="_blank" rel="noopener" class="a-btn a-btn-sm flex-1" title="Open">${ICON_LINK}<span>Open</span></a>
            <button onclick="copyUrl('${esc(img.url)}')" class="a-btn a-btn-sm a-btn-icon" title="Copy URL">${ICON_COPY}</button>
            <button onclick="deleteImage('${esc(img.id)}')" class="a-btn a-btn-sm a-btn-icon a-btn-danger" title="Delete">${ICON_TRASH}</button>
          </div>
        </div>
      </div>`).join('') + `
      <button id="quick-upload-card" class="a-card flex flex-col items-center justify-center p-8 min-h-[240px] cursor-pointer transition-colors" style="border-style:dashed;color:var(--a-muted)">
        <span class="flex items-center justify-center w-12 h-12 rounded-full mb-3" style="background:var(--a-surface-2);border:1px solid var(--a-border)">${ICON_PLUS}</span>
        <p class="text-sm font-semibold" style="color:var(--a-fg)">Quick upload</p>
        <p class="text-xs a-subtle mt-0.5 text-center">Click or drop files to add</p>
      </button>`;

    document.getElementById('quick-upload-card')?.addEventListener('click', () =>
      document.getElementById('admin-upload-input')?.click());

    const pag = document.getElementById('pagination')!;
    if (data.totalPages > 1) {
      const btn = (p: number, label: string, disabled = false, active = false) =>
        `<button onclick="loadPage(${p})" class="a-btn a-btn-sm a-btn-icon ${active ? 'a-btn-primary' : ''}" ${disabled ? 'disabled' : ''}>${label}</button>`;
      let html = btn(Math.max(1, page - 1), '‹', page === 1);
      for (let p = 1; p <= Math.min(data.totalPages, 5); p++) html += btn(p, String(p), false, p === page);
      if (data.totalPages > 5) html += `<span class="a-subtle px-1">…</span>` + btn(data.totalPages, String(data.totalPages), false, data.totalPages === page);
      html += btn(Math.min(data.totalPages, page + 1), '›', page === data.totalPages);
      pag.innerHTML = html;
    } else { pag.innerHTML = ''; }
  }

  (window as any).copyUrl = (url: string) => navigator.clipboard.writeText(url).then(() => showToast('URL copied'));
  (window as any).loadPage = (page: number) => loadImages(page);
  (window as any).deleteImage = async (id: string) => {
    if (!confirm('Delete this image permanently?')) return;
    await fetch('/api/admin/images', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    showToast('Image deleted');
    loadImages(currentPage);
  };

  async function uploadFiles(files: FileList | File[]) {
    const list = Array.from(files).filter(f => f.type.startsWith('image/'));
    if (!list.length) return;
    showToast(`Uploading ${list.length} file${list.length > 1 ? 's' : ''}…`);
    for (const file of list) {
      const form = new FormData();
      form.append('file', file);
      await fetch('/api/upload', { method: 'POST', body: form });
    }
    showToast('Upload complete');
    loadImages(1);
  }

  document.getElementById('admin-upload-input')?.addEventListener('change', (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files?.length) uploadFiles(files);
  });

  // Drag-and-drop anywhere over the drop zone
  const dz = document.getElementById('drop-zone')!;
  const setDrag = (on: boolean) => { dz.style.outlineColor = on ? 'var(--a-fg)' : 'transparent'; dz.style.background = on ? 'var(--a-surface-2)' : 'transparent'; };
  ['dragenter', 'dragover'].forEach(ev => dz.addEventListener(ev, (e) => { e.preventDefault(); setDrag(true); }));
  ['dragleave', 'drop'].forEach(ev => dz.addEventListener(ev, (e) => { e.preventDefault(); if (ev === 'dragleave' && dz.contains((e as DragEvent).relatedTarget as Node)) return; setDrag(false); }));
  dz.addEventListener('drop', (e) => { const dt = (e as DragEvent).dataTransfer; if (dt?.files?.length) uploadFiles(dt.files); });

  loadImages(1);
</script>

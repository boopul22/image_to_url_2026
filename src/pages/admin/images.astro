---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import AdminSidebar from '../../components/AdminSidebar.astro';
---

<Layout title="Image Library - Admin - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="images" />

    <main class="flex-1 p-8 space-y-6 bg-surface-container-lowest min-h-[calc(100vh-65px)]">
      <!-- Header -->
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-4xl font-headline italic font-black text-on-surface">Image Library</h1>
          <p class="text-on-surface-variant mt-1">Manage, curate, and optimize your global media assets with ease.</p>
        </div>
        <label class="bg-primary text-on-primary px-6 py-3 rounded-lg font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 transition-all cursor-pointer flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">upload</span>
          Upload New Assets
          <input type="file" accept="image/*" multiple class="hidden" id="admin-upload-input" />
        </label>
      </div>

      <!-- Filters -->
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-2 px-3 py-2 border-2 border-on-surface rounded-lg bg-surface">
            <span class="material-symbols-outlined text-sm text-outline">calendar_today</span>
            <input type="text" placeholder="mm/dd/yyyy" class="bg-transparent text-sm w-24 focus:outline-none font-body" />
          </div>
          <div class="flex gap-1" id="type-filters">
            <button class="px-3 py-1.5 rounded-full border-2 border-on-surface text-[10px] font-bold uppercase bg-on-surface text-surface" data-type="all">All</button>
            <button class="px-3 py-1.5 rounded-full border-2 border-on-surface text-[10px] font-bold uppercase bg-surface hover:bg-surface-container-highest transition-colors" data-type="jpg">JPG</button>
            <button class="px-3 py-1.5 rounded-full border-2 border-on-surface text-[10px] font-bold uppercase bg-surface hover:bg-surface-container-highest transition-colors" data-type="png">PNG</button>
            <button class="px-3 py-1.5 rounded-full border-2 border-on-surface text-[10px] font-bold uppercase bg-surface hover:bg-surface-container-highest transition-colors" data-type="webp">WebP</button>
            <button class="px-3 py-1.5 rounded-full border-2 border-on-surface text-[10px] font-bold uppercase bg-surface hover:bg-surface-container-highest transition-colors" data-type="gif">GIF</button>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm text-on-surface-variant" id="total-count">— assets total</span>
          <div class="flex border-2 border-on-surface rounded-lg overflow-hidden">
            <button class="p-2 bg-on-surface text-surface" id="view-grid">
              <span class="material-symbols-outlined text-lg">grid_view</span>
            </button>
            <button class="p-2 bg-surface hover:bg-surface-container-highest transition-colors" id="view-list">
              <span class="material-symbols-outlined text-lg">view_list</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Image Grid -->
      <div id="images-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        <div class="col-span-full p-12 text-center text-outline">
          <span class="material-symbols-outlined text-5xl">hourglass_empty</span>
          <p class="font-label text-xs uppercase mt-3">Loading images...</p>
        </div>
      </div>

      <!-- Pagination -->
      <div id="pagination" class="flex justify-center items-center gap-2 pt-4"></div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  let currentPage = 1;

  async function loadImages(page: number, search = '') {
    const params = new URLSearchParams({ page: String(page) });
    if (search) params.set('search', search);

    const res = await fetch(`/api/admin/images?${params}`);
    const data = await res.json();
    currentPage = page;

    document.getElementById('total-count')!.textContent = `${data.total.toLocaleString()} assets total`;

    const grid = document.getElementById('images-grid')!;
    if (!data.images?.length) {
      grid.innerHTML = '<div class="col-span-full p-12 text-center text-outline"><span class="material-symbols-outlined text-5xl">image</span><p class="font-label text-xs uppercase mt-3">No images found</p></div>';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }

    grid.innerHTML = data.images.map((img: any) => `
      <div class="bg-surface border-2 border-on-surface rounded-xl overflow-hidden hard-shadow group hover:-translate-y-1 transition-all">
        <div class="h-44 bg-surface-container-highest overflow-hidden relative">
          <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async" />
          <span class="absolute top-2 right-2 bg-on-surface/80 text-surface text-[10px] font-bold uppercase px-2 py-0.5 rounded-full">${esc(img.mime_type.split('/')[1])}</span>
        </div>
        <div class="p-4 space-y-2">
          <h3 class="font-bold text-sm truncate" title="${esc(img.filename)}">${esc(img.filename)}</h3>
          <div class="flex items-center justify-between text-[10px] text-outline uppercase tracking-wider">
            <span>Date: ${new Date(img.created_at).toLocaleDateString()}</span>
            <span>Size: ${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</span>
          </div>
          <div class="flex items-center justify-between pt-2">
            <button onclick="copyUrl('${esc(img.url)}')" class="text-primary font-label text-xs font-bold flex items-center gap-1 hover:underline">
              View Details <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
            <button onclick="deleteImage('${esc(img.id)}')" class="text-error hover:text-on-error hover:bg-error w-7 h-7 rounded-full flex items-center justify-center transition-colors">
              <span class="material-symbols-outlined text-sm">delete</span>
            </button>
          </div>
        </div>
      </div>
    `).join('') + `
      <div class="bg-surface border-2 border-dashed border-outline rounded-xl flex flex-col items-center justify-center p-8 hover:border-primary hover:bg-primary/5 transition-all cursor-pointer group min-h-[280px]" id="quick-upload-card">
        <div class="w-14 h-14 rounded-full bg-surface-container-highest border-2 border-outline flex items-center justify-center mb-4 group-hover:border-primary group-hover:bg-primary/10 transition-colors">
          <span class="material-symbols-outlined text-2xl text-outline group-hover:text-primary transition-colors">add</span>
        </div>
        <p class="font-headline italic text-lg font-bold text-on-surface mb-1">Quick Upload</p>
        <p class="text-xs text-outline text-center">Drag and drop to start processing</p>
      </div>
    `;

    document.getElementById('quick-upload-card')?.addEventListener('click', () => {
      document.getElementById('admin-upload-input')?.click();
    });

    // Pagination
    const pag = document.getElementById('pagination')!;
    if (data.totalPages > 1) {
      let html = `<button onclick="loadPage(${Math.max(1, page - 1)})" class="w-9 h-9 border-2 border-on-surface rounded-lg flex items-center justify-center hover:bg-surface-container-highest transition-colors ${page === 1 ? 'opacity-30' : ''}"><span class="material-symbols-outlined text-sm">chevron_left</span></button>`;
      for (let p = 1; p <= Math.min(data.totalPages, 5); p++) {
        html += `<button onclick="loadPage(${p})" class="w-9 h-9 border-2 border-on-surface rounded-lg flex items-center justify-center font-label text-xs font-bold ${p === page ? 'bg-primary text-on-primary' : 'bg-surface hover:bg-surface-container-highest'} transition-colors">${p}</button>`;
      }
      if (data.totalPages > 5) html += `<span class="px-2 text-outline">...</span><button onclick="loadPage(${data.totalPages})" class="w-9 h-9 border-2 border-on-surface rounded-lg flex items-center justify-center font-label text-xs font-bold bg-surface hover:bg-surface-container-highest transition-colors">${data.totalPages}</button>`;
      html += `<button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="w-9 h-9 border-2 border-on-surface rounded-lg flex items-center justify-center hover:bg-surface-container-highest transition-colors ${page === data.totalPages ? 'opacity-30' : ''}"><span class="material-symbols-outlined text-sm">chevron_right</span></button>`;
      pag.innerHTML = html;
    } else {
      pag.innerHTML = '';
    }
  }

  (window as any).copyUrl = (url: string) => navigator.clipboard.writeText(url);
  (window as any).loadPage = (page: number) => loadImages(page);
  (window as any).deleteImage = async (id: string) => {
    if (!confirm('Delete this image permanently?')) return;
    await fetch('/api/admin/images', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    loadImages(currentPage);
  };

  document.getElementById('admin-upload-input')?.addEventListener('change', async (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (!files?.length) return;
    for (const file of files) {
      const form = new FormData();
      form.append('file', file);
      await fetch('/api/upload', { method: 'POST', body: form });
    }
    loadImages(1);
  });

  loadImages(1);
</script>

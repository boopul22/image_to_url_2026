---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout
  title="Reviews"
  activePage="reviews"
  eyebrow="Moderation"
  heading="Reviews"
  subtitle="Approve, feature, or remove user-submitted reviews shown on the homepage."
>
  <!-- Status tabs -->
  <div class="a-tabs mb-5" id="review-tabs" role="tablist">
    <button data-status="pending"  class="a-tab is-active" role="tab" aria-selected="true">Pending</button>
    <button data-status="approved" class="a-tab" role="tab" aria-selected="false">Approved</button>
    <button data-status="rejected" class="a-tab" role="tab" aria-selected="false">Rejected</button>
    <button data-status=""         class="a-tab" role="tab" aria-selected="false">All</button>
  </div>

  <div id="reviews-list" class="space-y-3">
    <div class="a-card a-card-pad text-center" style="color: var(--a-subtle);">
      <p class="text-sm">Loading…</p>
    </div>
  </div>
</AdminLayout>

<script>
  const listEl = document.getElementById('reviews-list')!;
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.a-tab'));
  let currentStatus = 'pending';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s ?? '';
    return d.innerHTML;
  }

  function stars(n: number): string {
    const filled = '★'.repeat(n), empty = '☆'.repeat(5 - n);
    return `<span style="color:var(--a-fg);letter-spacing:1px;font-size:13px">${filled}<span style="color:var(--a-subtle)">${empty}</span></span>`;
  }

  function statusBadge(status: string): string {
    const map: Record<string, string> = {
      pending: 'a-badge-warn', approved: 'a-badge-ok', rejected: 'a-badge-danger',
    };
    return `<span class="a-badge ${map[status] || ''}">${esc(status)}</span>`;
  }

  function actionsFor(r: any): string {
    const btn = (action: string, label: string, cls: string) =>
      `<button data-id="${r.id}" data-action="${action}" class="rv-action a-btn a-btn-sm ${cls}">${label}</button>`;
    const out: string[] = [];
    if (r.status !== 'approved') out.push(btn('approve', 'Approve', 'a-btn-primary'));
    if (r.status !== 'rejected') out.push(btn('reject', 'Reject', ''));
    out.push(btn(r.featured ? 'unfeature' : 'feature', r.featured ? 'Unfeature' : 'Feature', ''));
    out.push(btn('delete', 'Delete', 'a-btn-danger'));
    return out.join('');
  }

  function render(reviews: any[]) {
    if (!reviews.length) {
      listEl.innerHTML = `<div class="a-card a-card-pad text-center" style="color: var(--a-subtle);"><p class="text-sm">No reviews here.</p></div>`;
      return;
    }
    listEl.innerHTML = reviews.map((r) => `
      <div class="a-card a-card-pad flex flex-col gap-3" data-row="${r.id}">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center text-xs font-semibold" style="background:var(--a-surface-2);border:1px solid var(--a-border);color:var(--a-text)">
              ${r.avatar_url ? `<img src="${esc(r.avatar_url)}" referrerpolicy="no-referrer" class="w-full h-full object-cover" onerror="this.remove()"/>` : esc((r.name || '?').slice(0, 1))}
            </div>
            <div class="min-w-0">
              <p class="font-semibold text-sm truncate" style="color:var(--a-fg)">${esc(r.name)}${r.role ? ` <span style="color:var(--a-muted);font-weight:400">· ${esc(r.role)}</span>` : ''}</p>
              <p class="text-xs mt-0.5" style="color:var(--a-subtle)">${esc(r.created_at)}</p>
            </div>
          </div>
          <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
            ${stars(r.rating)}
            <div class="flex items-center gap-1.5">${r.featured ? '<span class="a-badge a-badge-solid">Featured</span>' : ''}${statusBadge(r.status)}</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed" style="color:var(--a-text)">${esc(r.body)}</p>
        <div class="flex flex-wrap gap-2 pt-1">${actionsFor(r)}</div>
      </div>`).join('');
  }

  async function load() {
    listEl.innerHTML = `<div class="a-card a-card-pad text-center" style="color: var(--a-subtle);"><p class="text-sm">Loading…</p></div>`;
    const res = await fetch(`/api/admin/reviews?status=${encodeURIComponent(currentStatus)}`);
    const data = await res.json();
    render(data.reviews || []);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      currentStatus = tab.dataset.status || '';
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', String(active));
      });
      load();
    });
  });

  listEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.rv-action');
    if (!btn) return;
    const { id, action } = btn.dataset;
    if (action === 'delete' && !confirm('Delete this review permanently?')) return;
    btn.disabled = true;
    await fetch('/api/admin/reviews', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, action }),
    });
    load();
  });

  load();
</script>

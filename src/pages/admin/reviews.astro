---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import AdminSidebar from '../../components/AdminSidebar.astro';
---

<Layout title="Reviews - Admin - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="reviews" />

    <main class="flex-1 p-4 sm:p-6 md:p-8 space-y-4 sm:space-y-6 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-xl sm:text-2xl font-headline italic font-black text-on-surface">Reviews</h1>
          <p class="text-on-surface-variant mt-1">Approve, feature, or remove user-submitted reviews shown on the homepage.</p>
        </div>
      </div>

      <!-- Status tabs -->
      <div class="flex items-center gap-2" id="review-tabs">
        <button data-status="pending" class="review-tab bg-primary text-on-primary px-4 py-2 rounded-lg font-label text-xs font-bold uppercase tracking-wider border border-outline-variant/40">Pending</button>
        <button data-status="approved" class="review-tab bg-surface text-on-surface-variant px-4 py-2 rounded-lg font-label text-xs font-bold uppercase tracking-wider border border-outline-variant/40">Approved</button>
        <button data-status="rejected" class="review-tab bg-surface text-on-surface-variant px-4 py-2 rounded-lg font-label text-xs font-bold uppercase tracking-wider border border-outline-variant/40">Rejected</button>
        <button data-status="" class="review-tab bg-surface text-on-surface-variant px-4 py-2 rounded-lg font-label text-xs font-bold uppercase tracking-wider border border-outline-variant/40">All</button>
      </div>

      <div id="reviews-list" class="space-y-3">
        <div class="p-8 text-center text-outline">
          <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
          <p class="font-label text-xs uppercase mt-2">Loading...</p>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  const listEl = document.getElementById('reviews-list')!;
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.review-tab'));
  let currentStatus = 'pending';

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s ?? '';
    return d.innerHTML;
  }

  function stars(n: number): string {
    return '★★★★★☆☆☆☆☆'.slice(5 - n, 10 - n);
  }

  function actionsFor(r: any): string {
    const btn = (action: string, label: string, cls: string) =>
      `<button data-id="${r.id}" data-action="${action}" class="rv-action ${cls} px-3 py-1.5 rounded-lg font-label text-[11px] font-bold uppercase tracking-wider border border-outline-variant/40">${label}</button>`;
    const out: string[] = [];
    if (r.status !== 'approved') out.push(btn('approve', 'Approve', 'bg-primary text-on-primary'));
    if (r.status !== 'rejected') out.push(btn('reject', 'Reject', 'bg-surface text-on-surface-variant'));
    out.push(btn(r.featured ? 'unfeature' : 'feature', r.featured ? 'Unfeature' : 'Feature', 'bg-surface text-on-surface-variant'));
    out.push(btn('delete', 'Delete', 'bg-surface text-error'));
    return out.join(' ');
  }

  function render(reviews: any[]) {
    if (!reviews.length) {
      listEl.innerHTML = `<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No reviews here.</p></div>`;
      return;
    }
    listEl.innerHTML = reviews
      .map(
        (r) => `
      <div class="bg-surface border border-outline-variant/40 rounded-xl p-4 sm:p-5 flex flex-col gap-3" data-row="${r.id}">
        <div class="flex items-start justify-between gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-9 h-9 rounded-full overflow-hidden bg-primary-fixed flex-shrink-0 flex items-center justify-center text-xs font-black">
              ${r.avatar_url ? `<img src="${esc(r.avatar_url)}" referrerpolicy="no-referrer" class="w-full h-full object-cover" onerror="this.remove()"/>` : esc((r.name || '?').slice(0, 1))}
            </div>
            <div class="min-w-0">
              <p class="font-bold text-sm truncate">${esc(r.name)}${r.role ? ` · <span class="text-on-surface-variant font-normal">${esc(r.role)}</span>` : ''}</p>
              <p class="text-xs text-on-surface-variant">${esc(r.created_at)} · ${r.featured ? 'Featured · ' : ''}<span class="uppercase">${esc(r.status)}</span></p>
            </div>
          </div>
          <span class="text-amber-500 text-sm flex-shrink-0" title="${r.rating}/5">${stars(r.rating)}</span>
        </div>
        <p class="font-body text-sm text-on-surface leading-relaxed">${esc(r.body)}</p>
        <div class="flex flex-wrap gap-2 pt-1">${actionsFor(r)}</div>
      </div>`,
      )
      .join('');
  }

  async function load() {
    listEl.innerHTML = `<div class="p-8 text-center text-outline"><span class="material-symbols-outlined text-4xl">hourglass_empty</span></div>`;
    const res = await fetch(`/api/admin/reviews?status=${encodeURIComponent(currentStatus)}`);
    const data = await res.json();
    render(data.reviews || []);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      currentStatus = tab.dataset.status || '';
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('bg-primary', active);
        t.classList.toggle('text-on-primary', active);
        t.classList.toggle('bg-surface', !active);
        t.classList.toggle('text-on-surface-variant', !active);
      });
      load();
    });
  });

  listEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.rv-action');
    if (!btn) return;
    const { id, action } = btn.dataset;
    if (action === 'delete' && !confirm('Delete this review permanently?')) return;
    btn.disabled = true;
    await fetch('/api/admin/reviews', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id, action }),
    });
    load();
  });

  load();
</script>

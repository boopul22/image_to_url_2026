---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import Icon from '../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout
  title="Users"
  activePage="users"
  eyebrow="People"
  heading="User management"
  subtitle="Manage permissions and administrative access."
>
  <!-- Search -->
  <div class="relative mb-4 max-w-md">
    <span class="absolute left-3 top-1/2 -translate-y-1/2 a-subtle pointer-events-none"><Icon name="search" size={17} /></span>
    <input id="search-input" type="text" placeholder="Search by name or email…" class="a-input" style="padding-left:2.25rem" />
  </div>

  <!-- Users table -->
  <div id="users-table" class="a-card overflow-hidden">
    <div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div>
  </div>

  <!-- Pagination -->
  <div class="flex items-center justify-between gap-3 mt-4 flex-wrap">
    <p class="text-xs a-subtle" id="showing-text"></p>
    <div id="pagination" class="flex gap-2"></div>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 mt-6" id="user-stats">
    <div class="a-card a-card-pad">
      <div class="flex items-center gap-2 a-muted mb-2"><Icon name="trending-up" size={16} /><span class="a-stat-label">Growth</span></div>
      <p class="text-sm" style="color:var(--a-text)" id="growth-text">Loading…</p>
    </div>
    <div class="a-card a-card-pad">
      <div class="flex items-center gap-2 a-muted mb-2"><Icon name="users" size={16} /><span class="a-stat-label">Accounts</span></div>
      <p class="text-sm" style="color:var(--a-text)" id="conversion-text">All sign-ins via Google OAuth.</p>
    </div>
    <div class="a-card a-card-pad">
      <div class="flex items-center gap-2 a-muted mb-2"><Icon name="shield" size={16} /><span class="a-stat-label">Security</span></div>
      <p class="text-sm" style="color:var(--a-text)">Sessions are D1-backed and role-gated.</p>
    </div>
  </div>
</AdminLayout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s ?? '';
    return d.innerHTML;
  }

  let currentPage = 1;

  function roleBadge(role: string, isBanned: number) {
    if (isBanned) return '<span class="a-badge a-badge-danger">Banned</span>';
    if (role === 'admin') return '<span class="a-badge a-badge-solid">Admin</span>';
    return '<span class="a-badge">User</span>';
  }

  async function loadUsers(page: number, search = '') {
    const params = new URLSearchParams({ page: String(page) });
    if (search) params.set('search', search);
    const res = await fetch(`/api/admin/users?${params}`);
    const data = await res.json();
    currentPage = page;

    const table = document.getElementById('users-table')!;
    if (!data.users?.length) {
      table.innerHTML = '<div class="a-card-pad text-center a-subtle"><p class="text-sm">No users found</p></div>';
      document.getElementById('showing-text')!.textContent = '';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }

    table.innerHTML = `
      <div class="overflow-x-auto"><table class="a-table min-w-[720px]">
        <thead><tr><th>User</th><th>Email</th><th>Role</th><th>Joined</th><th>Images</th><th class="text-right">Actions</th></tr></thead>
        <tbody>
          ${data.users.map((u: any) => `
            <tr>
              <td>
                <div class="flex items-center gap-3 min-w-0">
                  ${u.avatar_url
                    ? `<img src="${esc(u.avatar_url)}" alt="" class="w-9 h-9 rounded-full object-cover flex-shrink-0" style="border:1px solid var(--a-border)" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
                    : `<div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-semibold" style="background:var(--a-surface-2);border:1px solid var(--a-border);color:var(--a-muted)">${esc((u.name||'?').charAt(0).toUpperCase())}</div>`}
                  <div class="min-w-0">
                    <p class="text-sm font-semibold truncate max-w-[180px]" style="color:var(--a-fg)">${esc(u.name)}</p>
                    <p class="text-[11px] a-subtle">${u.role === 'admin' ? 'Administrator' : 'Member'}</p>
                  </div>
                </div>
              </td>
              <td class="text-xs a-muted truncate max-w-[220px]">${esc(u.email)}</td>
              <td>${roleBadge(u.role, u.is_banned)}</td>
              <td class="text-xs a-muted whitespace-nowrap">${new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
              <td class="text-xs font-semibold a-num">${u.image_count}</td>
              <td>
                <div class="flex gap-2 justify-end">
                  ${u.is_banned
                    ? `<button onclick="adminAction('${u.id}','unban')" class="a-btn a-btn-sm">Unban</button>`
                    : `<button onclick="adminAction('${u.id}','ban')" class="a-btn a-btn-sm a-btn-danger">Ban</button>`}
                  ${u.role === 'admin'
                    ? `<button onclick="adminAction('${u.id}','remove_admin')" class="a-btn a-btn-sm a-btn-ghost">Remove admin</button>`
                    : `<button onclick="adminAction('${u.id}','make_admin')" class="a-btn a-btn-sm a-btn-primary">Make admin</button>`}
                </div>
              </td>
            </tr>`).join('')}
        </tbody>
      </table></div>`;

    const start = (page - 1) * 20 + 1;
    const end = Math.min(page * 20, data.total);
    document.getElementById('showing-text')!.textContent = `Showing ${start}–${end} of ${data.total.toLocaleString()} users`;
    document.getElementById('growth-text')!.textContent = `${data.total.toLocaleString()} total registered users.`;

    const pag = document.getElementById('pagination')!;
    pag.innerHTML = data.totalPages > 1
      ? `<button onclick="loadPage(${Math.max(1, page - 1)})" class="a-btn a-btn-sm" ${page === 1 ? 'disabled' : ''}>Previous</button>
         <span class="a-btn a-btn-sm a-btn-ghost" style="cursor:default">Page ${page} / ${data.totalPages}</span>
         <button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="a-btn a-btn-sm" ${page === data.totalPages ? 'disabled' : ''}>Next</button>`
      : '';
  }

  (window as any).adminAction = async (userId: string, action: string) => {
    if (!confirm(`Are you sure you want to ${action.replace('_', ' ')} this user?`)) return;
    await fetch('/api/admin/users', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, action }),
    });
    loadUsers(currentPage, (document.getElementById('search-input') as HTMLInputElement).value);
  };

  (window as any).loadPage = (page: number) =>
    loadUsers(page, (document.getElementById('search-input') as HTMLInputElement).value);

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  let searchTimeout: any;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => loadUsers(1, searchInput.value), 300);
  });

  loadUsers(1);
</script>

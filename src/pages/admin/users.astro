---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import AdminSidebar from '../../components/AdminSidebar.astro';
---

<Layout title="User Management - Admin - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="users" />

    <main class="flex-1 p-4 sm:p-6 md:p-8 space-y-4 sm:space-y-6 bg-surface-container-lowest min-h-[calc(100dvh-65px)]">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl sm:text-4xl font-headline italic font-black text-on-surface">User Management</h1>
          <p class="text-on-surface-variant mt-1" id="user-subtitle">Manage permissions, plans, and administrative access.</p>
        </div>
        <button class="bg-tertiary-fixed text-on-tertiary-fixed px-5 py-3 rounded-lg font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 transition-all flex items-center gap-2 active:scale-95 self-start sm:self-auto">
          <span class="material-symbols-outlined text-lg">person_add</span>
          Invite New Admin
        </button>
      </div>

      <!-- Search -->
      <div class="flex items-center gap-3 px-4 py-3 bg-surface border-2 border-on-surface rounded-xl">
        <span class="material-symbols-outlined text-outline">search</span>
        <input id="search-input" type="text" placeholder="Search users by name or email..." class="bg-transparent border-none focus:outline-none w-full font-body text-sm" />
      </div>

      <!-- Users Table -->
      <div id="users-table" class="bg-surface border-2 border-on-surface rounded-xl overflow-hidden hard-shadow">
        <div class="p-8 text-center text-outline">
          <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
          <p class="font-label text-xs uppercase mt-2">Loading...</p>
        </div>
      </div>

      <!-- Pagination -->
      <div class="flex items-center justify-between">
        <p class="text-sm text-outline" id="showing-text"></p>
        <div id="pagination" class="flex gap-2"></div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5" id="user-stats">
        <div class="bg-surface border-2 border-on-surface rounded-xl p-6 hard-shadow">
          <div class="flex items-center gap-3 mb-3">
            <span class="material-symbols-outlined text-primary text-2xl">trending_up</span>
            <span class="material-symbols-outlined text-tertiary">star</span>
          </div>
          <h3 class="font-headline italic text-2xl font-black text-on-surface">Growth</h3>
          <p class="text-sm text-on-surface-variant mt-1" id="growth-text">Loading...</p>
        </div>
        <div class="bg-surface border-2 border-on-surface rounded-xl p-6 hard-shadow">
          <div class="flex items-center gap-3 mb-3">
            <span class="material-symbols-outlined text-secondary text-2xl">sync_alt</span>
          </div>
          <h3 class="font-headline italic text-2xl font-black text-on-surface">Conversion</h3>
          <p class="text-sm text-on-surface-variant mt-1" id="conversion-text">User engagement metrics</p>
        </div>
        <div class="bg-surface border-2 border-on-surface rounded-xl p-6 hard-shadow">
          <div class="flex items-center gap-3 mb-3">
            <span class="material-symbols-outlined text-error text-2xl">shield</span>
          </div>
          <h3 class="font-headline italic text-2xl font-black text-on-surface">Security</h3>
          <p class="text-sm text-on-surface-variant mt-1">All accounts secured with OAuth</p>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  let currentPage = 1;
  let totalUsers = 0;

  async function loadUsers(page: number, search = '') {
    const params = new URLSearchParams({ page: String(page) });
    if (search) params.set('search', search);

    const res = await fetch(`/api/admin/users?${params}`);
    const data = await res.json();
    currentPage = page;
    totalUsers = data.total;

    document.getElementById('user-subtitle')!.textContent =
      `Manage permissions, plans, and administrative access for ${data.total.toLocaleString()} active users.`;

    const table = document.getElementById('users-table')!;
    if (!data.users?.length) {
      table.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No users found</p></div>';
      return;
    }

    const getRoleBadge = (role: string, isBanned: number) => {
      if (isBanned) return '<span class="px-3 py-1.5 rounded-full text-xs font-bold uppercase bg-error text-on-error border border-error">Banned</span>';
      if (role === 'admin') return '<span class="px-3 py-1.5 rounded-full text-xs font-bold uppercase bg-error-container text-on-error-container border border-error">Admin</span>';
      return '<span class="px-3 py-1.5 rounded-full text-xs font-bold uppercase bg-secondary-container text-on-secondary-container border border-secondary">User</span>';
    };

    table.innerHTML = `
      <div class="overflow-x-auto"><table class="w-full text-left min-w-[700px]">
        <thead>
          <tr class="border-b-2 border-on-surface">
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">User Profile</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Email Address</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Role</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Joined</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Images</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/50">
          ${data.users.map((u: any) => `
            <tr class="hover:bg-surface-container-lowest transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <img src="${esc(u.avatar_url)}" alt="${esc(u.name)}" class="w-10 h-10 rounded-full border-2 border-on-surface object-cover" referrerpolicy="no-referrer" loading="lazy" decoding="async" />
                  <div>
                    <p class="font-bold text-sm">${esc(u.name)}</p>
                    <p class="text-xs text-outline uppercase tracking-wider">${u.role === 'admin' ? 'Administrator' : 'Member'}</p>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-on-surface-variant">${esc(u.email)}</td>
              <td class="px-6 py-4">${getRoleBadge(u.role, u.is_banned)}</td>
              <td class="px-6 py-4 text-sm text-on-surface-variant">${new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</td>
              <td class="px-6 py-4 text-sm font-bold">${u.image_count}</td>
              <td class="px-6 py-4">
                <div class="flex gap-2">
                  ${u.is_banned
                    ? `<button onclick="adminAction('${u.id}', 'unban')" class="px-4 py-2 rounded-full text-xs font-bold uppercase border border-secondary text-secondary hover:bg-secondary hover:text-on-secondary active:bg-secondary active:text-on-secondary transition-colors">Unban</button>`
                    : `<button onclick="adminAction('${u.id}', 'ban')" class="px-4 py-2 rounded-full text-xs font-bold uppercase border border-error text-error hover:bg-error hover:text-on-error active:bg-error active:text-on-error transition-colors">Ban</button>`
                  }
                  ${u.role === 'admin'
                    ? `<button onclick="adminAction('${u.id}', 'remove_admin')" class="px-4 py-2 rounded-full text-xs font-bold uppercase border border-outline text-outline hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">Remove Admin</button>`
                    : `<button onclick="adminAction('${u.id}', 'make_admin')" class="px-4 py-2 rounded-full text-xs font-bold uppercase border border-primary text-primary hover:bg-primary hover:text-on-primary active:bg-primary active:text-on-primary transition-colors">Make Admin</button>`
                  }
                </div>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table></div>
    `;

    // Showing text
    const start = (page - 1) * 20 + 1;
    const end = Math.min(page * 20, data.total);
    document.getElementById('showing-text')!.textContent = `Showing ${start} to ${end} of ${data.total.toLocaleString()} users`;

    // Growth stat
    document.getElementById('growth-text')!.textContent = `${data.total} total users registered`;

    // Pagination
    const pag = document.getElementById('pagination')!;
    if (data.totalPages > 1) {
      pag.innerHTML = `
        <button onclick="loadPage(${Math.max(1, page - 1)})" class="px-4 py-2.5 border-2 border-on-surface rounded-lg font-label text-xs font-bold bg-surface hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors ${page === 1 ? 'opacity-30' : ''}">Previous</button>
        <button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="px-4 py-2.5 border-2 border-on-surface rounded-lg font-label text-xs font-bold bg-surface hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors ${page === data.totalPages ? 'opacity-30' : ''}">Next</button>
      `;
    } else {
      pag.innerHTML = '';
    }
  }

  (window as any).adminAction = async (userId: string, action: string) => {
    if (!confirm(`Are you sure you want to ${action.replace('_', ' ')} this user?`)) return;
    await fetch('/api/admin/users', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId, action }),
    });
    loadUsers(currentPage, (document.getElementById('search-input') as HTMLInputElement).value);
  };

  (window as any).loadPage = (page: number) => {
    loadUsers(page, (document.getElementById('search-input') as HTMLInputElement).value);
  };

  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  let searchTimeout: any;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => loadUsers(1, searchInput.value), 300);
  });

  loadUsers(1);
</script>

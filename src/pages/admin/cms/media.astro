---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout title="Media" activePage="cms" heading="Media library" subtitle="Manage uploaded images for your content.">
  <label slot="actions" class="a-btn a-btn-primary cursor-pointer">
    <Icon name="upload" size={16} /> Upload
    <input type="file" accept="image/*" multiple class="hidden" id="media-upload-input" />
  </label>

  <nav class="flex items-center gap-1.5 text-xs a-subtle mb-4" aria-label="Breadcrumb">
    <a href="/admin/cms" class="a-link" style="font-weight:500">Content</a>
    <Icon name="chevron-right" size={13} />
    <span style="color:var(--a-text)">Media</span>
  </nav>

  <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-4">
    <div class="a-tabs" id="folder-filters">
      <button class="a-tab is-active" data-folder="all">All</button>
      <button class="a-tab" data-folder="blog">Blog</button>
      <button class="a-tab" data-folder="pages">Pages</button>
      <button class="a-tab" data-folder="general">General</button>
    </div>
    <div class="sm:ml-auto flex items-center gap-2">
      <span class="text-xs a-subtle" id="media-count">—</span>
      <select id="upload-folder" class="a-select" style="height:32px;width:auto;font-size:.75rem">
        <option value="general">Upload to: General</option>
        <option value="blog">Upload to: Blog</option>
        <option value="pages">Upload to: Pages</option>
      </select>
    </div>
  </div>

  <div id="media-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 sm:gap-4">
    <div class="col-span-full a-card a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div>
  </div>

  <div id="pagination" class="flex justify-center items-center gap-2 pt-6"></div>
</AdminLayout>

<script>
  const ICON_TRASH = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
  function esc(s: string): string { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }

  let currentPage = 1, currentFolder = 'all';

  function showToast(message: string) {
    document.querySelector('.admin-toast')?.remove();
    const t = document.createElement('div');
    t.className = 'admin-toast';
    t.textContent = message;
    t.setAttribute('style', 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:var(--a-fg);color:#fff;padding:.65rem 1.1rem;border-radius:10px;font-size:.8125rem;font-weight:550;z-index:60;box-shadow:0 8px 24px rgba(0,0,0,.18);transition:opacity .3s');
    document.body.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2000);
  }

  async function loadMedia(page: number) {
    const params = new URLSearchParams({ page: String(page), limit: '24' });
    if (currentFolder !== 'all') params.set('folder', currentFolder);
    const res = await fetch(`/api/admin/cms/media?${params}`);
    const data = await res.json();
    currentPage = page;
    document.getElementById('media-count')!.textContent = `${data.total} files`;

    const grid = document.getElementById('media-grid')!;
    if (!data.media?.length) {
      grid.innerHTML = '<div class="col-span-full a-card a-card-pad text-center a-subtle"><p class="text-sm">No media found</p></div>';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }
    grid.innerHTML = data.media.map((m: any) => `
      <div class="a-card overflow-hidden">
        <div class="aspect-square overflow-hidden" style="background:var(--a-surface-2)">
          <img src="${esc(m.url)}" alt="${esc(m.altText || m.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </div>
        <div class="p-3">
          <p class="text-xs font-semibold truncate" style="color:var(--a-fg)" title="${esc(m.filename)}">${esc(m.filename)}</p>
          <div class="flex items-center justify-between text-[11px] a-subtle mt-1">
            <span class="a-badge" style="height:18px;text-transform:capitalize">${esc(m.folder)}</span>
            <span class="a-num">${(m.sizeBytes / 1024).toFixed(0)} KB</span>
          </div>
          <label class="block text-[11px] a-subtle mt-2.5 mb-1" for="alt-${esc(m.id)}">Alt text</label>
          <input id="alt-${esc(m.id)}" type="text" class="a-input alt-input" data-id="${esc(m.id)}" value="${esc(m.altText || '')}" placeholder="Describe this image…" style="height:30px;font-size:.75rem" />
          <div class="flex items-center gap-1.5 mt-2.5">
            <button onclick="copyUrl('${esc(m.url)}')" class="a-btn a-btn-sm flex-1">Copy URL</button>
            <button onclick="deleteMedia('${esc(m.id)}')" class="a-btn a-btn-sm a-btn-icon a-btn-danger" title="Delete">${ICON_TRASH}</button>
          </div>
        </div>
      </div>`).join('');

    const pag = document.getElementById('pagination')!;
    pag.innerHTML = data.totalPages > 1
      ? `<button onclick="loadPage(${Math.max(1, page - 1)})" class="a-btn a-btn-sm" ${page === 1 ? 'disabled' : ''}>Previous</button>
         <span class="a-btn a-btn-sm a-btn-ghost" style="cursor:default">Page ${page} / ${data.totalPages}</span>
         <button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="a-btn a-btn-sm" ${page === data.totalPages ? 'disabled' : ''}>Next</button>`
      : '';

    grid.querySelectorAll('.alt-input').forEach((el) => {
      const input = el as HTMLInputElement;
      let last = input.value;
      const save = async () => {
        const altText = input.value.trim();
        if (altText === last) return;
        try {
          const res = await fetch(`/api/admin/cms/media/${input.dataset.id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ altText }),
          });
          if (!res.ok) throw new Error();
          last = altText;
          showToast('Alt text saved');
        } catch { showToast('Failed to save alt text'); }
      };
      input.addEventListener('change', save);
      input.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') { e.preventDefault(); input.blur(); } });
    });
  }

  (window as any).copyUrl = (url: string) => navigator.clipboard.writeText(url).then(() => showToast('URL copied'));
  (window as any).deleteMedia = async (id: string) => {
    if (!confirm('Delete this media permanently?')) return;
    await fetch('/api/admin/cms/media', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    showToast('Deleted');
    loadMedia(currentPage);
  };
  (window as any).loadPage = (page: number) => loadMedia(page);

  document.getElementById('folder-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    currentFolder = btn.dataset.folder || 'all';
    document.querySelectorAll('#folder-filters .a-tab').forEach(b => b.classList.toggle('is-active', b === btn));
    loadMedia(1);
  });

  document.getElementById('media-upload-input')?.addEventListener('change', async (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (!files?.length) return;
    const folder = (document.getElementById('upload-folder') as HTMLSelectElement).value;
    showToast('Uploading…');
    for (const file of files) {
      const form = new FormData();
      form.append('file', file); form.append('folder', folder);
      await fetch('/api/admin/cms/media', { method: 'POST', body: form });
    }
    showToast('Upload complete');
    loadMedia(1);
  });

  loadMedia(1);
</script>

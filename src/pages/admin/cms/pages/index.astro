---
export const prerender = false;

import AdminLayout from '../../../../layouts/AdminLayout.astro';
import Icon from '../../../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout title="Pages" activePage="cms" heading="Pages" subtitle="Manage static pages like About, Terms, and Privacy.">
  <button slot="actions" id="new-page-btn" class="a-btn a-btn-primary"><Icon name="plus" size={16} /> New page</button>

  <nav class="flex items-center gap-1.5 text-xs a-subtle mb-4" aria-label="Breadcrumb">
    <a href="/admin/cms" class="a-link" style="font-weight:500">Content</a>
    <Icon name="chevron-right" size={13} />
    <span style="color:var(--a-text)">Pages</span>
  </nav>

  <!-- new/edit form -->
  <div id="new-page-form" class="hidden a-card a-card-pad space-y-3 mb-5">
    <h3 class="a-section-title">Create new page</h3>
    <div>
      <label class="a-field-label">Title</label>
      <input id="page-title" type="text" placeholder="Page title…" class="a-input" />
    </div>
    <div>
      <label class="a-field-label">Slug</label>
      <input id="page-slug" type="text" placeholder="page-slug (auto-generated)" class="a-input a-mono" />
    </div>
    <div>
      <label class="a-field-label">Content (HTML supported)</label>
      <textarea id="page-content" rows="10" placeholder="Page content…" class="a-textarea a-mono"></textarea>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="a-field-label">Status</label>
        <select id="page-status" class="a-select"><option value="draft">Draft</option><option value="published">Published</option></select>
      </div>
      <div>
        <label class="a-field-label">Meta title (optional)</label>
        <input id="page-meta-title" type="text" placeholder="Meta title" class="a-input" />
      </div>
    </div>
    <div class="flex gap-2 pt-1">
      <button id="save-page-btn" class="a-btn a-btn-primary"><Icon name="save" size={16} /> Save page</button>
      <button id="cancel-page-btn" class="a-btn">Cancel</button>
    </div>
  </div>

  <div id="pages-table" class="a-card overflow-hidden">
    <div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div>
  </div>
</AdminLayout>

<script>
  function esc(s: string): string { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }
  let editingPageId: string | null = null;

  async function loadPages() {
    const res = await fetch('/api/admin/cms/pages');
    const data = await res.json();
    const table = document.getElementById('pages-table')!;
    if (!data.pages?.length) {
      table.innerHTML = '<div class="a-card-pad text-center a-subtle"><p class="text-sm">No pages yet</p></div>';
      return;
    }
    table.innerHTML = `
      <div class="overflow-x-auto"><table class="a-table min-w-[600px]">
        <thead><tr><th>Title</th><th>Slug</th><th>Status</th><th>Updated</th><th class="text-right">Actions</th></tr></thead>
        <tbody>
          ${data.pages.map((p: any) => `
            <tr>
              <td class="text-sm font-semibold" style="color:var(--a-fg)">${esc(p.title)}</td>
              <td class="text-xs a-muted a-mono">/p/${esc(p.slug)}</td>
              <td><span class="a-badge ${p.status === 'published' ? 'a-badge-ok' : ''}">${esc(p.status)}</span></td>
              <td class="text-xs a-muted whitespace-nowrap">${new Date(p.updatedAt).toLocaleDateString()}</td>
              <td>
                <div class="flex gap-2 justify-end">
                  <button onclick="editPage('${esc(p.id)}')" class="a-btn a-btn-sm">Edit</button>
                  <button onclick="deletePage('${esc(p.id)}')" class="a-btn a-btn-sm a-btn-danger">Delete</button>
                </div>
              </td>
            </tr>`).join('')}
        </tbody>
      </table></div>`;
  }

  const form = document.getElementById('new-page-form')!;
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

  document.getElementById('new-page-btn')!.addEventListener('click', () => {
    editingPageId = null;
    form.classList.remove('hidden');
    form.querySelector('.a-section-title')!.textContent = 'Create new page';
    $('page-title').value = ''; $('page-slug').value = ''; ($('page-content') as any).value = '';
    $('page-status').value = 'draft'; $('page-meta-title').value = '';
    form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
  document.getElementById('cancel-page-btn')!.addEventListener('click', () => { form.classList.add('hidden'); editingPageId = null; });

  $('page-title').addEventListener('input', (e) => {
    if (editingPageId) return;
    $('page-slug').value = (e.target as HTMLInputElement).value.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
  });

  document.getElementById('save-page-btn')!.addEventListener('click', async () => {
    const title = $('page-title').value, slug = $('page-slug').value;
    const content = ($('page-content') as any).value, status = $('page-status').value;
    const metaTitle = $('page-meta-title').value;
    if (!title) return;
    const body = JSON.stringify({ title, slug, content, status, metaTitle: metaTitle || null });
    if (editingPageId) await fetch(`/api/admin/cms/pages/${editingPageId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body });
    else await fetch('/api/admin/cms/pages', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body });
    form.classList.add('hidden'); editingPageId = null;
    loadPages();
  });

  (window as any).editPage = async (id: string) => {
    const res = await fetch(`/api/admin/cms/pages/${id}`);
    const data = await res.json();
    if (!data.success) return;
    editingPageId = id;
    form.classList.remove('hidden');
    form.querySelector('.a-section-title')!.textContent = 'Edit page';
    $('page-title').value = data.page.title; $('page-slug').value = data.page.slug;
    ($('page-content') as any).value = data.page.content; $('page-status').value = data.page.status;
    $('page-meta-title').value = data.page.metaTitle || '';
    form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  };
  (window as any).deletePage = async (id: string) => {
    if (!confirm('Delete this page permanently?')) return;
    await fetch('/api/admin/cms/pages', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    loadPages();
  };

  loadPages();
</script>

---
export const prerender = false;

import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import AdminSidebar from '../../../../components/AdminSidebar.astro';
---

<Layout title="Posts - CMS - ImageToURL">
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="cms" />

    <main class="flex-1 p-4 sm:p-6 md:p-8 space-y-4 sm:space-y-6 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs font-label font-bold uppercase tracking-wider text-outline" aria-label="Breadcrumb">
        <a href="/admin/cms" class="hover:text-on-surface transition-colors">Content</a>
        <span class="material-symbols-outlined text-sm">chevron_right</span>
        <span class="text-on-surface">Posts</span>
      </nav>

      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h1 class="text-2xl sm:text-4xl font-headline italic font-black text-on-surface">Posts</h1>
          <p class="text-on-surface-variant mt-1" id="post-subtitle">Manage your blog content.</p>
        </div>
        <a href="/admin/cms/posts/new" class="bg-primary text-on-primary px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 active:scale-95 transition-all flex items-center gap-2 self-start sm:self-auto">
          <span class="material-symbols-outlined text-lg">add</span>
          New Post
        </a>
      </div>

      <!-- Filters -->
      <div class="flex flex-col md:flex-row gap-4">
        <div class="flex flex-wrap gap-1" id="status-filters">
          <button class="px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-on-surface text-surface active:scale-95 transition-all" data-status="all">All</button>
          <button class="px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-surface hover:bg-surface-container-highest active:scale-95 transition-all" data-status="published">Published</button>
          <button class="px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-surface hover:bg-surface-container-highest active:scale-95 transition-all" data-status="draft">Drafts</button>
          <button class="px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-surface hover:bg-surface-container-highest active:scale-95 transition-all" data-status="archived">Archived</button>
        </div>
        <select id="category-filter" class="px-4 py-2 border-2 border-on-surface rounded-lg bg-surface text-sm font-label font-bold">
          <option value="">All Categories</option>
        </select>
        <div class="flex items-center gap-3 px-4 py-2 bg-surface border-2 border-on-surface rounded-lg flex-1">
          <span class="material-symbols-outlined text-outline">search</span>
          <input id="search-input" type="text" placeholder="Search posts..." class="bg-transparent border-none focus:outline-none w-full font-body text-sm" />
        </div>
      </div>

      <!-- Posts Table -->
      <div id="posts-table" class="bg-surface border-2 border-on-surface rounded-xl overflow-hidden hard-shadow">
        <div class="p-8 text-center text-outline">
          <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
          <p class="font-label text-xs uppercase mt-2">Loading...</p>
        </div>
      </div>

      <!-- Pagination -->
      <div class="flex items-center justify-between">
        <p class="text-sm text-outline" id="showing-text"></p>
        <div id="pagination" class="flex gap-2"></div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  let currentPage = 1;
  let currentStatus = 'all';
  let currentCategory = '';
  let currentSearch = '';

  async function loadCategories() {
    const res = await fetch('/api/admin/cms/categories');
    const data = await res.json();
    const select = document.getElementById('category-filter') as HTMLSelectElement;
    for (const cat of data.categories || []) {
      const opt = document.createElement('option');
      opt.value = cat.id;
      opt.textContent = `${cat.name} (${cat.postCount})`;
      select.appendChild(opt);
    }
  }

  async function loadPosts(page: number) {
    const params = new URLSearchParams({ page: String(page), limit: '20' });
    if (currentStatus !== 'all') params.set('status', currentStatus);
    if (currentCategory) params.set('category', currentCategory);
    if (currentSearch) params.set('search', currentSearch);

    const res = await fetch(`/api/admin/cms/posts?${params}`);
    const data = await res.json();
    currentPage = page;

    document.getElementById('post-subtitle')!.textContent =
      `${data.total} posts total`;

    const table = document.getElementById('posts-table')!;
    if (!data.posts?.length) {
      table.innerHTML = '<div class="p-8 text-center text-outline"><span class="material-symbols-outlined text-4xl">article</span><p class="font-label text-xs uppercase mt-2">No posts found</p></div>';
      document.getElementById('showing-text')!.textContent = '';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }

    const statusBadge = (status: string) => {
      if (status === 'published') return '<span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase bg-secondary-container text-on-secondary-container border border-secondary">Published</span>';
      if (status === 'draft') return '<span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase bg-tertiary-fixed text-on-tertiary-fixed border border-tertiary">Draft</span>';
      return '<span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase bg-error-container text-on-error-container border border-error">Archived</span>';
    };

    table.innerHTML = `
      <div class="overflow-x-auto"><table class="w-full text-left min-w-[700px]">
        <thead>
          <tr class="border-b-2 border-on-surface">
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Title</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Category</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Status</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Author</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Updated</th>
            <th class="px-6 py-4 font-label text-xs uppercase font-bold text-outline tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/50">
          ${data.posts.map((p: any) => `
            <tr class="hover:bg-surface-container-lowest transition-colors">
              <td class="px-6 py-4">
                <div>
                  <a href="/admin/cms/posts/edit/${esc(p.id)}" class="font-bold text-sm hover:text-primary transition-colors">${esc(p.title)}</a>
                  ${p.featured ? '<span class="ml-2 text-xs text-tertiary font-bold uppercase">Featured</span>' : ''}
                  <p class="text-xs text-outline truncate mt-0.5 max-w-sm">${esc(p.excerpt)}</p>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-on-surface-variant">${esc(p.categoryName || '—')}</td>
              <td class="px-6 py-4">${statusBadge(p.status)}</td>
              <td class="px-6 py-4 text-sm text-on-surface-variant">${esc(p.authorName)}</td>
              <td class="px-6 py-4 text-sm text-on-surface-variant">${new Date(p.updatedAt).toLocaleDateString()}</td>
              <td class="px-6 py-4">
                <div class="flex gap-2">
                  <a href="/admin/cms/posts/edit/${esc(p.id)}" class="px-3 py-1 rounded-full text-xs font-bold uppercase border border-primary text-primary hover:bg-primary hover:text-on-primary transition-colors">Edit</a>
                  ${p.status === 'published'
                    ? `<button onclick="postAction('${p.id}', 'unpublish')" class="px-3 py-1 rounded-full text-xs font-bold uppercase border border-outline text-outline hover:bg-surface-container-highest transition-colors">Unpublish</button>`
                    : p.status === 'draft'
                    ? `<button onclick="postAction('${p.id}', 'publish')" class="px-3 py-1 rounded-full text-xs font-bold uppercase border border-secondary text-secondary hover:bg-secondary hover:text-on-secondary transition-colors">Publish</button>`
                    : ''
                  }
                  <button onclick="postAction('${p.id}', 'archive')" class="px-3 py-1 rounded-full text-xs font-bold uppercase border border-error text-error hover:bg-error hover:text-on-error transition-colors">Archive</button>
                </div>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table></div>
    `;

    // Showing text
    const start = (page - 1) * 20 + 1;
    const end = Math.min(page * 20, data.total);
    document.getElementById('showing-text')!.textContent = `Showing ${start}–${end} of ${data.total}`;

    // Pagination
    const pag = document.getElementById('pagination')!;
    if (data.totalPages > 1) {
      pag.innerHTML = `
        <button onclick="loadPage(${Math.max(1, page - 1)})" class="px-4 py-2.5 border-2 border-on-surface rounded-xl font-label text-xs font-bold bg-surface hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors ${page === 1 ? 'opacity-30' : ''}">Previous</button>
        <button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="px-4 py-2.5 border-2 border-on-surface rounded-xl font-label text-xs font-bold bg-surface hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors ${page === data.totalPages ? 'opacity-30' : ''}">Next</button>
      `;
    } else {
      pag.innerHTML = '';
    }
  }

  (window as any).postAction = async (id: string, action: string) => {
    if (action === 'archive') {
      if (!confirm('Archive this post?')) return;
      await fetch('/api/admin/cms/posts', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
    } else {
      await fetch(`/api/admin/cms/posts/${id}/${action}`, { method: 'POST' });
    }
    loadPosts(currentPage);
  };

  (window as any).loadPage = (page: number) => loadPosts(page);

  // Status filter
  document.getElementById('status-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    currentStatus = btn.dataset.status || 'all';
    document.querySelectorAll('#status-filters button').forEach(b => {
      b.className = b === btn
        ? 'px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-on-surface text-surface active:scale-95 transition-all'
        : 'px-4 py-2 rounded-full border-2 border-on-surface text-xs font-bold uppercase bg-surface hover:bg-surface-container-highest active:scale-95 transition-all';
    });
    loadPosts(1);
  });

  // Category filter
  document.getElementById('category-filter')?.addEventListener('change', (e) => {
    currentCategory = (e.target as HTMLSelectElement).value;
    loadPosts(1);
  });

  // Search
  let searchTimeout: any;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentSearch = (e.target as HTMLInputElement).value;
      loadPosts(1);
    }, 300);
  });

  loadCategories();
  loadPosts(1);
</script>

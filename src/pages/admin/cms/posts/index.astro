---
export const prerender = false;

import AdminLayout from '../../../../layouts/AdminLayout.astro';
import Icon from '../../../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout title="Posts" activePage="cms" heading="Posts" subtitle="Manage your blog content.">
  <a slot="actions" href="/admin/cms/posts/new" class="a-btn a-btn-primary"><Icon name="plus" size={16} /> New post</a>

  <!-- breadcrumb -->
  <nav class="flex items-center gap-1.5 text-xs a-subtle mb-4" aria-label="Breadcrumb">
    <a href="/admin/cms" class="a-link" style="font-weight:500">Content</a>
    <Icon name="chevron-right" size={13} />
    <span style="color:var(--a-text)">Posts</span>
  </nav>

  <!-- filters -->
  <div class="flex flex-col md:flex-row gap-3 mb-4">
    <div class="a-tabs" id="status-filters">
      <button class="a-tab is-active" data-status="all">All</button>
      <button class="a-tab" data-status="published">Published</button>
      <button class="a-tab" data-status="draft">Drafts</button>
      <button class="a-tab" data-status="archived">Archived</button>
    </div>
    <select id="category-filter" class="a-select md:w-48"><option value="">All categories</option></select>
    <div class="relative flex-1">
      <span class="absolute left-3 top-1/2 -translate-y-1/2 a-subtle pointer-events-none"><Icon name="search" size={17} /></span>
      <input id="search-input" type="text" placeholder="Search posts…" class="a-input" style="padding-left:2.25rem" />
    </div>
  </div>

  <div id="posts-table" class="a-card overflow-hidden">
    <div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div>
  </div>

  <div class="flex items-center justify-between gap-3 mt-4 flex-wrap">
    <p class="text-xs a-subtle" id="showing-text"></p>
    <div id="pagination" class="flex gap-2"></div>
  </div>
</AdminLayout>

<script>
  function esc(s: string): string { const d = document.createElement('div'); d.textContent = s ?? ''; return d.innerHTML; }

  let currentPage = 1, currentStatus = 'all', currentCategory = '', currentSearch = '';

  async function loadCategories() {
    const res = await fetch('/api/admin/cms/categories');
    const data = await res.json();
    const select = document.getElementById('category-filter') as HTMLSelectElement;
    for (const cat of data.categories || []) {
      const opt = document.createElement('option');
      opt.value = cat.id; opt.textContent = `${cat.name} (${cat.postCount})`;
      select.appendChild(opt);
    }
  }

  function statusBadge(status: string) {
    const cls = status === 'published' ? 'a-badge-ok' : status === 'draft' ? '' : 'a-badge-danger';
    return `<span class="a-badge ${cls}">${esc(status)}</span>`;
  }

  const toDate = (v: string | null | undefined): Date | null => {
    if (!v) return null;
    const s = /T.*(Z|[+-]\d{2}:?\d{2})$/.test(v) ? v : v.replace(' ', 'T') + 'Z';
    const d = new Date(s); return isNaN(d.getTime()) ? null : d;
  };
  const relativeTime = (d: Date): string => {
    const diff = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
    if (diff < 86400 * 30) return `${Math.floor(diff / 86400)}d ago`;
    return d.toLocaleDateString();
  };
  const updatedCell = (v: string | null | undefined) => {
    const d = toDate(v);
    if (!d) return '<span class="a-subtle">—</span>';
    return `<span title="${esc(d.toLocaleString())}"><span class="block text-xs" style="color:var(--a-text)">${esc(relativeTime(d))}</span><span class="block text-[10px] a-subtle">${esc(d.toLocaleDateString())}</span></span>`;
  };

  async function loadPosts(page: number) {
    const params = new URLSearchParams({ page: String(page), limit: '20' });
    if (currentStatus !== 'all') params.set('status', currentStatus);
    if (currentCategory) params.set('category', currentCategory);
    if (currentSearch) params.set('search', currentSearch);

    const res = await fetch(`/api/admin/cms/posts?${params}`);
    const data = await res.json();
    currentPage = page;

    const table = document.getElementById('posts-table')!;
    if (!data.posts?.length) {
      table.innerHTML = '<div class="a-card-pad text-center a-subtle"><p class="text-sm">No posts found</p></div>';
      document.getElementById('showing-text')!.textContent = '';
      document.getElementById('pagination')!.innerHTML = '';
      return;
    }

    table.innerHTML = `
      <div class="overflow-x-auto"><table class="a-table min-w-[720px]">
        <thead><tr><th>Title</th><th>Category</th><th>Status</th><th>Author</th><th>Updated</th><th class="text-right">Actions</th></tr></thead>
        <tbody>
          ${data.posts.map((p: any) => `
            <tr>
              <td>
                <a href="/admin/cms/posts/edit/${esc(p.id)}" class="text-sm font-semibold" style="color:var(--a-fg)">${esc(p.title)}</a>
                <p class="text-xs a-subtle truncate mt-0.5 max-w-sm">${esc(p.excerpt)}</p>
              </td>
              <td class="text-xs a-muted">${esc(p.categoryName || '—')}</td>
              <td>${statusBadge(p.status)}</td>
              <td class="text-xs a-muted">${esc(p.authorName)}</td>
              <td>${updatedCell(p.updatedAt)}</td>
              <td>
                <div class="flex gap-2 justify-end">
                  <a href="/admin/cms/posts/edit/${esc(p.id)}" class="a-btn a-btn-sm">Edit</a>
                  ${p.status === 'published'
                    ? `<button onclick="postAction('${p.id}','unpublish')" class="a-btn a-btn-sm a-btn-ghost">Unpublish</button>`
                    : p.status === 'draft'
                    ? `<button onclick="postAction('${p.id}','publish')" class="a-btn a-btn-sm a-btn-primary">Publish</button>` : ''}
                  <button onclick="postAction('${p.id}','archive')" class="a-btn a-btn-sm a-btn-danger">Archive</button>
                </div>
              </td>
            </tr>`).join('')}
        </tbody>
      </table></div>`;

    const start = (page - 1) * 20 + 1;
    const end = Math.min(page * 20, data.total);
    document.getElementById('showing-text')!.textContent = `Showing ${start}–${end} of ${data.total}`;

    const pag = document.getElementById('pagination')!;
    pag.innerHTML = data.totalPages > 1
      ? `<button onclick="loadPage(${Math.max(1, page - 1)})" class="a-btn a-btn-sm" ${page === 1 ? 'disabled' : ''}>Previous</button>
         <span class="a-btn a-btn-sm a-btn-ghost" style="cursor:default">Page ${page} / ${data.totalPages}</span>
         <button onclick="loadPage(${Math.min(data.totalPages, page + 1)})" class="a-btn a-btn-sm" ${page === data.totalPages ? 'disabled' : ''}>Next</button>`
      : '';
  }

  (window as any).postAction = async (id: string, action: string) => {
    if (action === 'archive') {
      if (!confirm('Archive this post?')) return;
      await fetch('/api/admin/cms/posts', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    } else {
      await fetch(`/api/admin/cms/posts/${id}/${action}`, { method: 'POST' });
    }
    loadPosts(currentPage);
  };
  (window as any).loadPage = (page: number) => loadPosts(page);

  document.getElementById('status-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button');
    if (!btn) return;
    currentStatus = btn.dataset.status || 'all';
    document.querySelectorAll('#status-filters .a-tab').forEach(b => b.classList.toggle('is-active', b === btn));
    loadPosts(1);
  });
  document.getElementById('category-filter')?.addEventListener('change', (e) => {
    currentCategory = (e.target as HTMLSelectElement).value; loadPosts(1);
  });
  let searchTimeout: any;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => { currentSearch = (e.target as HTMLInputElement).value; loadPosts(1); }, 300);
  });

  loadCategories();
  loadPosts(1);
</script>

---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import AdminSidebar from '../../../components/AdminSidebar.astro';
---

<Layout title="Content Management - Admin - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="cms" />

    <main class="flex-1 p-4 sm:p-6 md:p-8 space-y-4 sm:space-y-6 md:space-y-8 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <span class="inline-block px-3 py-1 bg-tertiary-fixed border-2 border-on-surface rounded-full font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed mb-3">Content Hub</span>
          <h1 class="text-xl sm:text-2xl font-headline italic font-black text-on-surface">Content Management</h1>
          <p class="text-on-surface-variant mt-1">Create, edit, and publish blog posts and pages.</p>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="flex flex-wrap gap-3 sm:gap-4">
        <a href="/admin/cms/posts/new" class="bg-primary text-on-primary px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 active:scale-95 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">add</span>
          New Post
        </a>
        <a href="/admin/cms/media" class="bg-secondary-container text-on-secondary-container px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 active:scale-95 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">upload</span>
          Upload Media
        </a>
        <a href="/admin/cms/categories" class="bg-tertiary-fixed text-on-tertiary-fixed px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider border-2 border-on-surface hard-shadow hover:-translate-y-1 active:scale-95 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">category</span>
          Categories
        </a>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-5" id="cms-stats">
        <div class="bg-secondary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <span class="material-symbols-outlined text-on-secondary-fixed text-2xl">article</span>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-secondary-fixed-variant mt-3">Total Posts</p>
          <p class="text-3xl font-headline font-black text-on-secondary-fixed" id="stat-posts">—</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <span class="material-symbols-outlined text-on-secondary-container text-2xl">publish</span>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-secondary-container/70 mt-3">Published</p>
          <p class="text-3xl font-headline font-black text-on-secondary-container" id="stat-published">—</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <span class="material-symbols-outlined text-on-tertiary-fixed text-2xl">edit_note</span>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed/70 mt-3">Drafts</p>
          <p class="text-3xl font-headline font-black text-on-tertiary-fixed" id="stat-drafts">—</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <span class="material-symbols-outlined text-on-primary-fixed text-2xl">category</span>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-primary-fixed-variant mt-3">Categories</p>
          <p class="text-3xl font-headline font-black text-on-primary-fixed" id="stat-categories">—</p>
        </div>
        <div class="bg-surface border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <span class="material-symbols-outlined text-on-surface text-2xl">image</span>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-outline mt-3">Media</p>
          <p class="text-3xl font-headline font-black text-on-surface" id="stat-media">—</p>
        </div>
      </div>

      <!-- Two Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
        <!-- Recent Posts -->
        <div class="bg-surface border-2 border-on-surface rounded-xl hard-shadow">
          <div class="p-5 border-b-2 border-on-surface flex items-center justify-between gap-3">
            <h2 class="font-headline italic text-xl font-black">Recent Posts</h2>
            <a href="/admin/cms/posts" class="font-label text-xs font-bold uppercase text-primary flex items-center gap-1">
              View All <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
          <div class="flex border-b-2 border-on-surface" role="tablist" aria-label="Recent posts filter">
            <button
              type="button"
              role="tab"
              aria-selected="true"
              data-tab="published"
              class="recent-tab flex-1 px-4 py-3 font-label text-xs font-bold uppercase tracking-wider border-r-2 border-on-surface bg-secondary-container text-on-secondary-container"
            >
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">publish</span>
                Published <span class="opacity-70" data-count="published">—</span>
              </span>
            </button>
            <button
              type="button"
              role="tab"
              aria-selected="false"
              data-tab="draft"
              class="recent-tab flex-1 px-4 py-3 font-label text-xs font-bold uppercase tracking-wider bg-surface text-on-surface-variant"
            >
              <span class="inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">edit_note</span>
                Drafts <span class="opacity-70" data-count="draft">—</span>
              </span>
            </button>
          </div>
          <div id="recent-posts-published" class="divide-y divide-outline-variant/50" role="tabpanel">
            <div class="p-8 text-center text-outline">
              <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
          <div id="recent-posts-draft" class="divide-y divide-outline-variant/50 hidden" role="tabpanel">
            <div class="p-8 text-center text-outline">
              <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="bg-surface border-2 border-on-surface rounded-xl hard-shadow">
          <div class="p-5 border-b-2 border-on-surface">
            <h2 class="font-headline italic text-xl font-black">Recent Activity</h2>
          </div>
          <div id="recent-activity" class="divide-y divide-outline-variant/50 max-h-[400px] overflow-y-auto">
            <div class="p-8 text-center text-outline">
              <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function renderPosts(container: HTMLElement, posts: any[], emptyLabel: string, isDraft: boolean) {
    if (!posts?.length) {
      container.innerHTML = `<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">${emptyLabel}</p></div>`;
      return;
    }
    container.innerHTML = posts.map((p: any) => `
      <a href="/admin/cms/posts/edit/${esc(p.id)}" class="flex items-center justify-between p-4 hover:bg-surface-container-lowest transition-colors${isDraft ? ' bg-tertiary-fixed/20' : ''}">
        <div class="flex-1 min-w-0">
          <p class="font-bold text-sm truncate">${esc(p.title)}</p>
          <p class="text-xs text-outline uppercase tracking-wider mt-1">${esc(p.categoryName || 'Uncategorized')} &middot; ${esc(p.readTime)}</p>
        </div>
        <span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase ml-3 ${
          p.status === 'published' ? 'bg-secondary-container text-on-secondary-container' :
          p.status === 'draft' ? 'bg-tertiary-fixed text-on-tertiary-fixed' :
          'bg-error-container text-on-error-container'
        }">${esc(p.status)}</span>
      </a>
    `).join('');
  }

  function setupTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.recent-tab');
    const panels: Record<string, HTMLElement> = {
      published: document.getElementById('recent-posts-published')!,
      draft: document.getElementById('recent-posts-draft')!,
    };
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab!;
        tabs.forEach((t) => {
          const active = t.dataset.tab === target;
          t.setAttribute('aria-selected', String(active));
          if (active) {
            t.classList.remove('bg-surface', 'text-on-surface-variant');
            t.classList.add(
              target === 'draft' ? 'bg-tertiary-fixed' : 'bg-secondary-container',
              target === 'draft' ? 'text-on-tertiary-fixed' : 'text-on-secondary-container',
            );
          } else {
            t.classList.remove('bg-tertiary-fixed', 'text-on-tertiary-fixed', 'bg-secondary-container', 'text-on-secondary-container');
            t.classList.add('bg-surface', 'text-on-surface-variant');
          }
        });
        Object.entries(panels).forEach(([key, panel]) => {
          panel.classList.toggle('hidden', key !== target);
        });
      });
    });
  }

  async function loadDashboard() {
    setupTabs();

    // Load stats and posts (published + drafts in parallel)
    const [publishedRes, draftsRes, categoriesRes, mediaRes, activityRes] = await Promise.all([
      fetch('/api/admin/cms/posts?status=published&limit=5'),
      fetch('/api/admin/cms/posts?status=draft&limit=5'),
      fetch('/api/admin/cms/categories'),
      fetch('/api/admin/cms/media?limit=1'),
      fetch('/api/admin/cms/activity?limit=10'),
    ]);

    const publishedData = await publishedRes.json();
    const draftsData = await draftsRes.json();
    const categoriesData = await categoriesRes.json();
    const mediaData = await mediaRes.json();
    const activityData = await activityRes.json();

    // Stats
    const publishedTotal = publishedData.total || 0;
    const draftsTotal = draftsData.total || 0;
    document.getElementById('stat-posts')!.textContent = String(publishedTotal + draftsTotal);
    document.getElementById('stat-published')!.textContent = String(publishedTotal);
    document.getElementById('stat-drafts')!.textContent = String(draftsTotal);
    document.getElementById('stat-categories')!.textContent = String(categoriesData.categories?.length || 0);
    document.getElementById('stat-media')!.textContent = String(mediaData.total || 0);

    // Tab counts
    document.querySelector('[data-count="published"]')!.textContent = `(${publishedTotal})`;
    document.querySelector('[data-count="draft"]')!.textContent = `(${draftsTotal})`;

    // Recent posts split by status
    renderPosts(document.getElementById('recent-posts-published')!, publishedData.posts || [], 'No published posts yet', false);
    renderPosts(document.getElementById('recent-posts-draft')!, draftsData.posts || [], 'No drafts', true);

    // Activity
    const actionIcons: Record<string, string> = {
      create_post: 'add_circle', update_post: 'edit', archive_post: 'archive',
      publish_post: 'publish', unpublish_post: 'unpublished',
      create_category: 'new_label', update_category: 'label', delete_category: 'label_off',
      upload_media: 'upload_file', delete_media: 'delete', update_media: 'image',
      create_page: 'note_add', update_page: 'edit_document', delete_page: 'delete',
      migrate_blog: 'sync',
    };

    const recentActivity = document.getElementById('recent-activity')!;
    if (activityData.activity?.length) {
      recentActivity.innerHTML = activityData.activity.map((a: any) => `
        <div class="flex items-center gap-3 p-4">
          <span class="material-symbols-outlined text-primary text-xl">${actionIcons[a.action] || 'info'}</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm"><strong>${esc(a.userName)}</strong> ${esc(a.action.replace(/_/g, ' '))} ${a.entityTitle ? `"${esc(a.entityTitle)}"` : ''}</p>
            <p class="text-xs text-outline uppercase tracking-wider mt-0.5">${new Date(a.createdAt).toLocaleString()}</p>
          </div>
        </div>
      `).join('');
    } else {
      recentActivity.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No activity yet</p></div>';
    }
  }

  loadDashboard();
</script>

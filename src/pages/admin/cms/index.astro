---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import Icon from '../../../components/admin/Icon.astro';

Astro.response.headers.set('Cache-Control', 'private, no-store');
---

<AdminLayout
  title="Content"
  activePage="cms"
  eyebrow="Content hub"
  heading="Content management"
  subtitle="Create, edit, and publish blog posts and pages."
>
  <Fragment slot="actions">
    <a href="/admin/cms/posts/new" class="a-btn a-btn-primary"><Icon name="plus" size={16} /> New post</a>
    <a href="/admin/cms/media" class="a-btn"><Icon name="upload" size={16} /> Media</a>
    <a href="/admin/cms/categories" class="a-btn"><Icon name="tag" size={16} /> Categories</a>
  </Fragment>

  <!-- stats -->
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4 mb-6">
    <a href="/admin/cms/posts" class="a-card a-card-pad">
      <div class="flex items-center justify-between"><span class="a-stat-label">Total posts</span><span class="a-subtle"><Icon name="file-text" size={16} /></span></div>
      <p class="a-stat-value mt-1.5" id="stat-posts">—</p>
    </a>
    <a href="/admin/cms/posts?status=published" class="a-card a-card-pad">
      <div class="flex items-center justify-between"><span class="a-stat-label">Published</span><span class="a-subtle"><Icon name="check-circle" size={16} /></span></div>
      <p class="a-stat-value mt-1.5" id="stat-published">—</p>
    </a>
    <a href="/admin/cms/posts?status=draft" class="a-card a-card-pad">
      <div class="flex items-center justify-between"><span class="a-stat-label">Drafts</span><span class="a-subtle"><Icon name="edit" size={16} /></span></div>
      <p class="a-stat-value mt-1.5" id="stat-drafts">—</p>
    </a>
    <a href="/admin/cms/categories" class="a-card a-card-pad">
      <div class="flex items-center justify-between"><span class="a-stat-label">Categories</span><span class="a-subtle"><Icon name="tag" size={16} /></span></div>
      <p class="a-stat-value mt-1.5" id="stat-categories">—</p>
    </a>
    <a href="/admin/cms/media" class="a-card a-card-pad">
      <div class="flex items-center justify-between"><span class="a-stat-label">Media</span><span class="a-subtle"><Icon name="image" size={16} /></span></div>
      <p class="a-stat-value mt-1.5" id="stat-media">—</p>
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
    <!-- recent posts -->
    <div class="a-card overflow-hidden">
      <div class="a-card-head">
        <h2 class="a-section-title">Recent posts</h2>
        <a href="/admin/cms/posts" class="a-link text-xs">View all →</a>
      </div>
      <div class="px-4 pt-3">
        <div class="a-tabs" role="tablist">
          <button type="button" role="tab" aria-selected="true" data-tab="published" class="recent-tab a-tab is-active">Published <span class="a-subtle" data-count="published">—</span></button>
          <button type="button" role="tab" aria-selected="false" data-tab="draft" class="recent-tab a-tab">Drafts <span class="a-subtle" data-count="draft">—</span></button>
        </div>
      </div>
      <div id="recent-posts-published" role="tabpanel"><div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div></div>
      <div id="recent-posts-draft" class="hidden" role="tabpanel"><div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div></div>
    </div>

    <!-- activity -->
    <div class="a-card overflow-hidden">
      <div class="a-card-head"><h2 class="a-section-title">Recent activity</h2></div>
      <div id="recent-activity" class="max-h-[420px] overflow-y-auto">
        <div class="a-card-pad text-center a-subtle"><p class="text-sm">Loading…</p></div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s ?? '';
    return d.innerHTML;
  }

  const PATHS: Record<string, string> = {
    edit: '<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/>',
    plus: '<path d="M5 12h14"/><path d="M12 5v14"/>',
    trash: '<path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>',
    upload: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/>',
    tag: '<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/>',
    file: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>',
    check: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>',
    'eye-off': '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>',
    refresh: '<path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/>',
    image: '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
    info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  };
  function svg(name: string): string {
    return `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none">${PATHS[name] || PATHS.info}</svg>`;
  }

  function statusBadge(status: string): string {
    const cls = status === 'published' ? 'a-badge-ok' : status === 'draft' ? '' : 'a-badge-danger';
    return `<span class="a-badge ${cls}">${esc(status)}</span>`;
  }

  function renderPosts(container: HTMLElement, posts: any[], emptyLabel: string) {
    if (!posts?.length) { container.innerHTML = `<div class="a-card-pad text-center a-subtle"><p class="text-sm">${emptyLabel}</p></div>`; return; }
    container.innerHTML = posts.map((p: any) => `
      <a href="/admin/cms/posts/edit/${esc(p.id)}" class="flex items-center justify-between gap-3 px-5 py-3.5" style="border-top:1px solid var(--a-border)">
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold truncate" style="color:var(--a-fg)">${esc(p.title)}</p>
          <p class="text-xs a-subtle mt-0.5">${esc(p.categoryName || 'Uncategorized')} · ${esc(p.readTime || '')}</p>
        </div>
        ${statusBadge(p.status)}
      </a>`).join('');
  }

  function setupTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.recent-tab');
    const panels: Record<string, HTMLElement> = {
      published: document.getElementById('recent-posts-published')!,
      draft: document.getElementById('recent-posts-draft')!,
    };
    tabs.forEach((tab) => tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      tabs.forEach((t) => { const a = t.dataset.tab === target; t.classList.toggle('is-active', a); t.setAttribute('aria-selected', String(a)); });
      Object.entries(panels).forEach(([k, p]) => p.classList.toggle('hidden', k !== target));
    }));
  }

  async function loadDashboard() {
    setupTabs();
    const [publishedRes, draftsRes, categoriesRes, mediaRes, activityRes] = await Promise.all([
      fetch('/api/admin/cms/posts?status=published&limit=5'),
      fetch('/api/admin/cms/posts?status=draft&limit=5'),
      fetch('/api/admin/cms/categories'),
      fetch('/api/admin/cms/media?limit=1'),
      fetch('/api/admin/cms/activity?limit=10'),
    ]);
    const publishedData = await publishedRes.json();
    const draftsData = await draftsRes.json();
    const categoriesData = await categoriesRes.json();
    const mediaData = await mediaRes.json();
    const activityData = await activityRes.json();

    const publishedTotal = publishedData.total || 0;
    const draftsTotal = draftsData.total || 0;
    document.getElementById('stat-posts')!.textContent = String(publishedTotal + draftsTotal);
    document.getElementById('stat-published')!.textContent = String(publishedTotal);
    document.getElementById('stat-drafts')!.textContent = String(draftsTotal);
    document.getElementById('stat-categories')!.textContent = String(categoriesData.categories?.length || 0);
    document.getElementById('stat-media')!.textContent = String(mediaData.total || 0);
    document.querySelector('[data-count="published"]')!.textContent = `(${publishedTotal})`;
    document.querySelector('[data-count="draft"]')!.textContent = `(${draftsTotal})`;

    renderPosts(document.getElementById('recent-posts-published')!, publishedData.posts || [], 'No published posts yet');
    renderPosts(document.getElementById('recent-posts-draft')!, draftsData.posts || [], 'No drafts');

    const actionIcons: Record<string, string> = {
      create_post: 'plus', update_post: 'edit', archive_post: 'file',
      publish_post: 'check', unpublish_post: 'eye-off',
      create_category: 'tag', update_category: 'tag', delete_category: 'trash',
      upload_media: 'upload', delete_media: 'trash', update_media: 'image',
      create_page: 'file', update_page: 'edit', delete_page: 'trash', migrate_blog: 'refresh',
    };

    const recentActivity = document.getElementById('recent-activity')!;
    recentActivity.innerHTML = activityData.activity?.length
      ? activityData.activity.map((a: any) => `
        <div class="flex items-center gap-3 px-5 py-3.5" style="border-top:1px solid var(--a-border)">
          <span class="a-muted">${svg(actionIcons[a.action] || 'info')}</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm" style="color:var(--a-text)"><strong style="color:var(--a-fg);font-weight:600">${esc(a.userName)}</strong> ${esc(a.action.replace(/_/g, ' '))}${a.entityTitle ? ` <span class="a-muted">“${esc(a.entityTitle)}”</span>` : ''}</p>
            <p class="text-xs a-subtle mt-0.5">${new Date(a.createdAt).toLocaleString()}</p>
          </div>
        </div>`).join('')
      : '<div class="a-card-pad text-center a-subtle"><p class="text-sm">No activity yet</p></div>';
  }

  loadDashboard();
</script>

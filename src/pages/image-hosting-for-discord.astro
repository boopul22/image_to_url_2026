---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ImageToURL — Image Hosting for Discord",
  "url": "https://imagetourl.cloud/image-hosting-for-discord",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Get permanent image URLs for Discord embeds. Discord CDN links expire — use ImageToURL for reliable, permanent image hosting."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Why do Discord image links expire?",
      "acceptedAnswer": { "@type": "Answer", "text": "Discord changed their CDN in 2023 to use signed URLs with expiration tokens. Images uploaded directly to Discord now have URLs that expire after a set period, causing broken images in bookmarks, wikis, and external embeds. ImageToURL provides permanent URLs that never expire." }
    },
    {
      "@type": "Question",
      "name": "Can I use ImageToURL images in Discord bot embeds?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. ImageToURL provides direct image URLs that work perfectly in Discord bot embed fields. The URLs are served over HTTPS with proper content-type headers, so Discord renders them as inline images in embed messages." }
    },
    {
      "@type": "Question",
      "name": "Do ImageToURL links work in Discord markdown?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. You can paste an ImageToURL link directly into a Discord message and it will display as an embedded image preview. The URLs also work in Discord's markdown format for bot messages and webhook content." }
    },
    {
      "@type": "Question",
      "name": "Is there a file size limit for Discord image hosting?",
      "acceptedAnswer": { "@type": "Answer", "text": "ImageToURL supports images up to 25MB, which covers virtually any image you would want to share on Discord. Unlike Discord's free tier which limits uploads to 25MB (or 50MB with Nitro), your images are hosted permanently without file size degradation." }
    },
    {
      "@type": "Question",
      "name": "Can I host animated GIFs for Discord?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. ImageToURL fully supports animated GIFs. Upload your GIF and get a permanent URL that plays the animation when embedded in Discord messages, bot embeds, or server descriptions." }
    }
  ]
};
---

<Layout title="Image Hosting for Discord — Permanent Embed Links | ImageToURL" description="Get permanent image URLs for Discord embeds. Discord CDN links expire — use ImageToURL for reliable, permanent image hosting that works in Discord." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Discord Users</span>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Image Hosting for Discord <span class="italic text-primary">that never expires.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Discord CDN links expire and break your embeds. Upload your images here and get permanent, reliable URLs that work forever in Discord messages, bots, and webhooks.
      </p>
    </header>
    </div>



    <!-- Why Discord Users Need External Hosting -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why Discord Users Need External Hosting</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">timer_off</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">CDN Links Expire</h3>
          <p class="font-body text-on-surface-variant">Since 2023, Discord uses signed URLs with expiration tokens. Images you upload to Discord get temporary links that stop working after a period, breaking any external references.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">broken_image</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Embeds Break Over Time</h3>
          <p class="font-body text-on-surface-variant">Bot embeds, webhook messages, and pinned images that rely on Discord CDN URLs eventually show broken image placeholders. External hosting keeps your embeds looking clean permanently.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">smart_toy</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Bot-Friendly URLs</h3>
          <p class="font-body text-on-surface-variant">ImageToURL links work perfectly in Discord.js, discord.py, and any bot framework. Set embed image fields with a permanent URL that never needs refreshing or token management.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">link</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Direct Hotlinks</h3>
          <p class="font-body text-on-surface-variant">Every uploaded image gets a clean, direct URL with the correct content-type headers. Discord automatically renders these as inline image previews in any channel.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">smart_toy</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Bot Developers</h3>
          <p class="font-body text-on-surface-variant text-sm">Use permanent image URLs in bot embeds, welcome messages, and automated responses without worrying about expired links.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">shield_person</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Server Admins</h3>
          <p class="font-body text-on-surface-variant text-sm">Set up server rules, info channels, and role descriptions with images that stay visible permanently, even in pinned messages.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">groups</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Community Managers</h3>
          <p class="font-body text-on-surface-variant text-sm">Create event announcements, community guides, and resource channels with reliable image embeds that never break.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-2xl sm:text-3xl">sports_esports</span>
          </div>
          <h3 class="text-lg font-black font-headline mb-2">Gamers</h3>
          <p class="font-body text-on-surface-variant text-sm">Share screenshots, game clips, memes, and fan art with permanent links that work in any Discord server or DM.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="reveal">
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Why do Discord image links expire?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Discord changed their CDN in 2023 to use signed URLs with expiration tokens. Images uploaded directly to Discord now have URLs that expire after a set period, causing broken images in bookmarks, wikis, and external embeds. ImageToURL provides permanent URLs that never expire.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I use ImageToURL images in Discord bot embeds?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. ImageToURL provides direct image URLs that work perfectly in Discord bot embed fields. The URLs are served over HTTPS with proper content-type headers, so Discord renders them as inline images in embed messages.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Do ImageToURL links work in Discord markdown?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Absolutely. You can paste an ImageToURL link directly into a Discord message and it will display as an embedded image preview. The URLs also work in Discord's markdown format for bot messages and webhook content.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Is there a file size limit for Discord image hosting?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">ImageToURL supports images up to 25MB, which covers virtually any image you would want to share on Discord. Unlike Discord's free tier which limits uploads to 25MB (or 50MB with Nitro), your images are hosted permanently without file size degradation.</div>
        </details>
        <details class="group border-2 border-on-background hard-shadow mb-3">
          <summary class="flex items-center justify-between p-4 sm:p-5 cursor-pointer font-headline font-bold text-sm sm:text-base">
            <span>Can I host animated GIFs for Discord?</span>
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5 font-body text-on-surface-variant text-sm sm:text-base">Yes. ImageToURL fully supports animated GIFs. Upload your GIF and get a permanent URL that plays the animation when embedded in Discord messages, bot embeds, or server descriptions.</div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6 reveal">
        <a href="/free-image-hosting" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Free Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">Host any image for free with global CDN</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-hosting-for-forums" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">Forum Image Hosting</h3>
            <p class="text-sm text-on-surface-variant">BBCode and HTML ready image links</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
        <a href="/image-hosting-for-github-readme" class="border-2 border-on-background p-5 sm:p-6 rounded-xl hard-shadow hover:-translate-y-1 transition-transform flex items-center justify-between gap-3">
          <div>
            <h3 class="font-headline font-bold text-base mb-1">GitHub README Hosting</h3>
            <p class="text-sm text-on-surface-variant">Permanent images for your README files</p>
          </div>
          <span class="material-symbols-outlined text-primary">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-2xl sm:text-4xl font-black font-headline tracking-tight mb-4">Stop losing images to expired Discord links</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload once, get a permanent URL. Works in embeds, bots, webhooks, and messages forever.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

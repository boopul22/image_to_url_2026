---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public PHP/API-key uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Hosting API — PHP Status"
  slug="image-hosting-api-php"
  metaDescription="Current PHP/API upload status for ImageToURL. Public API-key uploads are not live yet; use the website uploader today."
  h1Pre="Image hosting API"
  h1Highlight="not public yet."
  intro="The public PHP upload flow is not live yet. The current upload endpoint powers the website uploader and rejects non-same-site automation requests."
  lang="text"
  langLabel="PHP"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "PHP automation is roadmap", body: "Server-side PHP uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 50 MB file cap." },
    { title: "Contact for automation", body: "If you need WordPress, Laravel, or backend upload workflows, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I upload from PHP today?", a: "No. Public PHP/API-key uploads are not live yet; use the website uploader." },
    { q: "Should I use Guzzle or curl?", a: "Neither is supported for production uploads until public API-key access opens. The current /api/upload route is guarded for same-site browser requests." },
    { q: "WordPress integration?", a: "Not available as a public integration today. Use the web uploader for assets, or contact us if you need automation access reviewed." },
    { q: "Laravel Filesystem custom driver?", a: "Not today. A driver would need public API-key uploads, which are not live yet." },
    { q: "Max upload size?", a: "ImageToURL currently accepts up to 50 MB per website upload." },
    { q: "What are the live limits?", a: "Guests get 100 uploads per rolling 24 hours. Signed-in users get 150 credits per day (about 1 credit per MB)." },
    { q: "When will PHP automation work?", a: "It depends on API rollout. Until then, treat this page as a status note, not production API documentation." },
    { q: "Do I need an API key?", a: "No public upload API key is available today. Signed-in website uploads use your normal browser session." }
  ]}
  relatedSlugs={[
    { href: "/image-hosting-api-python/", title: "Python", body: "Python snippet." },
    { href: "/image-hosting-api-nodejs/", title: "Node.js", body: "Node snippet." },
    { href: "/en/image-hosting-for-wordpress/", title: "WordPress", body: "WP integration details." }
  ]}
/>

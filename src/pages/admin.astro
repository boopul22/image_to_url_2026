---
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import AdminSidebar from '../components/AdminSidebar.astro';

// No CDN caching — always fresh, private admin data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
---

<Layout title="Admin Dashboard - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="dashboard" />

    <main class="flex-1 p-3 sm:p-4 md:p-5 space-y-6 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">

      <!-- Welcome Header -->
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div>
          <span class="inline-block px-2 py-0.5 bg-tertiary-fixed border-2 border-on-surface rounded-full font-label text-[10px] font-bold uppercase tracking-widest text-on-tertiary-fixed mb-1.5">Admin Overview</span>
          <h1 class="text-lg sm:text-xl md:text-2xl font-headline italic font-black text-on-surface leading-tight">
            Welcome back, {user.name.split(' ')[0]}.
          </h1>
          <p class="text-[11px] text-outline mt-0.5">All time windows are in UTC.</p>
        </div>
        <button id="refresh-stats" class="flex items-center gap-1.5 bg-surface border-2 border-on-surface rounded-lg px-3 py-1.5 font-label text-[11px] font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-transform hard-shadow">
          <span class="material-symbols-outlined text-base">refresh</span> Refresh
        </button>
      </div>

      <!-- ====================== 1. OVERVIEW ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Overview</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="bg-secondary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <div class="flex items-center gap-1.5 text-on-secondary-fixed-variant">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">photo_library</span>
              <p class="font-label text-[10px] font-bold uppercase tracking-widest">Total Uploads</p>
            </div>
            <p class="text-2xl font-headline font-black text-on-secondary-fixed mt-1" id="kpi-images">—</p>
            <p class="font-label text-[10px] uppercase tracking-wider text-on-secondary-fixed-variant mt-0.5" id="kpi-images-delta">&nbsp;</p>
          </div>
          <div class="bg-secondary-container border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <div class="flex items-center gap-1.5 text-on-secondary-container/70">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">group</span>
              <p class="font-label text-[10px] font-bold uppercase tracking-widest">Registered Users</p>
            </div>
            <p class="text-2xl font-headline font-black text-on-secondary-container mt-1" id="kpi-users">—</p>
            <p class="font-label text-[10px] uppercase tracking-wider text-on-secondary-container/70 mt-0.5" id="kpi-users-delta">&nbsp;</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <div class="flex items-center gap-1.5 text-on-tertiary-fixed/70">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">cloud</span>
              <p class="font-label text-[10px] font-bold uppercase tracking-widest">Storage Used</p>
            </div>
            <p class="text-2xl font-headline font-black text-on-tertiary-fixed mt-1" id="kpi-storage">—</p>
            <p class="font-label text-[10px] uppercase tracking-wider text-on-tertiary-fixed/70 mt-0.5" id="kpi-storage-delta">&nbsp;</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <div class="flex items-center gap-1.5 text-on-primary-fixed-variant">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">key</span>
              <p class="font-label text-[10px] font-bold uppercase tracking-widest">API Keys</p>
            </div>
            <p class="text-2xl font-headline font-black text-on-primary-fixed mt-1" id="kpi-keys">—</p>
            <p class="font-label text-[10px] uppercase tracking-wider text-on-primary-fixed-variant mt-0.5" id="kpi-keys-delta">&nbsp;</p>
          </div>
        </div>
      </section>

      <!-- ====================== 2. UPLOAD ACTIVITY ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Upload Activity</h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Today</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="act-today">—</p>
            <p class="font-label text-[10px] uppercase text-outline mt-0.5" id="act-today-sub">&nbsp;</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Yesterday</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="act-yesterday">—</p>
            <p class="font-label text-[10px] uppercase text-outline mt-0.5" id="act-yesterday-sub">&nbsp;</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Last 7 days</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="act-7d">—</p>
            <p class="font-label text-[10px] uppercase mt-0.5" id="act-7d-sub">&nbsp;</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Last 30 days</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="act-30d">—</p>
            <p class="font-label text-[10px] uppercase mt-0.5" id="act-30d-sub">&nbsp;</p>
          </div>
        </div>
        <!-- 30-day breakdown bar: how the last-30d uploads split by source/auth/adblock -->
        <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline mb-2">Last 30 days · breakdown</p>
          <dl id="act-breakdown" class="grid grid-cols-2 sm:grid-cols-3 gap-x-4 gap-y-1.5 text-xs">
            <div class="flex items-baseline justify-between"><dt class="text-outline">Authenticated</dt><dd class="font-bold tabular-nums" data-breakdown="auth">—</dd></div>
            <div class="flex items-baseline justify-between"><dt class="text-outline">Anonymous</dt><dd class="font-bold tabular-nums" data-breakdown="anon">—</dd></div>
            <div class="flex items-baseline justify-between"><dt class="text-outline">Via web</dt><dd class="font-bold tabular-nums" data-breakdown="web">—</dd></div>
            <div class="flex items-baseline justify-between"><dt class="text-outline">Via API</dt><dd class="font-bold tabular-nums" data-breakdown="api">—</dd></div>
            <div class="flex items-baseline justify-between"><dt class="text-outline">With ad-blocker</dt><dd class="font-bold tabular-nums" data-breakdown="adblock">—</dd></div>
            <div class="flex items-baseline justify-between"><dt class="text-outline">No ad-blocker</dt><dd class="font-bold tabular-nums" data-breakdown="noadblock">—</dd></div>
          </dl>
        </div>
      </section>

      <!-- ====================== 3. USERS ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Users</h2>

        <!-- Top uploaders (last 30 days) -->
        <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-3 border-b-2 border-on-surface">
            <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Top Uploaders <span class="text-outline font-body not-italic font-normal normal-case">· last 30 days</span></h3>
            <span class="font-label text-[10px] font-bold uppercase tracking-wider text-outline" id="uploads-by-user-total">—</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[640px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Avg/day</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">First</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider w-1/3">Share</th>
                </tr>
              </thead>
              <tbody id="uploads-by-user-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Lifetime top uploaders + new signups + dormant -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
            <div class="p-3 border-b-2 border-on-surface">
              <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Top Uploaders <span class="text-outline font-body not-italic font-normal normal-case">· all-time</span></h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-left min-w-[420px]">
                <thead>
                  <tr class="border-b border-outline-variant">
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Since</th>
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last</th>
                  </tr>
                </thead>
                <tbody id="top-lifetime-body" class="divide-y divide-outline-variant/50">
                  <tr><td colspan="4" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
            <div class="p-3 border-b-2 border-on-surface">
              <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Recent Signups</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-left min-w-[420px]">
                <thead>
                  <tr class="border-b border-outline-variant">
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Joined</th>
                    <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Lifetime</th>
                  </tr>
                </thead>
                <tbody id="recent-signups-body" class="divide-y divide-outline-variant/50">
                  <tr><td colspan="3" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="p-3 border-b-2 border-on-surface">
            <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Dormant Registered Users <span class="text-outline font-body not-italic font-normal normal-case">· no upload in last 30 days</span></h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[560px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Email</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Joined</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Lifetime uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last upload</th>
                </tr>
              </thead>
              <tbody id="dormant-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="5" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ====================== 4. DAILY BREAKDOWN ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Daily Breakdown <span class="text-outline font-body not-italic font-normal normal-case text-xs">· last 30 days · UTC</span></h2>
        <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[640px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Date</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Unique users</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Anon</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Ad-block</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Size</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider w-1/4">Volume</th>
                </tr>
              </thead>
              <tbody id="daily-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="7" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- ====================== 5. PATTERNS ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Patterns <span class="text-outline font-body not-italic font-normal normal-case text-xs">· when uploads happen · UTC</span></h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
            <div class="p-3 border-b-2 border-on-surface">
              <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Hour of day <span class="text-outline font-body not-italic font-normal normal-case">· last 7 days</span></h3>
            </div>
            <div class="p-3 font-mono text-[11px] leading-snug" id="hourly-body">
              <p class="text-outline">Loading...</p>
            </div>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
            <div class="p-3 border-b-2 border-on-surface">
              <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Day of week <span class="text-outline font-body not-italic font-normal normal-case">· last 30 days</span></h3>
            </div>
            <div class="p-3 font-mono text-[11px] leading-snug" id="dow-body">
              <p class="text-outline">Loading...</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ====================== 6. ANONYMOUS TRAFFIC ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Anonymous Traffic <span class="text-outline font-body not-italic font-normal normal-case text-xs">· unique IPs as a proxy for visitors</span></h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Unique IPs · 7d</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="anon-ips-7d">—</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Unique IPs · 30d</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="anon-ips-30d">—</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Anon uploads · 30d</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="anon-uploads-30d">—</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Anon uploads · all-time</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="anon-uploads-total">—</p>
          </div>
        </div>
      </section>

      <!-- ====================== 7. ENGAGEMENT ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Engagement</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-3">
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Active sessions</p>
            <p class="text-2xl font-headline font-black text-on-surface mt-1" id="eng-sessions">—</p>
            <p class="font-label text-[10px] uppercase text-outline mt-0.5">Logged-in users right now</p>
          </div>
          <div class="bg-on-surface text-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-surface/70">Ad-blocker users <span class="text-surface/50 normal-case font-normal">· 30d</span></p>
            <p class="text-2xl font-headline font-black text-surface mt-1" id="eng-adblock-30d">—</p>
            <p class="font-label text-[10px] uppercase text-surface/60 mt-0.5" id="eng-adblock-30d-sub">&nbsp;</p>
          </div>
          <div class="bg-surface border-2 border-on-surface rounded-lg p-3 hard-shadow">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">CTA clicks <span class="normal-case font-normal">· 30d</span></p>
            <div id="eng-cta-list" class="mt-1 space-y-1 text-xs">
              <p class="text-outline">Loading...</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ====================== 8. RECENT UPLOADS ====================== -->
      <section class="space-y-3">
        <h2 class="text-sm font-headline italic font-black text-on-surface uppercase border-b-2 border-on-surface pb-1">Recent Uploads</h2>
        <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-3 border-b-2 border-on-surface">
            <h3 class="text-xs font-headline italic font-black text-on-surface uppercase">Last 10</h3>
            <a href="/admin/images" class="font-label text-[10px] font-bold uppercase tracking-wider text-primary hover:underline">View All</a>
          </div>
          <div id="recent-uploads">
            <div class="p-6 text-center text-outline">
              <span class="material-symbols-outlined text-3xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
        </div>
      </section>

    </main>
  </div>
</Layout>

<script>
  function esc(s: string | null | undefined): string {
    const d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function formatSize(bytes: number): string {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
  }

  function fmtDate(s: string | null | undefined): string {
    if (!s) return '—';
    // SQLite returns "YYYY-MM-DD HH:MM:SS" in UTC.
    const d = new Date(s.replace(' ', 'T') + 'Z');
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleDateString(undefined, { month: 'short', day: '2-digit', year: '2-digit' });
  }

  function fmtChange(pct: number | null): { text: string; cls: string } {
    if (pct === null || pct === undefined) return { text: 'n/a vs prev', cls: 'text-outline' };
    const sign = pct > 0 ? '+' : '';
    const rounded = Math.abs(pct) >= 10 ? pct.toFixed(0) : pct.toFixed(1);
    const cls = pct > 0 ? 'text-secondary font-bold' : pct < 0 ? 'text-error font-bold' : 'text-outline';
    return { text: `${sign}${rounded}% vs prev`, cls };
  }

  function textBar(value: number, max: number, width: number = 16): string {
    if (max <= 0) return '';
    const filled = Math.round((value / max) * width);
    return '█'.repeat(filled) + '░'.repeat(Math.max(0, width - filled));
  }

  const DOW_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

  type Data = any;

  function renderOverview(d: Data) {
    document.getElementById('kpi-images')!.textContent = d.uploads.allTime.toLocaleString();
    document.getElementById('kpi-images-delta')!.textContent =
      `+${(d.uploads.today ?? 0).toLocaleString()} today · +${(d.uploads.last7d ?? 0).toLocaleString()} this week`;

    document.getElementById('kpi-users')!.textContent = d.users.total.toLocaleString();
    document.getElementById('kpi-users-delta')!.textContent =
      `+${(d.users.newToday ?? 0).toLocaleString()} today · +${(d.users.new30d ?? 0).toLocaleString()} this month`;

    document.getElementById('kpi-storage')!.textContent = formatSize(d.storage.allTime);
    document.getElementById('kpi-storage-delta')!.textContent =
      `+${formatSize(d.storage.last7d)} this week · +${formatSize(d.storage.last30d)} this month`;

    document.getElementById('kpi-keys')!.textContent = (d.activeApiKeys ?? 0).toLocaleString();
    document.getElementById('kpi-keys-delta')!.textContent = `${(d.users.admins ?? 0).toLocaleString()} admin${d.users.admins === 1 ? '' : 's'} · ${(d.users.banned ?? 0).toLocaleString()} banned`;
  }

  function renderActivity(d: Data) {
    document.getElementById('act-today')!.textContent = (d.uploads.today ?? 0).toLocaleString();
    document.getElementById('act-today-sub')!.textContent = `${formatSize(d.storage.today)} uploaded`;

    document.getElementById('act-yesterday')!.textContent = (d.uploads.yesterday ?? 0).toLocaleString();
    const ydayDelta = (d.uploads.today ?? 0) - (d.uploads.yesterday ?? 0);
    document.getElementById('act-yesterday-sub')!.textContent =
      ydayDelta === 0 ? 'same as today' : `today is ${ydayDelta > 0 ? '+' : ''}${ydayDelta} vs yesterday`;

    document.getElementById('act-7d')!.textContent = (d.uploads.last7d ?? 0).toLocaleString();
    const c7 = fmtChange(d.uploads.change7dPct);
    const sub7 = document.getElementById('act-7d-sub')!;
    sub7.textContent = c7.text;
    sub7.className = `font-label text-[10px] uppercase mt-0.5 ${c7.cls}`;

    document.getElementById('act-30d')!.textContent = (d.uploads.last30d ?? 0).toLocaleString();
    const c30 = fmtChange(d.uploads.change30dPct);
    const sub30 = document.getElementById('act-30d-sub')!;
    sub30.textContent = c30.text;
    sub30.className = `font-label text-[10px] uppercase mt-0.5 ${c30.cls}`;

    // Breakdown bar
    const s = d.sources;
    const total = d.uploads.last30d || 1;
    const set = (key: string, n: number) => {
      const el = document.querySelector(`#act-breakdown [data-breakdown="${key}"]`);
      if (el) el.textContent = `${n.toLocaleString()} (${((n / total) * 100).toFixed(1)}%)`;
    };
    set('auth', s.authenticated30d);
    set('anon', s.anonymous30d);
    set('web', s.web30d);
    set('api', s.api30d);
    set('adblock', s.adblock30d);
    set('noadblock', s.noAdblock30d);
  }

  function renderTopUploaders30d(d: Data) {
    const rows: any[] = d.uploadsByUser ?? [];
    const total = rows.reduce((s, r) => s + Number(r.count), 0);
    const max = Math.max(1, ...rows.map(r => Number(r.count)));
    const totalEl = document.getElementById('uploads-by-user-total');
    if (totalEl) totalEl.textContent = `${rows.length.toLocaleString()} ${rows.length === 1 ? 'user' : 'users'} · ${total.toLocaleString()} uploads`;

    const body = document.getElementById('uploads-by-user-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads in the last 30 days</p></td></tr>';
      return;
    }
    const activeDays = (first: string, last: string) => {
      const f = new Date(first.replace(' ', 'T') + 'Z');
      const l = new Date(last.replace(' ', 'T') + 'Z');
      const days = Math.floor((l.getTime() - f.getTime()) / 86400000) + 1;
      return Math.max(1, days);
    };
    body.innerHTML = rows.map(r => {
      const span = activeDays(r.first_upload, r.last_upload);
      const avg = (Number(r.count) / span).toFixed(1);
      const isAnon = !r.user_id;
      const initial = (r.user_name || '?').trim().charAt(0).toUpperCase();
      const avatar = r.user_avatar
        ? `<img src="${esc(r.user_avatar)}" alt="${esc(r.user_name)}" class="w-7 h-7 rounded-full border border-on-surface object-cover flex-shrink-0" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
        : `<div class="w-7 h-7 rounded-full border border-on-surface bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="text-[10px] font-bold text-outline">${esc(initial)}</span></div>`;
      const sharePct = (Number(r.count) / max * 100).toFixed(1);
      return `
        <tr class="hover:bg-surface-container-lowest transition-colors">
          <td class="px-3 py-1.5">
            <div class="flex items-center gap-2 min-w-0">
              ${avatar}
              <div class="min-w-0">
                <p class="text-xs font-bold truncate max-w-[180px]">${esc(r.user_name)}${isAnon ? ' <span class="text-outline font-normal">(no account)</span>' : ''}</p>
                ${r.user_email ? `<p class="text-[10px] text-outline truncate max-w-[180px]">${esc(r.user_email)}</p>` : ''}
              </div>
            </div>
          </td>
          <td class="px-3 py-1.5 text-xs font-bold tabular-nums">${Number(r.count).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs tabular-nums text-on-surface-variant">${avg}</td>
          <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.first_upload)}</td>
          <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.last_upload)}</td>
          <td class="px-3 py-1.5"><div class="h-2 bg-primary border border-on-surface" style="width: ${sharePct}%; max-width: 100%;"></div></td>
        </tr>
      `;
    }).join('');
  }


---
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import AdminLayout from '../layouts/AdminLayout.astro';
import Icon from '../components/admin/Icon.astro';

// No CDN caching — always fresh, private admin data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
const firstName = user.name.split(' ')[0];
---

<AdminLayout
  title="Dashboard"
  activePage="dashboard"
  eyebrow="Overview · UTC"
  heading={`Welcome back, ${firstName}.`}
  subtitle="Here's how ImageToURL is performing."
>
  <button slot="actions" id="refresh-stats" class="a-btn">
    <Icon name="refresh" size={16} /> Refresh
  </button>

  <div class="space-y-5">

    <!-- UPLOADS KPI GRID -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Uploads today</p>
        <p class="a-stat-value mt-1.5" id="hero-today">—</p>
        <p class="text-xs mt-1 a-subtle" id="hero-today-sub">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Yesterday</p>
        <p class="a-stat-value mt-1.5" id="hero-yesterday">—</p>
        <p class="text-xs mt-1 a-subtle" id="hero-yesterday-sub">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Last 7 days</p>
        <p class="a-stat-value mt-1.5" id="hero-7d">—</p>
        <p class="text-xs mt-1 a-subtle" id="hero-7d-sub">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Last 30 days</p>
        <p class="a-stat-value mt-1.5" id="hero-30d">—</p>
        <p class="text-xs mt-1 a-subtle" id="hero-30d-sub">&nbsp;</p>
      </div>
    </div>

    <!-- SECONDARY KPI STRIP -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <div class="a-card a-card-pad">
        <div class="flex items-center justify-between">
          <p class="a-stat-label">Total uploads</p>
          <span class="a-subtle"><Icon name="images" size={16} /></span>
        </div>
        <p class="a-stat-value mt-1.5" id="kpi-images">—</p>
        <p class="text-xs mt-1 a-subtle" id="kpi-images-delta">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <div class="flex items-center justify-between">
          <p class="a-stat-label">Registered users</p>
          <span class="a-subtle"><Icon name="users" size={16} /></span>
        </div>
        <p class="a-stat-value mt-1.5" id="kpi-users">—</p>
        <p class="text-xs mt-1 a-subtle" id="kpi-users-delta">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <div class="flex items-center justify-between">
          <p class="a-stat-label">Storage used</p>
          <span class="a-subtle"><Icon name="hard-drive" size={16} /></span>
        </div>
        <p class="a-stat-value mt-1.5" id="kpi-storage">—</p>
        <p class="text-xs mt-1 a-subtle" id="kpi-storage-delta">&nbsp;</p>
      </div>
      <div class="a-card a-card-pad">
        <div class="flex items-center justify-between">
          <p class="a-stat-label">Active sessions</p>
          <span class="a-subtle"><Icon name="zap" size={16} /></span>
        </div>
        <p class="a-stat-value mt-1.5" id="kpi-sessions">—</p>
        <p class="text-xs mt-1 a-subtle" id="kpi-sessions-delta">Live right now</p>
      </div>
    </div>

    <!-- COMPOSITION -->
    <div class="a-card">
      <div class="a-card-head">
        <h2 class="a-section-title">Composition</h2>
        <span class="text-xs a-subtle">Last 30 days · <span id="comp-total" class="a-num">—</span> uploads</span>
      </div>
      <div class="a-card-pad space-y-4" id="comp-bars">
        <div>
          <div class="flex items-baseline justify-between text-xs mb-1.5">
            <span class="font-medium" style="color:var(--a-fg)">Authenticated <span class="a-subtle font-normal" id="comp-auth-num">—</span></span>
            <span class="a-muted">Anonymous <span class="font-medium" style="color:var(--a-fg)" id="comp-anon-num">—</span></span>
          </div>
          <div class="a-track">
            <div class="a-seg a-seg-1" id="comp-auth-bar" style="width:0%"></div>
            <div class="a-seg a-seg-2" id="comp-anon-bar" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between text-xs mb-1.5">
            <span class="font-medium" style="color:var(--a-fg)">Web <span class="a-subtle font-normal" id="comp-web-num">—</span></span>
            <span class="a-muted">API <span class="font-medium" style="color:var(--a-fg)" id="comp-api-num">—</span></span>
          </div>
          <div class="a-track">
            <div class="a-seg a-seg-1" id="comp-web-bar" style="width:0%"></div>
            <div class="a-seg a-seg-3" id="comp-api-bar" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex items-baseline justify-between text-xs mb-1.5">
            <span class="font-medium" style="color:var(--a-fg)">Ad-blocker <span class="a-subtle font-normal" id="comp-ab-num">—</span></span>
            <span class="a-muted">No blocker <span class="font-medium" style="color:var(--a-fg)" id="comp-noab-num">—</span></span>
          </div>
          <div class="a-track">
            <div class="a-seg a-seg-3" id="comp-ab-bar" style="width:0%"></div>
            <div class="a-seg a-seg-2" id="comp-noab-bar" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- USERS -->
    <div class="a-card overflow-hidden">
      <div class="a-card-head flex-wrap">
        <h2 class="a-section-title">Users</h2>
        <div class="a-tabs" role="tablist" id="user-tabs">
          <button data-tab="top30" class="user-tab a-tab is-active" type="button">Top · 30d</button>
          <button data-tab="topall" class="user-tab a-tab" type="button">Top · all-time</button>
          <button data-tab="recent" class="user-tab a-tab" type="button">Recent signups</button>
          <button data-tab="dormant" class="user-tab a-tab" type="button">Dormant</button>
        </div>
      </div>

      <div data-panel="top30" class="user-panel overflow-x-auto">
        <table class="a-table min-w-[560px]">
          <thead><tr><th>User</th><th>Uploads</th><th>Avg/day</th><th>Last</th><th class="w-1/3">Share</th></tr></thead>
          <tbody id="uploads-by-user-body"><tr><td colspan="5" class="text-center a-subtle">Loading…</td></tr></tbody>
        </table>
      </div>
      <div data-panel="topall" class="user-panel hidden overflow-x-auto">
        <table class="a-table min-w-[480px]">
          <thead><tr><th>User</th><th>Uploads</th><th>Since</th><th>Last</th></tr></thead>
          <tbody id="top-lifetime-body"><tr><td colspan="4" class="text-center a-subtle">Loading…</td></tr></tbody>
        </table>
      </div>
      <div data-panel="recent" class="user-panel hidden overflow-x-auto">
        <table class="a-table min-w-[480px]">
          <thead><tr><th>User</th><th>Joined</th><th>Lifetime</th></tr></thead>
          <tbody id="recent-signups-body"><tr><td colspan="3" class="text-center a-subtle">Loading…</td></tr></tbody>
        </table>
      </div>
      <div data-panel="dormant" class="user-panel hidden overflow-x-auto">
        <table class="a-table min-w-[560px]">
          <thead><tr><th>User</th><th>Joined</th><th>Lifetime</th><th>Last upload</th></tr></thead>
          <tbody id="dormant-body"><tr><td colspan="4" class="text-center a-subtle">Loading…</td></tr></tbody>
        </table>
      </div>
    </div>

    <!-- TRENDS -->
    <div class="grid grid-cols-1 xl:grid-cols-[2fr_1fr] gap-4">
      <div class="a-card overflow-hidden">
        <div class="a-card-head">
          <h2 class="a-section-title">Daily breakdown</h2>
          <span class="text-xs a-subtle">Last 30 days</span>
        </div>
        <div class="overflow-auto max-h-[480px]">
          <table class="a-table min-w-[560px]">
            <thead class="sticky top-0"><tr><th>Date</th><th>Uploads</th><th>Users</th><th>Anon</th><th>Size</th><th class="w-1/3">Volume</th></tr></thead>
            <tbody id="daily-body"><tr><td colspan="6" class="text-center a-subtle">Loading…</td></tr></tbody>
          </table>
        </div>
      </div>

      <div class="space-y-4">
        <div class="a-card overflow-hidden">
          <div class="a-card-head"><h2 class="a-section-title">Hour of day</h2><span class="text-xs a-subtle">7d</span></div>
          <div class="a-card-pad a-mono text-[11px] leading-relaxed" id="hourly-body"><p class="a-subtle">Loading…</p></div>
        </div>
        <div class="a-card overflow-hidden">
          <div class="a-card-head"><h2 class="a-section-title">Day of week</h2><span class="text-xs a-subtle">30d</span></div>
          <div class="a-card-pad a-mono text-[11px] leading-relaxed" id="dow-body"><p class="a-subtle">Loading…</p></div>
        </div>
      </div>
    </div>

    <!-- ENGAGEMENT -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Anon visitors · unique IPs</p>
        <div class="grid grid-cols-2 gap-4 mt-3">
          <div><p class="text-xl font-semibold a-num" style="color:var(--a-fg)" id="anon-ips-7d">—</p><p class="text-xs a-subtle mt-0.5">7 days</p></div>
          <div><p class="text-xl font-semibold a-num" style="color:var(--a-fg)" id="anon-ips-30d">—</p><p class="text-xs a-subtle mt-0.5">30 days</p></div>
        </div>
      </div>
      <div class="a-card a-card-pad">
        <p class="a-stat-label">Ad-blocker users · last 30 days</p>
        <div class="flex items-baseline gap-2 mt-3">
          <p class="text-xl font-semibold a-num" style="color:var(--a-fg)" id="eng-adblock-30d">—</p>
          <p class="text-xs a-subtle" id="eng-adblock-30d-sub">&nbsp;</p>
        </div>
      </div>
      <div class="a-card a-card-pad">
        <p class="a-stat-label">CTA clicks · last 30 days</p>
        <div id="eng-cta-list" class="mt-3 space-y-1.5 text-xs"><p class="a-subtle">Loading…</p></div>
      </div>
    </div>

    <!-- RECENT UPLOADS -->
    <div class="a-card overflow-hidden">
      <div class="a-card-head">
        <h2 class="a-section-title">Recent uploads</h2>
        <a href="/admin/images" class="a-link text-xs">View all →</a>
      </div>
      <div id="recent-uploads"><div class="a-card-pad text-center a-subtle">Loading…</div></div>
    </div>

  </div>
</AdminLayout>

<script>
  const ICON_LINK = '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';

  function esc(s: string | null | undefined): string {
    const d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function formatSize(bytes: number): string {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
  }

  function fmtDate(s: string | null | undefined): string {
    if (!s) return '—';
    const d = new Date(s.replace(' ', 'T') + 'Z');
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleDateString(undefined, { month: 'short', day: '2-digit', year: '2-digit' });
  }

  function fmtChange(pct: number | null): { text: string; cls: string } {
    if (pct === null || pct === undefined) return { text: 'no prev data', cls: 'a-subtle' };
    const sign = pct > 0 ? '+' : '';
    const rounded = Math.abs(pct) >= 10 ? pct.toFixed(0) : pct.toFixed(1);
    const cls = pct > 0 ? 'a-delta-up' : pct < 0 ? 'a-delta-down' : 'a-subtle';
    return { text: `${sign}${rounded}% vs prev`, cls };
  }

  function textBar(value: number, max: number, width: number = 16): string {
    if (max <= 0) return '';
    const filled = Math.round((value / max) * width);
    return '█'.repeat(filled) + '░'.repeat(Math.max(0, width - filled));
  }

  const DOW_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  type Data = any;

  function renderHero(d: Data) {
    document.getElementById('hero-today')!.textContent = (d.uploads.today ?? 0).toLocaleString();
    document.getElementById('hero-today-sub')!.textContent = `${formatSize(d.storage.today)} stored`;

    document.getElementById('hero-yesterday')!.textContent = (d.uploads.yesterday ?? 0).toLocaleString();
    const ydayDelta = (d.uploads.today ?? 0) - (d.uploads.yesterday ?? 0);
    document.getElementById('hero-yesterday-sub')!.textContent =
      ydayDelta === 0 ? 'same as today' : `today ${ydayDelta > 0 ? '+' : ''}${ydayDelta}`;

    document.getElementById('hero-7d')!.textContent = (d.uploads.last7d ?? 0).toLocaleString();
    const c7 = fmtChange(d.uploads.change7dPct);
    const sub7 = document.getElementById('hero-7d-sub')!;
    sub7.textContent = c7.text; sub7.className = `text-xs mt-1 ${c7.cls}`;

    document.getElementById('hero-30d')!.textContent = (d.uploads.last30d ?? 0).toLocaleString();
    const c30 = fmtChange(d.uploads.change30dPct);
    const sub30 = document.getElementById('hero-30d-sub')!;
    sub30.textContent = c30.text; sub30.className = `text-xs mt-1 ${c30.cls}`;
  }

  function renderKPIs(d: Data) {
    document.getElementById('kpi-images')!.textContent = (d.uploads.allTime ?? 0).toLocaleString();
    document.getElementById('kpi-images-delta')!.textContent = `+${(d.uploads.last7d ?? 0).toLocaleString()} this week`;
    document.getElementById('kpi-users')!.textContent = (d.users.total ?? 0).toLocaleString();
    document.getElementById('kpi-users-delta')!.textContent = `+${(d.users.new30d ?? 0).toLocaleString()} this month`;
    document.getElementById('kpi-storage')!.textContent = formatSize(d.storage.allTime);
    document.getElementById('kpi-storage-delta')!.textContent = `+${formatSize(d.storage.last30d)} this month`;
    document.getElementById('kpi-sessions')!.textContent = (d.engagement?.activeSessions ?? 0).toLocaleString();
  }

  function renderComposition(d: Data) {
    const total = d.uploads.last30d || 0;
    document.getElementById('comp-total')!.textContent = total.toLocaleString();
    const pct = (n: number) => (total > 0 ? (n / total) * 100 : 0);
    const fmt = (n: number) => `${n.toLocaleString()} (${pct(n).toFixed(0)}%)`;
    const setW = (id: string, n: number) => { (document.getElementById(id) as HTMLElement).style.width = `${pct(n)}%`; };

    document.getElementById('comp-auth-num')!.textContent = fmt(d.sources.authenticated30d ?? 0);
    document.getElementById('comp-anon-num')!.textContent = fmt(d.sources.anonymous30d ?? 0);
    setW('comp-auth-bar', d.sources.authenticated30d ?? 0); setW('comp-anon-bar', d.sources.anonymous30d ?? 0);

    document.getElementById('comp-web-num')!.textContent = fmt(d.sources.web30d ?? 0);
    document.getElementById('comp-api-num')!.textContent = fmt(d.sources.api30d ?? 0);
    setW('comp-web-bar', d.sources.web30d ?? 0); setW('comp-api-bar', d.sources.api30d ?? 0);

    document.getElementById('comp-ab-num')!.textContent = fmt(d.sources.adblock30d ?? 0);
    document.getElementById('comp-noab-num')!.textContent = fmt(d.sources.noAdblock30d ?? 0);
    setW('comp-ab-bar', d.sources.adblock30d ?? 0); setW('comp-noab-bar', d.sources.noAdblock30d ?? 0);
  }

  function avatarHTML(r: any): string {
    const initial = (r.user_name || r.name || r.email || '?').trim().charAt(0).toUpperCase();
    return (r.avatar_url || r.user_avatar)
      ? `<img src="${esc(r.avatar_url || r.user_avatar)}" alt="" class="w-7 h-7 rounded-full object-cover flex-shrink-0" style="border:1px solid var(--a-border)" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
      : `<div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-[10px] font-semibold" style="background:var(--a-surface-2);border:1px solid var(--a-border);color:var(--a-muted)">${esc(initial)}</div>`;
  }

  function userCell(name: string, email: string, anon: boolean): string {
    return `<div class="flex items-center gap-2.5 min-w-0">
      ${avatarHTML({ user_name: name, user_email: email })}
      <div class="min-w-0">
        <p class="text-xs font-semibold truncate max-w-[180px]" style="color:var(--a-fg)">${esc(name || 'Unnamed')}${anon ? ' <span class="a-subtle font-normal">(no account)</span>' : ''}</p>
        ${email ? `<p class="text-[11px] a-subtle truncate max-w-[180px]">${esc(email)}</p>` : ''}
      </div></div>`;
  }

  function renderTopUploaders30d(d: Data) {
    const rows: any[] = d.uploadsByUser ?? [];
    const body = document.getElementById('uploads-by-user-body')!;
    if (!rows.length) { body.innerHTML = '<tr><td colspan="5" class="text-center a-subtle">No uploads in the last 30 days</td></tr>'; return; }
    const max = Math.max(1, ...rows.map(r => Number(r.count)));
    const activeDays = (first: string, last: string) => {
      const f = new Date(first.replace(' ', 'T') + 'Z'), l = new Date(last.replace(' ', 'T') + 'Z');
      return Math.max(1, Math.floor((l.getTime() - f.getTime()) / 86400000) + 1);
    };
    body.innerHTML = rows.map(r => {
      const avg = (Number(r.count) / activeDays(r.first_upload, r.last_upload)).toFixed(1);
      const sharePct = (Number(r.count) / max * 100).toFixed(1);
      return `<tr>
        <td>${userCell(r.user_name, r.user_email, !r.user_id)}</td>
        <td class="text-xs font-semibold a-num">${Number(r.count).toLocaleString()}</td>
        <td class="text-xs a-num a-muted">${avg}</td>
        <td class="text-xs a-muted whitespace-nowrap">${fmtDate(r.last_upload)}</td>
        <td><div class="a-track a-track-sm" style="border:0;background:var(--a-surface-2)"><div class="a-bar-fill" style="width:${sharePct}%"></div></div></td>
      </tr>`;
    }).join('');
  }

  function renderTopLifetime(d: Data) {
    const rows: any[] = d.topUploadersAllTime ?? [];
    const body = document.getElementById('top-lifetime-body')!;
    if (!rows.length) { body.innerHTML = '<tr><td colspan="4" class="text-center a-subtle">No uploads yet</td></tr>'; return; }
    body.innerHTML = rows.map(r => `<tr>
      <td>${userCell(r.user_name, r.user_email, !r.user_id)}</td>
      <td class="text-xs font-semibold a-num">${Number(r.count).toLocaleString()}</td>
      <td class="text-xs a-muted whitespace-nowrap">${fmtDate(r.first_upload)}</td>
      <td class="text-xs a-muted whitespace-nowrap">${fmtDate(r.last_upload)}</td>
    </tr>`).join('');
  }

  function renderRecentSignups(d: Data) {
    const rows: any[] = d.recentSignups ?? [];
    const body = document.getElementById('recent-signups-body')!;
    if (!rows.length) { body.innerHTML = '<tr><td colspan="3" class="text-center a-subtle">No signups yet</td></tr>'; return; }
    body.innerHTML = rows.map(r => `<tr>
      <td>${userCell(r.name, r.email, false)}</td>
      <td class="text-xs a-muted whitespace-nowrap">${fmtDate(r.created_at)}</td>
      <td class="text-xs font-semibold a-num" ${Number(r.upload_count) === 0 ? 'style="color:var(--a-danger)"' : ''}>${Number(r.upload_count).toLocaleString()}</td>
    </tr>`).join('');
  }

  function renderDormant(d: Data) {
    const rows: any[] = d.dormantUsers ?? [];
    const body = document.getElementById('dormant-body')!;
    if (!rows.length) { body.innerHTML = '<tr><td colspan="4" class="text-center a-subtle">All registered users uploaded recently</td></tr>'; return; }
    body.innerHTML = rows.map(r => `<tr>
      <td>${userCell(r.name, r.email, false)}</td>
      <td class="text-xs a-muted whitespace-nowrap">${fmtDate(r.created_at)}</td>
      <td class="text-xs font-semibold a-num">${Number(r.lifetime_uploads).toLocaleString()}</td>
      <td class="text-xs a-muted whitespace-nowrap">${r.last_upload ? fmtDate(r.last_upload) : 'Never'}</td>
    </tr>`).join('');
  }

  function renderDaily(d: Data) {
    const rows: any[] = d.dailySeries ?? [];
    const body = document.getElementById('daily-body')!;
    if (!rows.length) { body.innerHTML = '<tr><td colspan="6" class="text-center a-subtle">No uploads in the last 30 days</td></tr>'; return; }
    const max = Math.max(1, ...rows.map(r => Number(r.uploads)));
    body.innerHTML = rows.map(r => {
      const widthPct = (Number(r.uploads) / max * 100).toFixed(1);
      return `<tr>
        <td class="text-xs font-semibold a-num whitespace-nowrap">${esc(r.day)}</td>
        <td class="text-xs font-semibold a-num">${Number(r.uploads).toLocaleString()}</td>
        <td class="text-xs a-num">${Number(r.unique_users).toLocaleString()}</td>
        <td class="text-xs a-num a-subtle">${Number(r.anon).toLocaleString()}</td>
        <td class="text-xs a-num a-muted whitespace-nowrap">${formatSize(Number(r.size))}</td>
        <td><div class="a-track a-track-sm" style="border:0;background:var(--a-surface-2)"><div class="a-bar-fill" style="width:${widthPct}%"></div></div></td>
      </tr>`;
    }).join('');
  }

  function patternLines(map: Map<number, number>, labels: string[]): string {
    const max = Math.max(1, ...Array.from(map.values()));
    return labels.map((label, i) => {
      const v = map.get(i) ?? 0;
      return `<div class="flex items-center gap-2"><span class="a-subtle" style="width:1.75rem">${label}</span><span style="color:var(--a-fg)">${textBar(v, max, 14)}</span><span class="a-num a-muted text-right" style="width:2rem">${v.toLocaleString()}</span></div>`;
    }).join('');
  }

  function renderHourly(d: Data) {
    const rows: any[] = d.hourOfDay ?? [];
    const el = document.getElementById('hourly-body')!;
    if (!rows.length) { el.innerHTML = '<p class="a-subtle">No data yet</p>'; return; }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.hour), Number(r.count));
    el.innerHTML = patternLines(map, Array.from({ length: 24 }, (_, h) => String(h).padStart(2, '0')));
  }

  function renderDayOfWeek(d: Data) {
    const rows: any[] = d.dayOfWeek ?? [];
    const el = document.getElementById('dow-body')!;
    if (!rows.length) { el.innerHTML = '<p class="a-subtle">No data yet</p>'; return; }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.dow), Number(r.count));
    el.innerHTML = patternLines(map, DOW_NAMES);
  }

  function renderAnonymous(d: Data) {
    document.getElementById('anon-ips-7d')!.textContent = (d.anonymous.uniqueIPs7d ?? 0).toLocaleString();
    document.getElementById('anon-ips-30d')!.textContent = (d.anonymous.uniqueIPs30d ?? 0).toLocaleString();
  }

  function renderEngagementBlock(d: Data) {
    document.getElementById('eng-adblock-30d')!.textContent = (d.sources.adblock30d ?? 0).toLocaleString();
    document.getElementById('eng-adblock-30d-sub')!.textContent = `${(d.sources.adblockPct30d ?? 0).toFixed(1)}% of uploads`;
    const ctaList: any[] = d.engagement.ctaBreakdown ?? [];
    const ctaEl = document.getElementById('eng-cta-list')!;
    ctaEl.innerHTML = !ctaList.length
      ? '<p class="a-subtle">No clicks in last 30 days</p>'
      : ctaList.map(c => `<div class="flex items-baseline justify-between gap-2"><span class="a-muted truncate">${esc(c.link_id)}</span><span class="font-semibold a-num" style="color:var(--a-fg)">${Number(c.count).toLocaleString()}</span></div>`).join('');
  }

  function renderRecent(d: Data) {
    const el = document.getElementById('recent-uploads')!;
    if (!d.recentUploads?.length) { el.innerHTML = '<div class="a-card-pad text-center a-subtle">No uploads yet</div>'; return; }
    el.innerHTML = `<div class="overflow-x-auto"><table class="a-table min-w-[500px]">
        <thead><tr><th>Asset</th><th>Owner</th><th>Size</th><th></th></tr></thead>
        <tbody>
          ${d.recentUploads.map((img: any) => `
            <tr>
              <td><div class="flex items-center gap-2.5">
                <div class="w-9 h-9 rounded-[8px] overflow-hidden flex-shrink-0" style="background:var(--a-surface-2);border:1px solid var(--a-border)">
                  <img src="${esc(img.url)}" alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" /></div>
                <span class="text-xs font-semibold truncate max-w-[200px]" style="color:var(--a-fg)">${esc(img.filename)}</span>
              </div></td>
              <td class="text-xs a-muted truncate max-w-[160px]">${esc(img.user_name || 'Anonymous')}</td>
              <td class="text-xs a-muted whitespace-nowrap">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</td>
              <td class="text-right"><button onclick="copyUrl('${esc(img.url)}')" class="a-btn a-btn-ghost a-btn-icon a-btn-sm" title="Copy URL">${ICON_LINK}</button></td>
            </tr>`).join('')}
        </tbody></table></div>`;
  }

  function bindTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.user-tab');
    const panels = document.querySelectorAll<HTMLElement>('.user-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => t.classList.toggle('is-active', t === tab));
        panels.forEach(p => p.classList.toggle('hidden', p.dataset.panel !== target));
      });
    });
  }

  async function loadStats() {
    const res = await fetch('/api/admin/stats');
    if (!res.ok) throw new Error('stats failed');
    const data = await res.json();
    renderHero(data); renderKPIs(data); renderComposition(data);
    renderTopUploaders30d(data); renderTopLifetime(data); renderRecentSignups(data); renderDormant(data);
    renderDaily(data); renderHourly(data); renderDayOfWeek(data);
    renderAnonymous(data); renderEngagementBlock(data); renderRecent(data);
  }

  function showToast(message: string) {
    document.querySelector('.admin-toast')?.remove();
    const toast = document.createElement('div');
    toast.className = 'admin-toast';
    toast.textContent = message;
    toast.setAttribute('style', 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:var(--a-fg);color:#fff;padding:.65rem 1.1rem;border-radius:10px;font-size:.8125rem;font-weight:550;z-index:60;box-shadow:0 8px 24px rgba(0,0,0,.18);transition:opacity .3s');
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
  }

  (window as any).copyUrl = (url: string) => navigator.clipboard.writeText(url).then(() => showToast('URL copied'));

  document.getElementById('refresh-stats')?.addEventListener('click', () => {
    loadStats().then(() => showToast('Refreshed')).catch(() => showToast('Refresh failed'));
  });

  bindTabs();
  loadStats().catch(() => showToast('Failed to load stats'));
</script>

    const body = document.getElementById('top-lifetime-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="4" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads yet</p></td></tr>';
      return;
    }
    body.innerHTML = rows.map(r => {
      const isAnon = !r.user_id;
      return `
        <tr class="hover:bg-surface-container-lowest">

  function avatarHTML(r: any): string {
    const initial = (r.user_name || r.name || r.email || '?').trim().charAt(0).toUpperCase();
    return r.avatar_url || r.user_avatar
      ? `<img src="${esc(r.avatar_url || r.user_avatar)}" alt="" class="w-7 h-7 rounded-full border border-outline-variant object-cover flex-shrink-0" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
      : `<div class="w-7 h-7 rounded-full border border-outline-variant bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="text-[10px] font-bold text-outline">${esc(initial)}</span></div>`;
  }

  function renderTopUploaders30d(d: Data) {
    const rows: any[] = d.uploadsByUser ?? [];
    const body = document.getElementById('uploads-by-user-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads in the last 30 days</p></td></tr>';
      return;
    }
    const max = Math.max(1, ...rows.map(r => Number(r.count)));
    const activeDays = (first: string, last: string) => {
      const f = new Date(first.replace(' ', 'T') + 'Z');
      const l = new Date(last.replace(' ', 'T') + 'Z');
      const days = Math.floor((l.getTime() - f.getTime()) / 86400000) + 1;
      return Math.max(1, days);
    };
    body.innerHTML = rows.map(r => {
      const span = activeDays(r.first_upload, r.last_upload);
      const avg = (Number(r.count) / span).toFixed(1);
      const isAnon = !r.user_id;
      const sharePct = (Number(r.count) / max * 100).toFixed(1);
      return `
        <tr class="hover:bg-surface-container-lowest">
          <td class="px-4 py-2">
            <div class="flex items-center gap-2 min-w-0">
              ${avatarHTML(r)}
              <div class="min-w-0">
                <p class="text-xs font-bold truncate max-w-[180px]">${esc(r.user_name)}${isAnon ? ' <span class="text-outline font-normal">(no account)</span>' : ''}</p>
                ${r.user_email ? `<p class="text-[10px] text-outline truncate max-w-[180px]">${esc(r.user_email)}</p>` : ''}
              </div>
            </div>
          </td>
          <td class="px-3 py-2 text-xs font-bold tabular-nums">${Number(r.count).toLocaleString()}</td>
          <td class="px-3 py-2 text-xs tabular-nums text-on-surface-variant">${avg}</td>
          <td class="px-3 py-2 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.last_upload)}</td>
          <td class="px-3 py-2"><div class="h-1.5 rounded-full bg-primary" style="width: ${sharePct}%; max-width: 100%;"></div></td>
        </tr>
      `;
    }).join('');
  }

  function renderTopLifetime(d: Data) {

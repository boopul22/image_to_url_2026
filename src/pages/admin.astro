          <div class="flex items-center gap-2 min-w-0">
            ${avatarHTML(r)}
            <div class="min-w-0">
              <p class="text-xs font-bold truncate max-w-[180px]">${esc(r.name || 'Unnamed')}</p>
              ${r.email ? `<p class="text-[10px] text-outline truncate max-w-[180px]">${esc(r.email)}</p>` : ''}

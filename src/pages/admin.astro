---
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import AdminSidebar from '../components/AdminSidebar.astro';

// No CDN caching — always fresh, private admin data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
---

<Layout title="Admin Dashboard - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="dashboard" />

    <main class="flex-1 p-3 sm:p-4 md:p-5 space-y-4 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">
      <!-- Welcome Header -->
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div>
          <span class="inline-block px-2 py-0.5 bg-tertiary-fixed border-2 border-on-surface rounded-full font-label text-[10px] font-bold uppercase tracking-widest text-on-tertiary-fixed mb-1.5">Admin Overview</span>
          <h1 class="text-lg sm:text-xl md:text-2xl font-headline italic font-black text-on-surface leading-tight">
            Welcome back, {user.name.split(' ')[0]}.
          </h1>
        </div>
        <button id="refresh-stats" class="flex items-center gap-1.5 bg-surface border-2 border-on-surface rounded-lg px-3 py-1.5 font-label text-[11px] font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-transform hard-shadow">
          <span class="material-symbols-outlined text-base">refresh</span> Refresh
        </button>
      </div>

      <!-- Stats Cards -->
      <div id="stats-cards" class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-secondary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-secondary-fixed-variant">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">photo_library</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">Total Images</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-secondary-fixed mt-1" id="stat-images">—</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-secondary-container/70">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">group</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">Active Users</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-secondary-container mt-1" id="stat-users">—</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-tertiary-fixed/70">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">cloud</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">Storage Used</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-tertiary-fixed mt-1" id="stat-storage">—</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-primary-fixed-variant">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">key</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">API Keys</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-primary-fixed mt-1" id="stat-keys">—</p>
        </div>
      </div>

      <!-- Uploads + Ad-block row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-secondary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-secondary-fixed-variant">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">today</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">Uploads Today</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-secondary-fixed mt-1" id="stat-uploads-today">—</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-surface rounded-lg p-3 hard-shadow">
          <div class="flex items-center gap-1.5 text-on-tertiary-fixed/70">
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">event_available</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest">Uploads Yesterday</p>
          </div>
          <p class="text-2xl font-headline font-black text-on-tertiary-fixed mt-1" id="stat-uploads-yesterday">—</p>
        </div>
        <!-- Ad-block uploads — how many uploads came from visitors running an ad blocker -->
        <div class="bg-on-surface text-surface border-2 border-on-surface rounded-lg p-3 hard-shadow col-span-2">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5 text-surface/70">
              <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">block</span>
              <p class="font-label text-[10px] font-bold uppercase tracking-widest">Uploads with Ad Blocker</p>
            </div>
            <span class="font-label text-[10px] font-bold uppercase tracking-wider text-surface/60" id="stat-adblock-pct">—</span>
          </div>
          <div class="flex items-baseline gap-2 mt-1">
            <p class="text-2xl font-headline font-black text-surface" id="stat-adblock">—</p>
            <span class="text-xs text-surface/50" id="stat-adblock-of">of all uploads block ads</span>
          </div>
        </div>
      </div>

      <!-- ExtractPics CTA + Uploads by User -->
      <div class="space-y-4">
        <div class="bg-primary border-2 border-on-surface rounded-lg p-3 hard-shadow flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-white/90 flex-shrink-0" style="font-variation-settings: 'FILL' 1;">image_search</span>
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-white/80">ExtractPics CTA Clicks</p>
          </div>
          <p class="text-2xl font-headline font-black text-white" id="stat-cta-clicks">—</p>
        </div>

        <div class="bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-3 border-b-2 border-on-surface">
            <h2 class="text-sm font-headline italic font-black text-on-surface uppercase">Uploads by User <span class="text-outline font-body not-italic font-normal normal-case">· last 30 days</span></h2>
            <span class="font-label text-[10px] font-bold uppercase tracking-wider text-outline" id="uploads-by-user-total">—</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[640px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider" title="Total uploads in the last 30 days">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider" title="Average uploads per active day">Avg/day</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">First</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider w-1/3">Share</th>
                </tr>
              </thead>
              <tbody id="uploads-by-user-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Recent Uploads + Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-3">
        <!-- Recent Uploads Table -->
        <div class="lg:col-span-3 bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-3 border-b-2 border-on-surface">
            <h2 class="text-sm font-headline italic font-black text-on-surface uppercase">Recent Uploads</h2>
            <a href="/admin/images" class="font-label text-[10px] font-bold uppercase tracking-wider text-primary hover:underline">View All</a>
          </div>
          <div id="recent-uploads">
            <div class="p-6 text-center text-outline">
              <span class="material-symbols-outlined text-3xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
        </div>

        <!-- Real-time Activity -->
        <div class="lg:col-span-2 bg-surface border-2 border-on-surface rounded-lg overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-3 border-b-2 border-on-surface">
            <h2 class="text-sm font-headline italic font-black text-on-surface uppercase">Real-time Activity</h2>
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
          </div>
          <div id="activity-feed" class="p-3 space-y-3">
            <div class="text-center text-outline py-4">
              <p class="font-label text-xs uppercase">Loading...</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  async function loadStats() {
    const res = await fetch('/api/admin/stats');
    const data = await res.json();

    const formatSize = (bytes: number) => {
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
      return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
    };

    document.getElementById('stat-images')!.textContent = data.totalImages.toLocaleString();
    document.getElementById('stat-users')!.textContent = data.totalUsers.toLocaleString();
    document.getElementById('stat-storage')!.textContent = formatSize(data.totalStorage);
    document.getElementById('stat-keys')!.textContent = data.activeApiKeys.toLocaleString();
    document.getElementById('stat-cta-clicks')!.textContent = (data.ctaClicks ?? 0).toLocaleString();

    // Ad-block uploads — how many uploads came from visitors running an ad blocker.
    const adblockUploads = Number(data.adblockUploads ?? 0);
    const totalImages = Number(data.totalImages ?? 0);
    const adblockPct = totalImages > 0 ? (adblockUploads / totalImages) * 100 : 0;
    document.getElementById('stat-adblock')!.textContent = adblockUploads.toLocaleString();
    document.getElementById('stat-adblock-pct')!.textContent = totalImages > 0 ? adblockPct.toFixed(1) + '%' : '—';
    document.getElementById('stat-adblock-of')!.textContent =
      `of ${totalImages.toLocaleString()} total uploads block ads`;

    // Uploads per day — UTC 30-min buckets aggregated into the admin's local timezone.
    // 30-min granularity handles half-hour timezones (e.g. IST = UTC+5:30) without smear.
    const buckets: Array<{ bucket: string; count: number; adblock: number }> = data.uploadsByBucket ?? [];
    const byLocalDate = new Map<string, number>();
    const adblockByLocalDate = new Map<string, number>();
    for (const b of buckets) {
      // bucket is "YYYY-MM-DD HH:MM" in UTC
      const utc = new Date(b.bucket.replace(' ', 'T') + ':00Z');
      const key = `${utc.getFullYear()}-${String(utc.getMonth() + 1).padStart(2, '0')}-${String(utc.getDate()).padStart(2, '0')}`;
      byLocalDate.set(key, (byLocalDate.get(key) ?? 0) + Number(b.count));
      adblockByLocalDate.set(key, (adblockByLocalDate.get(key) ?? 0) + Number(b.adblock ?? 0));
    }
    const dateKey = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    const today = new Date();
    const yesterday = new Date(today); yesterday.setDate(today.getDate() - 1);
    document.getElementById('stat-uploads-today')!.textContent = (byLocalDate.get(dateKey(today)) ?? 0).toLocaleString();
    document.getElementById('stat-uploads-yesterday')!.textContent = (byLocalDate.get(dateKey(yesterday)) ?? 0).toLocaleString();

    const dayRows: Array<{ date: Date; count: number; adblock: number }> = [];
    for (let i = 0; i < 30; i++) {
      const d = new Date(today); d.setDate(today.getDate() - i);
      dayRows.push({ date: d, count: byLocalDate.get(dateKey(d)) ?? 0, adblock: adblockByLocalDate.get(dateKey(d)) ?? 0 });
    }

    // Uploads by user — last 30 days, ordered by upload count.
    type UserRow = {
      user_id: string | null;
      user_name: string;
      user_email: string | null;
      user_avatar: string | null;
      count: number;
      first_upload: string;
      last_upload: string;
    };
    const userRows: UserRow[] = data.uploadsByUser ?? [];
    const usersTotal = userRows.reduce((s, r) => s + Number(r.count), 0);
    const maxUserCount = Math.max(1, ...userRows.map(r => Number(r.count)));
    const fmtDate = (s: string) => {
      // SQLite returns "YYYY-MM-DD HH:MM:SS" in UTC.
      const d = new Date(s.replace(' ', 'T') + 'Z');
      return d.toLocaleDateString(undefined, { month: 'short', day: '2-digit' });
    };
    const activeDays = (first: string, last: string) => {
      const f = new Date(first.replace(' ', 'T') + 'Z');
      const l = new Date(last.replace(' ', 'T') + 'Z');
      const days = Math.floor((l.getTime() - f.getTime()) / 86400000) + 1;
      return Math.max(1, days);
    };
    const totalEl = document.getElementById('uploads-by-user-total');
    if (totalEl) totalEl.textContent = `${userRows.length.toLocaleString()} ${userRows.length === 1 ? 'user' : 'users'} · ${usersTotal.toLocaleString()} uploads`;

    const userBody = document.getElementById('uploads-by-user-body');
    if (userBody) {
      if (!userRows.length) {
        userBody.innerHTML = '<tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads in the last 30 days</p></td></tr>';
      } else {
        userBody.innerHTML = userRows.map(r => {
          const span = activeDays(r.first_upload, r.last_upload);
          const avg = (Number(r.count) / span).toFixed(1);
          const isAnon = !r.user_id;
          const initial = (r.user_name || '?').trim().charAt(0).toUpperCase();
          const avatar = r.user_avatar
            ? `<img src="${esc(r.user_avatar)}" alt="${esc(r.user_name)}" class="w-7 h-7 rounded-full border border-on-surface object-cover flex-shrink-0" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
            : `<div class="w-7 h-7 rounded-full border border-on-surface bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="text-[10px] font-bold text-outline">${esc(initial)}</span></div>`;
          const sharePct = (Number(r.count) / maxUserCount * 100).toFixed(1);
          return `
            <tr class="hover:bg-surface-container-lowest transition-colors">
              <td class="px-3 py-1.5">
                <div class="flex items-center gap-2 min-w-0">
                  ${avatar}
                  <div class="min-w-0">
                    <p class="text-xs font-bold truncate max-w-[180px]">${esc(r.user_name)}${isAnon ? ' <span class="text-outline font-normal">(no account)</span>' : ''}</p>
                    ${r.user_email ? `<p class="text-[10px] text-outline truncate max-w-[180px]">${esc(r.user_email)}</p>` : ''}
                  </div>
                </div>
              </td>
              <td class="px-3 py-1.5 text-xs font-bold tabular-nums">${Number(r.count).toLocaleString()}</td>
              <td class="px-3 py-1.5 text-xs tabular-nums text-on-surface-variant">${avg}</td>
              <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.first_upload)}</td>
              <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.last_upload)}</td>
              <td class="px-3 py-1.5"><div class="h-2 bg-primary border border-on-surface" style="width: ${sharePct}%; max-width: 100%;"></div></td>
            </tr>
          `;
        }).join('');
      }
    }

    // Recent uploads
    const uploadsEl = document.getElementById('recent-uploads')!;
    if (!data.recentUploads?.length) {
      uploadsEl.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No uploads yet</p></div>';
    } else {
      uploadsEl.innerHTML = `
        <div class="overflow-x-auto"><table class="w-full text-left min-w-[500px]">
          <thead>
            <tr class="border-b border-outline-variant">
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Asset</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Owner</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Size</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/50">
            ${data.recentUploads.map((img: any) => `
              <tr class="hover:bg-surface-container-lowest transition-colors">
                <td class="px-5 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-surface-container-highest border border-outline-variant overflow-hidden flex-shrink-0">
                      <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                    </div>
                    <span class="text-sm font-bold truncate max-w-40">${esc(img.filename)}</span>
                  </div>
                </td>
                <td class="px-5 py-3">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center">
                      <span class="material-symbols-outlined text-xs text-outline">person</span>
                    </div>
                    <span class="text-sm text-on-surface-variant">${esc(img.user_name || 'Anonymous')}</span>
                  </div>
                </td>
                <td class="px-5 py-3 text-sm text-on-surface-variant">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</td>
                <td class="px-5 py-3">
                  <div class="flex gap-2">
                    <button onclick="copyUrl('${esc(img.url)}')" class="w-9 h-9 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
                      <span class="material-symbols-outlined text-sm text-outline">link</span>
                    </button>
                    <button class="w-9 h-9 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
                      <span class="material-symbols-outlined text-sm text-outline">more_horiz</span>
                    </button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table></div>
      `;
    }

    // Activity feed
    const activityEl = document.getElementById('activity-feed')!;
    const activities = data.recentUploads?.slice(0, 3).map((img: any, i: number) => {
      const icons = ['person_add', 'bolt', 'warning'];
      const titles = ['New Upload', 'API Activity', 'Image Processed'];
      const colors = ['bg-secondary', 'bg-tertiary', 'bg-primary'];
      return `
        <div class="flex gap-4">
          <div class="${colors[i % 3]} w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-white text-lg">${icons[i % 3]}</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-sm">${titles[i % 3]}</p>
            <p class="text-xs text-on-surface-variant truncate">${esc(img.filename)} uploaded${img.user_name ? ' by ' + esc(img.user_name) : ''}</p>
            <p class="text-xs text-outline mt-1">${new Date(img.created_at).toLocaleString()}</p>
          </div>
        </div>
      `;
    }) || [];

    activityEl.innerHTML = activities.length
      ? activities.join('')
      : '<div class="text-center text-outline py-4"><p class="font-label text-xs uppercase">No activity yet</p></div>';
  }

  function showToast(message: string) {
    const existing = document.querySelector('.admin-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'admin-toast fixed bottom-6 left-1/2 -translate-x-1/2 bg-on-surface text-surface px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider z-50 border-2 border-on-surface hard-shadow transition-opacity';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
  }

  (window as any).copyUrl = (url: string) => {
    navigator.clipboard.writeText(url).then(() => showToast('URL copied!'));
  };

  document.getElementById('refresh-stats')?.addEventListener('click', () => {
    loadStats().then(() => showToast('Refreshed')).catch(() => showToast('Refresh failed'));
  });

  loadStats();
</script>

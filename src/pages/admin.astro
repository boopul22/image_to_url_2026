---
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import AdminSidebar from '../components/AdminSidebar.astro';

// No CDN caching — always fresh, private admin data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
---

<Layout title="Admin Dashboard - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="dashboard" />

    <main class="flex-1 p-4 sm:p-6 md:p-8 space-y-6 sm:space-y-8 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">
      <!-- Welcome Header -->
      <div>
        <span class="inline-block px-3 py-1 bg-tertiary-fixed border-2 border-on-surface rounded-full font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed mb-3">Admin Overview</span>
        <h1 class="text-xl sm:text-2xl md:text-5xl font-headline italic font-black text-on-surface mb-2">
          Welcome back, {user.name.split(' ')[0]}.
        </h1>
        <p class="text-on-surface-variant">Your image-to-URL pipeline is running smoothly.</p>
      </div>

      <!-- Stats Cards -->
      <div id="stats-cards" class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
        <div class="bg-secondary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <div class="flex items-center justify-between mb-1">
            <span class="material-symbols-outlined text-on-secondary-fixed text-2xl" style="font-variation-settings: 'FILL' 1;">photo_library</span>
            <span class="text-xs font-bold text-on-secondary-fixed-variant bg-on-secondary-fixed/10 px-2 py-0.5 rounded-full" id="stat-images-change">—</span>
          </div>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-secondary-fixed-variant mt-3">Total Images</p>
          <p class="text-3xl font-headline font-black text-on-secondary-fixed" id="stat-images">—</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <div class="flex items-center justify-between mb-1">
            <span class="material-symbols-outlined text-on-secondary-container text-2xl" style="font-variation-settings: 'FILL' 1;">group</span>
            <span class="text-xs font-bold bg-secondary/10 px-2 py-0.5 rounded-full text-secondary">STABLE</span>
          </div>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-secondary-container/70 mt-3">Active Users</p>
          <p class="text-3xl font-headline font-black text-on-secondary-container" id="stat-users">—</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <div class="flex items-center justify-between mb-1">
            <span class="material-symbols-outlined text-on-tertiary-fixed text-2xl" style="font-variation-settings: 'FILL' 1;">cloud</span>
            <span class="text-xs font-bold bg-on-tertiary-fixed/10 px-2 py-0.5 rounded-full text-on-tertiary-fixed">HIGH</span>
          </div>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-tertiary-fixed/70 mt-3">Storage Used</p>
          <p class="text-3xl font-headline font-black text-on-tertiary-fixed" id="stat-storage">—</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-surface rounded-xl p-5 hard-shadow">
          <div class="flex items-center justify-between mb-1">
            <span class="material-symbols-outlined text-on-primary-fixed text-2xl" style="font-variation-settings: 'FILL' 1;">key</span>
          </div>
          <p class="font-label text-xs font-bold uppercase tracking-widest text-on-primary-fixed-variant mt-3">API Keys</p>
          <p class="text-3xl font-headline font-black text-on-primary-fixed" id="stat-keys">—</p>
        </div>
        <div class="bg-[#FF0000] border-2 border-on-surface rounded-xl p-5 hard-shadow col-span-2 lg:col-span-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-label text-xs font-bold uppercase tracking-widest text-white/70">YouTube CTA Clicks</p>
              <p class="text-3xl font-headline font-black text-white" id="stat-yt-clicks">—</p>
            </div>
            <svg class="w-10 h-10 text-white/80" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <p class="text-xs text-white/60 mt-1">Total clicks on "Support us" YouTube subscribe button</p>
        </div>
      </div>

      <!-- Recent Uploads + Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-4 sm:gap-6">
        <!-- Recent Uploads Table -->
        <div class="lg:col-span-3 bg-surface border-2 border-on-surface rounded-xl overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-5 border-b-2 border-on-surface">
            <h2 class="text-xl font-headline italic font-black text-on-surface">Recent Uploads</h2>
            <a href="/admin/images" class="font-label text-xs font-bold uppercase tracking-wider text-primary hover:underline">View All</a>
          </div>
          <div id="recent-uploads">
            <div class="p-8 text-center text-outline">
              <span class="material-symbols-outlined text-4xl">hourglass_empty</span>
              <p class="font-label text-xs uppercase mt-2">Loading...</p>
            </div>
          </div>
        </div>

        <!-- Real-time Activity -->
        <div class="lg:col-span-2 bg-surface border-2 border-on-surface rounded-xl overflow-hidden hard-shadow">
          <div class="flex items-center justify-between p-5 border-b-2 border-on-surface">
            <h2 class="text-xl font-headline italic font-black text-on-surface">Real-time Activity</h2>
            <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
          </div>
          <div id="activity-feed" class="p-5 space-y-5">
            <div class="text-center text-outline py-4">
              <p class="font-label text-xs uppercase">Loading...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- System Status -->
      <div class="bg-on-surface text-surface rounded-xl p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:justify-between hard-shadow border-2 border-on-surface">
        <div class="flex items-center gap-4">
          <span class="material-symbols-outlined text-secondary text-3xl" style="font-variation-settings: 'FILL' 1;">check_circle</span>
          <div>
            <p class="font-headline italic text-xl font-black">All Systems Operational</p>
            <p class="text-sm text-surface/60">99.98% uptime over the last 30 days. No incidents reported.</p>
          </div>
        </div>
        <a href="/admin" class="bg-surface text-on-surface px-5 py-2 rounded-xl font-label text-xs font-bold uppercase tracking-wider border-2 border-outline hover:-translate-y-1 transition-all">
          Check Status Page
        </a>
      </div>
    </main>
  </div>
</Layout>

<script>
  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  async function loadStats() {
    const res = await fetch('/api/admin/stats');
    const data = await res.json();

    const formatSize = (bytes: number) => {
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
      return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
    };

    document.getElementById('stat-images')!.textContent = data.totalImages.toLocaleString();
    document.getElementById('stat-users')!.textContent = data.totalUsers.toLocaleString();
    document.getElementById('stat-storage')!.textContent = formatSize(data.totalStorage);
    document.getElementById('stat-keys')!.textContent = data.activeApiKeys.toLocaleString();
    document.getElementById('stat-yt-clicks')!.textContent = (data.ytClicks ?? 0).toLocaleString();

    // Recent uploads
    const uploadsEl = document.getElementById('recent-uploads')!;
    if (!data.recentUploads?.length) {
      uploadsEl.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No uploads yet</p></div>';
    } else {
      uploadsEl.innerHTML = `
        <div class="overflow-x-auto"><table class="w-full text-left min-w-[500px]">
          <thead>
            <tr class="border-b border-outline-variant">
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Asset</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Owner</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Size</th>
              <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/50">
            ${data.recentUploads.map((img: any) => `
              <tr class="hover:bg-surface-container-lowest transition-colors">
                <td class="px-5 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-surface-container-highest border border-outline-variant overflow-hidden flex-shrink-0">
                      <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                    </div>
                    <span class="text-sm font-bold truncate max-w-40">${esc(img.filename)}</span>
                  </div>
                </td>
                <td class="px-5 py-3">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center">
                      <span class="material-symbols-outlined text-xs text-outline">person</span>
                    </div>
                    <span class="text-sm text-on-surface-variant">${esc(img.user_name || 'Anonymous')}</span>
                  </div>
                </td>
                <td class="px-5 py-3 text-sm text-on-surface-variant">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</td>
                <td class="px-5 py-3">
                  <div class="flex gap-2">
                    <button onclick="copyUrl('${esc(img.url)}')" class="w-9 h-9 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
                      <span class="material-symbols-outlined text-sm text-outline">link</span>
                    </button>
                    <button class="w-9 h-9 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
                      <span class="material-symbols-outlined text-sm text-outline">more_horiz</span>
                    </button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table></div>
      `;
    }

    // Activity feed
    const activityEl = document.getElementById('activity-feed')!;
    const activities = data.recentUploads?.slice(0, 3).map((img: any, i: number) => {
      const icons = ['person_add', 'bolt', 'warning'];
      const titles = ['New Upload', 'API Activity', 'Image Processed'];
      const colors = ['bg-secondary', 'bg-tertiary', 'bg-primary'];
      return `
        <div class="flex gap-4">
          <div class="${colors[i % 3]} w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-white text-lg">${icons[i % 3]}</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-sm">${titles[i % 3]}</p>
            <p class="text-xs text-on-surface-variant truncate">${esc(img.filename)} uploaded${img.user_name ? ' by ' + esc(img.user_name) : ''}</p>
            <p class="text-xs text-outline mt-1">${new Date(img.created_at).toLocaleString()}</p>
          </div>
        </div>
      `;
    }) || [];

    activityEl.innerHTML = activities.length
      ? activities.join('')
      : '<div class="text-center text-outline py-4"><p class="font-label text-xs uppercase">No activity yet</p></div>';
  }

  function showToast(message: string) {
    const existing = document.querySelector('.admin-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'admin-toast fixed bottom-6 left-1/2 -translate-x-1/2 bg-on-surface text-surface px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider z-50 border-2 border-on-surface hard-shadow transition-opacity';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
  }

  (window as any).copyUrl = (url: string) => {
    navigator.clipboard.writeText(url).then(() => showToast('URL copied!'));
  };

  loadStats();
</script>

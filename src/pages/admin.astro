  function renderDaily(d: Data) {
    const rows: any[] = d.dailySeries ?? [];
    const body = document.getElementById('daily-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads in the last 30 days</p></td></tr>';
      return;
    }
    const max = Math.max(1, ...rows.map(r => Number(r.uploads)));
    body.innerHTML = rows.map(r => {
      const widthPct = (Number(r.uploads) / max * 100).toFixed(1);
      return `
        <tr class="hover:bg-surface-container-lowest">
          <td class="px-4 py-1.5 text-[11px] font-bold tabular-nums whitespace-nowrap">${esc(r.day)}</td>
          <td class="px-3 py-1.5 text-[11px] font-bold tabular-nums">${Number(r.uploads).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-[11px] tabular-nums">${Number(r.unique_users).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-[11px] tabular-nums text-outline">${Number(r.anon).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-[11px] tabular-nums text-on-surface-variant whitespace-nowrap">${formatSize(Number(r.size))}</td>
          <td class="px-3 py-1.5"><div class="h-1.5 rounded-full bg-primary" style="width: ${widthPct}%; max-width: 100%;"></div></td>
        </tr>
      `;
    }).join('');
  }

  function renderHourly(d: Data) {
    const rows: any[] = d.hourOfDay ?? [];
    const el = document.getElementById('hourly-body')!;
    if (!rows.length) {
      el.innerHTML = '<p class="text-outline">No data yet</p>';
      return;
    }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.hour), Number(r.count));
    const max = Math.max(1, ...Array.from(map.values()));
    const lines: string[] = [];
    for (let h = 0; h < 24; h++) {
      const v = map.get(h) ?? 0;
      const hh = String(h).padStart(2, '0');
      lines.push(`<div class="flex items-center gap-2"><span class="text-outline w-6">${hh}</span><span class="text-primary">${textBar(v, max, 14)}</span><span class="tabular-nums text-on-surface-variant w-8 text-right">${v.toLocaleString()}</span></div>`);
    }
    el.innerHTML = lines.join('');
  }

  function renderDayOfWeek(d: Data) {
    const rows: any[] = d.dayOfWeek ?? [];
    const el = document.getElementById('dow-body')!;
    if (!rows.length) {
      el.innerHTML = '<p class="text-outline">No data yet</p>';
      return;
    }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.dow), Number(r.count));
    const max = Math.max(1, ...Array.from(map.values()));
    const lines: string[] = [];
    for (let i = 0; i < 7; i++) {
      const v = map.get(i) ?? 0;
      lines.push(`<div class="flex items-center gap-2"><span class="text-outline w-7">${DOW_NAMES[i]}</span><span class="text-primary">${textBar(v, max, 14)}</span><span class="tabular-nums text-on-surface-variant w-8 text-right">${v.toLocaleString()}</span></div>`);
    }
    el.innerHTML = lines.join('');
  }

  function renderAnonymous(d: Data) {
    document.getElementById('anon-ips-7d')!.textContent = (d.anonymous.uniqueIPs7d ?? 0).toLocaleString();
    document.getElementById('anon-ips-30d')!.textContent = (d.anonymous.uniqueIPs30d ?? 0).toLocaleString();
  }

  function renderEngagementBlock(d: Data) {
    document.getElementById('eng-adblock-30d')!.textContent = (d.sources.adblock30d ?? 0).toLocaleString();
    document.getElementById('eng-adblock-30d-sub')!.textContent =
      `${(d.sources.adblockPct30d ?? 0).toFixed(1)}% of uploads`;

    const ctaList: any[] = d.engagement.ctaBreakdown ?? [];
    const ctaEl = document.getElementById('eng-cta-list')!;
    if (!ctaList.length) {
      ctaEl.innerHTML = '<p class="text-outline">No clicks in last 30 days</p>';
    } else {
      ctaEl.innerHTML = ctaList.map(c =>
        `<div class="flex items-baseline justify-between"><span class="text-outline truncate mr-2">${esc(c.link_id)}</span><span class="font-bold tabular-nums">${Number(c.count).toLocaleString()}</span></div>`
      ).join('');
    }
  }

  function renderRecent(d: Data) {
    const el = document.getElementById('recent-uploads')!;
    if (!d.recentUploads?.length) {
      el.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No uploads yet</p></div>';
      return;
    }
    el.innerHTML = `
      <div class="overflow-x-auto"><table class="w-full text-left min-w-[500px]">
        <thead>
          <tr class="border-b border-outline-variant">
            <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Asset</th>
            <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Owner</th>
            <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Size</th>
            <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/50">
          ${d.recentUploads.map((img: any) => `
            <tr class="hover:bg-surface-container-lowest">
              <td class="px-4 py-2">
                <div class="flex items-center gap-2.5">
                  <div class="w-9 h-9 rounded-lg bg-surface-container-highest border border-outline-variant overflow-hidden flex-shrink-0">
                    <img src="${esc(img.url)}" alt="" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  </div>
                  <span class="text-xs font-bold truncate max-w-[200px]">${esc(img.filename)}</span>
                </div>
              </td>
              <td class="px-3 py-2 text-xs text-on-surface-variant truncate max-w-[160px]">${esc(img.user_name || 'Anonymous')}</td>
              <td class="px-3 py-2 text-xs text-on-surface-variant whitespace-nowrap">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</td>
              <td class="px-3 py-2 text-right">
                <button onclick="copyUrl('${esc(img.url)}')" class="w-8 h-8 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest">
                  <span class="material-symbols-outlined text-sm text-outline">link</span>
                </button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table></div>
    `;
  }

  function bindTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.user-tab');
    const panels = document.querySelectorAll<HTMLElement>('.user-panel');
    const activeCls = ['bg-on-surface', 'text-surface'];
    const idleCls = ['text-outline', 'hover:bg-surface-container-highest'];
    const setActive = (tab: HTMLButtonElement, on: boolean) => {
      if (on) {
        tab.classList.add(...activeCls);
        tab.classList.remove(...idleCls);
      } else {
        tab.classList.remove(...activeCls);
        tab.classList.add(...idleCls);
      }
    };
    tabs.forEach((tab, i) => {
      setActive(tab, i === 0);
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => setActive(t, t === tab));
        panels.forEach(p => p.classList.toggle('hidden', p.dataset.panel !== target));
      });
    });
  }

  async function loadStats() {
    const res = await fetch('/api/admin/stats');
    if (!res.ok) throw new Error('stats failed');
    const data = await res.json();

    renderHero(data);
    renderKPIs(data);
    renderComposition(data);
    renderTopUploaders30d(data);
    renderTopLifetime(data);
    renderRecentSignups(data);
    renderDormant(data);
    renderDaily(data);
    renderHourly(data);
    renderDayOfWeek(data);
    renderAnonymous(data);
    renderEngagementBlock(data);
    renderRecent(data);
  }

  function showToast(message: string) {
    const existing = document.querySelector('.admin-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'admin-toast fixed bottom-6 left-1/2 -translate-x-1/2 bg-on-surface text-surface px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider z-50 border-2 border-on-surface hard-shadow';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
  }

  (window as any).copyUrl = (url: string) => {
    navigator.clipboard.writeText(url).then(() => showToast('URL copied!'));
  };

  document.getElementById('refresh-stats')?.addEventListener('click', () => {
    loadStats().then(() => showToast('Refreshed')).catch(() => showToast('Refresh failed'));
  });

  bindTabs();
  loadStats().catch(() => showToast('Failed to load stats'));
</script>

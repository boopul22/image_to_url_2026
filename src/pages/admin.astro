---
// CSR-like — SSR with no caching. SEO doesn't matter here.
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import AdminSidebar from '../components/AdminSidebar.astro';

// No CDN caching — always fresh, private admin data
Astro.response.headers.set('Cache-Control', 'private, no-store');

const user = Astro.locals.user!;
---

<Layout title="Admin Dashboard - ImageToURL" noindex={true}>
  <Nav activePage="admin" />

  <div class="flex">
    <AdminSidebar activePage="dashboard" />

    <main class="flex-1 p-3 sm:p-4 md:p-5 space-y-4 bg-surface-container-lowest min-h-[calc(100dvh-var(--nav-h,57px))]">

      <!-- HEADER -->
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div>
          <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Dashboard · UTC</p>
          <h1 class="text-lg sm:text-xl md:text-2xl font-headline italic font-black text-on-surface leading-tight">
            Welcome back, {user.name.split(' ')[0]}.
          </h1>
        </div>
        <button id="refresh-stats" class="flex items-center gap-1.5 bg-surface border-2 border-on-surface rounded-lg px-3 py-1.5 font-label text-[11px] font-bold uppercase tracking-wider hover:-translate-y-0.5 transition-transform hard-shadow">
          <span class="material-symbols-outlined text-base">refresh</span> Refresh
        </button>
      </div>

      <!-- HERO PULSE — single dark panel; the only "loud" card on the page -->
      <div class="bg-on-surface text-surface border-2 border-on-surface rounded-2xl p-4 sm:p-5 hard-shadow">
        <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-4 md:gap-6 items-end">
          <!-- Today (hero) -->
          <div class="min-w-0">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-surface/60">Uploads today</p>
            <p class="text-5xl sm:text-6xl font-headline font-black leading-none mt-1 tabular-nums" id="hero-today">—</p>
            <p class="font-label text-[10px] uppercase tracking-wider text-surface/60 mt-1.5" id="hero-today-sub">&nbsp;</p>
          </div>
          <!-- Trio: yesterday / 7d / 30d -->
          <div class="grid grid-cols-3 gap-3 md:gap-4 border-t md:border-t-0 md:border-l border-surface/15 pt-3 md:pt-0 md:pl-6">
            <div>
              <p class="font-label text-[9px] font-bold uppercase tracking-widest text-surface/50">Yesterday</p>
              <p class="text-xl sm:text-2xl font-headline font-black mt-1 tabular-nums" id="hero-yesterday">—</p>
              <p class="font-label text-[9px] uppercase text-surface/40 mt-0.5" id="hero-yesterday-sub">&nbsp;</p>
            </div>
            <div>
              <p class="font-label text-[9px] font-bold uppercase tracking-widest text-surface/50">7 days</p>
              <p class="text-xl sm:text-2xl font-headline font-black mt-1 tabular-nums" id="hero-7d">—</p>
              <p class="font-label text-[9px] uppercase mt-0.5" id="hero-7d-sub">&nbsp;</p>
            </div>
            <div>
              <p class="font-label text-[9px] font-bold uppercase tracking-widest text-surface/50">30 days</p>
              <p class="text-xl sm:text-2xl font-headline font-black mt-1 tabular-nums" id="hero-30d">—</p>
              <p class="font-label text-[9px] uppercase mt-0.5" id="hero-30d-sub">&nbsp;</p>
            </div>
          </div>
        </div>
      </div>

      <!-- KPI STRIP — calm, monochrome -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        <div class="bg-surface border border-outline-variant rounded-xl p-3">
          <div class="flex items-center justify-between">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Total uploads</p>
            <span class="material-symbols-outlined text-base text-outline/60">photo_library</span>
          </div>
          <p class="text-2xl font-headline font-black text-on-surface mt-1 tabular-nums" id="kpi-images">—</p>
          <p class="font-label text-[10px] uppercase tracking-wider text-outline mt-0.5" id="kpi-images-delta">&nbsp;</p>
        </div>
        <div class="bg-surface border border-outline-variant rounded-xl p-3">
          <div class="flex items-center justify-between">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Registered users</p>
            <span class="material-symbols-outlined text-base text-outline/60">group</span>
          </div>
          <p class="text-2xl font-headline font-black text-on-surface mt-1 tabular-nums" id="kpi-users">—</p>
          <p class="font-label text-[10px] uppercase tracking-wider text-outline mt-0.5" id="kpi-users-delta">&nbsp;</p>
        </div>
        <div class="bg-surface border border-outline-variant rounded-xl p-3">
          <div class="flex items-center justify-between">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Storage</p>
            <span class="material-symbols-outlined text-base text-outline/60">cloud</span>
          </div>
          <p class="text-2xl font-headline font-black text-on-surface mt-1 tabular-nums" id="kpi-storage">—</p>
          <p class="font-label text-[10px] uppercase tracking-wider text-outline mt-0.5" id="kpi-storage-delta">&nbsp;</p>
        </div>
        <div class="bg-surface border border-outline-variant rounded-xl p-3">
          <div class="flex items-center justify-between">
            <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Active sessions</p>
            <span class="material-symbols-outlined text-base text-outline/60">bolt</span>
          </div>
          <p class="text-2xl font-headline font-black text-on-surface mt-1 tabular-nums" id="kpi-sessions">—</p>
          <p class="font-label text-[10px] uppercase tracking-wider text-outline mt-0.5" id="kpi-sessions-delta">Live right now</p>
        </div>
      </div>

      <!-- COMPOSITION — single panel, three horizontal stacked bars -->
      <div class="bg-surface border border-outline-variant rounded-xl p-4">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Composition</h2>
          <span class="font-label text-[10px] uppercase tracking-wider text-outline">Last 30 days · <span id="comp-total" class="tabular-nums">—</span> uploads</span>
        </div>
        <div class="space-y-3" id="comp-bars">
          <!-- Authenticated vs anonymous -->
          <div>
            <div class="flex items-baseline justify-between text-[11px] mb-1">
              <span class="font-bold text-on-surface">Authenticated <span class="text-outline font-normal" id="comp-auth-num">—</span></span>
              <span class="text-outline">Anonymous <span class="text-on-surface font-bold" id="comp-anon-num">—</span></span>
            </div>
            <div class="h-2.5 rounded-full bg-surface-container-highest border border-outline-variant overflow-hidden flex">
              <div class="h-full bg-primary" id="comp-auth-bar" style="width: 0%"></div>
              <div class="h-full bg-secondary" id="comp-anon-bar" style="width: 0%"></div>
            </div>
          </div>
          <!-- Web vs API -->
          <div>
            <div class="flex items-baseline justify-between text-[11px] mb-1">
              <span class="font-bold text-on-surface">Web <span class="text-outline font-normal" id="comp-web-num">—</span></span>
              <span class="text-outline">API <span class="text-on-surface font-bold" id="comp-api-num">—</span></span>
            </div>
            <div class="h-2.5 rounded-full bg-surface-container-highest border border-outline-variant overflow-hidden flex">
              <div class="h-full bg-primary" id="comp-web-bar" style="width: 0%"></div>
              <div class="h-full bg-tertiary" id="comp-api-bar" style="width: 0%"></div>
            </div>
          </div>
          <!-- Adblock vs not -->
          <div>
            <div class="flex items-baseline justify-between text-[11px] mb-1">
              <span class="font-bold text-on-surface">Ad-blocker <span class="text-outline font-normal" id="comp-ab-num">—</span></span>
              <span class="text-outline">No blocker <span class="text-on-surface font-bold" id="comp-noab-num">—</span></span>
            </div>
            <div class="h-2.5 rounded-full bg-surface-container-highest border border-outline-variant overflow-hidden flex">
              <div class="h-full bg-on-surface" id="comp-ab-bar" style="width: 0%"></div>
              <div class="h-full bg-secondary" id="comp-noab-bar" style="width: 0%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- USERS — single tabbed panel -->
      <div class="bg-surface border border-outline-variant rounded-xl overflow-hidden">
        <div class="flex items-center justify-between gap-3 px-4 py-3 border-b border-outline-variant flex-wrap">
          <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Users</h2>
          <div class="flex items-center gap-1 flex-wrap" role="tablist" id="user-tabs">
            <button data-tab="top30" class="user-tab font-label text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full transition-colors" type="button">Top · 30d</button>
            <button data-tab="topall" class="user-tab font-label text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full transition-colors" type="button">Top · all-time</button>
            <button data-tab="recent" class="user-tab font-label text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full transition-colors" type="button">Recent signups</button>
            <button data-tab="dormant" class="user-tab font-label text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full transition-colors" type="button">Dormant</button>
          </div>
        </div>

        <div data-panel="top30" class="user-panel">
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[560px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Avg/day</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider w-1/3">Share</th>
                </tr>
              </thead>
              <tbody id="uploads-by-user-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="5" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div data-panel="topall" class="user-panel hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[480px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Since</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last</th>
                </tr>
              </thead>
              <tbody id="top-lifetime-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="4" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div data-panel="recent" class="user-panel hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[480px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Joined</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Lifetime</th>
                </tr>
              </thead>
              <tbody id="recent-signups-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="3" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div data-panel="dormant" class="user-panel hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[560px]">
              <thead>
                <tr class="border-b border-outline-variant">
                  <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">User</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Joined</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Lifetime</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Last upload</th>
                </tr>
              </thead>
              <tbody id="dormant-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="4" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- TRENDS — daily table + patterns side by side -->
      <div class="grid grid-cols-1 xl:grid-cols-[2fr_1fr] gap-3">
        <div class="bg-surface border border-outline-variant rounded-xl overflow-hidden">
          <div class="px-4 py-3 border-b border-outline-variant flex items-baseline justify-between">
            <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Daily breakdown</h2>
            <span class="font-label text-[10px] uppercase tracking-wider text-outline">Last 30 days</span>
          </div>
          <div class="overflow-x-auto max-h-[480px] overflow-y-auto">
            <table class="w-full text-left min-w-[560px]">
              <thead class="sticky top-0 bg-surface">
                <tr class="border-b border-outline-variant">
                  <th class="px-4 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Date</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Uploads</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Users</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Anon</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider">Size</th>
                  <th class="px-3 py-2 font-label text-[10px] uppercase font-bold text-outline tracking-wider w-1/3">Volume</th>
                </tr>
              </thead>
              <tbody id="daily-body" class="divide-y divide-outline-variant/50">
                <tr><td colspan="6" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Loading...</p></td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="space-y-3">
          <div class="bg-surface border border-outline-variant rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-outline-variant flex items-baseline justify-between">
              <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Hour of day</h2>
              <span class="font-label text-[10px] uppercase tracking-wider text-outline">7d</span>
            </div>
            <div class="p-3 font-mono text-[11px] leading-snug" id="hourly-body">
              <p class="text-outline">Loading...</p>
            </div>
          </div>
          <div class="bg-surface border border-outline-variant rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-outline-variant flex items-baseline justify-between">
              <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Day of week</h2>
              <span class="font-label text-[10px] uppercase tracking-wider text-outline">30d</span>
            </div>
            <div class="p-3 font-mono text-[11px] leading-snug" id="dow-body">
              <p class="text-outline">Loading...</p>
            </div>
          </div>
        </div>
      </div>

      <!-- ENGAGEMENT — compact strip -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-3">
        <div class="bg-surface border border-outline-variant rounded-xl p-4">
          <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Anon visitors <span class="normal-case font-normal">· unique IPs</span></p>
          <div class="grid grid-cols-2 gap-3 mt-2">
            <div>
              <p class="text-xl font-headline font-black text-on-surface tabular-nums" id="anon-ips-7d">—</p>
              <p class="font-label text-[9px] uppercase text-outline">7 days</p>
            </div>
            <div>
              <p class="text-xl font-headline font-black text-on-surface tabular-nums" id="anon-ips-30d">—</p>
              <p class="font-label text-[9px] uppercase text-outline">30 days</p>
            </div>
          </div>
        </div>
        <div class="bg-surface border border-outline-variant rounded-xl p-4">
          <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Ad-blocker users <span class="normal-case font-normal">· last 30 days</span></p>
          <div class="flex items-baseline gap-2 mt-2">
            <p class="text-xl font-headline font-black text-on-surface tabular-nums" id="eng-adblock-30d">—</p>
            <p class="font-label text-[10px] uppercase text-outline" id="eng-adblock-30d-sub">&nbsp;</p>
          </div>
        </div>
        <div class="bg-surface border border-outline-variant rounded-xl p-4">
          <p class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">CTA clicks <span class="normal-case font-normal">· last 30 days</span></p>
          <div id="eng-cta-list" class="mt-2 space-y-1 text-[11px]">
            <p class="text-outline">Loading...</p>
          </div>
        </div>
      </div>

      <!-- RECENT UPLOADS -->
      <div class="bg-surface border border-outline-variant rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-outline-variant flex items-center justify-between">
          <h2 class="text-xs font-headline italic font-black text-on-surface uppercase">Recent uploads</h2>
          <a href="/admin/images" class="font-label text-[10px] font-bold uppercase tracking-wider text-primary hover:underline">View all →</a>
        </div>
        <div id="recent-uploads">
          <div class="p-6 text-center text-outline">
            <p class="font-label text-xs uppercase">Loading...</p>
          </div>
        </div>
      </div>

    </main>
  </div>
</Layout>

<script>
  function esc(s: string | null | undefined): string {
    const d = document.createElement('div');
    d.textContent = s == null ? '' : String(s);
    return d.innerHTML;
  }

  function formatSize(bytes: number): string {
    if (!bytes) return '0 KB';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
  }

  function fmtDate(s: string | null | undefined): string {
    if (!s) return '—';
    const d = new Date(s.replace(' ', 'T') + 'Z');
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleDateString(undefined, { month: 'short', day: '2-digit', year: '2-digit' });
  }

  function fmtChange(pct: number | null): { text: string; cls: string } {
    if (pct === null || pct === undefined) return { text: 'no prev data', cls: 'text-surface/40' };
    const sign = pct > 0 ? '+' : '';
    const rounded = Math.abs(pct) >= 10 ? pct.toFixed(0) : pct.toFixed(1);
    const cls = pct > 0 ? 'text-secondary font-bold' : pct < 0 ? 'text-error font-bold' : 'text-surface/50';
    return { text: `${sign}${rounded}% vs prev`, cls };
  }

  function textBar(value: number, max: number, width: number = 16): string {
    if (max <= 0) return '';
    const filled = Math.round((value / max) * width);
    return '█'.repeat(filled) + '░'.repeat(Math.max(0, width - filled));
  }

  const DOW_NAMES = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

  type Data = any;

  function renderHero(d: Data) {
    document.getElementById('hero-today')!.textContent = (d.uploads.today ?? 0).toLocaleString();
    document.getElementById('hero-today-sub')!.textContent = `${formatSize(d.storage.today)} stored`;

    document.getElementById('hero-yesterday')!.textContent = (d.uploads.yesterday ?? 0).toLocaleString();
    const ydayDelta = (d.uploads.today ?? 0) - (d.uploads.yesterday ?? 0);
    document.getElementById('hero-yesterday-sub')!.textContent =
      ydayDelta === 0 ? 'same as today' : `today ${ydayDelta > 0 ? '+' : ''}${ydayDelta}`;

    document.getElementById('hero-7d')!.textContent = (d.uploads.last7d ?? 0).toLocaleString();
    const c7 = fmtChange(d.uploads.change7dPct);
    const sub7 = document.getElementById('hero-7d-sub')!;
    sub7.textContent = c7.text;
    sub7.className = `font-label text-[9px] uppercase mt-0.5 ${c7.cls}`;

    document.getElementById('hero-30d')!.textContent = (d.uploads.last30d ?? 0).toLocaleString();
    const c30 = fmtChange(d.uploads.change30dPct);
    const sub30 = document.getElementById('hero-30d-sub')!;
    sub30.textContent = c30.text;
    sub30.className = `font-label text-[9px] uppercase mt-0.5 ${c30.cls}`;
  }

  function renderKPIs(d: Data) {
    document.getElementById('kpi-images')!.textContent = (d.uploads.allTime ?? 0).toLocaleString();
    document.getElementById('kpi-images-delta')!.textContent =
      `+${(d.uploads.last7d ?? 0).toLocaleString()} this week`;

    document.getElementById('kpi-users')!.textContent = (d.users.total ?? 0).toLocaleString();
    document.getElementById('kpi-users-delta')!.textContent =
      `+${(d.users.new30d ?? 0).toLocaleString()} this month`;

    document.getElementById('kpi-storage')!.textContent = formatSize(d.storage.allTime);
    document.getElementById('kpi-storage-delta')!.textContent = `+${formatSize(d.storage.last30d)} this month`;

    document.getElementById('kpi-sessions')!.textContent = (d.engagement?.activeSessions ?? 0).toLocaleString();
  }

  function renderComposition(d: Data) {
    const total = d.uploads.last30d || 0;
    document.getElementById('comp-total')!.textContent = total.toLocaleString();

    const pct = (n: number) => (total > 0 ? (n / total) * 100 : 0);
    const fmt = (n: number) => `${n.toLocaleString()} (${pct(n).toFixed(0)}%)`;

    document.getElementById('comp-auth-num')!.textContent = fmt(d.sources.authenticated30d ?? 0);
    document.getElementById('comp-anon-num')!.textContent = fmt(d.sources.anonymous30d ?? 0);
    (document.getElementById('comp-auth-bar') as HTMLElement).style.width = `${pct(d.sources.authenticated30d ?? 0)}%`;
    (document.getElementById('comp-anon-bar') as HTMLElement).style.width = `${pct(d.sources.anonymous30d ?? 0)}%`;

    document.getElementById('comp-web-num')!.textContent = fmt(d.sources.web30d ?? 0);
    document.getElementById('comp-api-num')!.textContent = fmt(d.sources.api30d ?? 0);
    (document.getElementById('comp-web-bar') as HTMLElement).style.width = `${pct(d.sources.web30d ?? 0)}%`;
    (document.getElementById('comp-api-bar') as HTMLElement).style.width = `${pct(d.sources.api30d ?? 0)}%`;

    document.getElementById('comp-ab-num')!.textContent = fmt(d.sources.adblock30d ?? 0);
    document.getElementById('comp-noab-num')!.textContent = fmt(d.sources.noAdblock30d ?? 0);
    (document.getElementById('comp-ab-bar') as HTMLElement).style.width = `${pct(d.sources.adblock30d ?? 0)}%`;
    (document.getElementById('comp-noab-bar') as HTMLElement).style.width = `${pct(d.sources.noAdblock30d ?? 0)}%`;

  function renderDormant(d: Data) {
    const rows: any[] = d.dormantUsers ?? [];
    const body = document.getElementById('dormant-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="5" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">Every registered user uploaded in the last 30 days</p></td></tr>';
      return;
    }
    body.innerHTML = rows.map(r => {
      const initial = (r.name || r.email || '?').trim().charAt(0).toUpperCase();
      const avatar = r.avatar_url
        ? `<img src="${esc(r.avatar_url)}" alt="${esc(r.name)}" class="w-7 h-7 rounded-full border border-on-surface object-cover flex-shrink-0" referrerpolicy="no-referrer" loading="lazy" decoding="async" />`
        : `<div class="w-7 h-7 rounded-full border border-on-surface bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="text-[10px] font-bold text-outline">${esc(initial)}</span></div>`;
      return `
        <tr class="hover:bg-surface-container-lowest transition-colors">
          <td class="px-3 py-1.5">
            <div class="flex items-center gap-2 min-w-0">
              ${avatar}
              <p class="text-xs font-bold truncate max-w-[160px]">${esc(r.name || 'Unnamed')}</p>
            </div>
          </td>
          <td class="px-3 py-1.5 text-xs text-on-surface-variant truncate max-w-[220px]">${esc(r.email)}</td>
          <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${fmtDate(r.created_at)}</td>
          <td class="px-3 py-1.5 text-xs font-bold tabular-nums">${Number(r.lifetime_uploads).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs text-on-surface-variant whitespace-nowrap">${r.last_upload ? fmtDate(r.last_upload) : 'Never'}</td>
        </tr>
      `;
    }).join('');
  }

  function renderDaily(d: Data) {
    const rows: any[] = d.dailySeries ?? [];
    const body = document.getElementById('daily-body')!;
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="7" class="p-6 text-center text-outline"><p class="font-label text-xs uppercase">No uploads in the last 30 days</p></td></tr>';
      return;
    }
    const max = Math.max(1, ...rows.map(r => Number(r.uploads)));
    body.innerHTML = rows.map(r => {
      const widthPct = (Number(r.uploads) / max * 100).toFixed(1);
      return `
        <tr class="hover:bg-surface-container-lowest transition-colors">
          <td class="px-3 py-1.5 text-xs font-bold tabular-nums whitespace-nowrap">${esc(r.day)}</td>
          <td class="px-3 py-1.5 text-xs font-bold tabular-nums">${Number(r.uploads).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs tabular-nums">${Number(r.unique_users).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs tabular-nums text-outline">${Number(r.anon).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs tabular-nums text-outline">${Number(r.adblock).toLocaleString()}</td>
          <td class="px-3 py-1.5 text-xs tabular-nums text-on-surface-variant whitespace-nowrap">${formatSize(Number(r.size))}</td>
          <td class="px-3 py-1.5"><div class="h-2 bg-primary border border-on-surface" style="width: ${widthPct}%; max-width: 100%;"></div></td>
        </tr>
      `;
    }).join('');
  }

  function renderHourly(d: Data) {
    const rows: any[] = d.hourOfDay ?? [];
    const el = document.getElementById('hourly-body')!;
    if (!rows.length) {
      el.innerHTML = '<p class="text-outline">No data yet</p>';
      return;
    }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.hour), Number(r.count));
    const max = Math.max(1, ...Array.from(map.values()));
    const lines: string[] = [];
    for (let h = 0; h < 24; h++) {
      const v = map.get(h) ?? 0;
      const hh = String(h).padStart(2, '0');
      lines.push(`<div class="flex items-center gap-2"><span class="text-outline w-7">${hh}</span><span class="text-primary">${textBar(v, max, 18)}</span><span class="tabular-nums text-on-surface-variant w-10 text-right">${v.toLocaleString()}</span></div>`);
    }
    el.innerHTML = lines.join('');
  }

  function renderDayOfWeek(d: Data) {
    const rows: any[] = d.dayOfWeek ?? [];
    const el = document.getElementById('dow-body')!;
    if (!rows.length) {
      el.innerHTML = '<p class="text-outline">No data yet</p>';
      return;
    }
    const map = new Map<number, number>();
    for (const r of rows) map.set(Number(r.dow), Number(r.count));
    const max = Math.max(1, ...Array.from(map.values()));
    const lines: string[] = [];
    for (let i = 0; i < 7; i++) {
      const v = map.get(i) ?? 0;
      lines.push(`<div class="flex items-center gap-2"><span class="text-outline w-7">${DOW_NAMES[i]}</span><span class="text-primary">${textBar(v, max, 18)}</span><span class="tabular-nums text-on-surface-variant w-10 text-right">${v.toLocaleString()}</span></div>`);
    }
    el.innerHTML = lines.join('');
  }

  function renderAnonymous(d: Data) {
    document.getElementById('anon-ips-7d')!.textContent = (d.anonymous.uniqueIPs7d ?? 0).toLocaleString();
    document.getElementById('anon-ips-30d')!.textContent = (d.anonymous.uniqueIPs30d ?? 0).toLocaleString();
    document.getElementById('anon-uploads-30d')!.textContent = (d.sources.anonymous30d ?? 0).toLocaleString();
    document.getElementById('anon-uploads-total')!.textContent = (d.anonymous.totalUploadsAllTime ?? 0).toLocaleString();
  }

  function renderEngagement(d: Data) {
    document.getElementById('eng-sessions')!.textContent = (d.engagement.activeSessions ?? 0).toLocaleString();

    document.getElementById('eng-adblock-30d')!.textContent = (d.sources.adblock30d ?? 0).toLocaleString();
    document.getElementById('eng-adblock-30d-sub')!.textContent =
      `${(d.sources.adblockPct30d ?? 0).toFixed(1)}% of last-30d uploads`;

    const ctaList: any[] = d.engagement.ctaBreakdown ?? [];
    const ctaEl = document.getElementById('eng-cta-list')!;
    if (!ctaList.length) {
      ctaEl.innerHTML = '<p class="text-outline">No clicks in last 30 days</p>';
    } else {
      ctaEl.innerHTML = ctaList.map(c =>
        `<div class="flex items-baseline justify-between"><span class="text-outline truncate mr-2">${esc(c.link_id)}</span><span class="font-bold tabular-nums">${Number(c.count).toLocaleString()}</span></div>`
      ).join('');
    }
  }

  function renderRecent(d: Data) {
    const el = document.getElementById('recent-uploads')!;
    if (!d.recentUploads?.length) {
      el.innerHTML = '<div class="p-8 text-center text-outline"><p class="font-label text-xs uppercase">No uploads yet</p></div>';
      return;
    }
    el.innerHTML = `
      <div class="overflow-x-auto"><table class="w-full text-left min-w-[500px]">
        <thead>
          <tr class="border-b border-outline-variant">
            <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Asset</th>
            <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Owner</th>
            <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Size</th>
            <th class="px-5 py-3 font-label text-xs uppercase font-bold text-outline tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/50">
          ${d.recentUploads.map((img: any) => `
            <tr class="hover:bg-surface-container-lowest transition-colors">
              <td class="px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-surface-container-highest border border-outline-variant overflow-hidden flex-shrink-0">
                    <img src="${esc(img.url)}" alt="${esc(img.filename)}" class="w-full h-full object-cover" loading="lazy" decoding="async" />
                  </div>
                  <span class="text-sm font-bold truncate max-w-40">${esc(img.filename)}</span>
                </div>
              </td>
              <td class="px-5 py-3">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-surface-container-highest border border-outline-variant flex items-center justify-center">
                    <span class="material-symbols-outlined text-xs text-outline">person</span>
                  </div>
                  <span class="text-sm text-on-surface-variant">${esc(img.user_name || 'Anonymous')}</span>
                </div>
              </td>
              <td class="px-5 py-3 text-sm text-on-surface-variant">${(img.size_bytes / (1024 * 1024)).toFixed(1)} MB</td>
              <td class="px-5 py-3">
                <div class="flex gap-2">
                  <button onclick="copyUrl('${esc(img.url)}')" class="w-9 h-9 rounded-full border border-outline-variant flex items-center justify-center hover:bg-surface-container-highest active:bg-surface-container-highest transition-colors">
                    <span class="material-symbols-outlined text-sm text-outline">link</span>
                  </button>
                </div>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table></div>
    `;
  }

  async function loadStats() {
    const res = await fetch('/api/admin/stats');
    if (!res.ok) throw new Error('stats failed');
    const data = await res.json();

    renderOverview(data);
    renderActivity(data);
    renderTopUploaders30d(data);
    renderTopLifetime(data);
    renderRecentSignups(data);
    renderDormant(data);
    renderDaily(data);
    renderHourly(data);
    renderDayOfWeek(data);
    renderAnonymous(data);
    renderEngagement(data);
    renderRecent(data);
  }

  function showToast(message: string) {
    const existing = document.querySelector('.admin-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'admin-toast fixed bottom-6 left-1/2 -translate-x-1/2 bg-on-surface text-surface px-5 py-3 rounded-xl font-label text-xs font-bold uppercase tracking-wider z-50 border-2 border-on-surface hard-shadow transition-opacity';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 2000);
  }

  (window as any).copyUrl = (url: string) => {
    navigator.clipboard.writeText(url).then(() => showToast('URL copied!'));
  };

  document.getElementById('refresh-stats')?.addEventListener('click', () => {
    loadStats().then(() => showToast('Refreshed')).catch(() => showToast('Refresh failed'));
  });

  loadStats().catch(() => showToast('Failed to load stats'));
</script>

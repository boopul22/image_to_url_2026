            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Works Anywhere</h3>
            <p class="font-body text-on-surface-variant">Embed your extracted image URL in emails, forums, wikis, Markdown files, social posts, or any platform that accepts direct image links.</p>
          </div>
        </div>
      </div>
    </section>


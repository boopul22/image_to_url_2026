        <div>
          <p class="font-black font-headline text-sm sm:text-base mb-1">Looking for extract.pics or extractpics?</p>
          <p class="font-body text-on-surface-variant text-sm">ImageToURL is a free alternative — save any image from a website and get a permanent, CDN-hosted direct URL with no account required and no inactivity purge.</p>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How to Extract Images from a Website</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">1</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Save the Image</h3>
            <p class="font-body text-on-surface-variant">Right-click on the image on any website and select "Save image as…" to save it to your device. Works on desktop and mobile browsers.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">2</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload Here</h3>

---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;
function lp(path: string): string { return `/${locale}${path}`; }

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Image Extractor — Extract Images from Any Website",
  "url": "https://imagetourl.cloud/image-extractor",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Free online image extractor. Upload any image from a website and get a permanent direct URL. The best free alternative to extract.pics — no signup, no limits.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to extract an image from a website and get a direct URL",
  "totalTime": "PT15S",
  "step": [
    { "@type": "HowToStep", "name": "Save the image from the website", "text": "Right-click the image on the source website and choose 'Save image as…' to download it to your device." },
    { "@type": "HowToStep", "name": "Upload to ImageToURL", "text": "Drag the saved image into the uploader or click to browse. Supports JPG, PNG, WebP, GIF — up to 10MB." },
    { "@type": "HowToStep", "name": "Get your permanent direct URL", "text": "Your extracted image is hosted on our CDN and assigned a permanent direct link you can use anywhere." }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I extract an image from a website for free?",
      "acceptedAnswer": { "@type": "Answer", "text": "Right-click the image on any website and select 'Save image as…'. Then upload the saved file here — you'll get a permanent direct URL for the extracted image in seconds. No signup required." }
    },
    {
      "@type": "Question",
      "name": "Is ImageToURL a free alternative to extract.pics?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. ImageToURL is a free alternative to extract.pics and extractpics. Upload any image you've saved from a website and get a permanent CDN-hosted direct link with no limits and no signup." }
    },
    {
      "@type": "Question",
      "name": "What image formats can I extract and upload?",
      "acceptedAnswer": { "@type": "Answer", "text": "We support JPG, JPEG, PNG, WebP, GIF, and SVG. Most website images are JPG or PNG — both work perfectly." }
    },
    {
      "@type": "Question",
      "name": "Does the image quality change after extraction?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. We store and serve your image exactly as you uploaded it — no compression, no re-encoding, no quality loss whatsoever." }
    },
    {
      "@type": "Question",
      "name": "How long does the extracted image URL last?",
      "acceptedAnswer": { "@type": "Answer", "text": "Extracted image URLs are permanent and never expire unless you set an auto-delete option. Your image stays hosted on our global CDN indefinitely." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between extract.pics and ImageToURL?",
      "acceptedAnswer": { "@type": "Answer", "text": "Extract.pics scrapes all images from a page URL automatically. ImageToURL focuses on giving each individually uploaded image a permanent, CDN-hosted direct URL — great for re-hosting extracted images with stable links that never break." }
    },
    {
      "@type": "Question",
      "name": "Can I use the extracted image URL to hotlink on other websites?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every URL from ImageToURL supports hotlinking — embed the extracted image directly in any website, forum, email, or Markdown document without restrictions." }
    }
  ]
};
---

<Layout title="Image Extractor — Extract & Download Images from Any Website, Free | ImageToURL" description="Free image extractor from websites. Upload any saved image and get a permanent direct URL instantly. Best free alternative to extract.pics — no signup required." schema={[schema, howToSchema, faqSchema]} noHreflang>
  <Nav />
  <main>
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
      <ImageUploader />
      <header class="mb-5 sm:mb-8 reveal">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Image Extractor</span>
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
          Extract images from any website — get a <span class="italic text-primary">permanent direct URL, free.</span>
        </h1>
        <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
          Save an image from any website, upload it here, and get a permanent CDN-hosted direct URL in seconds. The best free alternative to extract.pics and extractpics — no signup, no limits, no catch.
        </p>
      </header>
    </div>

    <!-- Alternative Badge -->
    <div class="max-w-5xl mx-auto px-3 sm:px-6 mb-6">
      <div class="bg-primary-fixed border-2 border-on-background rounded-xl p-4 sm:p-5 hard-shadow flex items-start gap-4 reveal">

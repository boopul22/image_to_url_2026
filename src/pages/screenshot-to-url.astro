---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ImageUploader from '../components/ImageUploader.astro';
import { defaultLocale } from '../i18n/config';
import type { Locale } from '../i18n/config';

const locale: Locale = Astro.locals.locale ?? defaultLocale;

function lp(path: string): string {
  return `/${locale}${path}`;
}

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Screenshot to URL Converter",
  "url": "https://imagetourl.cloud/screenshot-to-url",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Turn screenshots into shareable URLs in seconds. Paste from clipboard, drag & drop, or upload.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can I paste a screenshot from my clipboard?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! After taking a screenshot, you can paste it directly into our uploader using Ctrl+V (or Cmd+V on Mac). No need to save the file first."
      }
    },
    {
      "@type": "Question",
      "name": "What screenshot formats are supported?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We support all common screenshot formats: PNG (default for most systems), JPG, WebP, and BMP. Whatever your OS or tool produces, we handle it."
      }
    },
    {
      "@type": "Question",
      "name": "How fast is the upload?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Screenshots typically upload in under 2 seconds. Your permanent URL is generated instantly upon upload completion."
      }
    },
    {
      "@type": "Question",
      "name": "Can I share screenshots in Slack and Discord?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Copy your screenshot URL and paste it into any chat platform. Slack, Discord, Teams, and most chat apps will automatically show an image preview."
      }
    },
    {
      "@type": "Question",
      "name": "Are screenshot URLs permanent?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Every screenshot you upload gets a permanent URL that never expires. Share it in documentation today, and it will still work years from now."
      }
    }
  ]
};
---

<Layout title="Screenshot to URL — Share Screenshots as Links Instantly | ImageToURL" description="Turn screenshots into shareable URLs in seconds. Paste from clipboard, drag & drop, or upload. Perfect for bug reports, tutorials, and quick sharing." schema={[schema, faqSchema]} noHreflang>
  <Nav />

  <main>


    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
    <!-- Hero -->
    <ImageUploader />

    <header class="mb-5 sm:mb-8 reveal">
      <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Screenshot Sharing</span>
      <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
        Screenshot to URL <span class="italic text-primary">— paste and share.</span>
      </h1>
      <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
        Turn screenshots into shareable URLs in seconds. Paste from clipboard, drag & drop, or upload — perfect for bug reports, tutorials, and quick sharing.
      </p>
    </header>
    </div>



    <!-- How It Works -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">1</div>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">screenshot_monitor</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Capture Your Screen</h3>
          <p class="font-body text-on-surface-variant">Take a screenshot using your system shortcut (Cmd+Shift+4 on Mac, Win+Shift+S on Windows, or any tool you prefer).</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">2</div>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">content_paste</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Upload or Paste</h3>
          <p class="font-body text-on-surface-variant">Drag your screenshot file into our uploader, or paste directly from your clipboard. Both methods work instantly.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 h-10 bg-primary text-on-primary rounded-full flex items-center justify-center font-black font-headline text-lg mb-4">3</div>
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">link</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Share the Link</h3>
          <p class="font-body text-on-surface-variant">Copy the generated URL and paste it into Slack, email, GitHub issues, Jira tickets, or any conversation.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Why Screenshot to URL? -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why Screenshot to URL?</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">content_paste_go</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Clipboard Paste Support</h3>
          <p class="font-body text-on-surface-variant">Paste screenshots directly from your clipboard. No need to save the file first — just Ctrl+V and upload.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">bug_report</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Instant Bug Reports</h3>
          <p class="font-body text-on-surface-variant">Capture an issue, upload the screenshot, share the URL in your bug tracker. The fastest bug reporting workflow.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">link</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Clean Direct Links</h3>
          <p class="font-body text-on-surface-variant">Get clean, direct image URLs — not gallery pages with ads. Perfect for embedding in documentation and tickets.</p>
        </div>
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">screenshot</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Works with Any Screenshot Tool</h3>
          <p class="font-body text-on-surface-variant">Whether you use Snipping Tool, Greenshot, Lightshot, or native OS screenshots — all formats supported.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- Perfect For -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Perfect For</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
        <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">terminal</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Developers & QA Teams</h3>
          <p class="font-body text-on-surface-variant">Attach visual bug reports to GitHub issues, Jira tickets, and pull request reviews with a single URL.</p>
        </div>
        <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">groups</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Remote Teams</h3>
          <p class="font-body text-on-surface-variant">Share your screen context in Slack, Teams, or email without file attachment limits or compression.</p>
        </div>
        <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">menu_book</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Tutorial Writers</h3>
          <p class="font-body text-on-surface-variant">Create step-by-step visual guides with permanent screenshot URLs for documentation and blogs.</p>
        </div>
        <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
          <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
            <span class="material-symbols-outlined text-primary text-lg sm:text-xl">support_agent</span>
          </div>
          <h3 class="text-base sm:text-lg font-black font-headline mb-2">Customer Support</h3>
          <p class="font-body text-on-surface-variant">Ask customers to share screenshots as links — easier to receive, view, and archive than email attachments.</p>
        </div>
      </div>
    </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Frequently Asked Questions</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="space-y-4 reveal">
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Can I paste a screenshot from my clipboard?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes! After taking a screenshot, you can paste it directly into our uploader using Ctrl+V (or Cmd+V on Mac). No need to save the file first.</p>
          </div>
        </details>
        <details class="bg-tertiary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            What screenshot formats are supported?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">We support all common screenshot formats: PNG (default for most systems), JPG, WebP, and BMP. Whatever your OS or tool produces, we handle it.</p>
          </div>
        </details>
        <details class="bg-primary-fixed border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            How fast is the upload?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Screenshots typically upload in under 2 seconds. Your permanent URL is generated instantly upon upload completion.</p>
          </div>
        </details>
        <details class="bg-surface-variant border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Can I share screenshots in Slack and Discord?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes. Copy your screenshot URL and paste it into any chat platform. Slack, Discord, Teams, and most chat apps will automatically show an image preview.</p>
          </div>
        </details>
        <details class="bg-secondary-container border-2 border-on-background rounded-xl hard-shadow group">
          <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between">
            Are screenshot URLs permanent?
            <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="px-4 sm:px-5 pb-4 sm:pb-5">
            <p class="font-body text-on-surface-variant">Yes. Every screenshot you upload gets a permanent URL that never expires. Share it in documentation today, and it will still work years from now.</p>
          </div>
        </details>
      </div>
    </div>
    </section>

    <!-- Related Tools -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related Tools</h2>
        <div class="h-1 flex-grow bg-on-background opacity-10"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <a href="/photo-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">Photo to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Turn any photo into a shareable link</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/png-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">PNG to URL</h3>
            <p class="font-body text-on-surface-variant text-sm">Convert PNG images to shareable links</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
        <a href="/bulk-image-upload" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
          <div>
            <h3 class="text-sm sm:text-base font-black font-headline mb-1">Bulk Image Upload</h3>
            <p class="font-body text-on-surface-variant text-sm">Upload multiple images at once</p>
          </div>
          <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
        </a>
      </div>
    </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
      <div class="reveal">
      <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
        <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">Share your screenshot as a link</h2>
        <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">Upload or paste a screenshot and get a permanent URL in seconds. No signup, no ads, no catch.</p>
        <a href={lp('/')} class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
          Upload Screenshot Now
        </a>
      </div>
    </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

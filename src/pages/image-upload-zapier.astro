---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public Zapier webhook uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Upload via Zapier — Current Status"
  slug="image-upload-zapier"
  metaDescription="Current Zapier upload status for ImageToURL. Public webhook/API uploads are not live yet; use the website uploader today."
  h1Pre="Zapier image upload"
  h1Highlight="not public yet."
  intro="Zapier automation is not live yet because public API-key uploads are not open. Use the website uploader today, or contact us if your workflow needs automation access."
  lang="bash"
  langLabel="Zapier Webhook"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "Zapier is roadmap", body: "No-code uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 100 uploads per rolling 24 hours and signed-in users get 150 credits per day (about 1 credit per MB), with a 50 MB file cap." },
    { title: "Contact for automation", body: "If you need Zapier for forms, Airtable, or support intake, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I use Zapier today?", a: "No. Public webhook/API uploads are not live yet; use the website uploader." },
    { q: "What trigger should I use later?", a: "Anything that provides a file URL or attachment: Typeform file upload, Gmail attachment, Airtable attachment field, or Dropbox new file." },
    { q: "Do I need a paid Zapier plan?", a: "Likely yes once automation opens, because Webhooks by Zapier is usually a multi-step paid feature. ImageToURL does not provide a live webhook endpoint today." },
    { q: "How do I pass the file?", a: "That will be documented when public API-key uploads launch. The current /api/upload route is only for same-site website uploads." },
    { q: "Is the API key safe in Zapier?", a: "No public upload API key is available today. Once available, store it in Zapier's encrypted connection/header fields and rotate shared credentials." },
    { q: "Can I handle upload failures?", a: "Zapier can branch on status codes, but ImageToURL webhook uploads are not live today." },
    { q: "What about multi-file uploads?", a: "Not available today through public Zapier automation." },
    { q: "Cost at scale?", a: "Zapier pricing depends on task volume. ImageToURL does not have a self-serve paid automation tier today; contact us if you need higher limits or API access." },
    { q: "Alternatives to Zapier?", a: "Make (Integromat) has a more flexible HTTP module. n8n is self-hostable and cheaper for high volume." }
  ]}
  relatedSlugs={[
    { href: "/image-upload-make/", title: "Make", body: "Same pattern on Make.com." },
    { href: "/image-upload-n8n/", title: "n8n", body: "Self-hosted alternative." },
    { href: "/image-hosting-api-curl/", title: "cURL", body: "See the underlying API call." }
  ]}
/>

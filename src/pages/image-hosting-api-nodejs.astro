---
export const prerender = true;
import DevApiPage from '../components/DevApiPage.astro';

const code = `# Current status
# Public Node/API-key uploads are not live yet.
#
# The active /api/upload route is used by the ImageToURL website uploader
# and requires a same-site browser request from imagetourl.cloud.
#
# Use the web uploader today, or contact us if you need automation access.`;
---
<DevApiPage
  title="Image Hosting API — Node.js Status"
  slug="image-hosting-api-nodejs"
  metaDescription="Current Node/API upload status for ImageToURL. Public API-key uploads are not live yet; use the website uploader today."
  h1Pre="Image hosting API"
  h1Highlight="not public yet."
  intro="The public Node upload flow is not live yet. The current upload endpoint powers the website uploader and rejects non-same-site automation requests."
  lang="text"
  langLabel="Node.js"
  codeSnippet={code}
  whys={[
    { title: "Website uploads are live", body: "Use the main uploader today for guest links, signed-in dashboard history, and the Never delete option." },
    { title: "Node automation is roadmap", body: "Server actions, route handlers, workers, and CI uploads need public API-key access before they are reliable." },
    { title: "Current limits are clear", body: "Guests get 5 temporary uploads per rolling 24 hours and signed-in users get 50 permanent uploads per day plus unlimited temporary uploads, with a 50 MB file cap." },
    { title: "Contact for automation", body: "If you need Node upload workflows, contact us so the use case can be reviewed manually." }
  ]}
  faqs={[
    { q: "Can I upload from Node today?", a: "No. Public Node/API-key uploads are not live yet; use the website uploader." },
    { q: "Do I need node-fetch?", a: "No public Node upload snippet is supported today. Node 18+ fetch will be the natural path once API-key uploads are available." },
    { q: "What about Next.js server components?", a: "Not today. Public API-key uploads are not live yet, so Next.js route handlers and server actions should not call /api/upload directly." },
    { q: "Deno / Bun?", a: "Same status: no public upload API today." },
    { q: "Can I upload a Buffer directly?", a: "Not through a public ImageToURL API today. Upload the saved file through the website uploader." },
    { q: "Retry on 429?", a: "The live website uploader respects the current 5 guest and 25 signed-in uploads per rolling 24 hours." },
    { q: "TypeScript types?", a: "Public TypeScript response types will be documented when API-key uploads launch." },
    { q: "Express middleware for server-side uploads?", a: "Not available today. Use the website uploader or contact us if you need automation access reviewed." }
  ]}
  relatedSlugs={[
    { href: "/image-hosting-api-python/", title: "Python", body: "Python snippet." },
    { href: "/image-hosting-for-nextjs/", title: "Next.js", body: "Next.js integration." },
    { href: "/image-upload-api/", title: "API overview", body: "Endpoint docs." }
  ]}
/>

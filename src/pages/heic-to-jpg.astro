---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeicConverter from '../components/HeicConverter.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "HEIC to JPG Converter — 100% in your browser",
  "url": "https://imagetourl.cloud/heic-to-jpg",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Convert HEIC and HEIF photos from your iPhone to JPG entirely in your browser. Files never leave your device. Free, unlimited, no signup.",
  "provider": { "@id": "https://imagetourl.cloud/#organization" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are my photos really private?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Conversion happens entirely in your browser using WebAssembly. No file is uploaded to any server unless you explicitly click \"Get URL\" to host the converted JPG. You can verify this in your browser's DevTools Network tab — there are zero requests during conversion."
      }
    },
    {
      "@type": "Question",
      "name": "What is HEIC and why do I need to convert it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HEIC (High Efficiency Image Container) is the default photo format on iPhones since iOS 11. It produces smaller files than JPG at the same quality, but it isn't widely supported on Windows, Android, web browsers, or most email clients — which is why you usually need to convert it to JPG before sharing."
      }
    },
    {
      "@type": "Question",
      "name": "Is there a file size or count limit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Because conversion happens locally in your browser, there is no upload limit. You can convert as many HEIC files as your device's memory allows — typically dozens at a time without issue."
      }
    },
    {
      "@type": "Question",
      "name": "Will I lose quality converting HEIC to JPG?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "JPG is a lossy format, so a tiny amount of compression is unavoidable. We default to 92% quality, which is visually indistinguishable from the original on screen. You can adjust the slider from 60% (smaller file) to 100% (highest quality) to suit your needs."
      }
    },
    {
      "@type": "Question",
      "name": "Can I convert multiple files at once?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Drop several .heic files at once or use multi-select in the file picker. Each file is converted in turn and shows up in the results list with its own download button."
      }
    },
    {
      "@type": "Question",
      "name": "How do I get HEIC files from my iPhone to my computer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Email the photos to yourself, drop them into a chat app on desktop, AirDrop to a Mac, or plug your iPhone into a computer and copy the photos folder. Then drag the .heic files onto this page."
      }
    },
    {
      "@type": "Question",
      "name": "What browsers are supported?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Any modern browser with WebAssembly support — Chrome, Edge, Firefox, Safari, Brave, and Arc all work. Mobile browsers are supported too."
      }
    },
    {
      "@type": "Question",
      "name": "Is this really free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, completely free with no signup, no watermarks, no ads. Because the work happens on your computer instead of ours, there's no cost to run it."
      }
    }
  ]
};
---

<Layout
  title="HEIC to JPG Converter — 100% in your browser | Free & Private"
  description="Convert HEIC photos from your iPhone to JPG entirely in your browser. Files never leave your device. Free, unlimited, no signup, no upload."
  schema={[schema, faqSchema]}
  noHreflang
>
  <Nav />

  <main>
    <div class="max-w-5xl mx-auto px-3 sm:px-6 pt-6 sm:pt-10">
      <header class="mb-5 sm:mb-8 reveal">
        <span class="inline-block bg-tertiary-fixed text-on-tertiary-fixed px-3 py-1 rounded-full text-xs font-bold font-label uppercase tracking-widest mb-3 sm:mb-4 border border-on-background">Browser-only Tool</span>
        <h1 class="text-xl sm:text-2xl lg:text-3xl font-black font-headline leading-none tracking-tighter mb-4 sm:mb-6">
          HEIC to JPG Converter <span class="italic text-primary">100% in your browser.</span>
        </h1>
        <p class="text-sm sm:text-base font-headline font-medium max-w-2xl text-on-surface-variant leading-relaxed">
          Drop your iPhone HEIC photos here and get JPG files instantly. Conversion runs entirely on your device — your photos never leave your computer. Free, unlimited, no signup.
        </p>
      </header>

      <HeicConverter />
    </div>

    <!-- How It Works -->
    <section class="py-8 sm:py-12 mt-8 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">How It Works</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">1</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Drop your HEIC files</h3>
            <p class="font-body text-on-surface-variant">Drag photos straight from your iPhone, Mac Finder, or downloads folder. Multi-select is supported.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">2</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Convert in your browser</h3>
            <p class="font-body text-on-surface-variant">A WebAssembly decoder runs locally on your device. Zero network calls — verify it in DevTools.</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-primary text-on-primary border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4 text-lg sm:text-xl font-black font-headline">3</div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Download or host</h3>
            <p class="font-body text-on-surface-variant">Save the JPG to your device, or one-click "Get URL" to host it on our CDN and grab a shareable link.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Convert -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Why convert HEIC to JPG?</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div class="bg-secondary-container border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">desktop_windows</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Windows compatibility</h3>
            <p class="font-body text-on-surface-variant">Windows can't open HEIC out of the box without paid codecs. JPG opens everywhere, every time.</p>
          </div>
          <div class="bg-tertiary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">android</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Android & messaging</h3>
            <p class="font-body text-on-surface-variant">Many Android phones and chat apps still struggle with HEIC. JPG just works in WhatsApp, Messenger, Slack, and email.</p>
          </div>
          <div class="bg-primary-fixed border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">public</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Web & social</h3>
            <p class="font-body text-on-surface-variant">Most blogs, CMSs, and older social platforms reject HEIC uploads. Convert first to avoid the upload error.</p>
          </div>
          <div class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow reveal">
            <div class="w-10 sm:w-12 h-10 sm:h-12 bg-white border-2 border-on-background rounded-lg flex items-center justify-center mb-3 sm:mb-4">
              <span class="material-symbols-outlined text-primary text-lg sm:text-xl">lock</span>
            </div>
            <h3 class="text-base sm:text-lg font-black font-headline mb-2">Privacy by default</h3>
            <p class="font-body text-on-surface-variant">Other converters upload your photos to their servers. Ours never does — the file stays on your device unless you explicitly choose to host it.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-y border-outline-variant/40">
      <div class="max-w-3xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">FAQ</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="flex flex-col gap-3 sm:gap-4">
          {faqSchema.mainEntity.map((q, i) => (
            <details class={`border-2 border-on-background rounded-xl hard-shadow group ${i % 2 === 0 ? 'bg-secondary-container' : 'bg-surface-variant'}`}>
              <summary class="p-4 sm:p-5 cursor-pointer font-black font-headline text-sm sm:text-base list-none flex items-center justify-between gap-3">
                {q.name}
                <span class="material-symbols-outlined text-primary transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              <div class="px-4 sm:px-5 pb-4 sm:pb-5">
                <p class="font-body text-on-surface-variant">{q.acceptedAnswer.text}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="py-8 sm:py-12">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="flex items-baseline gap-4 mb-5 sm:mb-8 reveal">
          <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight">Related</h2>
          <div class="h-1 flex-grow bg-on-background opacity-10"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
          <a href="/jpg-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">JPG to URL</h3>
              <p class="font-body text-on-surface-variant text-sm">Host your converted JPG and get a permanent link</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
          <a href="/png-to-url" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">PNG to URL</h3>
              <p class="font-body text-on-surface-variant text-sm">Convert PNG screenshots to shareable links</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
          <a href="/free-image-hosting" class="bg-surface-variant border-2 border-on-background p-4 sm:p-5 rounded-xl hard-shadow hard-shadow-hover flex items-center justify-between transition-all reveal">
            <div>
              <h3 class="text-sm sm:text-base font-black font-headline mb-1">Free Image Hosting</h3>
              <p class="font-body text-on-surface-variant text-sm">Host any image format for free</p>
            </div>
            <span class="material-symbols-outlined text-primary text-2xl">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-8 sm:py-12 bg-surface-container-low border-t border-outline-variant/40">
      <div class="max-w-5xl mx-auto px-3 sm:px-6">
        <div class="reveal">
          <div class="bg-on-surface text-surface rounded-xl p-5 sm:p-8 border-2 border-on-surface hard-shadow text-center">
            <h2 class="text-xl sm:text-2xl font-black font-headline tracking-tight mb-4">Need a permanent URL too?</h2>
            <p class="font-body text-surface/70 mb-4 sm:mb-6 max-w-lg mx-auto">After converting, click "Get URL" on any file to host it on our global CDN — free, no signup.</p>
            <a href="/" class="inline-block bg-primary text-on-primary px-6 py-3 border-2 border-on-background font-label text-sm font-bold uppercase tracking-wider hard-shadow hard-shadow-hover active:scale-95 transition-all">
              Try the main uploader
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

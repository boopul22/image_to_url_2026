---
import '../styles/global.css';
import { locales, localeOgTags, defaultLocale, isRtl } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { stripLocalePrefix } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schema?: object | object[];
  /** Disable hreflang tags for root-level English-only pages (e.g. /png-to-url) */
  noHreflang?: boolean;
  /** Override hreflang generation with explicit per-locale URLs. Used by pages
   *  with translated slugs where the URL differs per locale (dynamic landing route). */
  hreflangAlternates?: { locale: Locale; url: string }[];
  /** Breadcrumb items for BreadcrumbList schema: [{name, url}] */
  breadcrumbs?: { name: string; url: string }[];
  /** ISO-8601 date string surfaced as visible text and `WebPage.dateModified` */
  lastModified?: string;
}

const {
  title = "ImageToURL \u2014 Free Image Hosting | Turn Images into Shareable Links",
  description = "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery. Upload JPG, PNG, WebP, GIF, SVG and get an instant shareable URL.",
  ogImage = "/og-default.png",
  ogType = "website",
  noindex = false,
  schema,
  noHreflang = false,
  hreflangAlternates,
  breadcrumbs,
  lastModified,
} = Astro.props;

const locale: Locale = Astro.locals.locale ?? defaultLocale;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const basePath = stripLocalePrefix(Astro.url.pathname);

// Sitewide schemas
const sitewideSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://imagetourl.cloud/#organization",
    "name": "ImageToURL",
    "url": "https://imagetourl.cloud",
    "logo": {
      "@type": "ImageObject",
      "url": "https://imagetourl.cloud/icon-512.png",
      "width": 512,
      "height": 512
    },
    "description": "ImageToURL is a cloud-based image hosting service that converts uploaded images into permanent, CDN-delivered shareable URLs instantly.",
    "foundingDate": "2025",
    "sameAs": [
      "https://github.com/boopul22",
      "https://www.instagram.com/bipul.skill",
      "https://bipul.online/"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "blog.boopul@gmail.com",
      "contactType": "customer support",
      "availableLanguage": ["English"]
    },
    "founder": {
      "@type": "Person",
      "@id": "https://imagetourl.cloud/#founder",
      "name": "Bipul",
      "url": "https://bipul.online/",
      "sameAs": [
        "https://github.com/boopul22",
        "https://www.instagram.com/bipul.skill"
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://imagetourl.cloud/#website",
    "url": "https://imagetourl.cloud",
    "name": "ImageToURL",
    "description": "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery.",
    "publisher": { "@id": "https://imagetourl.cloud/#organization" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://imagetourl.cloud/blog?search={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  }
];

// Auto-generate breadcrumbs for root-level English pages AND locale-prefixed
// landing pages. Uses a localized "Home" label for each supported locale.
const SITE_URL = 'https://imagetourl.cloud';
const HOME_LABELS: Record<string, string> = {
  en: 'Home', hi: 'होम', es: 'Inicio', fr: 'Accueil', de: 'Startseite',
  ja: 'ホーム', 'zh-Hans': '首页', id: 'Beranda', vi: 'Trang chủ',
  'pt-BR': 'Início', tr: 'Ana Sayfa', tl: 'Home', pl: 'Strona główna',
  nl: 'Home', it: 'Home', ar: 'الرئيسية', bn: 'হোম', fa: 'خانه',
  ur: 'ہوم', ru: 'Главная', th: 'หน้าแรก', ko: '홈', sw: 'Nyumbani',
  ms: 'Laman Utama', ta: 'முகப்பு', mr: 'मुख्यपृष्ठ', te: 'హోమ్', 'zh-Hant': '首頁',
};
function detectLocale(path: string): string | null {
  const m = path.match(/^\/([^\/]+)(?:\/|$)/);
  if (!m) return null;
  return HOME_LABELS[m[1]] !== undefined ? m[1] : null;
}
const pathname = Astro.url.pathname;
const pageLocale = detectLocale(pathname);
const cleanTitle = title.replace(/\s*[\u2014\-|].*(ImageToURL|imagetourl).*$/i, '').trim();
const autoBreadcrumbs: { name: string; url: string }[] | undefined = breadcrumbs ?? (
  pathname === '/' ? undefined :
  pageLocale ? [
    { name: HOME_LABELS[pageLocale], url: SITE_URL + `/${pageLocale}/` },
    { name: cleanTitle, url: SITE_URL + pathname },
  ] :
  noHreflang ? [
    { name: HOME_LABELS.en, url: SITE_URL + '/' },
    { name: cleanTitle, url: SITE_URL + pathname },
  ] : undefined
);

// BreadcrumbList schema
const breadcrumbSchema = autoBreadcrumbs?.length ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": autoBreadcrumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.name,
    "item": crumb.url,
  })),
} : null;

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const allSchemas = [...sitewideSchemas, ...pageSchemas, ...(breadcrumbSchema ? [breadcrumbSchema] : [])];
const schemaJson = JSON.stringify(allSchemas);

// Build hreflang URLs for all locales
const SITE = Astro.site?.origin ?? 'https://imagetourl.cloud';
function hreflangUrl(loc: Locale): string {
  return `${SITE}/${loc}${basePath}`;
}
---

<!doctype html>
<html lang={locale} dir={isRtl(locale) ? 'rtl' : 'ltr'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="manifest" href="/site.webmanifest?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e11d48" />

    <!-- hreflang for all locales (skip for root-level English-only pages) -->
    {!noHreflang && hreflangAlternates && hreflangAlternates.map(a => (
      <link rel="alternate" hreflang={a.locale} href={`${SITE}${a.url}`} />
    ))}
    {!noHreflang && hreflangAlternates && (
      <link rel="alternate" hreflang="x-default" href={`${SITE}${hreflangAlternates.find(a => a.locale === defaultLocale)?.url ?? '/'}`} />
    )}
    {!noHreflang && !hreflangAlternates && locales.map(loc => (
      <link rel="alternate" hreflang={loc} href={hreflangUrl(loc)} />
    ))}
    {!noHreflang && !hreflangAlternates && <link rel="alternate" hreflang="x-default" href={hreflangUrl(defaultLocale)} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="ImageToURL" />
    <meta property="og:locale" content={localeOgTags[locale]} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{title}</title>

    <!-- Fonts: preconnect + non-render-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Space+Grotesk:wght@500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL@24,400,0..1&display=swap"
    />
    <link
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Space+Grotesk:wght@500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL@24,400,0..1&display=swap"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Space+Grotesk:wght@500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL@24,400,0..1&display=swap" />
    </noscript>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={schemaJson} />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7803867089582138" crossorigin="anonymous"></script>

    <!-- Per-page head injections -->
    <slot name="head" />
  </head>
  <body class="bg-background font-body text-on-surface relative overflow-x-hidden">
    <main>
      <slot />
    </main>
    <script>
      // Scroll-reveal: dual strategy (IO + scroll fallback)
      const revealed = new WeakSet();
      function reveal(el: Element) {
        if (!revealed.has(el)) {
          revealed.add(el);
          el.classList.add('revealed');
        }
      }

      // Primary: IntersectionObserver (most reliable)
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => { if (e.isIntersecting) { reveal(e.target); io.unobserve(e.target); } });
        }, { rootMargin: '50px 0px', threshold: 0 });
        document.querySelectorAll('.reveal').forEach(el => io.observe(el));
      }

      // Fallback: scroll-based check for elements above fold on load
      function revealCheck() {
        document.querySelectorAll('.reveal:not(.revealed)').forEach((el) => {
          if (el.getBoundingClientRect().top < window.innerHeight + 50) reveal(el);
        });
      }
      revealCheck();
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => { revealCheck(); ticking = false; });
          ticking = true;
        }
      }, { passive: true });
    </script>

    <!-- Google Analytics — deferred to avoid blocking LCP -->
    <script is:inline>
      (function(){
        // Load GA after first user interaction or after 3s, whichever is first
        var loaded = false;
        function loadGA() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-CFY17JKKYK';
          s.async = true;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-CFY17JKKYK');
        }
        // Trigger on first interaction
        ['scroll','click','keydown','touchstart'].forEach(function(evt){
          document.addEventListener(evt, loadGA, {once:true, passive:true});
        });
        // Fallback: load after 3 seconds
        setTimeout(loadGA, 3000);
      })();
    </script>
  </body>
</html>

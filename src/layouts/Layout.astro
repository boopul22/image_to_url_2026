---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "ImageToURL — Turn Images into Shareable Links", description = "The fastest way to host your images for free. No account required, permanent hosting, and lightning-fast CDN delivery." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,700;0,6..72,800;1,6..72,400;1,6..72,500;1,6..72,700;1,6..72,800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background font-body text-on-surface relative overflow-x-hidden">
    <div class="grain-overlay"></div>
    <slot />
  </body>
</html>

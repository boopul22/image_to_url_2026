# .dev.vars.example — OPTIONAL local secrets.
#
# Content contributors DO NOT need any of these. `npm run dev` runs fully local
# (no Cloudflare login, no secrets) and renders the whole site. These vars only
# enable backend features (image upload, Google login, AI translation) against
# your own resources. To use them, copy this file to `.dev.vars` and fill in
# values. `.dev.vars` is gitignored and must never be committed.

# Google OAuth (login / admin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=

# Cloudflare R2 (image upload, S3-compatible signed requests)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# OpenRouter (content translation scripts) — optional
OPENROUTER_API_KEY=
